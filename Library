      ? source.situation
      : {};
    const situationValue = line(rawSituation.value, settings.MAX_STATE_VALUE_CHARS)
      .replace(/[.!?]+$/g, "")
      .trim();
    if (situationValue) {
      const threshold = settings.SITUATION_EXPERIENCE_CONFIRMATIONS;
      const situationTargetKey = normalizedTargetKey(rawSituation.targetKey);
      result.situation = {
        value: situationValue,
        updatedClock: Math.max(0, Number(rawSituation.updatedClock ?? fallbackClock) || 0),
        confirmations: Math.max(0, Math.min(threshold, Math.floor(Number(rawSituation.confirmations) || 0))),
        evidenceIds: unique(Array.isArray(rawSituation.evidenceIds) ? rawSituation.evidenceIds : [], 20)
          .map(value => value.toUpperCase())
          .filter(value => /^E\d+$/.test(value)),
        targetKey: situationTargetKey,
        targetName: storedTargetName(situationTargetKey, rawSituation.targetName),
