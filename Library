    if (!eventSignature) return { ok: false, error: "The View provenance signature could not be created." };

    const provenance = appendProvenanceRecord({
      prefix: "V",
      ownerKey: owner.key,
      targetKey,
      targetName: storedTargetName(targetKey, result.targetName),
      destination,
      priorCategory: result.priorCategory,
      resultingCategory: result.resultingCategory,
      priorViewState: result.priorViewState,
      resultingViewState: result.resultingViewState,
      viewOperationMode: operationMode,
      viewSeverity: severity,
      signature: eventSignature,
      managedSignature: result.managedSignature,
      sourceIds,
      storyEvidenceIds,
      uses: (result.narrowUses || []).map(use => use.signature),
      value: result.resultingCategory || destination,
      explanation: line(result.correctedExplanation, 500),
      createdClock: CC.stateClock + 1,
      ownerOpportunity: plan && plan.ownerOpportunity || CC.ownerOpportunities[owner.key] || 0,
      active: true
    });
    if (!provenance.ok) {
      return { ok: false, error: "V# provenance could not commit: " + provenance.error };
    }

    for (const use of result.narrowUses || []) {
      const sourceRecord = provenanceRecordById(use.sourceId);
      if (!sourceRecord || !["relationship", "experience"].includes(sourceRecord.kind)) {
        return { ok: false, error: "Narrow View-use source " + use.sourceId + " disappeared during V# creation." };
      }
      if (!sourceRecord.active || !managedSignatureStillValid(sourceRecord)) {
        return { ok: false, error: "Narrow View-use source " + use.sourceId + " became stale before use commit." };
      }
      const recomputed = viewUseSignatureForRecord(
        sourceRecord, owner.key, targetKey, destination, operationMode
      );
      if (!recomputed || recomputed !== use.signature) {
        return { ok: false, error: "Narrow View-use signature for " + use.sourceId + " changed before commit." };
      }
      if (provenanceUseCommitted(sourceRecord, recomputed)) {
        return { ok: false, error: "Narrow View-use signature for " + use.sourceId + " was already committed." };
      }
      const committedUse = commitProvenanceUse(sourceRecord, recomputed);
      if (!committedUse.ok || committedUse.duplicate
        || !provenanceUseCommitted(sourceRecord, recomputed)) {
        return { ok: false, error: "Narrow View-use signature for " + use.sourceId + " could not commit exactly once." };
      }
    }

    refreshProvenanceActivity();
    const committed = provenanceRecordById(provenance.record.id);
    if (!committed || !committed.active || !managedSignatureStillValid(committed)) {
      return { ok: false, error: "The new V# could not bind to the committed managed View state." };
    }
    CC.last.viewUseDiagnostics = unique((CC.last.viewUseDiagnostics || []).concat(
      "Committed " + committed.id + " after managed View success"
        + ((result.narrowUses || []).length
          ? "; narrow uses " + result.narrowUses.map(use =>
            use.sourceId + ":" + destination + ":" + operationMode).join(", ")
          : "; no derived uses")
    ), 500).slice(-40);
    CC.last.provenanceDiagnostics = unique((CC.last.provenanceDiagnostics || []).concat(
      "View provenance committed: " + committed.id + " from "
        + (sourceIds.join(",") || "None")
        + " with raw lineage " + (storyEvidenceIds.join(",") || "None")
        + "; " + result.priorViewState + " -> " + result.resultingViewState
        + "; mode " + operationMode
    ), 500).slice(-20);
    CC.viewTransactionDiagnostics = unique((CC.viewTransactionDiagnostics || []).concat(
      "Committed " + committed.id + " transactionally for " + owner.name + " -> "
        + modelTargetName(targetKey, result.targetName)
        + " via " + operationMode
    ), 300).slice(-30);
    return { ok: true, record: committed };
  }

  function baseViewRecord(target, category, explanation, buried) {
    return {
      targetKey: target.key,
      targetName: target.key === "player" ? "Player" : (target.key === "self" ? "Self" : target.name),
      category,
      explanation,
      buried: !!buried,
      page: 0,
      card: null,
      line: 0,
      duplicate: false,
      conflict: false,
      oversize: false,
      writable: true
    };
  }

  function applyViewCandidate(owner, candidate, plan, evidenceItems) {
    const resolved = resolveViewTarget(owner, candidate, plan);
    if (!resolved.ok) return resolved;
    const target = resolved.target;
    if (resolved.fresh && !newTargetGrounded(target, evidenceItems)) {
      return { ok: false, error: "The NEW target name was not grounded in its cited completed evidence." };
    }
    refreshViewsStore(false);
    const ownerData = viewsForOwner(owner.key);
    const activeRecord = ownerData && ownerData.activeRecords.find(record => record.targetKey === target.key);
    const buriedRecord = ownerData && ownerData.buriedRecords.find(record => record.targetKey === target.key);
    const categoryDestination = VIEW_CATEGORIES.includes(candidate.destination);
    if (categoryDestination) {
      candidate = {
        ...candidate,
        explanation: correctedViewExplanation(candidate.explanation, candidate.destination)
      };
    }
    const priorState = viewManagedStateSnapshot(owner.key, target.key);

    if (candidate.destination === "Buried") {
      if (!activeRecord) return { ok: false, error: "Burial required one valid active View record." };
      if (buriedRecord) return { ok: false, error: "A prior buried View for this owner–target must be recovered and reconciled before another burial." };
      const result = transactViews(owner, ({ activePages, buriedPages }) => {
        const active = plannedRecord(activePages, target.key);
        if (!active || !active.page.safe || !active.record.writable) return { ok: false, error: "The active View could not be moved safely from its page." };
        removePlannedRecord(active);
        const placed = placePlannedRecord(owner, true, buriedPages, { ...active.record, buried: true }, 0);
        return placed.ok ? { ok: true, summary: owner.name + " buried the View of " + target.name } : placed;
      });
      return result.ok
        ? finalizeViewMutationResult(owner, target, candidate, evidenceItems, priorState, result)
        : result;
    }

    if (candidate.destination === "Recovered") {
      if (!buriedRecord) return { ok: false, error: "Recovery required one valid buried View record." };
      if (activeRecord) {
        if (!activeRecord.writable || !buriedRecord.writable) {
          return { ok: false, error: "The active or buried recovery source belonged to an unsafe page." };
        }
        const markerKey = recoveringViewKey(owner.key, target.key);
        if (CC.recoveringViews[markerKey]) return { ok: false, unchanged: true, error: "" };
        CC.recoveringViews[markerKey] = {
          ownerKey: owner.key,
          targetKey: target.key
        };
        return finalizeViewMutationResult(owner, target, candidate, evidenceItems, priorState, {
          ok: true,
          summary: owner.name + " recovered an earlier View of " + target.name + " for reconciliation"
        });
      }
      const result = transactViews(owner, ({ activePages, buriedPages }) => {
        const buried = plannedRecord(buriedPages, target.key);
        if (!buried || !buried.page.safe || !buried.record.writable) return { ok: false, error: "The buried View could not be restored safely from its page." };
        removePlannedRecord(buried);
        const placed = placePlannedRecord(owner, false, activePages, { ...buried.record, buried: false }, 0);
        return placed.ok ? { ok: true, summary: owner.name + " restored the View of " + target.name } : placed;
      });
      return result.ok
        ? finalizeViewMutationResult(owner, target, candidate, evidenceItems, priorState, result)
        : result;
    }

    if (!categoryDestination) return { ok: false, error: "The View destination was not a supported category or memory operation." };
    const marker = recoveringMarker(owner.key, target.key);
    if (target.mode === "recovering" || marker) {
      if (!marker || !activeRecord || !buriedRecord) return { ok: false, error: "Reconciliation required an intact active/buried recovering pair." };
      if (candidate.severity === "O" && categoryDistance(activeRecord.category, candidate.destination) > 1) {
        return { ok: false, error: "Ordinary reconciliation may retain the current category or move one adjacent step." };
      }
      const result = transactViews(owner, ({ activePages, buriedPages }) => {
        const active = plannedRecord(activePages, target.key);
        const buried = plannedRecord(buriedPages, target.key);
        if (!active || !buried) return { ok: false, error: "The recovering pair changed before reconciliation could commit." };
        const updated = updatePlannedRecord(owner, false, activePages, active, {
          category: candidate.destination,
          explanation: candidate.explanation
        });
        if (!updated.ok) return updated;
        if (!buried.page.safe || !buried.record.writable) return { ok: false, error: "The recovered buried record belonged to an unsafe page." };
        removePlannedRecord(buried);
        return { ok: true, summary: owner.name + " reconciled the View of " + target.name + " as " + candidate.destination };
      });
      if (result.ok) delete CC.recoveringViews[recoveringViewKey(owner.key, target.key)];
      return result.ok
        ? finalizeViewMutationResult(owner, target, candidate, evidenceItems, priorState, result)
        : result;
    }

    if (target.mode === "buried") {
      return { ok: false, error: "A buried target code authorizes recovery, not an active category update." };
    }

    if (activeRecord) {
      if (activeRecord.category === candidate.destination && keyOf(activeRecord.explanation) === keyOf(candidate.explanation)) {
        return { ok: false, unchanged: true, error: "" };
      }
      if (candidate.severity === "O" && categoryDistance(activeRecord.category, candidate.destination) > 1) {
        return { ok: false, error: "An ordinary View operation may retain its category or move one adjacent step." };
      }
      const result = transactViews(owner, ({ activePages }) => {
        const active = plannedRecord(activePages, target.key);
        if (!active) return { ok: false, error: "The active target changed before its update could commit." };
        const updated = updatePlannedRecord(owner, false, activePages, active, {
          category: candidate.destination,
          explanation: candidate.explanation
        });
        return updated.ok
          ? { ok: true, summary: owner.name + " moved the View of " + target.name + " to " + candidate.destination }
          : updated;
      });
      return result.ok
        ? finalizeViewMutationResult(owner, target, candidate, evidenceItems, priorState, result)
        : result;
    }

    const result = transactViews(owner, ({ activePages }) => {
      const record = baseViewRecord(target, candidate.destination, candidate.explanation, false);
      const placed = placePlannedRecord(owner, false, activePages, record, 0);
      return placed.ok
        ? { ok: true, summary: owner.name + " added " + target.name + " to " + candidate.destination }
        : placed;
    });
    return result.ok
      ? finalizeViewMutationResult(owner, target, candidate, evidenceItems, priorState, result)
      : result;
  }

  function resetLastForContext() {
    Object.assign(CC.last, {
      warning: "", error: "", rulesTokens: 0, outerTokens: 0, innerTokens: 0, stateTokens: 0,
      namesTokens: 0, relationshipsTokens: 0, viewsTokens: 0, experiencesTokens: 0, evidenceTokens: 0, taskTokens: 0,
      injectedTokens: 0, effectiveBudget: runtime.continuityBudget, headroomTokens: runtime.continuityBudget, recentStoryChars: 0,
      task: "none", owner: "", candidate: "not requested", update: "None",
      protocol: "None", cast: "None", timeJumpReset: false, gracefulFallback: false,
      selectedNames: [], omittedNames: [], selectedRelationships: [], omittedRelationships: [],
      selectedViews: [], omittedViews: [], selectedExperiences: [], omittedExperiences: [],
      suppliedEvidence: [], suppliedTargets: [],
      operationDecay: "None",
      nameDiagnostics: [], relationshipSourceDiagnostics: [], viewSourceDiagnostics: [], modelOmitted: []
    });
  }

  function buildContext() {
    resetLastForContext();
    refreshViewsStore(false);
    refreshNamesStore();
    applyManagedNameForms();
    refreshRelationshipsStore();
    refreshExperiencesStore(false);
    const plan = beginContinueIfNeeded(originalText);
    if (!plan.relationshipPace || typeof plan.relationshipPace !== "object") {
      plan.relationshipPace = clone(runtime.relationshipPace);
    }
    const recent = recentStoryFromContext(originalText);
    const currentInput = plan.kind === "input" || plan.retry ? CC.lastInput : "";
    const source = [currentInput, recent].filter(Boolean).join("\n").slice(-16000);
    if (plan.opening) {
      plan.task = "none";
      plan.taskDelivered = false;
      plan.activeKeys = [];
      CC.last.context = "Opening prompt retained; only its immediate automatic output will be suppressed.";
      return originalText;
    }
    expireTemporaryState(CC.stateClock);
    if (!plan.retry && plan.inputEvidenceId && plan.inputEvidenceId !== CC.lastTimeJumpEvidenceId && TIME_JUMP.test(currentInput)) {
      resetSceneForTimeJump(plan.inputEvidenceId);
      CC.lastTimeJumpEvidenceId = plan.inputEvidenceId;
    }
    let active = selectActive(source, currentInput, plan);
    if (plan.retry && Array.isArray(plan.retryActiveKeys) && plan.retryActiveKeys.length) {
      const repeated = plan.retryActiveKeys
        .map(key => characters.find(character => character.key === key))
        .filter(Boolean)
        .slice(0, runtime.maxActive);
      if (repeated.length) active = repeated;
    }
    let focus = selectFocus(active, currentInput);
    if (plan.retry && plan.retryFocusKey) focus = active.find(character => character.key === plan.retryFocusKey) || focus;
    if (!active.length || !focus) {
      CC.activeKeys = [];
      CC.modelActiveKeys = [];
      CC.focusKey = "";
      plan.activeKeys = [];
      plan.task = "none";
      plan.taskDelivered = false;
      CC.last.context = "No predetermined active NPC was detected.";
      return originalText;
    }
    CC.activeKeys = active.map(character => character.key);
    CC.focusKey = focus.key;

    const scoringFrozenEvidenceIds = plan.retry && Array.isArray(plan.retryEvidenceIds) && plan.retryEvidenceIds.length
      ? plan.retryEvidenceIds
      : (plan.opportunityCounted && Array.isArray(plan.evidenceIds) ? plan.evidenceIds : []);
    const scoringFrozenEligibility = plan.retry && plan.retryEvidenceEligibility
      ? plan.retryEvidenceEligibility
      : (plan.opportunityCounted && plan.evidenceEligibility ? plan.evidenceEligibility : null);
    const scoringFrozenOpportunity = plan.opportunityCounted && Number.isFinite(Number(plan.ownerOpportunity))
      ? Math.max(0, Number(plan.ownerOpportunity) - 1)
      : null;
    const scoringEvidence = availableEvidence(
      focus,
      recent,
      plan.inputEvidenceId || "",
      scoringFrozenEvidenceIds,
      scoringFrozenOpportunity,
      scoringFrozenEligibility
    );
    const scoringRelationships = relevantRelationshipRecords(focus, active, currentInput, recent);
    const scoringActiveViews = relevantViewRecords(focus, active, currentInput, recent, scoringEvidence, false);
    const scoringBuriedViews = relevantViewRecords(focus, active, currentInput, recent, scoringEvidence, true);
    const scoringTargets = operationTargetMap(
      focus,
      active,
      scoringActiveViews,
      scoringBuriedViews,
      scoringRelationships,
      currentInput,
      scoringEvidence,
      recent
    );
    const scoringFrozenSourcePacket = plan.retry && Array.isArray(plan.retrySourcePacket)
      ? plan.retrySourcePacket
      : (plan.opportunityCounted && Array.isArray(plan.sourcePacket) ? plan.sourcePacket : null);
    const scoringDerivedRelationships = relationshipDerivedEvidenceCandidates(
      focus,
      scoringTargets,
      scoringFrozenOpportunity,
      scoringFrozenSourcePacket
    );
    const scoringDerivedViews = viewDerivedEvidenceCandidates(
      focus,
      scoringTargets,
      scoringFrozenOpportunity,
      scoringFrozenSourcePacket
    );
    const scoringSources = scoringEvidence.concat(scoringDerivedRelationships, scoringDerivedViews);
    freezeOperationSelection(plan, focus, scoringTargets, scoringSources, plan.inputEvidenceId || "", recent);

    const attempt = assembleContext(originalText, active, focus, currentInput, recent, plan);
    if (!attempt.ok) {
      CC.last.context = "Distinct portrayal could not fit safely: " + attempt.reason;
      CC.last.error = attempt.reason;
      plan.task = "none";
      plan.taskDelivered = false;
      CC.modelActiveKeys = [];
      return originalText;
    }

    plan.task = attempt.taskDelivered ? "operation" : (CC.recoveryPending ? "recovery" : "none");
    plan.taskDelivered = attempt.taskDelivered;
    plan.ownerKey = focus.key;
    plan.focusKey = focus.key;
    plan.targets = clone(attempt.targets || []);
    plan.evidenceIds = clone(attempt.evidenceIds || []);
    plan.operationTaskText = textOf(attempt.taskText);
    plan.operationTaskKind = line(attempt.taskKind, 40);
    plan.operationTaskTokens = Math.max(0, Math.floor(Number(attempt.taskTokens) || 0));
    if (attempt.taskDelivered && attempt.operationEvidenceSignature) {
      plan.selectedEvidenceSignature = line(attempt.operationEvidenceSignature, 500);
    }
    plan.evidenceEligibility = {};
    (attempt.evidenceCandidates || []).forEach(candidate => {
      plan.evidenceEligibility[candidate.item.id] = {
        name: attempt.taskKind === "name" && candidate.nameEligible === true,
        state: attempt.taskKind === "state" && candidate.stateEligible === true,
        relationship: attempt.taskKind === "relationship" && candidate.relationshipEligible === true,
        view: attempt.taskKind === "view" && candidate.viewEligible === true,
        age: candidate.age
      };
    });
    const freshSourcePacket = (attempt.evidenceCandidates || []).map(candidate => {
      const prefix = candidate.item.id.charAt(0);
      const derived = candidate.item.source === "provenance";
      return {
        id: candidate.item.id,
        prefix,
        text: derived
          ? candidate.item.text
          : modelEvidenceText(candidate.item, plan.inputEvidenceId || "", recent),
        source: candidate.item.source,
        name: attempt.taskKind === "name" && candidate.nameEligible === true,
        state: attempt.taskKind === "state" && candidate.stateEligible === true,
        relationship: attempt.taskKind === "relationship" && candidate.relationshipEligible === true,
        view: attempt.taskKind === "view" && candidate.viewEligible === true,
        age: candidate.age,
        ownerKey: derived ? candidate.ownerKey : focus.key,
        targetKey: derived ? candidate.targetKey : "",
        targetName: derived ? candidate.targetName : "",
        allowedFields: derived ? clone(candidate.allowedFields || []) : [],
        allowedDestinations: derived ? clone(candidate.allowedDestinations || []) : [],
        allowedModes: derived ? clone(candidate.allowedModes || []) : [],
        interpretations: derived ? clone(candidate.interpretations || []) : [],
        managedSignature: derived ? candidate.managedSignature : "",
        rawLineage: derived ? clone(candidate.rawLineage || []) : [candidate.item.id],
        gain: derived ? Math.max(0, Number(candidate.gain) || 0) : 0,
        useSignatures: derived ? clone(candidate.useSignatures || {}) : {},
        directAllowed: derived ? false : true,
        reason: derived ? candidate.eligibilityReason || "" : ""
      };
    });
    plan.sourcePacket = plan.retry && Array.isArray(plan.retrySourcePacket) && plan.retrySourcePacket.length
      ? clone(plan.retrySourcePacket)
      : freshSourcePacket;
    plan.sourcePacketText = plan.retry && textOf(plan.retrySourcePacketText)
      ? textOf(plan.retrySourcePacketText)
      : evidencePacketForKind(
        focus,
        attempt.taskKind,
        attempt.evidenceCandidates || [],
        plan.inputEvidenceId || "",
        recent,
        attempt.targets[0] || null
      );
    plan.sourcePacketTokens = estimateTokens(plan.sourcePacketText);
    plan.activeKeys = active.map(character => character.key);
    plan.modelActiveKeys = attempt.modelActive.map(character => character.key);
    plan.recentStory = recent;
    if (attempt.taskDelivered && !plan.opportunityCounted) {
      CC.ownerOpportunities[focus.key] = Math.max(0, Number(CC.ownerOpportunities[focus.key]) || 0) + 1;
      plan.opportunityCounted = true;
      plan.ownerOpportunity = CC.ownerOpportunities[focus.key];
      const decay = materializeOwnerDrainDecay(focus.key, plan.ownerOpportunity);
      plan.operationDecay = clone(decay);
      CC.last.operationDecay = decay.summary;
    }
    CC.modelActiveKeys = plan.modelActiveKeys.slice();

    Object.assign(CC.last, {
      rulesTokens: attempt.rulesTokens,
      outerTokens: attempt.outerTokens,
      namesTokens: attempt.namesTokens,
      innerTokens: attempt.innerTokens,
      stateTokens: attempt.stateTokens,
      relationshipsTokens: attempt.relationshipsTokens,
      viewsTokens: attempt.viewsTokens,
      experiencesTokens: attempt.experiencesTokens,
      evidenceTokens: attempt.evidenceTokens,
      taskTokens: attempt.taskTokens,
      injectedTokens: attempt.tokens,
      effectiveBudget: attempt.effectiveBudget,
      headroomTokens: attempt.headroom,
      recentStoryChars: attempt.recentChars,
      task: plan.task,
      owner: attempt.taskDelivered ? focus.name : "",
      selectedNames: attempt.selectedNames,
      omittedNames: attempt.omittedNames,
      selectedRelationships: attempt.selectedRelationships,
      omittedRelationships: attempt.omittedRelationships,
      selectedViews: attempt.selectedViews,
      omittedViews: attempt.omittedViews,
      selectedExperiences: attempt.selectedExperiences,
      omittedExperiences: attempt.omittedExperiences,
      suppliedEvidence: attempt.evidenceIds,
      suppliedSources: (plan.sourcePacket || []).map(source => source.id + "=" + source.prefix),
      sourcePacketTokens: plan.sourcePacketTokens || 0,
      suppliedTargets: attempt.targets.map(target => target.code + "=" + target.name)
    });
    if (plan.opportunity && !attempt.taskDelivered) {
      CC.last.gracefulFallback = true;
      CC.last.warning = "Operation deferred: " + (attempt.taskDeferredReason || "the complete packet was unavailable");
    }
    CC.last.context = "Scene-relevant " + active.map(character => character.name).join(", ")
      + "; model-facing " + attempt.modelActive.map(character => character.name).join(", ")
      + "; focus " + focus.name + (attempt.taskDelivered
        ? "; one " + operationKindLabel(attempt.taskKind) + " CCO task delivered."
        : ".");
    return attempt.text;
  }

  function candidateSourceLabel(sourceIds) {
    return (Array.isArray(sourceIds) ? sourceIds : []).join(",") || "no sources";
  }

  function operationOutcomeIdentity(owner, plan, parsedCandidate, result) {
    const selected = plan && plan.selectedCandidate && typeof plan.selectedCandidate === "object"
      ? plan.selectedCandidate
      : {};
    const candidate = parsedCandidate && typeof parsedCandidate === "object" ? parsedCandidate : {};
    const kind = keyOf(plan && plan.selectedOperationKind || candidate.kind || selected.kind);
    let targetKey = normalizedTargetKey(result && result.targetKey || selected.targetKey);
    if (!targetKey && kind === "state" && candidate.targetCode) {
      const target = targetForCode(plan, candidate.targetCode);
      targetKey = normalizedTargetKey(target && target.key);
    }
    if (!targetKey && kind === "relationship" && candidate.targetCode) {
      const target = targetForCode(plan, candidate.targetCode);
      targetKey = normalizedTargetKey(target && target.key);
    }
    if (!targetKey && kind === "view") {
      const field = textOf(candidate.targetField).trim();
      const fresh = field.match(/^NEW=(.+)$/i);
      if (fresh) {
        const target = canonicalViewTarget(owner, fresh[1]);
        targetKey = normalizedTargetKey(target && target.key);
      } else if (field) {
        const target = targetForCode(plan, field.toUpperCase());
        targetKey = normalizedTargetKey(target && target.key);
      }
    }
    if (!targetKey && kind === "name") targetKey = normalizedTargetKey(result && result.subjectKey || selected.targetKey);
    const field = line(result && result.field || candidate.field || selected.field, 80);
    let destination = line(candidate.destination || selected.destination, 120);
    if (!destination && kind === "name") destination = line(candidate.transition, 120);
    return {
      ownerKey: owner ? owner.key : line(plan && plan.ownerKey, 160),
      kind,
      targetKey,
      field,
      destination,
      evidenceSignature: line(plan && plan.selectedEvidenceSignature || selected.evidenceSignature, 500)
    };
  }

  function applyOperationOutcomeDrain(owner, plan, parsedCandidate, result, outcome) {
    const normalizedOutcome = keyOf(outcome);
    const points = {
      success: settings.OPERATION_POINTS.SUCCESS_DRAIN,
      unchanged: settings.OPERATION_POINTS.UNCHANGED_DRAIN,
      rejected: settings.OPERATION_POINTS.REJECTED_DRAIN,
      malformed: settings.OPERATION_POINTS.MALFORMED_DRAIN
    }[normalizedOutcome];
    if (!owner || !plan || !plan.taskDelivered || !Number.isFinite(Number(points))) return null;
    const identity = operationOutcomeIdentity(owner, plan, parsedCandidate, result);
    if (!MODEL_OPERATION_KINDS.includes(identity.kind) || !identity.ownerKey || !identity.evidenceSignature) return null;
    const opportunity = Math.max(0, Number(plan.ownerOpportunity) || Number(CC.ownerOpportunities[owner.key]) || 0);
    materializeOwnerDrainDecay(owner.key, opportunity);
    const key = operationDrainKey(identity);
    let record = (Array.isArray(CC.operationState.drains) ? CC.operationState.drains : [])
      .map(normalizeOperationDrainRecord)
      .find(item => item && item.key === key) || null;
    const priorValue = record ? effectiveOperationDrainValue(record, opportunity) : 0;
    const repeated = priorValue > 0 ? settings.OPERATION_POINTS.REPEATED_SIGNATURE_DRAIN : 0;
    const added = Math.max(0, Number(points) || 0) + Math.max(0, Number(repeated) || 0);
    if (!record) {
      record = normalizeOperationDrainRecord({ ...identity, value: 0, updatedOpportunity: opportunity, attempts: 0 });
    }
    if (!record) return null;
    record.value = Math.min(settings.OPERATION_DRAIN_CAP, priorValue + added);
    record.updatedOpportunity = opportunity;
    record.attempts += 1;
    record.lastResult = normalizedOutcome;
    record.key = operationDrainKey(record);
    const others = (Array.isArray(CC.operationState.drains) ? CC.operationState.drains : [])
      .map(normalizeOperationDrainRecord)
      .filter(item => item && item.key !== record.key);
    CC.operationState.drains = others.concat(record)
      .sort((left, right) => left.updatedOpportunity - right.updatedOpportunity)
      .slice(-settings.MAX_OPERATION_DRAIN_RECORDS);

    if (!CC.operationState.owners[owner.key]) CC.operationState.owners[owner.key] = blankOwnerOperationState();
    const meter = CC.operationState.owners[owner.key][identity.kind] || blankOperationMeter();
    meter.gain = Math.max(0, Number(plan.selectedGain) || 0);
    meter.drain = record.value;
    meter.lastServedOpportunity = opportunity;
    meter.lastResult = normalizedOutcome;
    meter.lastSignature = identity.evidenceSignature;
    meter.lastTargetKey = identity.targetKey;
    meter.lastField = identity.field;
    CC.operationState.owners[owner.key][identity.kind] = normalizeOperationMeter(meter);

    const summary = operationKindLabel(identity.kind) + " " + normalizedOutcome
      + " drain " + priorValue + " + " + Math.max(0, Number(points) || 0)
      + (repeated ? " + repeated " + repeated : "") + " = " + record.value
      + " at owner opportunity " + opportunity + ".";
    CC.last.operationOutcome = operationKindLabel(identity.kind) + " " + normalizedOutcome;
    CC.last.operationDrainChange = summary;
    return { record, priorValue, base: points, repeated, summary };
  }

  function processOutput(outputValue) {
    const plan = CC.currentPlan || { task: "none", taskDelivered: false, activeKeys: CC.activeKeys || [] };
    if (plan.opening) {
      CC.last.output = "Suppressed only the automatic output immediately following the retained opening prompt.";
      CC.last.candidate = "not requested";
      plan.completed = true;
      return " ";
    }

    const instructionEcho = stripOperationInstructionEchoes(outputValue, plan);
    const parsed = parseTerminalCandidate(outputValue, plan);
    if (instructionEcho.count > 0 && !parsed.candidate && !parsed.unauthorized) {
      parsed.malformed = true;
      parsed.reason = "Operation instruction echo stripped (" + instructionEcho.count + " line"
        + (instructionEcho.count === 1 ? "" : "s") + ")."
        + (parsed.hadProtocol ? " " + parsed.reason : "");
      parsed.raw = instructionEcho.sample;
    }
    const protocolSummary = parsed.hadProtocol
      ? parsed.reason + (parsed.raw ? " Record: " + line(parsed.raw, 180) : "")
      : (parsed.reason || "No CCO record");
    CC.last.protocol = instructionEcho.count > 0 && parsed.candidate
      ? "Operation instruction echo stripped (" + instructionEcho.count + "). " + protocolSummary
      : protocolSummary;
    const story = parsed.story.trim();
    if (!hasCompleteStory(story)) {
      const owner = characters.find(character => character.key === plan.ownerKey) || null;

      CC.recoveryPending = true;
      CC.last.candidate = parsed.unauthorized
        ? "unauthorized stripped"
        : (parsed.malformed
          ? "malformed stripped"
          : (parsed.candidate
            ? "rejected: no complete story"
            : "absent: no complete story"));

      CC.last.operationOutcome = "None";
      CC.last.operationDrainChange = "No drain change";
      if (owner && plan.taskDelivered) {
        const outcome = parsed.malformed
          ? "malformed"
          : (parsed.unauthorized || parsed.candidate ? "rejected" : "unchanged");
        applyOperationOutcomeDrain(owner, plan, parsed.candidate, null, outcome);
      }

      CC.last.output = "No complete story survived; no operation was applied and prose-only recovery remains pending.";
      CC.last.error = "The response did not finish complete story prose.";
      return " ";
    }

    const nextGeneration = CC.visibleGenerationCount + 1;
    const nextStateClock = CC.stateClock + 1;
    const storyTimeJump = TIME_JUMP.test(story);
    if (storyTimeJump) resetSceneForTimeJump();
    const owner = characters.find(character => character.key === plan.ownerKey) || null;
    const focus = characters.find(character => character.key === plan.focusKey) || owner || null;
    let result = null;
    let evidenceResult = null;

    if (parsed.unauthorized) {
      CC.last.candidate = "unauthorized stripped";
      CC.last.error = parsed.reason || "An unauthorized CCO record was stripped while complete story survived.";
    } else if (parsed.malformed) {
      CC.last.candidate = "malformed stripped";
      CC.last.error = parsed.reason || "A malformed CCO record was stripped while complete story survived.";
    } else if (!parsed.candidate) {
      CC.last.candidate = plan.taskDelivered ? "absent/no update" : "not requested";
    } else if (!owner || plan.task !== "operation" || !plan.taskDelivered) {
      result = { ok: false, error: "The parsed operation had no authorized fixed owner or delivered task." };
    } else if (parsed.candidate.kind !== keyOf(plan.selectedOperationKind)) {
      result = { ok: false, error: "The parsed operation kind did not match the frozen JavaScript selection." };
    } else if (parsed.candidate.kind === "name") {
      const subject = nameSubjectForCandidate(owner, parsed.candidate, plan);
      if (!subject.ok) result = subject;
      else {
        evidenceResult = citedEvidenceForOperation(owner, parsed.candidate, plan, subject.identity.key);
        result = evidenceResult.ok
          ? applyNameCandidate(owner, parsed.candidate, plan, evidenceResult.items)
          : evidenceResult;
        if (result.ok) {
          consumeNameEvidence(evidenceResult.items, result.subjectKey || subject.identity.key, result.aliasKey || nameKeyOf(parsed.candidate.alias));
          CC.last.lastName = result.nameDetail || result.summary;
        }
      }
    } else if (parsed.candidate.kind === "state") {
      const target = targetForCode(plan, parsed.candidate.targetCode);
      if (!target) result = { ok: false, error: "State used an About code outside the frozen target map." };
      else if (storyTimeJump) result = { ok: false, error: "A generated time jump cleared immediate State and blocked the pre-jump State operation." };
      else {
        evidenceResult = citedEvidenceForOperation(owner, parsed.candidate, plan, target.key);
        result = evidenceResult.ok
          ? applyStateCandidate(owner, parsed.candidate, nextStateClock, plan, evidenceResult.items)
          : evidenceResult;
        if (result.ok) consumeStateEvidence(evidenceResult.items, owner);
      }
    } else if (parsed.candidate.kind === "relationship") {
      const target = targetForCode(plan, parsed.candidate.targetCode);
      if (!target || target.relationship !== true) {
        result = { ok: false, error: "Relationship used a target outside the frozen directional target map." };
      } else {
        evidenceResult = citedEvidenceForOperation(owner, parsed.candidate, plan, target.key);
        if (!evidenceResult.ok) {
          result = evidenceResult;
        } else {
          const relationshipSnapshot = captureRelationshipProvenanceTransaction();
          result = applyRelationshipCandidate(owner, parsed.candidate, plan, evidenceResult.items);
          if (result.ok) {
            const provenance = commitRelationshipProvenance(owner, result, plan);
            if (!provenance.ok) {
              const restored = restoreRelationshipProvenanceTransaction(
                relationshipSnapshot,
                provenance.error
              );
              result = {
                ok: false,
                error: "Relationship mutation rolled back because R# provenance or narrow use could not commit: "
                  + provenance.error + (restored ? "" : " (managed-card rollback was incomplete)")
              };
            } else {
              result.provenanceId = provenance.record.id;
              consumeRelationshipEvidence(evidenceResult.items, owner, result.targetKey || target.key);
              CC.last.lastRelationship = (result.relationshipDetail || result.summary)
                + "; provenance " + provenance.record.id;
              CC.last.relationshipChange = "Actual stage " + (result.actualStage || "unknown")
                + "; numeric change " + Math.trunc(Number(result.actualChange) || 0)
                + "; stage " + (result.stageChanged ? "changed" : "unchanged")
                + "; description " + (result.descriptionChanged ? "changed" : "unchanged")
                + (result.recordRemoved ? "; empty record removed" : "");
              CC.last.relationshipSourceDiagnostics = unique(
                (CC.last.relationshipSourceDiagnostics || []).concat(
                  "5C-D accepted " + candidateSourceLabel(parsed.candidate.evidenceIds || [])
                    + " as " + parsed.candidate.eventKind + " for " + parsed.candidate.field
                    + "; actual stage " + (result.actualStage || "unknown")
                    + "; R# " + provenance.record.id
                    + "; derived narrow uses committed "
                    + ((result.narrowUses || []).length || 0)
                ), 500
              ).slice(-40);
            }
          }
        }
      }
    } else if (parsed.candidate.kind === "view") {
      const targetResolution = resolveViewTarget(owner, parsed.candidate, plan);
      if (!targetResolution.ok) result = targetResolution;
      else {
        evidenceResult = citedEvidenceForOperation(owner, parsed.candidate, plan, targetResolution.target.key);
        if (!evidenceResult.ok) {
          result = evidenceResult;
        } else {
          const viewSnapshot = captureViewProvenanceTransaction();
          result = applyViewCandidate(owner, parsed.candidate, plan, evidenceResult.items);
          if (!result.ok && result.rollbackRequired) {
            const restored = restoreViewProvenanceTransaction(viewSnapshot, result.error);
            result = {
              ok: false,
              error: "View mutation rolled back because the managed write could not be verified: "
                + result.error + (restored ? "" : " (managed-card rollback was incomplete)")
            };
          } else if (result.ok) {
            const provenance = commitViewProvenance(owner, result, plan);
            if (!provenance.ok) {
              const restored = restoreViewProvenanceTransaction(viewSnapshot, provenance.error);
              result = {
                ok: false,
                error: "View mutation rolled back because V# provenance or narrow use could not commit: "
                  + provenance.error + (restored ? "" : " (managed-card rollback was incomplete)")
              };
            } else {
              result.provenanceId = provenance.record.id;
              consumeViewEvidence(evidenceResult.items, owner, result.targetKey || targetResolution.target.key);
              const derivedValidated = (evidenceResult.items || []).filter(item => item && item.source === "provenance");
              CC.last.viewSourceDiagnostics = unique((CC.last.viewSourceDiagnostics || []).concat(
                "5D-D accepted " + candidateSourceLabel(parsed.candidate.evidenceIds || [])
                  + " for " + parsed.candidate.destination
                  + " via " + result.operationMode
                  + "; V# " + provenance.record.id
                  + "; derived narrow uses committed " + ((result.narrowUses || []).length || 0)
              ), 500).slice(-40);
              CC.last.viewUseDiagnostics = unique((CC.last.viewUseDiagnostics || []).concat(
                derivedValidated.length
                  ? "Committed View uses: " + derivedValidated.map(item =>
                    item.id + ":" + item.destination + ":" + item.operationMode).join(", ")
                  : "Committed " + provenance.record.id + " from raw E# only; no derived View use."
              ), 500).slice(-40);
            }
          }
        }
      }
    }

    if (result) {
      if (result.ok) {
        CC.last.candidate = "accepted";
        CC.last.update = result.summary;
        CC.last.error = "";
        if (result.warning) CC.last.warning = result.warning;
      } else {
        CC.last.candidate = result.unchanged ? "unchanged" : "rejected";
        CC.last.error = result.unchanged ? "" : result.error;
      }
    }
    if (owner && plan.taskDelivered) {
      const outcome = parsed.malformed
        ? "malformed"
        : (parsed.unauthorized
          ? "rejected"
          : (!parsed.candidate
            ? "unchanged"
            : (result && result.ok ? "success" : (result && result.unchanged ? "unchanged" : "rejected"))));
      applyOperationOutcomeDrain(owner, plan, parsed.candidate, result, outcome);
    }
    if (instructionEcho.count > 0 && parsed.candidate) {
      CC.last.warning = [CC.last.warning, "Operation instruction echo was stripped before the valid CCO record and story were processed."]
        .filter(Boolean).join(" ");
    }

    CC.visibleGenerationCount = nextGeneration;
    CC.stateClock = nextStateClock;
    expireTemporaryState(CC.stateClock);
    CC.recoveryPending = false;
    if (focus) {
      updateScenePresence(story, focus.key, nextGeneration);
      CC.focusLastServed[focus.key] = nextGeneration;
    }
    const conversationSpeaker = inferredConversationSpeaker(story, (plan.modelActiveKeys || plan.activeKeys || [])
      .map(key => characters.find(character => character.key === key)).filter(Boolean));
    CC.conversationKey = conversationSpeaker ? conversationSpeaker.key : "";
    plan.completed = true;
    CC.lastVisibleOutputAnchor = outputAnchorFor(story, plan);
    const storyEvidence = addEvidence("story", story);
    if (storyTimeJump && storyEvidence) CC.lastTimeJumpEvidenceId = storyEvidence.id;
    CC.last.output = result && result.ok
      ? "Complete story survived and the accepted " + parsed.candidate.kind + " operation committed transactionally."
      : result && result.unchanged
      ? "Complete story survived; the proposed operation already matched and was not refreshed."
      : "Complete story survived; " + (CC.last.candidate === "absent/no update"
        ? "Names, State, Relationships, Views, and Experiences remained unchanged."
        : (CC.last.candidate === "not requested" ? "no operation was scheduled." : "no continuity operation was applied."));
    return story;
  }

  function stateStatus(character) {
    const state = normalizeState(CC.npcs[character.key] && CC.npcs[character.key].state, CC.stateClock);
    const present = [["T", "thought"], ["F", "feeling"], ["G", "goal"], ["X", "tension"], ["S", "situation"]]
      .filter(([, field]) => state[field].value)
      .map(([label]) => label)
      .join("");
    const threshold = settings.SITUATION_EXPERIENCE_CONFIRMATIONS;
    return character.name + " " + (present || "empty")
      + (state.target.name ? " → " + state.target.name : "")
      + (state.triggers.value.length ? " [" + state.triggers.value.join(",") + "]" : "")
      + (state.situation.value ? " {Situation " + state.situation.confirmations + "/" + threshold
        + (state.situation.promotedSignature ? ", promoted" : "") + "}" : "");
  }

  function castStatus(character) {
    const cast = castFor(character);
    const label = cast.status === "main" ? "Main" : "Side";
    return character.name + " " + label + (cast.status === "main"
      ? " inactive " + cast.inactiveStreak + "/" + runtime.mainInactivityLimit
      : " interactions " + cast.interactionProgress + "/" + runtime.sidePromotionInteractions);
  }

  function outerStatus(character) {
    const maximum = settings.MAX_OUTER_CARD_CHARS;
    const warning = character.outerWarnings.length ? " [" + character.outerWarnings.join(" ") + "]" : " ready";
    return character.name + " " + character.outerRetainedChars + "/" + maximum + warning;
  }

  function innerStatus(character) {
    if (!character.innerCard) {
      return character.name + " missing ["
        + (character.innerWarnings.join(" ") || "Inner card missing.") + "]";
    }
    const maximum = settings.MAX_INNER_CARD_CHARS;
    const warning = character.innerWarnings.length ? " [" + character.innerWarnings.join(" ") + "]" : " ready";
    return character.name + " " + character.innerRetainedChars + "/" + maximum + warning;
  }

  function viewsStatus(character) {
    const owner = viewsForOwner(character.key);
    const activeCount = owner ? owner.activeRecords.length : 0;
    const buriedCount = owner ? owner.buriedRecords.length : 0;
    const recoveringCount = Object.values(CC.recoveringViews).filter(marker => marker && marker.ownerKey === character.key).length;
    return character.name + " active " + activeCount + ", buried " + buriedCount + ", recovering " + recoveringCount;
  }

  function relationshipsStatus(character) {
    const owner = relationshipsForOwner(character.key);
    const records = owner ? owner.records.filter(record => !record.duplicate).length : 0;
    const pages = owner ? owner.pages.length : 0;
    return character.name + " " + records + " records / " + pages + " pages";
  }

  function namesStatus(identity) {
    const identityData = namesForIdentity(identity.key);
    const records = identityData ? identityData.records.filter(record => !record.duplicate && !record.conflict) : [];
    const counts = NAME_STATUSES.map(status => status + " " + records.filter(record => record.status === status).length)
      .join(", ");
    return identity.headerOwner + " " + records.length + " aliases (" + counts + ") / "
      + (identityData ? identityData.pages.length : 0) + " pages";
  }

  function experiencesStatus(character) {
    const owner = experiencesForOwner(character.key);
    const records = owner ? owner.records.filter(record => !record.duplicate).length : 0;
    const pages = owner ? owner.pages.length : 0;
    const safe = owner ? owner.contextRecords.length : 0;
    return character.name + " " + records + " records, " + pages + " pages, " + safe + " context-safe";
  }

  function pendingEvidenceStatus(character) {
    const recent = CC.currentPlan && typeof CC.currentPlan.recentStory === "string"
      ? CC.currentPlan.recentStory
      : recentStoryFromContext(originalText);
    const eligible = CC.evidence.filter(item => {
      if (!openingEvidenceEligible(item, recent)) return false;
      const statePending = !item.usedStateBy[character.key] && CC.stateClock - item.stateClock < runtime.stateLifetime;
      const viewPending = viewEvidenceAge(item, character) < settings.VIEW_EVIDENCE_OPPORTUNITIES;
      const relationshipTargets = ["player"].concat(characters
        .filter(target => target.key !== character.key)
        .map(target => "npc:" + target.key));
      const relationshipUses = item.usedRelationshipsBy[character.key] || {};
      const relationshipPending = viewEvidenceAge(item, character) < settings.RELATIONSHIP_EVIDENCE_OPPORTUNITIES
        && relationshipTargets.some(targetKey => !relationshipUses[targetKey]);
      const namePending = viewEvidenceAge(item, character) < settings.NAME_EVIDENCE_OPPORTUNITIES;
      return statePending || viewPending || relationshipPending || namePending;
    });
    const oldest = eligible.length ? Math.max(...eligible.map(item => viewEvidenceAge(item, character))) : 0;
    return character.name + " " + eligible.length + " pending, oldest durable age " + oldest + "/"
      + Math.max(settings.VIEW_EVIDENCE_OPPORTUNITIES, settings.RELATIONSHIP_EVIDENCE_OPPORTUNITIES, settings.NAME_EVIDENCE_OPPORTUNITIES);
  }


  function derivedRelationshipSources(plan) {
    const source = plan && typeof plan === "object" && !Array.isArray(plan) ? plan : {};
    return (Array.isArray(source.sourcePacket) ? source.sourcePacket : []).filter(item => {
      const id = continuitySourceId(item && item.id);
      return !!(id && /^[SX]/.test(id) && item.relationship === true);
    });
  }

  function derivedRelationshipSourceSummary(plan) {
    const derived = derivedRelationshipSources(plan);
    if (!derived.length) return "None";
    return derived.map(source => source.id + "["
      + ((source.allowedFields || []).join("/") || "no fields")
      + "; gain " + Math.max(0, Number(source.gain) || 0) + "]").join(", ");
  }

  function derivedRelationshipSourcesSupplied(plan) {
    return derivedRelationshipSources(plan).length > 0;
  }

  function derivedViewSources(plan) {
    const source = plan && typeof plan === "object" && !Array.isArray(plan) ? plan : {};
    return (Array.isArray(source.sourcePacket) ? source.sourcePacket : []).filter(item => {
      const id = continuitySourceId(item && item.id);
      return !!(id && ["R", "X"].includes(id.charAt(0)) && item.view === true);
    });
  }

  function derivedViewSourceSummary(plan) {
    const derived = derivedViewSources(plan);
    if (!derived.length) return "None";
    return derived.map(source => source.id + "[gain " + Math.max(0, Number(source.gain) || 0)
      + "; target " + (source.targetKey || "None")
      + "; destinations " + ((source.allowedDestinations || []).join("/") || "model-selected")
      + "; modes " + ((source.allowedModes || []).join("/") || "model-selected") + "]").join(", ");
  }

  function derivedViewSourcesSupplied(plan) {
    return derivedViewSources(plan).length > 0;
  }

  function provenanceStatusSnapshot() {
    refreshProvenanceActivity();
    const counts = {};
    Object.keys(PROVENANCE_KINDS).forEach(prefix => {
      const records = CC.provenance.records.filter(record => record.id.charAt(0) === prefix);
      counts[prefix] = {
        total: records.length,
        active: records.filter(record => record.active).length
      };
    });
    const latest = CC.provenance.records.length
      ? CC.provenance.records[CC.provenance.records.length - 1]
      : null;
    const parsedUses = CC.provenance.records.flatMap(record =>
      provenanceUseSignatures(record.uses).map(parseProvenanceUseSignature).filter(Boolean)
    );
    const relationshipUses = new Set(parsedUses
      .filter(use => use.kind === "relationship").map(use => use.signature)).size;
    const viewUses = new Set(parsedUses
      .filter(use => use.kind === "view").map(use => use.signature)).size;
    return { counts, latest, relationshipUses, viewUses };
  }

  function provenanceDebugRows() {
    const snapshot = provenanceStatusSnapshot();
    const rows = [
      "Provenance creation: " + (CC.last.provenanceCreated || "None"),
      "Provenance counts: " + Object.keys(PROVENANCE_KINDS).map(prefix => prefix + "="
        + snapshot.counts[prefix].active + " active/" + snapshot.counts[prefix].total + " total").join(", "),
      "Derived Relationship sources supplied: " + derivedRelationshipSourceSummary(CC.currentPlan),
      "Derived View sources supplied: " + derivedViewSourceSummary(CC.currentPlan),
      "Relationship source diagnostics: " + ((CC.last.relationshipSourceDiagnostics || []).join("; ") || "None"),
      "Relationship use diagnostics: " + ((CC.last.relationshipUseDiagnostics || []).join("; ") || "None"),
      "Relationship narrow uses stored: " + snapshot.relationshipUses,
      "View source diagnostics: " + ((CC.last.viewSourceDiagnostics || []).join("; ") || "None"),
      "View use diagnostics: " + ((CC.last.viewUseDiagnostics || []).join("; ") || "None"),
      "View narrow uses stored: " + snapshot.viewUses,
      "Provenance transaction diagnostics: " + ((CC.last.provenanceDiagnostics || []).join("; ") || "None")
    ];
    derivedRelationshipSources(CC.currentPlan).forEach(source => {
      rows.push(source.id
        + " derived Relationship source"
        + " | owner " + (source.ownerKey || "None")
        + " | target " + (source.targetKey || "None")
        + " | fields " + ((source.allowedFields || []).join(",") || "None")
        + " | managed " + (source.managedSignature || "None")
        + " | raw lineage " + ((source.rawLineage || []).join(",") || "None")
        + " | gain " + Math.max(0, Number(source.gain) || 0)
        + " | authorisation A only"
        + " | uses " + (Object.keys(source.useSignatures || {}).map(field =>
          field + "=" + source.useSignatures[field]).join(",") || "None"));
    });
    derivedViewSources(CC.currentPlan).forEach(source => {
      rows.push(source.id
        + " derived View source"
        + " | owner " + (source.ownerKey || "None")
        + " | target " + (source.targetKey || "None")
        + " | destinations " + ((source.allowedDestinations || []).join(",") || "None")
        + " | modes " + ((source.allowedModes || []).join(",") || "None")
        + " | managed " + (source.managedSignature || "None")
        + " | raw lineage " + ((source.rawLineage || []).join(",") || "None")
        + " | gain " + Math.max(0, Number(source.gain) || 0)
        + " | category predetermined no"
        + " | uses " + (Object.keys(source.useSignatures || {}).map(interpretation =>
          interpretation + "=" + source.useSignatures[interpretation]).join(",") || "None"));
    });
    CC.provenance.records.slice(-12).reverse().forEach(record => {
      let detail = record.id + " " + record.kind
        + " | active " + (record.active ? "yes" : "no")
        + " | owner " + (record.ownerKey || "None")
        + " | target " + (record.targetKey || "None")
        + " | confirmation " + (record.confirmation || 0)
        + " | sources " + (record.sourceIds.join(",") || "None")
        + " | raw lineage " + (storyLineageForSources(record.sourceIds).join(",") || "None")
        + " | managed " + (record.managedSignature || "None")
        + " | valid " + (managedSignatureStillValid(record) ? "yes" : "no")
        + " | uses " + (provenanceUseSignatures(record.uses).join(" ; ") || "None");
      if (record.kind === "relationship") {
        detail += " | event " + (record.eventKind || "None")
          + " | field " + (record.field || "None")
          + " | change " + record.actualChange
          + " | prior " + (record.priorValue || "None")
          + " | result " + (record.resultingValue || "None")
          + " | stage " + (record.resultingStage || "None")
          + " | pace " + record.paceValue;
      }
      if (record.kind === "view") {
        detail += " | mode " + (record.viewOperationMode || "None")
          + " | severity " + (record.viewSeverity || "None")
          + " | prior category " + (record.priorCategory || "None")
          + " | result category " + (record.resultingCategory || "None")
          + " | prior state " + (record.priorViewState || "None")
          + " | result state " + (record.resultingViewState || "None");
      }
      rows.push(detail);
    });
    return rows;
  }

  function selectedOperationStatus(plan) {
    const source = plan && typeof plan === "object" && !Array.isArray(plan) ? plan : {};
    if (source.operationSelectionFrozen !== true) return "Not scored";
    return operationKindLabel(source.selectedOperationKind) + " | gain "
      + Math.max(0, Number(source.selectedGain) || 0) + " | drain "
      + Math.max(0, Number(source.selectedDrain) || 0) + " | net "
      + (Number(source.selectedNet) || 0);
  }

  function operationCandidateDebugRows(plan) {
    const source = plan && typeof plan === "object" && !Array.isArray(plan) ? plan : {};
    if (source.operationSelectionFrozen !== true) return ["Operation selection: Not scored"];
    const rows = (Array.isArray(source.operationCandidates) ? source.operationCandidates : []).map(candidate => {
      const target = candidate.targetKey || "unspecified";
      const specificity = [candidate.field, candidate.destination].filter(Boolean).join(" → ");
      return "Operation candidate " + operationKindLabel(candidate.kind) + " / " + target
        + (specificity ? " / " + specificity : "")
        + ": gain " + candidate.gain + " | drain " + candidate.drain + " | net " + candidate.net
        + " | relevance " + candidate.currentRelevance + " | last served " + candidate.lastServedOpportunity
        + " | oldest evidence " + (candidate.oldestEvidenceOrder || "none")
        + " | direct " + (candidate.direct ? "yes" : "no")
        + " | derived " + (candidate.derived ? "yes" : "no")
        + " | allowed fields " + ((candidate.allowedFields || []).join(",") || "none")
        + " | sources " + ((candidate.sourceIds || []).join(",") || "none")
        + " | signature " + (candidate.evidenceSignature || "none")
        + " | reasons " + ((candidate.reasons || []).join("; ") || "none");
    });
    rows.push("Operation tie-break: " + (source.operationTieBreak || "None"));
    rows.push("Operation selection reasons: " + ((source.selectionReasons || []).join("; ") || "None"));
    return rows;
  }

  function debugPageTitle(page) {
    return settings.DEBUG_TITLE + (page > 1 ? " " + page : "");
  }

  function debugTitlePage(title) {
    const source = line(title, 260);
    if (source === settings.DEBUG_TITLE) return 1;
    const match = source.match(new RegExp("^" + escapeRegExp(settings.DEBUG_TITLE) + "\\s+(\\d+)$", "i"));
    if (!match) return 0;
    const page = Number(match[1]);
    return Number.isSafeInteger(page) && page >= 2 ? page : 0;
  }

  function debugPageCards() {
    return cards.map(card => ({ card, page: debugTitlePage(titleOf(card)) }))
      .filter(item => item.page > 0)
      .sort((left, right) => left.page - right.page || cardIndex(left.card) - cardIndex(right.card));
  }

  function splitOversizeDebugText(value, maximum, continuationPrefix) {
    const source = line(value, 100000);
    const limit = Math.max(40, Number(maximum) || settings.MAX_DEBUG_CARD_CHARS);
    if (!source) return [];
    if (source.length <= limit) return [source];

    const prefix = line(continuationPrefix, Math.floor(limit / 2));
    const parts = [];
    let remaining = source;
    let first = true;
    while (remaining) {
      const activePrefix = first ? "" : prefix;
      const available = Math.max(20, limit - activePrefix.length);
      if (remaining.length <= available) {
        parts.push(activePrefix + remaining);
        break;
      }
      let splitAt = remaining.lastIndexOf(" ", available);
      if (splitAt < Math.floor(available * 0.55)) splitAt = available;
      const piece = remaining.slice(0, splitAt).trimEnd();
      parts.push(activePrefix + piece);
      remaining = remaining.slice(splitAt).trimStart();
      first = false;
    }
    return parts;
  }

  function splitDebugRow(value) {
    const source = line(value, 100000);
    const maximum = settings.MAX_DEBUG_CARD_CHARS;
    if (!source || source.length <= maximum) return source ? [source] : [];

    const labelMatch = source.match(/^([^:]{1,120}:)\s*(.*)$/);
    const label = labelMatch ? labelMatch[1] : "Debug:";
    const body = labelMatch ? labelMatch[2] : source;
    const separator = body.includes("; ") ? "; " : "";
    if (!separator) {
      return splitOversizeDebugText(source, maximum, label + " (continued): ");
    }

    const items = body.split(separator).map(item => item.trim()).filter(Boolean);
    const rows = [];
    let current = label;
    let continued = false;
    items.forEach(item => {
      const itemPrefix = current === label || current.endsWith(":") ? " " : separator;
      const proposed = current + itemPrefix + item;
      if (proposed.length <= maximum) {
        current = proposed;
        return;
      }
      if (current !== label && !current.endsWith(": ")) rows.push(current);
      const nextLabel = label.slice(0, -1) + " (continued):";
      const next = nextLabel + " " + item;
      if (next.length <= maximum) {
        current = next;
      } else {
        const fragments = splitOversizeDebugText(next, maximum, nextLabel + " ");
        rows.push(...fragments.slice(0, -1));
        current = fragments[fragments.length - 1] || nextLabel;
      }
      continued = true;
    });
    if (current && (current !== label || continued)) rows.push(current);
    return rows;
  }

  function paginateDebugRows(rows) {
    const maximum = settings.MAX_DEBUG_CARD_CHARS;
    const normalized = [];
    (Array.isArray(rows) ? rows : []).forEach(row => {
      splitDebugRow(row).forEach(part => {
        const item = line(part, 100000);
        if (item) normalized.push(item);
      });
    });

    const pages = [];
    let current = [];
    let currentLength = 0;
    normalized.forEach(row => {
      const added = row.length + (current.length ? 1 : 0);
      if (current.length && currentLength + added > maximum) {
        pages.push(current.join("\n"));
        current = [];
        currentLength = 0;
      }
      current.push(row);
      currentLength += row.length + (current.length > 1 ? 1 : 0);
    });
    if (current.length) pages.push(current.join("\n"));
    return pages.length ? pages : ["Debug information is currently unavailable."];
  }

  function removeAllDebugPages() {
    try {
      removeCards(debugPageCards().map(item => item.card));
    } catch (error) {
      debug("Could not remove Debug pages: " + error.message);
    }
  }

  function writeDebugPages(rows) {
    try {
      const entries = paginateDebugRows(rows);
      const keptCards = [];
      let allSaved = true;
      entries.forEach((entry, index) => {
        if (entry.length > settings.MAX_DEBUG_CARD_CHARS) {
          allSaved = false;
          debug("Skipped oversize Debug page " + (index + 1) + ".");
          return;
        }
        const saved = upsertCard(debugPageTitle(index + 1), entry);
        if (saved) keptCards.push(saved);
        else allSaved = false;
      });

      if (!allSaved) return false;
      const stale = debugPageCards().filter(item => !keptCards.some(kept => cardIndex(kept) === cardIndex(item.card)));
      removeCards(stale.map(item => item.card));
      return true;
    } catch (error) {
      debug("Could not write Debug pages: " + error.message);
      return false;
    }
  }

  function writeStatusCard() {
    const rosterSlots = activeNpcRosterStatus();
    const activeNames = (CC.activeKeys || []).map(key => {
      const character = characters.find(item => item.key === key);
      if (!character) return "";
      return character.name + " (" + (currentCastStatus(character) === "main" ? "Main" : "Side") + ")";
    }).filter(Boolean);
    const modelActiveNames = (CC.modelActiveKeys || []).map(key => characters.find(item => item.key === key)?.name || "").filter(Boolean);
    const focusName = characters.find(character => character.key === CC.focusKey)?.name || "None";
    const warning = [runtime.warning, ...activeRosterDiagnostics, ...characterDiscoveryDiagnostics, CC.last.warning, CC.last.error]
      .filter(Boolean).join(" ") || "None";
    const entry = [
      "Active NPC slots: " + rosterSlots,
      "Scene / model / focus: " + (activeNames.join(" → ") || "None") + " / " + (modelActiveNames.join(" → ") || "None") + " / " + focusName,
      "Model omissions: " + ((CC.last.modelOmitted || []).join("; ") || "None"),
      "Cast: " + (characters.map(castStatus).join("; ") || "None") + " | Dynamic " + (runtime.dynamicCast ? "on" : "off"),
      "Names: " + (nameIdentities.map(namesStatus).join("; ") || "None"),
      "Last Name: " + (CC.last.lastName || "None"),
      "State: " + (characters.map(stateStatus).join("; ") || "None"),
      "Relationships: " + (characters.map(relationshipsStatus).join("; ") || "None"),
      "Relationship pace: " + runtime.relationshipPace.name + " | A " + runtime.relationshipPace.accumulated
        + " / D " + runtime.relationshipPace.direct + " | maximum " + runtime.relationshipPace.maxStages
        + " stage" + (runtime.relationshipPace.maxStages === 1 ? "" : "s"),
      "Last Relationship: " + (CC.last.lastRelationship || "None"),
      "Views: " + (characters.map(viewsStatus).join("; ") || "None"),
      "Experiences: " + (characters.map(experiencesStatus).join("; ") || "None"),
      "Evidence: " + (characters.map(pendingEvidenceStatus).join("; ") || "None") + " | Ledger " + CC.evidence.length + "/" + settings.MAX_EVIDENCE_ITEMS,
      "State clock / lifetime: " + CC.stateClock + " / " + runtime.stateLifetime,
      "Story turns / genuine inputs: " + CC.visibleGenerationCount + " / " + CC.inputCount,
      "Last task: " + CC.last.task + (CC.last.owner ? " for " + CC.last.owner : ""),
      "Selected operation: " + selectedOperationStatus(CC.currentPlan),
      "Last operation outcome: " + (CC.last.operationOutcome || "None")
        + " | " + (CC.last.operationDrainChange || "No drain change"),
      "Operation drains: " + CC.operationState.drains.filter(record => Number(record.value) > 0).length
        + "/" + settings.MAX_OPERATION_DRAIN_RECORDS + " active | last decay " + (CC.last.operationDecay || "None"),
      "Provenance: " + (() => {
        const snapshot = provenanceStatusSnapshot();
        return Object.keys(PROVENANCE_KINDS).map(prefix => prefix + "="
          + snapshot.counts[prefix].active + "/" + snapshot.counts[prefix].total).join(", ")
          + " | latest " + (snapshot.latest ? snapshot.latest.id : "None")
          + " | derived Relationship supplied " + derivedRelationshipSourceSummary(CC.currentPlan)
          + " | derived View supplied " + derivedViewSourceSummary(CC.currentPlan)
          + " | Relationship narrow uses " + snapshot.relationshipUses
          + " | View narrow uses " + snapshot.viewUses;
      })(),
      "Last candidate / update: " + CC.last.candidate + " / " + CC.last.update,
      "Last cast progress: " + CC.last.cast,
      "Continuity budget configured / effective / used / headroom: " + runtime.continuityBudget + " / " + CC.last.effectiveBudget + " / " + CC.last.injectedTokens + " / " + CC.last.headroomTokens,
      "Recent Story retained: " + CC.last.recentStoryChars + " characters",
      "Retry / Continue / fallback: " + (CC.last.retry ? "Yes" : "No") + " / " + (CC.last.continue ? "Yes" : "No") + " / " + (CC.last.gracefulFallback ? "Yes" : "No"),
      "Last context: " + CC.last.context,
      "Last output: " + CC.last.output,
      "Warning: " + warning,
      "Version: " + settings.VERSION
    ].join("\n");
    upsertCard(settings.STATUS_TITLE, entry);

    if (!runtime.debug) {
      removeAllDebugPages();
      return;
    }
    const debugRows = [
      "Last task / owner: " + CC.last.task + " / " + (CC.last.owner || "None"),
      "Registered / roster / scene / model / focus: " + characters.length + " / "
        + activeNpcRosterCharacterSlots(false).length + " / " + (activeNames.join(", ") || "None")
        + " / " + (modelActiveNames.join(", ") || "None") + " / " + focusName,
      "Active NPC slots: " + rosterSlots,
      "Active NPC diagnostics: " + (activeRosterDiagnostics.join("; ") || "None"),
      "Identity discovery: " + (characterDiscoveryDiagnostics.join("; ") || "None"),
      "Outer: " + (characters.map(outerStatus).join("; ") || "None"),
      "Names: " + (nameIdentities.map(namesStatus).join("; ") || "None"),
      "Names pages: " + ((namesStore && namesStore.pageStats || []).join("; ") || "None"),
      "Names diagnostics: " + ((namesStore && namesStore.diagnostics || []).join("; ") || "None"),
      "Names repair history: " + ((CC.nameRepairDiagnostics || []).join("; ") || "None"),
      "Names transaction history: " + ((CC.nameTransactionDiagnostics || []).join("; ") || "None"),
      "Selected Names: " + ((CC.last.selectedNames || []).join("; ") || "None"),
      "Omitted Names: " + ((CC.last.omittedNames || []).join("; ") || "None"),
      "Name resolution diagnostics: " + ((CC.last.nameDiagnostics || []).join("; ") || "None"),
      "Last Name: " + (CC.last.lastName || "None"),
      "Inner: " + (characters.map(innerStatus).join("; ") || "None"),
      "Relationships: " + (characters.map(relationshipsStatus).join("; ") || "None"),
      "Relationship pace effective now: " + runtime.relationshipPace.name + " | A " + runtime.relationshipPace.accumulated
        + " / D " + runtime.relationshipPace.direct + " | maximum " + runtime.relationshipPace.maxStages,
      "Relationship pace frozen for operation: " + (CC.currentPlan && CC.currentPlan.relationshipPace
        ? CC.currentPlan.relationshipPace.name + " | A " + CC.currentPlan.relationshipPace.accumulated
          + " / D " + CC.currentPlan.relationshipPace.direct + " | maximum " + CC.currentPlan.relationshipPace.maxStages
        : "None"),
      "Relationships pages: " + ((relationshipsStore && relationshipsStore.pageStats || []).join("; ") || "None"),
      "Relationships diagnostics: " + ((relationshipsStore && relationshipsStore.diagnostics || []).join("; ") || "None"),
      "Relationships repair history: " + ((CC.relationshipRepairDiagnostics || []).join("; ") || "None"),
      "Relationships transaction history: " + ((CC.relationshipTransactionDiagnostics || []).join("; ") || "None"),
      "Selected Relationships: " + ((CC.last.selectedRelationships || []).join("; ") || "None"),
      "Omitted Relationships: " + ((CC.last.omittedRelationships || []).join("; ") || "None"),
      "Last Relationship / change: " + (CC.last.lastRelationship || "None") + " / " + (CC.last.relationshipChange || "None"),
      "Views: " + (characters.map(viewsStatus).join("; ") || "None"),
      "Views pages: " + ((viewsStore && viewsStore.pageStats || []).join("; ") || "None"),
      "Views diagnostics: " + ((viewsStore && viewsStore.diagnostics || []).join("; ") || "None"),
      "Views repair history: " + ((CC.viewRepairDiagnostics || []).join("; ") || "None"),
      "Views transaction history: " + ((CC.viewTransactionDiagnostics || []).join("; ") || "None"),
      "Selected Views: " + ((CC.last.selectedViews || []).join("; ") || "None"),
      "Omitted Views: " + ((CC.last.omittedViews || []).join("; ") || "None"),
      "Experiences: " + (characters.map(experiencesStatus).join("; ") || "None"),
      "Experiences pages: " + ((experiencesStore && experiencesStore.pageStats || []).join("; ") || "None"),
      "Experiences diagnostics: " + ((experiencesStore && experiencesStore.diagnostics || []).join("; ") || "None"),
      "Selected Experiences: " + ((CC.last.selectedExperiences || []).join("; ") || "None"),
      "Omitted Experiences: " + ((CC.last.omittedExperiences || []).join("; ") || "None"),
      "Cast: " + (characters.map(castStatus).join("; ") || "None") + " | Dynamic " + (runtime.dynamicCast ? "on" : "off"),
      "Last cast progress: " + CC.last.cast,
      "Focus last served: " + characters.map(character => character.name + "=" + (CC.focusLastServed[character.key] ?? "never")).join(", "),
      "Conversational carry: " + (characters.find(character => character.key === CC.conversationKey)?.name || "None"),
      "State clock / lifetime: " + CC.stateClock + " / " + runtime.stateLifetime,
      "Owner opportunities: " + characters.map(character => character.name + "=" + (CC.ownerOpportunities[character.key] || 0)).join(", "),
      "Evidence supplied: " + ((CC.last.suppliedEvidence || []).join(", ") || "None"),
      "Targets supplied: " + ((CC.last.suppliedTargets || []).join(", ") || "None"),
      "Evidence diagnostics: " + ((CC.last.evidenceDiagnostics || []).join("; ") || "None"),
      ...provenanceDebugRows(),
      "Operation meters: " + characters.map(character => {
        const ownerState = CC.operationState.owners[character.key] || blankOwnerOperationState();
        return character.name + " [" + OPERATION_KINDS.map(kind => {
          const meter = ownerState[kind] || blankOperationMeter();
          return kind.charAt(0).toUpperCase() + ":" + meter.gain + "/" + meter.drain
            + "/" + (meter.lastResult || "none") + "@" + meter.lastServedOpportunity;
        }).join(" ") + "]";
      }).join("; ") + " | narrow drains " + CC.operationState.drains.length + "/" + settings.MAX_OPERATION_DRAIN_RECORDS,
      "Operation last outcome: " + (CC.last.operationOutcome || "None"),
      "Operation drain change: " + (CC.last.operationDrainChange || "None"),
      "Operation decay: " + (CC.last.operationDecay || "None"),
      "Operation drain records: " + ((CC.operationState.drains || []).map(record =>
        record.ownerKey + "/" + record.kind + "/" + (record.targetKey || "-") + "/"
          + (record.field || "-") + "/" + (record.destination || "-") + "=" + record.value
          + "@" + record.updatedOpportunity + " " + (record.lastResult || "none")
      ).join("; ") || "None"),
      ...operationCandidateDebugRows(CC.currentPlan),
      "Time-jump reset: " + (CC.last.timeJumpReset ? "Yes" : "No"),
      "CCO parse: " + CC.last.protocol,
      "Components: rules " + CC.last.rulesTokens + ", Outer " + CC.last.outerTokens + ", Names " + CC.last.namesTokens + ", Inner " + CC.last.innerTokens + ", State " + CC.last.stateTokens + ", Relationships " + CC.last.relationshipsTokens + ", Views " + CC.last.viewsTokens + ", Experiences " + CC.last.experiencesTokens + ", evidence " + CC.last.evidenceTokens + ", source packet " + CC.last.sourcePacketTokens + ", task " + CC.last.taskTokens,
      "Budget configured / effective / used / headroom: " + runtime.continuityBudget + " / " + CC.last.effectiveBudget + " / " + CC.last.injectedTokens + " / " + CC.last.headroomTokens,
      "Recent Story retained: " + CC.last.recentStoryChars + " characters",
      "Output anchor: " + (CC.lastVisibleOutputAnchor ? "Present" : "None"),
      "Version: " + settings.VERSION
    ];
    const priorityDebugRows = [
      "Error: " + (CC.last.error || "None"),
      "CCO parse: " + CC.last.protocol,
      "Last task / owner: " + CC.last.task + " / " + (CC.last.owner || "None"),
      "Last candidate / update: " + CC.last.candidate + " / " + CC.last.update,
      "Operation outcome / drain: " + (CC.last.operationOutcome || "None") + " / " + (CC.last.operationDrainChange || "None"),
      "Last Name: " + (CC.last.lastName || "None"),
      "Last Relationship / change: " + (CC.last.lastRelationship || "None") + " / " + (CC.last.relationshipChange || "None")
    ];
    const repeatedPriorityLabels = [
      "Error:", "CCO parse:", "Last task / owner:", "Last candidate / update:", "Operation outcome / drain:",
      "Last Name:", "Last Relationship / change:"
    ];
    writeDebugPages(priorityDebugRows.concat(debugRows.filter(row =>
      !repeatedPriorityLabels.some(label => textOf(row).startsWith(label))
    )));
  }

  if (hook === "input") {
    beginInput(originalText);
    writeAllStateCards();
    writeStatusCard();
    return finish(originalText);
  }

  if (hook === "context") {
    const result = buildContext();
    writeAllStateCards();
    writeStatusCard();
    return finish(result);
  }

  if (hook === "output") {
    const result = processOutput(originalText);
    writeAllStateCards();
    writeStatusCard();
    return finish(result);
  }

  writeStatusCard();
  return finish(originalText);
}
