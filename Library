    const activeTargetKeys = new Set(active.filter(character => character.key !== owner.key).map(character => "npc:" + character.key));
    return records.map(record => {
      let score = 0;
      if (recordMentioned(record, owner, currentInput)) score = Math.max(score, 1000);
      if (recordMentioned(record, owner, evidenceText)) score = Math.max(score, 900);
      if (record.targetKey === "player" && (interactionScore(owner, currentInput) > 0 || CC.conversationKey === owner.key)) {
        score = Math.max(score, 800);
      }
      if (activeTargetKeys.has(record.targetKey) && recordMentioned(record, owner, currentInput + "\n" + recent)) {
        score = Math.max(score, 700);
