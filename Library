  CC.stateClock = Math.max(0, Number(CC.stateClock) || 0);

  function characterForActiveRosterName(name) {
    const matches = characters.filter(character => sameNameForm(character.name, name));
    return matches.length === 1 ? matches[0] : null;
  }

  function initializeActiveNpcRoster() {
    if (activeNpcRoster.card) return;
    const chosen = [];
    const addCharacter = character => {
      if (!character || character.onboardingPending || chosen.some(item => item.key === character.key)
        || chosen.length >= settings.MAX_ACTIVE_NPCS) return;
      chosen.push(character);
    };
    (Array.isArray(CC.activeKeys) ? CC.activeKeys : []).forEach(key => {
      addCharacter(characters.find(character => character.key === key));
    });
    characters.forEach(addCharacter);
    activeNpcRoster.slots.forEach((slot, index) => {
      slot.name = chosen[index] ? chosen[index].name : "";
      slot.valid = true;
    });
    const entry = activeNpcRosterEntry(activeNpcRoster.slots.map(slot => slot.name));
    const saved = addCard(settings.ACTIVE_NPCS_TITLE, entry);
    activeNpcRoster.card = saved;
    activeNpcRoster.source = entry;
    activeNpcRoster.wrapperValid = true;
    if (!saved) {
      activeRosterDiagnostics.push("CC — Active NPCs could not be created; its seeded in-memory roster is temporary.");
    } else if (characters.length > chosen.length) {
      activeRosterDiagnostics.push("CC — Active NPCs was seeded with " + chosen.length
        + " of " + characters.length + " registered NPCs; preserved NPCs outside the five slots can be reconnected manually.");
    }
  }

  function removeOnboardingMarker(card) {
    if (!card || !onboardingMarkerPresent(entryOf(card))) return card;
    const entry = textOf(entryOf(card)).replace(/\r/g, "").split("\n")
      .filter(row => !/^[ \\t]*Onboarding[ \\t]*:[ \\t]*Pending[ \\t]*$/i.test(row))
      .join("\n");
    return saveCard(card, entry);
  }

  function finalizeReadyOnboardingTemplates() {
    characters.filter(character => character.onboardingGenerated && !character.onboardingPending)
      .forEach(character => {
        const outerSaved = removeOnboardingMarker(character.outerCard);
        const innerSaved = removeOnboardingMarker(character.innerCard);
        if (outerSaved) character.outerCard = outerSaved;
        if (innerSaved) character.innerCard = innerSaved;
        if (outerSaved && innerSaved) {
          activeRosterDiagnostics.push(character.name + " onboarding completed; Outer and Inner are creator-authored and active.");
        } else {
          activeRosterDiagnostics.push(character.name + " is ready, but a Pending marker could not be cleared from its template.");
        }
      });
  }

  function activeNpcRosterCharacterSlots(includePending) {
    const used = new Set();
    return activeNpcRoster.slots.map(slot => {
      if (!slot || !slot.valid || !slot.name) return null;
      const character = characterForActiveRosterName(slot.name);
      if (!character || used.has(character.key)) return null;
      if (!includePending && character.onboardingPending) return null;
      used.add(character.key);
      return { number: slot.number, code: slot.code, name: character.name, character };
    }).filter(Boolean);
  }

  function activeNpcRosterCharacters() {
    return activeNpcRosterCharacterSlots(false).map(item => item.character);
  }

  function activeNpcRosterStatus() {
    return activeNpcRoster.slots.map(slot => {
      if (!slot.valid) return slot.code + "=Invalid";
      if (!slot.name) return slot.code + "=Empty";
      const character = characterForActiveRosterName(slot.name);
      if (!character) return slot.code + "=" + slot.name + " (Pending)";
      return slot.code + "=" + character.name + (character.onboardingPending ? " (Pending)" : "");
    }).join(", ");
  }

  initializeActiveNpcRoster();
  finalizeReadyOnboardingTemplates();

  function numberedNamedTitleParts(title, label) {
    const match = line(title, 260).match(new RegExp(
      "^(.+?)\\s+(?:—|–|-)\\s+" + escapeRegExp(label) + "(?:\\s+(\\d+))?$",
      "i"
    ));
    if (!match) return null;
    const page = match[2] ? Number(match[2]) : 1;
    if (match[2] && page === 1) return null;
    return Number.isSafeInteger(page) && page >= 1
      ? { owner: line(match[1], 120), page }
      : null;
  }

  function viewPageTitle(character, buried, page) {
    const label = buried
      ? settings.BURIED_VIEWS_LABEL
      : settings.VIEWS_LABEL;
    return namedTitle(character.name, label) + (page > 1 ? " " + page : "");
  }

  function viewPageHeader(character, buried, page) {
    return character.name + "'s " + (buried ? "Buried Views" : "Views") + (page > 1 ? " " + page : "") + ":";
  }

  function renderViewsPage(character, buried, page, records) {
    const grouped = {};
    VIEW_CATEGORIES.forEach(category => { grouped[category] = []; });
    (Array.isArray(records) ? records : []).forEach(record => {
      if (grouped[record.category]) grouped[record.category].push(record);
    });
    const rows = ["{", viewPageHeader(character, buried, page)];
    VIEW_CATEGORIES.forEach(category => {
      rows.push(category + ":");
      grouped[category].forEach(record => {
        rows.push(record.targetName + " — " + record.explanation);
      });
    });
    rows.push("}");
    return rows.join("\n");
  }

  function emptyViewsEntry(character, buried, page) {
    return renderViewsPage(character, buried, page, []);
  }

  function canonicalViewTarget(owner, value) {
    const supplied = line(value, 160);
    const normalized = nameKeyOf(supplied);
    if (!normalized) return null;
    if (normalized === "self") return { key: "self", name: "Self" };
    if (["player", "the player", "you"].includes(normalized)) {
      return { key: "player", name: "Player" };
    }
    const matches = identityReferenceMatches(supplied, false);
    if (matches.length > 1) return null;
    if (matches.length === 1) {
      const identity = matches[0];
      if (owner && identity.character && identity.character.key === owner.key) {
        return { key: "self", name: "Self" };
      }
      return identity.player
        ? { key: "player", name: "Player" }
        : { key: "npc:" + identity.character.key, name: identity.character.name };
    }
    return { key: "target:" + keyOf(supplied), name: supplied };
  }

  function storedTargetName(targetKey, fallbackName) {
    const key = normalizedTargetKey(targetKey);
    if (key === "self") return "Self";
    if (key === "player") return "Player";
    if (key.startsWith("npc:")) {
      const character = characters.find(item => "npc:" + item.key === key);
      if (character) return character.name;
    }
    return line(fallbackName, 120);
  }

  function modelTargetName(targetKey, fallbackName) {
    const key = normalizedTargetKey(targetKey);
    if (key === "player") return player.name;
    return storedTargetName(key, fallbackName);
  }

  function viewTargetAliases(record, owner) {
    if (!record) return [];
    if (record.targetKey === "self") return uniqueNameForms(["Self", owner && owner.name].concat(owner && owner.aliases || []), 160);
    if (record.targetKey === "player") return uniqueNameForms(["Player", "the player", "you", player.name].concat(player.aliases || []), 160);
    if (record.targetKey.startsWith("npc:")) {
      const character = characters.find(item => "npc:" + item.key === record.targetKey);
      return character ? character.aliases : [record.targetName];
    }
    return [record.targetName];
  }

  function parseViewsPage(character, card, buried, page) {
    const source = entryOf(card).replace(/\r/g, "");
    const trimmed = source.trim();
    const rows = source.split("\n");
    const expectedHeader = nameKeyOf(viewPageHeader(character, buried, page));
    const headingsSeen = new Set();
    const records = [];
    const invalid = [];
    let currentCategory = "";
    let headerSeen = false;
    rows.forEach((raw, index) => {
      const row = raw.trim();
      if (!row || row === "{" || row === "}") return;
      const withoutBrace = row.replace(/^\{\s*/, "").replace(/\s*\}$/, "").trim();
      if (!headerSeen && nameKeyOf(withoutBrace) === expectedHeader) {
        headerSeen = true;
        return;
      }
      const category = VIEW_CATEGORIES.find(item => keyOf(item + ":") === keyOf(withoutBrace));
      if (category) {
        currentCategory = category;
        headingsSeen.add(category);
        return;
      }
      const match = withoutBrace.match(/^(.+?)\s+(?:—|–|-)\s+(.+)$/);
      if (!currentCategory || !match) {
        invalid.push({ line: index + 1, text: line(raw, 240), reason: currentCategory ? "invalid record" : "unheaded content" });
        return;
      }
      const target = canonicalViewTarget(character, match[1]);
      const explanation = wholeLine(match[2], 0);
      if (!target || !explanation) {
        invalid.push({ line: index + 1, text: line(raw, 240), reason: "empty target or explanation" });
        return;
      }
      const record = {
        targetKey: target.key,
        targetName: target.name,
        category: currentCategory,
        explanation,
        buried: !!buried,
        page,
        card,
        line: index + 1,
        duplicate: false,
        conflict: false,
        oversize: false,
        writable: true
      };
      const emptyLength = renderViewsPage(character, buried, 1, [record]).length;
      if (emptyLength > settings.MAX_VIEWS_CARD_CHARS) record.oversize = true;
      records.push(record);
    });
    const wrapperValid = trimmed.startsWith("{") && trimmed.endsWith("}") && headerSeen;
    const headingsValid = VIEW_CATEGORIES.every(category => headingsSeen.has(category));
    const safe = invalid.length === 0;
    records.forEach(record => { record.writable = safe; });
    return {
      card, page, buried: !!buried, title: titleOf(card), source, records, invalid,
      wrapperValid, headingsValid, safe,
      chars: source.length
    };
  }

  function viewPageCards(character, buried) {
    const label = buried
      ? settings.BURIED_VIEWS_LABEL
      : settings.VIEWS_LABEL;
    return cards.map(card => {
      const parts = numberedNamedTitleParts(titleOf(card), label);
      return parts && nameKeyOf(parts.owner) === character.key
        ? { card, page: parts.page }
        : null;
    }).filter(Boolean).sort((left, right) => left.page - right.page || cards.indexOf(left.card) - cards.indexOf(right.card));
  }

  function ensureBaseViewsCard(character) {
    const existing = viewPageCards(character, false).find(item => item.page === 1);
    if (existing) return existing.card;
    return addCard(viewPageTitle(character, false, 1), emptyViewsEntry(character, false, 1));
  }

  function nextViewsPageNumber(pages) {
    return Math.max(0, ...(Array.isArray(pages) ? pages.map(page => page.page) : [])) + 1;
  }

  function markViewDuplicates(pages, diagnostics, collectionName) {
    const groups = {};
    pages.forEach(page => page.records.forEach(record => {
      if (!groups[record.targetKey]) groups[record.targetKey] = [];
      groups[record.targetKey].push(record);
    }));
    Object.keys(groups).forEach(targetKey => {
      const records = groups[targetKey];
      if (records.length < 2) return;
      const signatures = [];
      records.forEach(record => {
        const signature = keyOf(record.category) + "|" + keyOf(record.explanation);
        const prior = signatures.find(item => item.signature === signature);
        if (prior) record.duplicate = true;
        else signatures.push({ signature, record });
      });
      if (signatures.length > 1) {
        records.forEach(record => { record.conflict = true; });
        diagnostics.push(collectionName + " has conflicting records for " + records[0].targetName + ".");
      } else if (records.some(record => record.duplicate)) {
        diagnostics.push(collectionName + " consolidated an exact duplicate for " + records[0].targetName + ".");
      }
    });
  }

  function markDuplicateViewPages(character, buried, pages, diagnostics) {
    const counts = {};
    pages.forEach(page => { counts[page.page] = (counts[page.page] || 0) + 1; });
    const duplicatePageNumbers = Object.keys(counts)
      .map(Number)
      .filter(pageNumber => counts[pageNumber] > 1);
    duplicatePageNumbers.forEach(pageNumber => diagnostics.push(
      viewPageTitle(character, buried, pageNumber) + " has duplicate physical pages and was left unchanged."
    ));
    pages.forEach(page => {
      page.duplicatePage = duplicatePageNumbers.includes(page.page);
      if (!page.duplicatePage) return;
      page.safe = false;
      page.records.forEach(record => { record.writable = false; });
    });
  }

  function repairViewsCollection(character, buried, pages, diagnostics) {
    const maximum = settings.MAX_VIEWS_CARD_CHARS;
    let changed = false;
    const movablePages = pages.filter(page => page.safe && !page.duplicatePage);
    const oversizedPages = movablePages.filter(page => page.records.some(record => record.oversize));
    oversizedPages.forEach(page => page.records.filter(record => record.oversize).forEach(record => {
      diagnostics.push(page.title + " has an oversized record for " + record.targetName + "; it was preserved and excluded.");
    }));
    const repairablePages = movablePages.filter(page => !oversizedPages.includes(page));
    repairablePages.forEach(page => {
      page.records = page.records.filter(record => !record.duplicate);
      page.records.forEach(record => {
        if (record.conflict || record.oversize || !record.writable) return;
        const corrected = correctedViewExplanation(record.explanation, record.category);
        if (!corrected || corrected === record.explanation) return;
        record.explanation = corrected;
        diagnostics.push("Aligned " + character.name + "→" + record.targetName
          + " View explanation with the managed " + record.category + " category.");
        changed = true;
      });
    });

    const overflow = [];
    repairablePages.forEach(page => {
      while (renderViewsPage(character, buried, page.page, page.records).length > maximum && page.records.length) {
        overflow.unshift(page.records.pop());
      }
    });
    overflow.forEach(record => {
      let destination = repairablePages.find(page => {
        const candidate = page.records.concat({ ...record, page: page.page, card: page.card });
        return renderViewsPage(character, buried, page.page, candidate).length <= maximum;
      });
      if (!destination) {
        const pageNumber = nextViewsPageNumber(pages);
        const title = viewPageTitle(character, buried, pageNumber);
        const card = addCard(title, emptyViewsEntry(character, buried, pageNumber));
        if (!card) {
          diagnostics.push("Could not create " + title + " while redistributing whole records.");
          return;
        }
        destination = {
          card, page: pageNumber, buried: !!buried, title, source: entryOf(card), records: [], invalid: [],
          wrapperValid: true, headingsValid: true, safe: true, chars: entryOf(card).length
        };
        pages.push(destination);
        repairablePages.push(destination);
      }
      record.page = destination.page;
      record.card = destination.card;
      destination.records.push(record);
    });

    repairablePages.forEach(page => {
      const entry = renderViewsPage(character, buried, page.page, page.records);
      if (entry !== entryOf(page.card)) {
        const saved = saveCard(page.card, entry);
        if (saved) {
          page.card = saved;
          page.records.forEach(record => { record.card = page.card; });
          diagnostics.push("Repaired " + page.title + " structurally.");
          changed = true;
        } else {
          diagnostics.push("Could not repair " + page.title + " through the Story Card API.");
        }
      }
    });
    return changed || overflow.length > 0;
  }

  let viewsStore = null;

  function refreshViewsStore(repair) {
    const store = { owners: {}, diagnostics: [], pageStats: [] };
    characters.forEach(character => {
      ensureBaseViewsCard(character);
      const activeRefs = viewPageCards(character, false);
      const buriedRefs = viewPageCards(character, true);
      const activePages = activeRefs.map(ref => parseViewsPage(character, ref.card, false, ref.page));
      const buriedPages = buriedRefs.map(ref => parseViewsPage(character, ref.card, true, ref.page));
      markDuplicateViewPages(character, false, activePages, store.diagnostics);
      markDuplicateViewPages(character, true, buriedPages, store.diagnostics);
      markViewDuplicates(activePages, store.diagnostics, character.name + " active Views");
      markViewDuplicates(buriedPages, store.diagnostics, character.name + " buried Views");
      activePages.concat(buriedPages).forEach(page => {
        if (textOf(page.card.type) !== settings.CARD_TYPE) {
          page.card = saveCard(page.card, entryOf(page.card)) || page.card;
        }
        page.records.forEach(record => { record.card = page.card; });
        if (!page.wrapperValid) store.diagnostics.push(page.title + " wrapper was missing or mismatched.");
        if (!page.headingsValid) store.diagnostics.push(page.title + " was missing one or more category headings.");
        page.invalid.forEach(item => store.diagnostics.push(page.title + " line " + item.line + " contained " + item.reason + "."));
        page.records.filter(record => record.oversize).forEach(record => store.diagnostics.push(
          page.title + " has an oversized record for " + record.targetName + "; it was preserved and excluded."
        ));
        store.pageStats.push(page.title + " " + page.chars + "/" + settings.MAX_VIEWS_CARD_CHARS
          + " chars, " + page.records.length + " records" + (page.safe ? "" : ", unsafe"));
      });
      store.owners[character.key] = {
        character,
        activePages,
        buriedPages,
        activeRecords: activePages.flatMap(page => page.records).filter(record => record.writable && !record.duplicate && !record.conflict && !record.oversize),
        buriedRecords: buriedPages.flatMap(page => page.records).filter(record => record.writable && !record.duplicate && !record.conflict && !record.oversize)
      };
    });

    if (repair) {
      const priorBindings = viewManagedBindings(store);
      let changed = false;
      characters.forEach(character => {
        const owner = store.owners[character.key];
        changed = repairViewsCollection(character, false, owner.activePages, store.diagnostics) || changed;
        changed = repairViewsCollection(character, true, owner.buriedPages, store.diagnostics) || changed;
      });
      if (changed) {
        const repaired = refreshViewsStore(false);
        const nextBindings = viewManagedBindings(repaired);
        priorBindings.forEach(prior => {
          const next = nextBindings.find(item => item.ownerKey === prior.ownerKey
            && item.targetKey === prior.targetKey);
          if (!next || next.signature === prior.signature) return;
          const rebound = rebindViewExplanationProvenance(
            prior.ownerKey,
            prior.targetKey,
            prior.signature,
            next.signature,
            next.category
          );
          if (rebound) {
            store.diagnostics.push("Rebound " + rebound + " View provenance record"
              + (rebound === 1 ? "" : "s") + " after deterministic explanation alignment.");
          }
        });
        CC.viewRepairDiagnostics = unique(CC.viewRepairDiagnostics.concat(store.diagnostics), 300).slice(-30);
        repaired.diagnostics = unique(store.diagnostics.concat(repaired.diagnostics), 300);
        return repaired;
      }
    }
    viewsStore = store;
    return store;
  }

  function viewsForOwner(ownerKey) {
    return viewsStore && viewsStore.owners ? viewsStore.owners[ownerKey] || null : null;
  }

  function canonicalManagedViewRecord(record) {
    if (!record) return null;
    const category = canonicalViewDestination(record.category);
    const explanation = line(record.explanation, 2000);
    if (!category || !explanation) return null;
    return [category, hashString(explanation)];
  }

  function viewManagedSignature(ownerKey, targetKey, activeRecord, buriedRecord, recovering) {
    const normalizedOwner = line(ownerKey, 160);
    const normalizedTarget = normalizedTargetKey(targetKey);
    const active = canonicalManagedViewRecord(activeRecord);
    const buried = canonicalManagedViewRecord(buriedRecord);
    const recoveringFlag = recovering === true && !!active && !!buried;
    if (recovering === true && !recoveringFlag) return "";
    if (!normalizedOwner || !normalizedTarget || (!active && !buried && !recoveringFlag)) return "";
    return line(JSON.stringify([
      "view",
      normalizedOwner,
      normalizedTarget,
      active,
      buried,
      recoveringFlag
    ]), 500);
  }

  function currentViewManagedSignature(ownerKey, targetKey) {
    const normalizedTarget = normalizedTargetKey(targetKey);
    if (!ownerKey || !normalizedTarget) return "";
    const ownerData = viewsForOwner(ownerKey);
    if (!ownerData) return "";
    const active = ownerData.activeRecords.find(record => record.targetKey === normalizedTarget) || null;
    const buried = ownerData.buriedRecords.find(record => record.targetKey === normalizedTarget) || null;
    const recovering = !!recoveringMarker(ownerKey, normalizedTarget) && !!active && !!buried;
    return viewManagedSignature(ownerKey, normalizedTarget, active, buried, recovering);
  }

  function viewManagedBindings(store) {
    const bindings = [];
    Object.values(store && store.owners || {}).forEach(ownerData => {
      const ownerKey = ownerData.character && ownerData.character.key;
      if (!ownerKey) return;
      const targetKeys = unique(
        (ownerData.activeRecords || []).concat(ownerData.buriedRecords || [])
          .map(record => record.targetKey),
        200
      );
      targetKeys.forEach(targetKey => {
        const active = (ownerData.activeRecords || []).find(record => record.targetKey === targetKey) || null;
        const buried = (ownerData.buriedRecords || []).find(record => record.targetKey === targetKey) || null;
        const recovering = !!recoveringMarker(ownerKey, targetKey) && !!active && !!buried;
        const signature = viewManagedSignature(ownerKey, targetKey, active, buried, recovering);
        if (!signature) return;
        bindings.push({
          ownerKey,
          targetKey,
          signature,
          category: active && active.category || buried && buried.category || ""
        });
      });
    });
    return bindings;
  }

  function viewManagedStateSnapshot(ownerKey, targetKey) {
    const normalizedTarget = normalizedTargetKey(targetKey);
    if (!ownerKey || !normalizedTarget) {
      return {
        ownerKey: line(ownerKey, 160), targetKey: normalizedTarget,
        activeCategory: "", buriedCategory: "",
        activeExplanation: "", buriedExplanation: "",
        recovering: false, signature: "", description: "Absent"
      };
    }
    refreshViewsStore(false);
    const ownerData = viewsForOwner(ownerKey);
    const active = ownerData && ownerData.activeRecords.find(record => record.targetKey === normalizedTarget) || null;
    const buried = ownerData && ownerData.buriedRecords.find(record => record.targetKey === normalizedTarget) || null;
    const recovering = !!recoveringMarker(ownerKey, normalizedTarget) && !!active && !!buried;
    const activeCategory = active ? canonicalViewDestination(active.category) : "";
    const buriedCategory = buried ? canonicalViewDestination(buried.category) : "";
    const parts = [];
    if (activeCategory) parts.push("Active " + activeCategory);
    if (buriedCategory) parts.push("Buried " + buriedCategory);
    if (recovering) parts.push("Recovering");
    return {
      ownerKey: line(ownerKey, 160),
      targetKey: normalizedTarget,
      activeCategory,
      buriedCategory,
      activeExplanation: active ? line(active.explanation, 2000) : "",
      buriedExplanation: buried ? line(buried.explanation, 2000) : "",
      recovering,
      signature: viewManagedSignature(ownerKey, normalizedTarget, active, buried, recovering),
      description: parts.join(" + ") || "Absent"
    };
  }

  function managedViewsCard(card) {
    const title = titleOf(card);
    return !!characters.some(character => {
      const active = numberedNamedTitleParts(title, settings.VIEWS_LABEL);
      const buried = numberedNamedTitleParts(title, settings.BURIED_VIEWS_LABEL);
      return (active && nameKeyOf(active.owner) === character.key)
        || (buried && nameKeyOf(buried.owner) === character.key);
    });
  }

  function captureManagedViewsCards() {
    const titleCounts = {};
    return cards.filter(managedViewsCard).map(card => {
      const title = titleOf(card);
      const titleKey = nameKeyOf(title);
      const occurrence = titleCounts[titleKey] || 0;
      titleCounts[titleKey] = occurrence + 1;
      return {
        title,
        occurrence,
        entry: entryOf(card),
        keys: card.keys,
        type: card.type
      };
    });
  }

  function restoreManagedViewsCards(snapshot) {
    if (!Array.isArray(snapshot)) return false;
    const existing = cards.filter(managedViewsCard);
    const pools = {};
    existing.forEach(card => {
      const titleKey = nameKeyOf(titleOf(card));
      if (!pools[titleKey]) pools[titleKey] = [];
      pools[titleKey].push(card);
    });
    const used = new Set();
    const restoredCounts = {};
    let restored = true;
    snapshot.forEach(item => {
      const titleKey = nameKeyOf(item.title);
      const fallbackOccurrence = restoredCounts[titleKey] || 0;
      const occurrence = Number.isSafeInteger(item.occurrence) && item.occurrence >= 0
        ? item.occurrence
        : fallbackOccurrence;
      restoredCounts[titleKey] = fallbackOccurrence + 1;
      let card = pools[titleKey] && pools[titleKey][occurrence];
      if (!card) card = addCard(item.title, item.entry);
      if (!card) {
        restored = false;
        return;
      }
      used.add(card);
      const index = cardIndex(card);
      if (!updateCardAt(index, item.keys, item.entry, item.type)) restored = false;
    });
    if (!removeCards(existing.filter(card => !used.has(card)))) restored = false;
    refreshViewsStore(false);
    return restored;
  }

  function plannedViewsPages(ownerData, buried) {
    const source = buried ? ownerData.buriedPages : ownerData.activePages;
    return source.map(page => ({
      card: page.card,
      page: page.page,
      title: page.title,
      safe: page.safe,
      dirty: false,
      created: false,
      records: page.records.map(record => ({ ...record }))
    }));
  }

  function plannedRecord(pages, targetKey) {
    for (const page of pages) {
      const record = page.records.find(item => item.targetKey === targetKey && !item.duplicate && !item.conflict && !item.oversize);
      if (record) return { page, record };
    }
    return null;
  }

  function plannedPageFits(character, buried, page, records) {
    return renderViewsPage(character, buried, page.page, records).length
      <= settings.MAX_VIEWS_CARD_CHARS;
  }

  function createPlannedPage(character, buried, pages) {
    const pageNumber = nextViewsPageNumber(pages);
    const page = {
      card: null,
      page: pageNumber,
      title: viewPageTitle(character, buried, pageNumber),
      safe: true,
      dirty: true,
      created: true,
      records: []
    };
    pages.push(page);
    pages.sort((left, right) => left.page - right.page);
    return page;
  }

  function placePlannedRecord(character, buried, pages, record, preferredPage) {
    const candidates = pages.filter(page => page.safe).sort((left, right) => {
      const leftPreferred = left.page === preferredPage ? 1 : 0;
      const rightPreferred = right.page === preferredPage ? 1 : 0;
      return rightPreferred - leftPreferred || left.page - right.page;
    });
    let destination = candidates.find(page => plannedPageFits(character, buried, page, page.records.concat(record)));
    if (!destination) destination = createPlannedPage(character, buried, pages);
    if (!plannedPageFits(character, buried, destination, destination.records.concat(record))) {
      return { ok: false, error: "The complete View record cannot fit an empty 1,000-character page." };
    }
    const placed = { ...record, buried: !!buried, page: destination.page, card: destination.card };
    destination.records.push(placed);
    destination.dirty = true;
    return { ok: true, page: destination, record: placed };
  }

  function removePlannedRecord(found) {
    if (!found || !found.page || !found.record) return false;
    const index = found.page.records.indexOf(found.record);
    if (index < 0) return false;
    found.page.records.splice(index, 1);
    found.page.dirty = true;
    return true;
  }

  function updatePlannedRecord(character, buried, pages, found, changes) {
    if (!found || !found.page.safe || !found.record.writable) {
      return { ok: false, error: "The target record belongs to a structurally unsafe page." };
    }
    const updated = { ...found.record, ...changes };
    const index = found.page.records.indexOf(found.record);
    const samePage = found.page.records.slice();
    samePage[index] = updated;
    if (plannedPageFits(character, buried, found.page, samePage)) {
      found.page.records = samePage;
      found.page.dirty = true;
      updated.page = found.page.page;
      updated.card = found.page.card;
      return { ok: true, page: found.page, record: updated };
    }
    removePlannedRecord(found);
    return placePlannedRecord(character, buried, pages, updated, 0);
  }

  function commitPlannedViews(character, activePages, buriedPages) {
    const pageSets = [
      { buried: false, pages: activePages },
      { buried: true, pages: buriedPages }
    ];
    const createdCards = [];
    const priorEntries = [];
    try {
      for (const set of pageSets) {
        for (const page of set.pages.filter(item => item.dirty && item.created)) {
          const entry = renderViewsPage(character, set.buried, page.page, page.records);
          if (entry.length > settings.MAX_VIEWS_CARD_CHARS) {
            throw new Error(page.title + " exceeded the 1,000-character hard limit.");
          }
          const card = addCard(page.title, entry);
          if (!card) throw new Error("Could not create " + page.title + ".");
          page.card = card;
          createdCards.push(card);
        }
      }
      for (const set of pageSets) {
        for (const page of set.pages.filter(item => item.dirty && !item.created)) {
          const entry = renderViewsPage(character, set.buried, page.page, page.records);
          if (entry.length > settings.MAX_VIEWS_CARD_CHARS) {
            throw new Error(page.title + " exceeded the 1,000-character hard limit.");
          }
          priorEntries.push({
            index: cardIndex(page.card),
            entry: entryOf(page.card),
            keys: page.card.keys,
            type: page.card.type
          });
          const saved = saveCard(page.card, entry);
          if (!saved) throw new Error("Could not update " + page.title + ".");
          page.card = saved;
          page.records.forEach(record => { record.card = page.card; });
        }
      }
    } catch (error) {
      priorEntries.slice().reverse().forEach(item => {
        updateCardAt(item.index, item.keys, item.entry, item.type);
      });
      removeCards(createdCards);
      refreshViewsStore(false);
      return { ok: false, error: error.message || "The Views card transaction failed." };
    }
    refreshViewsStore(false);
    return { ok: true };
  }

  function transactViews(owner, operation) {
    refreshViewsStore(false);
    const ownerData = viewsForOwner(owner.key);
    if (!ownerData) return { ok: false, error: "The fixed owner had no managed Views collection." };
    const activePages = plannedViewsPages(ownerData, false);
    const buriedPages = plannedViewsPages(ownerData, true);
    const result = operation({ activePages, buriedPages });
    if (!result || !result.ok) return result || { ok: false, error: "The Views mutation was invalid." };
    const committed = commitPlannedViews(owner, activePages, buriedPages);
    return committed.ok ? result : committed;
  }

  const NAME_STATUSES = ["Emerging", "Active", "Retired", "Rejected"];

  function allNameIdentities() {
    return [{
      key: "player",
      canonical: player.name,
      titleBase: "Player",
      headerOwner: "Player",
      player: true,
      character: null
    }].concat(characters.map(character => ({
      key: "npc:" + character.key,
      canonical: character.name,
      titleBase: character.name,
      headerOwner: character.name,
      player: false,
      character
    })));
  }

  const nameIdentities = allNameIdentities();

  function nameIdentityForKey(identityKey) {
    return nameIdentities.find(identity => identity.key === identityKey) || null;
  }

  function namePageTitle(identity, page) {
    return namedTitle(identity.titleBase, settings.NAMES_LABEL) + (page > 1 ? " " + page : "");
  }

  function namePageHeader(identity) {
    return identity.headerOwner + "'s Names:";
  }

  function canonicalPermission(value) {
    const supplied = line(value, 160);
    const normalized = nameKeyOf(supplied);
    if (!normalized) return null;
    if (normalized === "general") return { key: "general", name: "General" };
    if (normalized === "none") return { key: "none", name: "None" };
    if (["player", "the player", "you"].includes(normalized)) {
      return { key: "player", name: "Player" };
    }
    const matches = [];
    if (nameKeyOf(player.name) === normalized) matches.push({ key: "player", name: "Player" });
    characters.filter(character => nameKeyOf(character.name) === normalized)
      .forEach(character => matches.push({ key: "npc:" + character.key, name: character.name }));
    return matches.length === 1 ? matches[0] : null;
  }

  function parseNameUse(value) {
    const raw = line(value, 2000);
    if (!raw) return { safe: false, raw, normalized: raw, reason: "missing Use permission" };
    const supplied = raw.split(/\s*,\s*/).filter(Boolean);
    const permissions = supplied.map(canonicalPermission);
    if (!permissions.length || permissions.some(permission => !permission)) {
      return { safe: false, raw, normalized: raw, reason: "unknown or ambiguous Use permission" };
    }
    const keys = new Set(permissions.map(permission => permission.key));
    if ((keys.has("general") || keys.has("none")) && keys.size > 1) {
      return { safe: false, raw, normalized: raw, reason: "General or None was mixed with named permissions" };
    }
    const uniquePermissions = [];
    permissions.forEach(permission => {
      if (!uniquePermissions.some(existing => existing.key === permission.key)) uniquePermissions.push(permission);
    });
    const normalized = uniquePermissions.map(permission => permission.name).join(", ");
    return { safe: true, raw, normalized, permissions: uniquePermissions, corrected: raw !== normalized };
  }

  function parseNameProgress(value) {
    const raw = line(value, 2000);
    if (!raw) return { safe: true, raw: "", normalized: "", progress: [], corrected: false };
    const threshold = settings.NAME_ESTABLISHMENT_CONFIRMATIONS;
    const segments = raw.split(/\s*;\s*/).filter(Boolean);
    const progress = [];
    for (const segment of segments) {
      const bare = segment.match(/^(\d+)\s*\/\s*(\d+)$/);
      const named = segment.match(/^(.+?)\s+(\d+)\s*\/\s*(\d+)$/);
      const permissionText = bare ? "General" : (named ? named[1] : "");
      const count = Number(bare ? bare[1] : (named && named[2]));
      const suppliedThreshold = Number(bare ? bare[2] : (named && named[3]));
      const permission = canonicalPermission(permissionText);
      if (!permission || permission.key === "none" || !Number.isSafeInteger(count)
        || count < 1 || count >= threshold || suppliedThreshold !== threshold) {
        return { safe: false, raw, normalized: raw, reason: "invalid alias establishment Progress" };
      }
      const existing = progress.find(item => item.key === permission.key);
      if (existing) existing.count = Math.max(existing.count, count);
      else progress.push({ key: permission.key, name: permission.name, count });
    }
    const normalized = progress.map(item => item.name + " " + item.count + "/" + threshold).join("; ");
    return { safe: true, raw, normalized, progress, corrected: raw !== normalized };
  }

  function renderNameRecord(record) {
    const values = record && record.values || {};
    return [
      "Alias: " + (record && record.alias || ""),
      "Status: " + textOf(values.Status || ""),
      "Use: " + textOf(values.Use || ""),
      "Progress: " + textOf(values.Progress || ""),
      "Reason: " + textOf(values.Reason || "")
    ].join("\n");
  }

  function renderNamesPage(identity, page, items) {
    const rows = ["{", namePageHeader(identity), "Canonical: " + identity.canonical];
    (Array.isArray(items) ? items : []).forEach((item, index) => {
      rows.push("");
      rows.push(item.kind === "record" ? renderNameRecord(item) : textOf(item.raw));
    });
    rows.push("}");
    return rows.join("\n");
  }

  function emptyNamesEntry(identity, page) {
    return renderNamesPage(identity, page, []);
  }

  function parseNameRecord(identity, raw, page, card, startLine) {
    const rows = textOf(raw).replace(/\r/g, "").split("\n").filter(row => row.trim());
    if (rows.length !== 5) {
      return { kind: "raw", raw, page, card, line: startLine, reason: "malformed fixed Alias record", oversize: false };
    }
    const labels = ["Alias", "Status", "Use", "Progress", "Reason"];
    const values = {};
    for (let index = 0; index < labels.length; index++) {
      const match = rows[index].match(new RegExp("^\\s*" + escapeRegExp(labels[index]) + "\\s*:\\s*(.*?)\\s*$", "i"));
      if (!match) {
        return { kind: "raw", raw, page, card, line: startLine, reason: "missing or reordered " + labels[index] + " field", oversize: false };
      }
      values[labels[index]] = line(match[1], 4000);
    }
    const alias = values.Alias;
    if (!alias || alias !== line(alias, 160) || sameNameForm(alias, identity.canonical) || /[{}\[\]|\r\n]/.test(alias)) {
      return { kind: "raw", raw, page, card, line: startLine, reason: "empty, overlong, canonical, or structurally unsafe Alias", oversize: false };
    }
    const status = NAME_STATUSES.find(item => nameKeyOf(item) === nameKeyOf(values.Status));
    const use = parseNameUse(values.Use);
    const progress = parseNameProgress(values.Progress);
    const reason = wholeLine(values.Reason, 0);
    const fieldUnsafe = {};
    if (!status) fieldUnsafe.Status = "unsupported alias lifecycle status";
    if (!use.safe) fieldUnsafe.Use = use.reason;
    if (!progress.safe) fieldUnsafe.Progress = progress.reason;
    if (!reason) fieldUnsafe.Reason = "missing Reason";
    else if (/[{}\[\]]/.test(reason)) fieldUnsafe.Reason = "reserved wrapper character in Reason";
    const normalizedValues = {
      Status: status || values.Status,
      Use: use.safe ? use.normalized : values.Use,
      Progress: progress.safe ? progress.normalized : values.Progress,
      Reason: reason
    };
    if ((status === "Retired" || status === "Rejected") && use.safe && use.normalized !== "None") {
      normalizedValues.Use = "None";
    }
    if ((status === "Retired" || status === "Rejected") && progress.safe && progress.normalized) {
      normalizedValues.Progress = "";
    }
    return {
      kind: "record",
      alias,
      aliasKey: nameKeyOf(alias),
      values: { Status: values.Status, Use: values.Use, Progress: values.Progress, Reason: values.Reason },
      normalizedValues,
      status: status || "",
      use,
      progress,
      reason,
      fieldUnsafe,
      corrected: Object.keys(normalizedValues).some(field => values[field] !== normalizedValues[field]),
      page, card, line: startLine,
      duplicate: false, conflict: false, oversize: false, writable: true
    };
  }

  function parseNamesPage(identity, card, page) {
    const source = entryOf(card).replace(/\r/g, "");
    const rows = source.split("\n");
    const nonempty = rows.map((value, index) => ({ value: value.trim(), index })).filter(item => item.value);
    const wrapperValid = nonempty.length >= 4
      && nonempty[0].value === "{"
      && nameKeyOf(nonempty[1].value) === nameKeyOf(namePageHeader(identity))
      && nameKeyOf(extractLine(source, "Canonical")) === nameKeyOf(identity.canonical)
      && nonempty[nonempty.length - 1].value === "}";
    const items = [];
    const invalid = [];
    const canonicalRow = nonempty.find(item => /^Canonical\s*:/i.test(item.value));
    const bodyStart = canonicalRow ? canonicalRow.index + 1 : (nonempty.length >= 2 ? nonempty[1].index + 1 : 0);
    const closingIndex = nonempty.length ? nonempty[nonempty.length - 1].index : rows.length;
    const starts = [];
    for (let index = bodyStart; index < closingIndex; index++) {
      if (/^\s*Alias\s*:/i.test(rows[index])) starts.push(index);
    }
    const firstStart = starts.length ? starts[0] : closingIndex;
    for (let index = bodyStart; index < firstStart; index++) {
      if (rows[index].trim()) invalid.push({ line: index + 1, reason: "content outside an Alias-started record", outside: true });
    }
    starts.forEach((start, recordIndex) => {
      const end = recordIndex + 1 < starts.length ? starts[recordIndex + 1] : closingIndex;
      const rawRows = rows.slice(start, end);
      while (rawRows.length && !rawRows[rawRows.length - 1].trim()) rawRows.pop();
      const raw = rawRows.join("\n");
      const item = parseNameRecord(identity, raw, page, card, start + 1);
      items.push(item);
      if (item.kind !== "record") invalid.push({ line: start + 1, reason: item.reason });
    });
    const pageSafe = wrapperValid && !invalid.some(item => item.outside);
    items.forEach(item => {
      item.oversize = renderNamesPage(identity, 1, [item]).length > settings.MAX_NAMES_CARD_CHARS;
      if (item.kind === "record") item.writable = pageSafe;
    });
    return {
      card, page, title: titleOf(card), source, items,
      records: items.filter(item => item.kind === "record"),
      invalid, wrapperValid, safe: pageSafe, duplicatePage: false, chars: source.length
    };
  }

  function namePageCards(identity) {
    return cards.map(card => {
      const parts = numberedNamedTitleParts(titleOf(card), settings.NAMES_LABEL);
      return parts && nameKeyOf(parts.owner) === nameKeyOf(identity.titleBase)
        ? { card, page: parts.page }
        : null;
    }).filter(Boolean).sort((left, right) => left.page - right.page || cards.indexOf(left.card) - cards.indexOf(right.card));
  }

  function ensureBaseNamesCard(identity) {
    const existing = namePageCards(identity).find(item => item.page === 1);
    return existing ? existing.card : addCard(namePageTitle(identity, 1), emptyNamesEntry(identity, 1));
  }

  function nameRecordSignature(record) {
    return [record.values.Status, record.values.Use, record.values.Progress, record.values.Reason]
      .map(value => textOf(value).replace(/\s+/g, " ").trim()).join("\u241f");
  }

  function markNameDuplicates(pages, diagnostics, identity) {
    const groups = {};
    pages.forEach(page => page.records.forEach(record => {
      if (!groups[record.aliasKey]) groups[record.aliasKey] = [];
      groups[record.aliasKey].push(record);
    }));
    Object.keys(groups).forEach(aliasKey => {
      const records = groups[aliasKey].sort((left, right) => left.page - right.page || left.line - right.line);
      if (records.length < 2) return;
      const signatures = [];
      records.forEach(record => {
        const signature = nameRecordSignature(record);
        if (signatures.some(item => item.signature === signature)) record.duplicate = true;
        else signatures.push({ signature, record });
      });
      if (signatures.length > 1) {
        records.forEach(record => { record.conflict = true; });
        diagnostics.push(identity.canonical + " alias " + records[0].alias + " has conflicting records; all were preserved and excluded.");
      } else if (records.some(record => record.duplicate)) {
        diagnostics.push(identity.canonical + " alias " + records[0].alias + " has exact duplicates; later copies are repairable.");
      }
    });
  }

  let namesStore = null;

  function refreshNamesStore() {
    const store = { identities: {}, diagnostics: [], pageStats: [] };
    nameIdentities.forEach(identity => {
      ensureBaseNamesCard(identity);
      const refs = namePageCards(identity);
      const pages = refs.map(ref => parseNamesPage(identity, ref.card, ref.page));
      const counts = {};
      pages.forEach(page => { counts[page.page] = (counts[page.page] || 0) + 1; });
      pages.forEach(page => {
        if (textOf(page.card.type) !== settings.CARD_TYPE) {
          const saved = saveCard(page.card, entryOf(page.card));
          if (saved) {
            page.card = saved;
            page.items.forEach(item => { item.card = saved; });
            page.records.forEach(record => { record.card = saved; });
          } else {
            store.diagnostics.push(page.title + " could not be normalized to the Continuity Story Card type.");
          }
        }
        page.duplicatePage = counts[page.page] > 1;
        if (page.duplicatePage) {
          page.safe = false;
          page.records.forEach(record => { record.writable = false; });
          store.diagnostics.push(page.title + " has duplicate physical pages and was left unchanged.");
        }
        if (!page.wrapperValid) store.diagnostics.push(page.title + " has an unsafe wrapper, header, or Canonical line.");
        page.invalid.forEach(item => store.diagnostics.push(page.title + " line " + item.line + " has " + item.reason + "."));
        page.items.filter(item => item.oversize).forEach(item => store.diagnostics.push(
          page.title + " line " + item.line + " has an oversized whole Alias record; it was preserved and excluded."
        ));
        page.records.forEach(record => {
          Object.keys(record.fieldUnsafe).forEach(field => store.diagnostics.push(
            page.title + " " + record.alias + " " + field + " is unsafe: " + record.fieldUnsafe[field] + "."
          ));
          if (record.corrected) store.diagnostics.push(page.title + " " + record.alias + " requires normalized lifecycle fields.");
        });
        store.pageStats.push(page.title + " " + page.chars + "/" + settings.MAX_NAMES_CARD_CHARS
          + " chars, " + page.records.length + " aliases" + (page.safe ? "" : ", unsafe"));
      });
      markNameDuplicates(pages, store.diagnostics, identity);
      const records = pages.flatMap(page => page.records);
      store.identities[identity.key] = {
        identity, pages, records,
        contextRecords: records.filter(record => record.writable && !record.duplicate && !record.conflict
          && !record.oversize && !Object.keys(record.fieldUnsafe).length),
        updateRecords: records.filter(record => record.writable && !record.duplicate && !record.conflict && !record.oversize)
      };
    });
    namesStore = store;
    return store;
  }

  function namesForIdentity(identityKey) {
    return namesStore && namesStore.identities ? namesStore.identities[identityKey] || null : null;
  }

  function managedNamesCard(card) {
    const parts = numberedNamedTitleParts(titleOf(card), settings.NAMES_LABEL);
    return !!(parts && nameIdentities.some(identity => nameKeyOf(parts.owner) === nameKeyOf(identity.titleBase)));
  }

  function captureManagedNamesCards() {
    const titleCounts = {};
    return cards.filter(managedNamesCard).map(card => {
      const title = titleOf(card);
      const titleKey = nameKeyOf(title);
      const occurrence = titleCounts[titleKey] || 0;
      titleCounts[titleKey] = occurrence + 1;
      return { title, occurrence, entry: entryOf(card), keys: card.keys, type: card.type };
    });
  }

  function restoreManagedNamesCards(snapshot) {
    if (!Array.isArray(snapshot)) return false;
    const existing = cards.filter(managedNamesCard);
    const pools = {};
    existing.forEach(card => {
      const titleKey = nameKeyOf(titleOf(card));
      if (!pools[titleKey]) pools[titleKey] = [];
      pools[titleKey].push(card);
    });
    const used = new Set();
    const restoredCounts = {};
    let restored = true;
    snapshot.forEach(item => {
      const titleKey = nameKeyOf(item.title);
      const fallbackOccurrence = restoredCounts[titleKey] || 0;
      const occurrence = Number.isSafeInteger(item.occurrence) && item.occurrence >= 0 ? item.occurrence : fallbackOccurrence;
      restoredCounts[titleKey] = fallbackOccurrence + 1;
      let card = pools[titleKey] && pools[titleKey][occurrence];
      if (!card) card = addCard(item.title, item.entry);
      if (!card) {
        restored = false;
        return;
      }
      used.add(card);
      if (!updateCardAt(cardIndex(card), item.keys, item.entry, item.type)) restored = false;
    });
    if (!removeCards(existing.filter(card => !used.has(card)))) restored = false;
    refreshNamesStore();
    applyManagedNameForms();
    return restored;
  }

  function copyNameItem(item) {
    if (!item || item.kind !== "record") return { ...item };
    return {
      ...item,
      values: { ...item.values },
      normalizedValues: { ...item.normalizedValues },
      use: item.use ? { ...item.use, permissions: (item.use.permissions || []).map(permission => ({ ...permission })) } : item.use,
      progress: item.progress ? { ...item.progress, progress: (item.progress.progress || []).map(progress => ({ ...progress })) } : item.progress,
      fieldUnsafe: { ...item.fieldUnsafe }
    };
  }

  function plannedNamesPages(identityData) {
    return identityData.pages.map(page => ({
      card: page.card, page: page.page, title: page.title,
      safe: page.safe && !page.duplicatePage,
      movable: page.safe && !page.duplicatePage && !page.items.some(item => item.oversize),
      dirty: false, created: false, remove: false,
      items: page.items.map(copyNameItem)
    }));
  }

  function nextNamesPageNumber(pages) {
    return Math.max(0, ...(Array.isArray(pages) ? pages.map(page => page.page) : [])) + 1;
  }

  function createPlannedNamesPage(identity, pages) {
    const pageNumber = nextNamesPageNumber(pages);
    const page = {
      card: null, page: pageNumber, title: namePageTitle(identity, pageNumber),
      safe: true, movable: true, dirty: true, created: true, remove: false, items: []
    };
    pages.push(page);
    pages.sort((left, right) => left.page - right.page);
    return page;
  }

  function plannedNamesPageFits(identity, page, items) {
    return renderNamesPage(identity, page.page, items).length <= settings.MAX_NAMES_CARD_CHARS;
  }

  function reparsePlannedNameRecord(identity, record) {
    const parsed = parseNameRecord(identity, renderNameRecord(record), record.page, record.card, record.line || 0);
    if (parsed.kind !== "record") return false;
    const location = { page: record.page, card: record.card, line: record.line || 0 };
    Object.assign(record, parsed, location);
    return true;
  }

  function plannedNameAlias(pages, alias) {
    const aliasKey = nameKeyOf(alias);
    const matches = pages.flatMap(page => page.items
      .filter(item => item.kind === "record" && item.aliasKey === aliasKey)
      .map(record => ({ page, record })));
    if (!matches.length) return { ok: true, found: null };
    if (matches.length !== 1 || matches.some(match => match.record.duplicate || match.record.conflict)) {
      return { ok: false, error: "The Alias has duplicate or conflicting Names records." };
    }
    const found = matches[0];
    if (!found.page.safe || !found.page.movable || found.record.oversize || !found.record.writable) {
      return { ok: false, error: "The Alias record belongs to an unsafe or oversized Names page." };
    }
    return { ok: true, found };
  }

  function removePlannedNameItem(page, item) {
    const index = page && page.items ? page.items.indexOf(item) : -1;
    if (index < 0) return false;
    page.items.splice(index, 1);
    page.dirty = true;
    return true;
  }

  function repackPlannedNames(identity, pages) {
    const movablePages = pages.filter(page => page.movable && !page.remove).sort((left, right) => left.page - right.page);
    const items = movablePages.flatMap(page => page.items.map(item => ({
      item, order: page.page * 100000 + Math.max(0, Number(item.line) || 0)
    }))).sort((left, right) => left.order - right.order).map(item => item.item);
    movablePages.forEach(page => {
      if (page.items.length) page.dirty = true;
      page.items = [];
    });
    for (const item of items) {
      let destination = movablePages.find(page => plannedNamesPageFits(identity, page, page.items.concat(item)));
      if (!destination) {
        destination = createPlannedNamesPage(identity, pages);
        movablePages.push(destination);
        movablePages.sort((left, right) => left.page - right.page);
      }
      if (!plannedNamesPageFits(identity, destination, destination.items.concat(item))) {
        return { ok: false, error: "A complete Alias record could not fit an empty 1,000-character page." };
      }
      item.page = destination.page;
      item.card = destination.card;
      destination.items.push(item);
      destination.dirty = true;
    }
    pages.forEach(page => {
      page.remove = page.page > 1 && page.movable && page.items.length === 0;
      if (page.remove) page.dirty = true;
    });
    return { ok: true };
  }

  function commitPlannedNames(identity, pages) {
    const snapshot = captureManagedNamesCards();
    try {
      for (const page of pages.filter(item => item.created && !item.remove)) {
        const entry = renderNamesPage(identity, page.page, page.items);
        if (entry.length > settings.MAX_NAMES_CARD_CHARS) throw new Error(page.title + " exceeded the 1,000-character hard limit.");
        const card = addCard(page.title, entry);
        if (!card) throw new Error("Could not create " + page.title + ".");
        page.card = card;
        page.items.forEach(item => { item.card = card; });
      }
      for (const page of pages.filter(item => item.dirty && !item.created && !item.remove)) {
        const entry = renderNamesPage(identity, page.page, page.items);
        if (entry.length > settings.MAX_NAMES_CARD_CHARS) throw new Error(page.title + " exceeded the 1,000-character hard limit.");
        const saved = saveCard(page.card, entry);
        if (!saved) throw new Error("Could not update " + page.title + ".");
        page.card = saved;
      }
      for (const page of pages.filter(item => item.remove && !item.created)) {
        if (!removeCard(page.card)) throw new Error("Could not remove empty " + page.title + ".");
      }
    } catch (error) {
      const restored = restoreManagedNamesCards(snapshot);
      CC.nameTransactionDiagnostics = (CC.nameTransactionDiagnostics || []).concat(
        "Rolled back " + identity.canonical + " Names after API failure: " + (error.message || "unknown failure")
          + (restored ? "" : " (rollback was incomplete)")
      ).slice(-20);
      refreshNamesStore();
      applyManagedNameForms();
      return { ok: false, error: error.message || "The Names card transaction failed." };
    }
    CC.nameTransactionDiagnostics = (CC.nameTransactionDiagnostics || []).concat(
      "Committed and repacked " + identity.canonical + " Names transactionally."
    ).slice(-20);
    refreshNamesStore();
    applyManagedNameForms();
    return { ok: true };
  }

  function transactNames(identity, operation) {
    refreshNamesStore();
    const identityData = namesForIdentity(identity.key);
    if (!identityData) return { ok: false, error: "The identity had no managed Names collection." };
    const pages = plannedNamesPages(identityData);
    const result = operation({ pages });
    if (!result || !result.ok) return result || { ok: false, error: "The Names mutation was invalid." };
    const repacked = repackPlannedNames(identity, pages);
    if (!repacked.ok) return repacked;
    const committed = commitPlannedNames(identity, pages);
    return committed.ok ? result : committed;
  }

  function baseNameRecord(identity, alias, status, use, progress, reason) {
    const record = {
      kind: "record", alias: line(alias, 160), aliasKey: nameKeyOf(alias),
      values: {
        Status: status,
        Use: use,
        Progress: progress || "",
        Reason: line(reason, 2000)
      },
      page: 0, card: null, line: 0,
      duplicate: false, conflict: false, oversize: false, writable: true
    };
    return reparsePlannedNameRecord(identity, record) ? record : null;
  }

  function repairNamesStore() {
    refreshNamesStore();
    const messages = [];
    nameIdentities.forEach(identity => {
      const identityData = namesForIdentity(identity.key);
      if (!identityData) return;
      const pages = plannedNamesPages(identityData);
      let changed = false;
      pages.forEach(page => {
        if (!page.movable) return;
        page.items.slice().forEach(item => {
          if (item.kind !== "record") return;
          if (item.duplicate && !item.conflict) {
            removePlannedNameItem(page, item);
            messages.push("Collapsed an exact duplicate " + identity.canonical + " alias " + item.alias + ".");
            changed = true;
            return;
          }
          if (item.conflict || item.oversize || Object.keys(item.fieldUnsafe).length) return;
          if (item.corrected) {
            item.values = { ...item.normalizedValues };
            reparsePlannedNameRecord(identity, item);
            page.dirty = true;
            changed = true;
            messages.push("Normalized " + identity.canonical + " alias " + item.alias + " lifecycle fields.");
          }
        });
        if (page.items.length && renderNamesPage(identity, page.page, page.items).length > settings.MAX_NAMES_CARD_CHARS) changed = true;
      });
      if (!changed) return;
      const repacked = repackPlannedNames(identity, pages);
      if (!repacked.ok) {
        messages.push("Could not repack " + identity.canonical + " Names: " + repacked.error);
        return;
      }
      const committed = commitPlannedNames(identity, pages);
      if (!committed.ok) messages.push("Could not repair " + identity.canonical + " Names: " + committed.error);
    });
    CC.nameRepairDiagnostics = unique((CC.nameRepairDiagnostics || []).concat(messages), 500).slice(-30);
    refreshNamesStore();
    applyManagedNameForms();
  }

  function applyManagedNameForms() {
    nameIdentities.forEach(identity => {
      const identityData = namesForIdentity(identity.key);
      const records = identityData ? identityData.contextRecords : [];
      const resolving = records.map(record => record.alias);
      const emerging = records.filter(record => record.status === "Emerging").map(record => record.alias);
      const forms = uniqueNameForms([identity.canonical].concat(resolving), 160);
      if (identity.player) {
        player.aliases = forms;
        player.emergingAliases = uniqueNameForms(emerging, 160);
        player.nameRecords = records;
      } else if (identity.character) {
        identity.character.aliases = forms;
        identity.character.emergingAliases = uniqueNameForms(emerging, 160);
        identity.character.nameRecords = records;
      }
    });
  }

  function identityReferenceMatches(value, includeEmerging) {
    const supplied = line(value, 160);
    if (!supplied) return [];
    return nameIdentities.filter(identity => {
      const forms = identity.player
        ? (player.aliases || [player.name]).concat(includeEmerging ? player.emergingAliases || [] : [])
        : (identity.character.aliases || [identity.canonical])
          .concat(includeEmerging ? identity.character.emergingAliases || [] : []);
      return forms.some(form => sameNameForm(form, supplied));
    });
  }

  function unambiguousIdentityForm(value, includeEmerging) {
    const matches = identityReferenceMatches(value, includeEmerging);
    return matches.length === 1 ? matches[0] : null;
  }

  refreshNamesStore();
  repairNamesStore();
  applyManagedNameForms();
  refreshViewsStore(true);

  function relationshipPageTitle(character, page) {
    return namedTitle(character.name, settings.RELATIONSHIPS_LABEL) + (page > 1 ? " " + page : "");
  }

  function relationshipPageHeader(character) {
    return character.name + "'s Relationships:";
  }

  function canonicalRelationshipTarget(owner, value) {
    const supplied = line(value, 160);
    const normalized = nameKeyOf(supplied);
    if (!normalized || normalized === "self") return null;
    if (["player", "the player", "you"].includes(normalized)) {
      return { key: "player", name: "Player" };
    }
    const matches = identityReferenceMatches(supplied, false);
    if (matches.length !== 1) return null;
    const identity = matches[0];
    if (!identity.player && owner && identity.character.key === owner.key) return null;
    return identity.player
      ? { key: "player", name: "Player" }
      : { key: "npc:" + identity.character.key, name: identity.character.name };
  }

  function relationshipTargetAliases(record, owner) {
    if (!record) return [];
    if (record.targetKey === "player") return uniqueNameForms(["Player", "the player", "you", player.name].concat(player.aliases || []), 160);
    if (record.targetKey.startsWith("npc:")) {
      const character = characters.find(item => "npc:" + item.key === record.targetKey);
      return character ? character.aliases : [record.targetName];
    }
    return [record.targetName];
  }

  function parseRelationshipField(field, value) {
    const raw = line(value, 4000);
    if (!raw) return { blank: true, safe: true, raw: "", normalized: "", corrected: false };
    const special = raw.match(/^(Former)(?:\s+(?:—|–|-)\s+(.+))?$/i);
    if (field === "Role" && special) {
      const description = line(special[2], 2000);
      if (/[{}\[\]]/.test(description)) {
        return {
          blank: false, safe: false, raw, normalized: raw, corrected: false,
          reason: "reserved wrapper character in description"
        };
      }
      const normalized = "Former" + (description ? " — " + description : "");
      return {
        blank: false, safe: true, special: "Former", stage: "Former", description,
        raw, normalized, corrected: raw !== normalized
      };
    }
    const match = raw.match(/^(-?\d+)\s*\(([^)]+)\)(?:\s+(?:—|–|-)\s+(.+))?$/);
    if (!match) {
      return { blank: false, safe: false, raw, normalized: raw, corrected: false, reason: "missing numeric score/stage form" };
    }
    const suppliedScore = Number(match[1]);
    if (!Number.isSafeInteger(suppliedScore)) {
      return { blank: false, safe: false, raw, normalized: raw, corrected: false, reason: "nonnumeric score" };
    }
    const range = relationshipRange(field);
    const score = Math.max(range.minimum, Math.min(range.maximum, suppliedScore));
    const stage = relationshipStage(field, score);
    if (!stage) {
      return { blank: false, safe: false, raw, normalized: raw, corrected: false, reason: "unsupported score" };
    }
    const description = line(match[3], 2000);
    if (/[{}\[\]]/.test(description)) {
      return {
        blank: false, safe: false, raw, normalized: raw, corrected: false,
        reason: "reserved wrapper character in description"
      };
    }
    const normalized = score + " (" + stage.label + ")" + (description ? " — " + description : "");
    return {
      blank: false, safe: true, score, stage: stage.label, description,
      raw, normalized,
      corrected: suppliedScore !== score || keyOf(match[2]) !== keyOf(stage.label) || raw !== normalized,
      clamped: suppliedScore !== score,
      suppliedStage: line(match[2], 120)
    };
  }

  function canonicalRelationshipManagedValue(field, value) {
    const canonicalField = canonicalRelationshipFieldName(field);
    if (!canonicalField) return null;
    const parsed = parseRelationshipField(canonicalField, value);
    return parsed && parsed.safe ? parsed.normalized : null;
  }

  function relationshipManagedSignature(ownerKey, targetKey, field, value) {
    const canonicalField = canonicalRelationshipFieldName(field);
    const normalizedOwner = line(ownerKey, 160);
    const normalizedTarget = normalizedTargetKey(targetKey);
    const canonicalValue = canonicalRelationshipManagedValue(canonicalField, value);
    if (!normalizedOwner || !normalizedTarget || !canonicalField || canonicalValue === null) return "";
    return line(JSON.stringify([
      "relationship",
      normalizedOwner,
      normalizedTarget,
      canonicalField,
      hashString(canonicalValue),
      canonicalValue.slice(0, 240)
    ]), 500);
  }

  function currentRelationshipManagedSignature(ownerKey, targetKey, field) {
    const canonicalField = canonicalRelationshipFieldName(field);
    const normalizedTarget = normalizedTargetKey(targetKey);
    const ownerData = relationshipsForOwner(ownerKey);
    if (!canonicalField || !normalizedTarget || !ownerData) return "";
    const matching = ownerData.records.filter(item => item.targetKey === normalizedTarget);
    if (!matching.length) {
      if (ownerData.pages.some(page => !page.safe || page.duplicatePage)) return "";
      return relationshipManagedSignature(ownerKey, normalizedTarget, canonicalField, "");
    }
    if (matching.length !== 1 || !ownerData.contextRecords.includes(matching[0])) return "";
    const record = matching[0];
    const parsed = record.parsedFields && record.parsedFields[canonicalField];
    if (!parsed || !parsed.safe) return "";
    const value = record.values ? record.values[canonicalField] : "";
    return relationshipManagedSignature(ownerKey, normalizedTarget, canonicalField, value);
  }

  function renderRelationshipRecord(record) {
    const values = record && record.values || {};
    return [
      "About: " + (record && record.targetName || ""),
      ...RELATIONSHIP_FIELDS.map(field => field + ": " + textOf(values[field] || ""))
    ].join("\n");
  }

  function renderRelationshipsPage(character, page, items) {
    const rows = ["{", relationshipPageHeader(character)];
    (Array.isArray(items) ? items : []).forEach((item, index) => {
      if (index > 0) rows.push("");
      rows.push(item.kind === "record" ? renderRelationshipRecord(item) : textOf(item.raw));
    });
    rows.push("}");
    return rows.join("\n");
  }

  function emptyRelationshipsEntry(character, page) {
    return renderRelationshipsPage(character, page, []);
  }

  function parseRelationshipRecord(character, raw, page, card, startLine) {
    const rows = textOf(raw).replace(/\r/g, "").split("\n").filter(row => row.trim());
    if (rows.length !== 6) {
      return { kind: "raw", raw, page, card, line: startLine, reason: "malformed fixed Relationship record", oversize: false };
    }
    const labels = ["About"].concat(RELATIONSHIP_FIELDS);
    const values = {};
    for (let index = 0; index < labels.length; index++) {
      const match = rows[index].match(new RegExp("^\\s*" + escapeRegExp(labels[index]) + "\\s*:\\s*(.*?)\\s*$", "i"));
      if (!match) {
        return { kind: "raw", raw, page, card, line: startLine, reason: "missing or reordered " + labels[index] + " field", oversize: false };
      }
      values[labels[index]] = line(match[1], 4000);
    }
    const target = canonicalRelationshipTarget(character, values.About);
    if (!target) {
      return { kind: "raw", raw, page, card, line: startLine, reason: "invalid Relationship target", oversize: false };
    }
    const parsedFields = {};
    const fieldUnsafe = {};
    RELATIONSHIP_FIELDS.forEach(field => {
      parsedFields[field] = parseRelationshipField(field, values[field]);
      if (!parsedFields[field].safe) fieldUnsafe[field] = parsedFields[field].reason || "unsafe field";
    });
    return {
      kind: "record",
      targetKey: target.key,
      targetName: target.name,
      targetCorrected: values.About !== target.name,
      values: RELATIONSHIP_FIELDS.reduce((result, field) => {
        result[field] = values[field];
        return result;
      }, {}),
      parsedFields,
      fieldUnsafe,
      page,
      card,
      line: startLine,
      duplicate: false,
      conflict: false,
      oversize: false,
      writable: true
    };
  }

  function parseRelationshipsPage(character, card, page) {
    const source = entryOf(card).replace(/\r/g, "");
    const rows = source.split("\n");
    const nonempty = rows.map((value, index) => ({ value: value.trim(), index })).filter(item => item.value);
    const wrapperValid = nonempty.length >= 3
      && nonempty[0].value === "{"
      && nameKeyOf(nonempty[1].value) === nameKeyOf(relationshipPageHeader(character))
      && nonempty[nonempty.length - 1].value === "}";
    const items = [];
    const invalid = [];
    const bodyStart = nonempty.length >= 2 ? nonempty[1].index + 1 : 0;
    const closingIndex = nonempty.length ? nonempty[nonempty.length - 1].index : rows.length;
    const starts = [];
    for (let index = bodyStart; index < closingIndex; index++) {
      if (/^\s*About\s*:/i.test(rows[index])) starts.push(index);
    }
    const firstStart = starts.length ? starts[0] : closingIndex;
    for (let index = bodyStart; index < firstStart; index++) {
      if (rows[index].trim()) invalid.push({
        line: index + 1,
        reason: "content outside an About-started Relationship record",
        outside: true
      });
    }
    starts.forEach((start, recordIndex) => {
      const end = recordIndex + 1 < starts.length ? starts[recordIndex + 1] : closingIndex;
      const rawRows = rows.slice(start, end);
      while (rawRows.length && !rawRows[rawRows.length - 1].trim()) rawRows.pop();
      const raw = rawRows.join("\n");
      const item = parseRelationshipRecord(character, raw, page, card, start + 1);
      items.push(item);
      if (item.kind !== "record") invalid.push({ line: start + 1, reason: item.reason });
    });
    const pageSafe = wrapperValid && !invalid.some(item => item.outside);
    items.forEach(item => {
      const single = renderRelationshipsPage(character, 1, [item]);
      item.oversize = single.length > settings.MAX_RELATIONSHIPS_CARD_CHARS;
      if (item.kind === "record") item.writable = pageSafe;
    });
    return {
      card,
      page,
      title: titleOf(card),
      source,
      items,
      records: items.filter(item => item.kind === "record"),
      invalid,
      wrapperValid,
      safe: pageSafe,
      duplicatePage: false,
      chars: source.length
    };
  }

  function relationshipPageCards(character) {
    return cards.map(card => {
      const parts = numberedNamedTitleParts(titleOf(card), settings.RELATIONSHIPS_LABEL);
      return parts && nameKeyOf(parts.owner) === character.key ? { card, page: parts.page } : null;
    }).filter(Boolean).sort((left, right) => left.page - right.page || cards.indexOf(left.card) - cards.indexOf(right.card));
  }

  function ensureBaseRelationshipsCard(character) {
    const existing = relationshipPageCards(character).find(item => item.page === 1);
    return existing
      ? existing.card
      : addCard(relationshipPageTitle(character, 1), emptyRelationshipsEntry(character, 1));
  }

  function relationshipRecordSignature(record) {
    return RELATIONSHIP_FIELDS.map(field => textOf(record && record.values && record.values[field])
      .replace(/\s+/g, " ").trim()).join("\u241f");
  }

  function markRelationshipDuplicates(pages, diagnostics) {
    const groups = {};
    pages.forEach(page => page.records.forEach(record => {
      if (!groups[record.targetKey]) groups[record.targetKey] = [];
      groups[record.targetKey].push(record);
    }));
    Object.keys(groups).forEach(targetKey => {
      const records = groups[targetKey].sort((left, right) => left.page - right.page || left.line - right.line);
      if (records.length < 2) return;
      const signatures = [];
      records.forEach(record => {
        const signature = relationshipRecordSignature(record);
        const prior = signatures.find(item => item.signature === signature);
        if (prior) record.duplicate = true;
        else signatures.push({ signature, record });
      });
      if (signatures.length > 1) {
        records.forEach(record => { record.conflict = true; });
        diagnostics.push(records[0].targetName + " has conflicting directional Relationship records; all were preserved and excluded.");
      } else if (records.some(record => record.duplicate)) {
        diagnostics.push(records[0].targetName + " has exact duplicate Relationship records; later copies are repairable.");
      }
    });
  }

  let relationshipsStore = null;

  function refreshRelationshipsStore() {
    const store = { owners: {}, diagnostics: [], pageStats: [] };
    characters.forEach(character => {
      ensureBaseRelationshipsCard(character);
      const refs = relationshipPageCards(character);
      const pages = refs.map(ref => parseRelationshipsPage(character, ref.card, ref.page));
      const pageCounts = {};
      pages.forEach(page => { pageCounts[page.page] = (pageCounts[page.page] || 0) + 1; });
      pages.forEach(page => {
        if (textOf(page.card.type) !== settings.CARD_TYPE) {
          const saved = saveCard(page.card, entryOf(page.card));
          if (saved) {
            page.card = saved;
            page.items.forEach(item => { item.card = saved; });
            page.records.forEach(record => { record.card = saved; });
          } else {
            store.diagnostics.push(page.title + " could not be normalized to the Continuity Story Card type.");
          }
        }
        page.duplicatePage = pageCounts[page.page] > 1;
        if (page.duplicatePage) {
          page.safe = false;
          page.records.forEach(record => { record.writable = false; });
          store.diagnostics.push(page.title + " has duplicate physical pages and was left unchanged.");
        }
        if (!page.wrapperValid) store.diagnostics.push(page.title + " has an unsafe wrapper or owner header.");
        page.invalid.forEach(item => store.diagnostics.push(page.title + " line " + item.line + " has " + item.reason + "."));
        page.items.filter(item => item.oversize).forEach(item => store.diagnostics.push(
          page.title + " line " + item.line + " has an oversized whole Relationship record; it was preserved and excluded."
        ));
        page.records.forEach(record => {
          if (record.targetCorrected) store.diagnostics.push(
            page.title + " " + record.targetName + " target requires canonical About spelling."
          );
          Object.keys(record.fieldUnsafe).forEach(field => store.diagnostics.push(
            page.title + " " + record.targetName + " " + field + " is unsafe: " + record.fieldUnsafe[field] + "."
          ));
          RELATIONSHIP_FIELDS.forEach(field => {
            const parsed = record.parsedFields[field];
            if (parsed && parsed.safe && parsed.corrected) store.diagnostics.push(
              page.title + " " + record.targetName + " " + field + " requires score/stage correction to " + parsed.normalized + "."
            );
          });
        });
        store.pageStats.push(page.title + " " + page.chars + "/" + settings.MAX_RELATIONSHIPS_CARD_CHARS
          + " chars, " + page.records.length + " records" + (page.safe ? "" : ", unsafe"));
      });
      markRelationshipDuplicates(pages, store.diagnostics);
      const records = pages.flatMap(page => page.records);
      store.owners[character.key] = {
        character,
        pages,
        records,
        contextRecords: records.filter(record => record.writable && !record.duplicate && !record.conflict && !record.oversize),
        updateRecords: records.filter(record => record.writable && !record.duplicate && !record.conflict && !record.oversize)
      };
    });
    relationshipsStore = store;
    return store;
  }

  function relationshipsForOwner(ownerKey) {
    return relationshipsStore && relationshipsStore.owners
      ? relationshipsStore.owners[ownerKey] || null
      : null;
  }

  function managedRelationshipsCard(card) {
    const parts = numberedNamedTitleParts(titleOf(card), settings.RELATIONSHIPS_LABEL);
    return !!(parts && characters.some(character => nameKeyOf(parts.owner) === character.key));
  }

  function captureManagedRelationshipsCards() {
    const titleCounts = {};
    return cards.filter(managedRelationshipsCard).map(card => {
      const title = titleOf(card);
      const titleKey = nameKeyOf(title);
      const occurrence = titleCounts[titleKey] || 0;
      titleCounts[titleKey] = occurrence + 1;
      return { title, occurrence, entry: entryOf(card), keys: card.keys, type: card.type };
    });
  }

  function restoreManagedRelationshipsCards(snapshot) {
    if (!Array.isArray(snapshot)) return false;
    const existing = cards.filter(managedRelationshipsCard);
    const pools = {};
    existing.forEach(card => {
      const titleKey = nameKeyOf(titleOf(card));
      if (!pools[titleKey]) pools[titleKey] = [];
      pools[titleKey].push(card);
    });
    const used = new Set();
    const restoredCounts = {};
    let restored = true;
    snapshot.forEach(item => {
      const titleKey = nameKeyOf(item.title);
      const fallbackOccurrence = restoredCounts[titleKey] || 0;
      const occurrence = Number.isSafeInteger(item.occurrence) && item.occurrence >= 0
        ? item.occurrence
        : fallbackOccurrence;
      restoredCounts[titleKey] = fallbackOccurrence + 1;
      let card = pools[titleKey] && pools[titleKey][occurrence];
      if (!card) card = addCard(item.title, item.entry);
      if (!card) {
        restored = false;
        return;
      }
      used.add(card);
      if (!updateCardAt(cardIndex(card), item.keys, item.entry, item.type)) restored = false;
    });
    if (!removeCards(existing.filter(card => !used.has(card)))) restored = false;
    refreshRelationshipsStore();
    return restored;
  }

  function copyRelationshipItem(item) {
    if (!item || item.kind !== "record") return { ...item };
    return {
      ...item,
      values: { ...item.values },
      parsedFields: RELATIONSHIP_FIELDS.reduce((result, field) => {
        result[field] = { ...(item.parsedFields[field] || {}) };
        return result;
      }, {}),
      fieldUnsafe: { ...item.fieldUnsafe }
    };
  }

  function plannedRelationshipsPages(ownerData) {
    return ownerData.pages.map(page => ({
      card: page.card,
      page: page.page,
      title: page.title,
      safe: page.safe && !page.duplicatePage,
      movable: page.safe && !page.duplicatePage && !page.items.some(item => item.oversize),
      dirty: false,
      created: false,
      remove: false,
      items: page.items.map(copyRelationshipItem)
    }));
  }

  function nextRelationshipsPageNumber(pages) {
    return Math.max(0, ...(Array.isArray(pages) ? pages.map(page => page.page) : [])) + 1;
  }

  function createPlannedRelationshipsPage(character, pages) {
    const pageNumber = nextRelationshipsPageNumber(pages);
    const page = {
      card: null,
      page: pageNumber,
      title: relationshipPageTitle(character, pageNumber),
      safe: true,
      movable: true,
      dirty: true,
      created: true,
      remove: false,
      items: []
    };
    pages.push(page);
    pages.sort((left, right) => left.page - right.page);
    return page;
  }

  function plannedRelationshipsPageFits(character, page, items) {
    return renderRelationshipsPage(character, page.page, items).length
      <= settings.MAX_RELATIONSHIPS_CARD_CHARS;
  }

  function reparsePlannedRelationshipRecord(record) {
    record.parsedFields = {};
    record.fieldUnsafe = {};
    RELATIONSHIP_FIELDS.forEach(field => {
      const parsed = parseRelationshipField(field, record.values[field]);
      record.parsedFields[field] = parsed;
      if (!parsed.safe) record.fieldUnsafe[field] = parsed.reason || "unsafe field";
    });
    return record;
  }

  function plannedRelationshipTarget(pages, targetKey) {
    const matches = pages.flatMap(page => page.items
      .filter(item => item.kind === "record" && item.targetKey === targetKey)
      .map(record => ({ page, record })));
    if (!matches.length) return { ok: true, found: null };
    if (matches.length !== 1 || matches.some(match => match.record.duplicate || match.record.conflict)) {
      return { ok: false, error: "The target has duplicate or conflicting Relationship records." };
    }
    const found = matches[0];
    if (!found.page.safe || !found.page.movable || found.record.oversize || !found.record.writable) {
      return { ok: false, error: "The target Relationship record belongs to an unsafe or oversized page." };
    }
    return { ok: true, found };
  }

  function removePlannedRelationshipItem(page, item) {
    const index = page && page.items ? page.items.indexOf(item) : -1;
    if (index < 0) return false;
    page.items.splice(index, 1);
    page.dirty = true;
    return true;
  }

  function repackPlannedRelationships(character, pages) {
    const movablePages = pages.filter(page => page.movable && !page.remove)
      .sort((left, right) => left.page - right.page);
    const items = movablePages.flatMap(page => page.items.map(item => ({
      item,
      order: page.page * 100000 + Math.max(0, Number(item.line) || 0)
    }))).sort((left, right) => left.order - right.order).map(item => item.item);
    movablePages.forEach(page => {
      if (page.items.length) page.dirty = true;
      page.items = [];
    });
    for (const item of items) {
      let destination = movablePages.find(page => plannedRelationshipsPageFits(character, page, page.items.concat(item)));
      if (!destination) {
        destination = createPlannedRelationshipsPage(character, pages);
        movablePages.push(destination);
        movablePages.sort((left, right) => left.page - right.page);
      }
      if (!plannedRelationshipsPageFits(character, destination, destination.items.concat(item))) {
        return { ok: false, error: "A complete Relationship record could not fit an empty 1,000-character page." };
      }
      item.page = destination.page;
      item.card = destination.card;
      destination.items.push(item);
      destination.dirty = true;
    }
    pages.forEach(page => {
      page.remove = page.page > 1 && page.movable && page.items.length === 0;
      if (page.remove) page.dirty = true;
    });
    return { ok: true };
  }

  function commitPlannedRelationships(character, pages) {
    const snapshot = captureManagedRelationshipsCards();
    try {
      for (const page of pages.filter(item => item.created && !item.remove)) {
        const entry = renderRelationshipsPage(character, page.page, page.items);
        if (entry.length > settings.MAX_RELATIONSHIPS_CARD_CHARS) {
          throw new Error(page.title + " exceeded the 1,000-character hard limit.");
        }
        const card = addCard(page.title, entry);
        if (!card) throw new Error("Could not create " + page.title + ".");
        page.card = card;
        page.items.forEach(item => { item.card = card; });
      }
      for (const page of pages.filter(item => item.dirty && !item.created && !item.remove)) {
        const entry = renderRelationshipsPage(character, page.page, page.items);
        if (entry.length > settings.MAX_RELATIONSHIPS_CARD_CHARS) {
          throw new Error(page.title + " exceeded the 1,000-character hard limit.");
        }
        const saved = saveCard(page.card, entry);
        if (!saved) throw new Error("Could not update " + page.title + ".");
        page.card = saved;
      }
      for (const page of pages.filter(item => item.remove && !item.created)) {
        if (!removeCard(page.card)) throw new Error("Could not remove empty " + page.title + ".");
      }
    } catch (error) {
      const restored = restoreManagedRelationshipsCards(snapshot);
      CC.relationshipTransactionDiagnostics = (CC.relationshipTransactionDiagnostics || []).concat(
        "Rolled back " + character.name + " Relationships after API failure: " + (error.message || "unknown failure")
          + (restored ? "" : " (rollback was incomplete)")
      ).slice(-20);
      refreshRelationshipsStore();
      return { ok: false, error: error.message || "The Relationships card transaction failed." };
    }
    CC.relationshipTransactionDiagnostics = (CC.relationshipTransactionDiagnostics || []).concat(
      "Committed and repacked " + character.name + " Relationships transactionally."
    ).slice(-20);
    refreshRelationshipsStore();
    return { ok: true };
  }

  function transactRelationships(owner, operation) {
    refreshRelationshipsStore();
    const ownerData = relationshipsForOwner(owner.key);
    if (!ownerData) return { ok: false, error: "The fixed owner had no managed Relationships collection." };
    const pages = plannedRelationshipsPages(ownerData);
    const result = operation({ pages });
    if (!result || !result.ok) return result || { ok: false, error: "The Relationships mutation was invalid." };
    const repacked = repackPlannedRelationships(owner, pages);
    if (!repacked.ok) return repacked;
    const committed = commitPlannedRelationships(owner, pages);
    return committed.ok ? result : committed;
  }

  function repairRelationshipsStore() {
    refreshRelationshipsStore();
    const repairMessages = [];
    characters.forEach(character => {
      const ownerData = relationshipsForOwner(character.key);
      if (!ownerData) return;
      const pages = plannedRelationshipsPages(ownerData);
      const provenanceRepairs = [];
      let changed = false;
      pages.forEach(page => {
        if (!page.movable) return;
        page.items.slice().forEach(item => {
          if (item.kind !== "record") return;
          if (item.duplicate && !item.conflict) {
            removePlannedRelationshipItem(page, item);
            repairMessages.push("Collapsed an exact duplicate " + character.name + "→" + item.targetName + " Relationship record.");
            changed = true;
            return;
          }
          if (item.conflict || item.oversize) return;
          if (item.targetCorrected) {
            item.targetCorrected = false;
            repairMessages.push("Canonicalized " + character.name + "→" + item.targetName + " Relationship target.");
            changed = true;
          }
          RELATIONSHIP_FIELDS.forEach(field => {
            const parsed = item.parsedFields[field];
            if (!parsed || !parsed.safe) return;
            const priorValue = item.values[field];
            let repairedValue = parsed.corrected ? parsed.normalized : item.values[field];
            const repairedParsed = parsed.corrected
              ? parseRelationshipField(field, repairedValue)
              : parsed;
            const actualStage = repairedParsed.special || repairedParsed.stage || "";
            const repairedExplanation = repairedParsed.description && actualStage
              ? correctedRelationshipExplanation(repairedParsed.description, actualStage)
              : repairedParsed.description;
            const explanationChanged = keyOf(repairedExplanation) !== keyOf(repairedParsed.description);
            if (explanationChanged) {
              repairedValue = relationshipStoredValue(
                field,
                actualStage,
                repairedParsed.score,
                repairedExplanation
              );
            }
            if (repairedValue === item.values[field]) return;
            if (explanationChanged) {
              const priorManagedSignature = relationshipManagedSignature(
                character.key,
                item.targetKey,
                field,
                priorValue
              );
              const nextManagedSignature = relationshipManagedSignature(
                character.key,
                item.targetKey,
                field,
                repairedValue
              );
              if (priorManagedSignature && nextManagedSignature
                && priorManagedSignature !== nextManagedSignature) {
                provenanceRepairs.push({
                  targetKey: item.targetKey,
                  field,
                  priorManagedSignature,
                  nextManagedSignature,
                  actualStage,
                  correctedExplanation: repairedExplanation
                });
              }
            }
            item.values[field] = repairedValue;
            if (parsed.corrected) {
              repairMessages.push("Corrected " + character.name + "→" + item.targetName + " " + field
                + " to its canonical score-stage form.");
            }
            if (explanationChanged) {
              repairMessages.push("Aligned " + character.name + "→" + item.targetName + " " + field
                + " description with the managed " + actualStage + " stage.");
            }
            changed = true;
          });
          if (changed) reparsePlannedRelationshipRecord(item);
        });
        if (page.items.length && renderRelationshipsPage(character, page.page, page.items).length > settings.MAX_RELATIONSHIPS_CARD_CHARS) {
          changed = true;
        }
      });
      if (!changed) return;
      const repacked = repackPlannedRelationships(character, pages);
      if (!repacked.ok) {
        repairMessages.push("Could not repack " + character.name + " Relationships: " + repacked.error);
        return;
      }
      const committed = commitPlannedRelationships(character, pages);
      if (!committed.ok) {
        repairMessages.push("Could not repair " + character.name + " Relationships: " + committed.error);
        return;
      }
      provenanceRepairs.forEach(repair => {
        const currentSignature = currentRelationshipManagedSignature(
          character.key,
          repair.targetKey,
          repair.field
        );
        if (currentSignature !== repair.nextManagedSignature) return;
        const rebound = rebindRelationshipExplanationProvenance(
          character.key,
          repair.targetKey,
          repair.field,
          repair.priorManagedSignature,
          repair.nextManagedSignature,
          repair.actualStage,
          repair.correctedExplanation
        );
        if (rebound) {
          repairMessages.push("Rebound " + rebound + " " + character.name + "→"
            + storedTargetName(repair.targetKey, repair.targetKey) + " " + repair.field
            + " provenance record" + (rebound === 1 ? "" : "s")
            + " after deterministic explanation alignment.");
        }
      });
    });
    CC.relationshipRepairDiagnostics = unique(
      (CC.relationshipRepairDiagnostics || []).concat(repairMessages),
      500
    ).slice(-30);
    refreshRelationshipsStore();
  }

  refreshRelationshipsStore();
  repairRelationshipsStore();

  function stateTitle(character) {
    return namedTitle(character.name, settings.STATE_LABEL);
  }

  function situationPhrase(value) {
    return line(value, settings.MAX_STATE_VALUE_CHARS)
      .replace(/[.!?]+$/g, "")
      .trim();
  }

  function stateEntry(character, npc) {
    const state = normalizeState(npc && npc.state, CC.stateClock);
    return [
      "{ " + character.name + "'s current private State:",
      "Thought: " + state.thought.value,
      "Feeling: " + state.feeling.value,
      "Goal: " + state.goal.value,
      "Tension: " + state.tension.value,
      "Situation: " + state.situation.value,
      "About: " + state.target.name,
      "Triggers: " + state.triggers.value.join(", "),
      "}"
    ].join("\n");
  }

  function stateTargetForName(owner, value) {
    const target = canonicalViewTarget(owner, value);
    if (!target) return { key: "", name: "" };
    return {
      key: target.key,
      name: storedTargetName(target.key, target.name)
    };
  }

  function parseStateEntry(character, source, existing) {
    const prior = normalizeState(existing, CC.stateClock);
    const result = normalizeState(prior, CC.stateClock);
    ["Thought", "Feeling", "Goal", "Tension"].forEach(label => {
      const field = keyOf(label);
      const value = line(extractLine(source, label), settings.MAX_STATE_VALUE_CHARS);
      if (value !== prior[field].value) result[field] = { value, updatedClock: CC.stateClock };
    });
    const target = stateTargetForName(character, extractLine(source, "About"));
    const targetChanged = target.key !== prior.target.key || target.name !== prior.target.name;
    if (targetChanged) {
      result.target = { key: target.key, name: target.name, updatedClock: CC.stateClock };
    }
    const situation = situationPhrase(extractLine(source, "Situation"));
    const situationChanged = situation !== prior.situation.value;
    if (situationChanged || targetChanged) {
      result.situation = situation
        ? {
          value: situation,
          updatedClock: CC.stateClock,
          confirmations: 0,
          evidenceIds: [],
          targetKey: target.key,
          targetName: target.name,
          promotedSignature: ""
        }
        : blankSituation();
    }
    const triggers = triggerList(extractLine(source, "Triggers"));
    if (triggers.join("|") !== prior.triggers.value.join("|")) {
      result.triggers = { value: triggers, updatedClock: CC.stateClock };
    }
    return result;
  }

  function canonicalizeStateAboutLine(card, source, target) {
    const canonical = target && target.name;
    const supplied = extractLine(source, "About");
    if (!card || !canonical || !supplied || supplied === canonical) {
      return { card, source, changed: false };
    }
    const rows = textOf(source).replace(/\r/g, "").split("\n");
    const matches = rows.map((row, index) => ({
      index,
      match: row.match(/^([ \t]*About[ \t]*:[ \t]*)([^{}\[\]\r\n]*)[ \t]*$/i)
    })).filter(item => item.match);
    if (matches.length !== 1) return { card, source, changed: false };
    rows[matches[0].index] = matches[0].match[1] + canonical;
    const entry = rows.join("\n");
    const saved = saveCard(card, entry);
    return saved
      ? { card: saved, source: entry, changed: true }
      : { card, source, changed: false };
  }

  function syncStateCard(character) {
    const title = stateTitle(character);
    let card = namedCard(character.name, settings.STATE_LABEL);
    if (!card) return;
    let source = entryOf(card);
    const currentHash = hashString(source);
    const storedHash = CC.cardHashes[title];
    if (!storedHash || currentHash !== storedHash) {
      CC.npcs[character.key].state = parseStateEntry(character, source, CC.npcs[character.key].state);
    }
    const target = stateTargetForName(character, extractLine(source, "About"));
    const correction = canonicalizeStateAboutLine(card, source, target);
    if (correction.changed) {
      card = correction.card;
      source = correction.source;
      CC.cardHashes[title] = hashString(source);
    }
  }

  function writeStateCard(character) {
    const npc = CC.npcs[character.key];
    if (!npc) return;
    const title = stateTitle(character);
    const entry = stateEntry(character, npc);
    const card = namedCard(character.name, settings.STATE_LABEL);
    const saved = card ? saveCard(card, entry) : addCard(title, entry);
    if (saved) CC.cardHashes[title] = hashString(entry);
    return saved;
  }

  function syncAllStateCards() {
    characters.forEach(syncStateCard);
  }

  function writeAllStateCards() {
    characters.forEach(writeStateCard);
    CC.cardsInitialized = true;
  }

  syncAllStateCards();
  if (!CC.cardsInitialized) writeAllStateCards();

  function experiencesPageTitle(character, page) {
    return character.name + "'s " + settings.EXPERIENCES_LABEL
      + (page > 1 ? " " + page : "");
  }

  function experiencesPageHeader(character, page) {
    return experiencesPageTitle(character, page) + ":";
  }

  function experiencesTitleParts(title) {
    const label = settings.EXPERIENCES_LABEL;
    const match = line(title, 260).match(new RegExp(
      "^(.+?)['’]s\\s+" + escapeRegExp(label) + "(?:\\s+(\\d+))?$",
      "i"
    ));
    if (!match) return null;
    const page = match[2] ? Number(match[2]) : 1;
    if ((match[2] && page === 1) || !Number.isSafeInteger(page) || page < 1) return null;
    const matches = characters.filter(character => sameNameForm(character.name, match[1]));
    const owner = matches.length === 1 ? matches[0] : null;
    return owner ? { owner, page } : null;
  }

  function experienceSignature(ownerKey, targetKey, situation) {
    return ownerKey + "|" + normalizedTargetKey(targetKey) + "|" + keyOf(situationPhrase(situation));
  }

  function baseExperienceRecord(owner, target, situation) {
    const phrase = situationPhrase(situation);
    const targetKey = normalizedTargetKey(target && target.key);
    return {
      targetKey,
      targetName: storedTargetName(targetKey, target && target.name),
      situation: phrase,
      signature: experienceSignature(owner.key, target && target.key, phrase),
      page: 0,
      line: 0,
      card: null,
      duplicate: false,
      writable: true
    };
  }

  function renderExperienceRecord(owner, record) {
    return "- [About: " + line(record.targetName, 120) + "] " + owner.name
      + " experienced: " + situationPhrase(record.situation) + ".";
  }

  function renderExperiencesPage(owner, page, records) {
    return ["{ " + experiencesPageHeader(owner, page)]
      .concat((Array.isArray(records) ? records : []).map(record => renderExperienceRecord(owner, record)))
      .concat("}")
      .join("\n");
  }

  function parseExperiencesPage(owner, card, page) {
    const source = entryOf(card).replace(/\r/g, "");
    const trimmed = source.trim();
    const rows = trimmed.split("\n");
    const expectedFirst = "{ " + experiencesPageHeader(owner, page);
    const recordPattern = new RegExp(
      "^- \\[About:\\s*([^\\]\\r\\n]+)\\]\\s*" + escapeRegExp(owner.name)
        + "\\s+experienced:\\s*(.+)\\.$",
      "i"
    );
    const records = [];
    let malformed = 0;
    rows.slice(1, -1).forEach((row, index) => {
      if (!row.trim()) {
        malformed += 1;
        return;
      }
      const match = row.match(recordPattern);
      if (!match) {
        malformed += 1;
        return;
      }
      const targetSource = wholeLine(match[1], 120);
      const situationSource = wholeLine(match[2], settings.MAX_STATE_VALUE_CHARS);
      const target = targetSource ? canonicalViewTarget(owner, targetSource) : null;
      const situation = situationPhrase(situationSource);
      if (!target || !situation || /[{}|\r\n]/.test(targetSource + situationSource)) {
        malformed += 1;
        return;
      }
      const sourceCanonicalExceptTarget = "- [About: " + targetSource + "] " + owner.name
        + " experienced: " + situation + ".";
      if (row !== sourceCanonicalExceptTarget) {
        malformed += 1;
        return;
      }
      const record = baseExperienceRecord(owner, target, situation);
      record.targetCorrected = targetSource !== record.targetName;
      record.page = page;
      record.line = index + 2;
      record.card = card;
      records.push(record);
    });
    const canonical = renderExperiencesPage(owner, page, records);
    const maximum = settings.MAX_EXPERIENCES_CARD_CHARS;
    const structureSafe = rows[0] === expectedFirst
      && rows[rows.length - 1] === "}"
      && malformed === 0
      && trimmed.length <= maximum
      && canonical.length <= maximum;
    const targetCorrected = records.some(record => record.targetCorrected);
    return {
      owner,
      card,
      page,
      title: titleOf(card),
      records,
      malformed,
      canonical,
      targetCorrected,
      repairable: structureSafe && targetCorrected,
      safe: structureSafe && !targetCorrected && canonical === trimmed,
      duplicatePage: false
    };
  }

  let experiencesStore = null;

  function refreshExperiencesStore(internalize) {
    const store = { owners: {}, diagnostics: [], pageStats: [] };
    characters.forEach(character => {
      store.owners[character.key] = { character, pages: [], records: [], contextRecords: [] };
    });
    cards.forEach(card => {
      const parts = experiencesTitleParts(titleOf(card));
      if (!parts) return;
      const parsed = parseExperiencesPage(parts.owner, card, parts.page);
      store.owners[parts.owner.key].pages.push(parsed);
    });
    Object.values(store.owners).forEach(ownerData => {
      ownerData.pages.sort((left, right) => left.page - right.page || cardIndex(left.card) - cardIndex(right.card));
      const counts = {};
      ownerData.pages.forEach(page => { counts[page.page] = (counts[page.page] || 0) + 1; });
      const seen = new Set();
      ownerData.pages.forEach(page => {
        if (counts[page.page] > 1) {
          page.duplicatePage = true;
          page.safe = false;
          store.diagnostics.push(page.title + " has duplicate physical pages and was left unchanged.");
        }
        if (internalize && page.repairable && !page.duplicatePage) {
          const saved = saveCard(page.card, page.canonical);
          if (saved) {
            page.card = saved;
            page.records.forEach(record => {
              record.card = saved;
              record.targetCorrected = false;
            });
            page.targetCorrected = false;
            page.repairable = false;
            page.safe = true;
            store.diagnostics.push(page.title + " canonicalized all alias-authored About targets.");
          }
        }
        if (!page.safe && !page.duplicatePage) {
          store.diagnostics.push(page.title + " is noncanonical, malformed, or over 1,000 characters and was left unchanged.");
        }
        if (internalize && textOf(page.card.type) !== settings.CARD_TYPE) {
          const saved = saveCard(page.card, entryOf(page.card));
          if (saved) {
            page.card = saved;
            page.records.forEach(record => { record.card = page.card; });
          }
        }
        page.records.forEach(record => {
          if (seen.has(record.signature)) record.duplicate = true;
          else seen.add(record.signature);
          record.writable = page.safe && !record.duplicate;
          ownerData.records.push(record);
          if (record.writable) ownerData.contextRecords.push(record);
        });
        store.pageStats.push(page.title + " " + entryOf(page.card).length + "/"
          + settings.MAX_EXPERIENCES_CARD_CHARS
          + (page.safe ? " ready" : " unsafe"));
      });
    });
    experiencesStore = store;
    return store;
  }

  function experiencesForOwner(ownerKey) {
    return experiencesStore && experiencesStore.owners
      ? experiencesStore.owners[ownerKey] || null
      : null;
  }

  function managedExperienceCard(card) {
    return !!experiencesTitleParts(titleOf(card));
  }

  function captureManagedExperienceCards() {
    const titleCounts = {};
    return cards.filter(managedExperienceCard).map(card => {
      const title = titleOf(card);
      const titleKey = nameKeyOf(title);
      const occurrence = titleCounts[titleKey] || 0;
      titleCounts[titleKey] = occurrence + 1;
      return {
        title,
        occurrence,
        entry: entryOf(card),
        keys: card.keys,
        type: card.type
      };
    });
  }

  function restoreManagedExperienceCards(snapshot) {
    if (!Array.isArray(snapshot)) return false;
    const existing = cards.filter(managedExperienceCard);
    const pools = {};
    existing.forEach(card => {
      const titleKey = nameKeyOf(titleOf(card));
      if (!pools[titleKey]) pools[titleKey] = [];
      pools[titleKey].push(card);
    });
    const used = new Set();
    const restoredCounts = {};
    let restored = true;
    snapshot.forEach(item => {
      const titleKey = nameKeyOf(item.title);
      const fallbackOccurrence = restoredCounts[titleKey] || 0;
      const occurrence = Number.isSafeInteger(item.occurrence) && item.occurrence >= 0
        ? item.occurrence
        : fallbackOccurrence;
      restoredCounts[titleKey] = fallbackOccurrence + 1;
      let card = pools[titleKey] && pools[titleKey][occurrence];
      if (!card) card = addCard(item.title, item.entry);
      if (!card) {
        restored = false;
        return;
      }
      used.add(card);
      const index = cardIndex(card);
      if (!updateCardAt(index, item.keys, item.entry, item.type)) restored = false;
    });
    if (!removeCards(existing.filter(card => !used.has(card)))) restored = false;
    refreshExperiencesStore(false);
    return restored;
  }

  function nextExperiencesPageNumber(pages) {
    const used = new Set((Array.isArray(pages) ? pages : []).map(page => page.page));
    let page = 1;
    while (used.has(page)) page += 1;
    return page;
  }

  function appendExperience(owner, target, situation) {
    refreshExperiencesStore(false);
    const ownerData = experiencesForOwner(owner.key);
    if (!ownerData) return { ok: false, error: "The Experience owner was not registered." };
    const record = baseExperienceRecord(owner, target, situation);
    if (!record.targetKey || !record.targetName || !record.situation) {
      return { ok: false, error: "The Experience lacked a complete About target or Situation." };
    }
    const existing = ownerData.records.find(item => item.signature === record.signature) || null;
    if (existing) {
      if (!existing.writable || !ownerData.contextRecords.some(item => item.signature === record.signature)) {
        return { ok: false, error: "The matching Experience existed only in an unsafe or duplicate managed record." };
      }
      return {
        ok: true,
        deduplicated: true,
        signature: record.signature,
        managedSignature: record.signature,
        page: existing.page,
        summary: "Experience already existed"
      };
    }
    const maximum = settings.MAX_EXPERIENCES_CARD_CHARS;
    const candidates = ownerData.pages.filter(page => page.safe && !page.duplicatePage)
      .sort((left, right) => right.page - left.page);
    let page = candidates.find(item => renderExperiencesPage(owner, item.page, item.records.concat(record)).length <= maximum);
    let created = false;
    if (!page) {
      const pageNumber = nextExperiencesPageNumber(ownerData.pages);
      page = { owner, card: null, page: pageNumber, records: [], safe: true, duplicatePage: false };
      created = true;
    }
    const placed = { ...record, page: page.page, line: page.records.length + 2, card: page.card };
    const entry = renderExperiencesPage(owner, page.page, page.records.concat(placed));
    if (entry.length > maximum) {
      return { ok: false, error: "The complete Experience record could not fit an empty 1,000-character page." };
    }
    let saved = null;
    if (created) {
      saved = addCard(experiencesPageTitle(owner, page.page), entry);
    } else {
      saved = saveCard(page.card, entry);
    }
    if (!saved) return { ok: false, error: "The Experience page could not be saved." };
    refreshExperiencesStore(false);
    const committed = experiencesForOwner(owner.key);
    const committedRecord = committed && committed.contextRecords.find(item => item.signature === record.signature);
    if (!committedRecord) {
      if (created) removeCard(saved);
      refreshExperiencesStore(false);
      return { ok: false, error: "The Experience page could not be verified as a canonical managed record after saving." };
    }
    return {
      ok: true,
      deduplicated: false,
      signature: record.signature,
      managedSignature: committedRecord.signature,
      page: committedRecord.page,
      summary: owner.name + " added a persistent Experience about "
        + modelTargetName(record.targetKey, record.targetName)
    };
  }

  function experienceProvenanceForSignature(ownerKey, targetKey, signature) {
    const normalizedTarget = normalizedTargetKey(targetKey);
    return CC.provenance.records.find(record => record.kind === "experience"
      && record.ownerKey === ownerKey
      && record.targetKey === normalizedTarget
      && record.signature === signature) || null;
  }

  function acceptedStateConfirmationsForExperience(owner, target, situation) {
    const signature = experienceSignature(owner.key, target && target.key, situation);
    const matching = activeProvenanceRecords({
      ownerKey: owner.key,
      targetKey: target && target.key,
      kind: "state"
    }).filter(record => record.signature === signature && record.confirmation > 0)
      .sort((left, right) => left.confirmation - right.confirmation
        || left.createdClock - right.createdClock
        || left.id.localeCompare(right.id));
    const selectedByConfirmation = {};
    matching.forEach(record => {
      if (!selectedByConfirmation[record.confirmation]) selectedByConfirmation[record.confirmation] = record;
    });
    const selected = [];
    const seenStory = new Set();
    for (let confirmation = 1; confirmation <= settings.SITUATION_EXPERIENCE_CONFIRMATIONS; confirmation++) {
      const record = selectedByConfirmation[confirmation];
      if (!record) return [];
      const lineage = storyLineageForSources(record.sourceIds.concat(record.storyEvidenceIds || []));
      const novel = lineage.filter(id => !seenStory.has(id));
      if (!novel.length) return [];
      lineage.forEach(id => seenStory.add(id));
      selected.push(record);
    }
    return selected;
  }

  function promoteExperienceWithProvenance(owner, target, situation, plan) {
    const signature = experienceSignature(owner.key, target && target.key, situation);
    const confirmations = acceptedStateConfirmationsForExperience(owner, target, situation);
    if (confirmations.length !== settings.SITUATION_EXPERIENCE_CONFIRMATIONS) {
      return { ok: false, error: "Experience promotion required three distinct accepted S# confirmations." };
    }
    const promotion = appendExperience(owner, target, situation);
    if (!promotion.ok) return promotion;

    refreshProvenanceActivity();
    const existing = experienceProvenanceForSignature(owner.key, target && target.key, signature);
    if (existing) {
      existing.active = managedSignatureStillValid(existing);
      if (!existing.active) {
        return { ok: false, error: "The existing X# record could not bind to the current managed Experience." };
      }
      CC.last.provenanceDiagnostics = unique((CC.last.provenanceDiagnostics || []).concat(
        "Experience provenance deduplicated: " + existing.id + " remained bound to " + signature
      ), 500).slice(-20);
      return {
        ok: true,
        deduplicated: true,
        signature,
        managedSignature: promotion.managedSignature || signature,
        page: promotion.page,
        provenanceRecord: existing,
        stateSourceIds: confirmations.map(record => record.id),
        storyEvidenceIds: storyLineageForSources(confirmations.map(record => record.id)),
        summary: promotion.summary
      };
    }

    const sourceIds = confirmations.map(record => record.id);
    const storyEvidenceIds = storyLineageForSources(sourceIds);
    const provenance = appendProvenanceRecord({
      prefix: "X",
      ownerKey: owner.key,
      targetKey: target && target.key,
      targetName: storedTargetName(target && target.key, target && target.name),
      signature,
      managedSignature: promotion.managedSignature || signature,
      confirmation: confirmations.length,
      sourceIds,
      storyEvidenceIds,
      value: situationPhrase(situation),
      explanation: "Promoted deterministically from " + sourceIds.join(", "),
      createdClock: Math.max(CC.stateClock, ...confirmations.map(record => record.createdClock)),
      ownerOpportunity: plan && plan.ownerOpportunity || CC.ownerOpportunities[owner.key] || 0,
      active: true
    });
    if (!provenance.ok) {
      return { ok: false, error: "The Experience changed but X# provenance could not commit: " + provenance.error };
    }
    CC.last.provenanceDiagnostics = unique((CC.last.provenanceDiagnostics || []).concat(
      "Experience provenance committed: " + provenance.record.id + " from " + sourceIds.join(",")
        + " with raw lineage " + (storyEvidenceIds.join(",") || "None")
    ), 500).slice(-20);
    return {
      ok: true,
      deduplicated: promotion.deduplicated,
      signature,
      managedSignature: promotion.managedSignature || signature,
      page: promotion.page,
      provenanceRecord: provenance.record,
      stateSourceIds: sourceIds,
      storyEvidenceIds,
      summary: promotion.summary
    };
  }

  function backfillExperienceProvenance() {
    refreshExperiencesStore(false);
    Object.values(experiencesStore && experiencesStore.owners || {}).forEach(ownerData => {
      const owner = ownerData && ownerData.character;
      if (!owner) return;
      ownerData.contextRecords.forEach(record => {
        if (experienceProvenanceForSignature(owner.key, record.targetKey, record.signature)) return;
        const target = {
          key: record.targetKey,
          name: storedTargetName(record.targetKey, record.targetName)
        };
        const confirmations = acceptedStateConfirmationsForExperience(owner, target, record.situation);
        if (confirmations.length !== settings.SITUATION_EXPERIENCE_CONFIRMATIONS) return;
        const priorProvenance = clone(CC.provenance);
        const priorCreated = CC.last.provenanceCreated;
        const sourceIds = confirmations.map(item => item.id);
        const storyEvidenceIds = storyLineageForSources(sourceIds);
        const appended = appendProvenanceRecord({
          prefix: "X",
          ownerKey: owner.key,
          targetKey: record.targetKey,
          targetName: record.targetName,
          signature: record.signature,
          managedSignature: record.signature,
          confirmation: confirmations.length,
          sourceIds,
          storyEvidenceIds,
          value: record.situation,
          explanation: "Backfilled deterministically from " + sourceIds.join(", "),
          createdClock: Math.max(CC.stateClock, ...confirmations.map(item => item.createdClock)),
          ownerOpportunity: Math.max(0, Number(CC.ownerOpportunities[owner.key]) || 0),
          active: true
        });
        if (!appended.ok) {
          CC.provenance = normalizeProvenanceLedger(priorProvenance);
          CC.last.provenanceCreated = priorCreated;
          CC.last.provenanceDiagnostics = unique((CC.last.provenanceDiagnostics || []).concat(
            "Experience provenance backfill rolled back for " + record.signature + ": " + appended.error
          ), 500).slice(-20);
          return;
        }
        CC.last.provenanceDiagnostics = unique((CC.last.provenanceDiagnostics || []).concat(
          "Experience provenance backfilled: " + appended.record.id + " from " + sourceIds.join(",")
            + " with raw lineage " + (storyEvidenceIds.join(",") || "None")
        ), 500).slice(-20);
      });
    });
  }

  refreshExperiencesStore(true);
  backfillExperienceProvenance();

  function clearTemporaryState() {
    Object.values(CC.npcs || {}).forEach(npc => { npc.state = blankState(); });
  }

  function expireTemporaryState(clock) {
    let expired = 0;
    Object.values(CC.npcs || {}).forEach(npc => {
      npc.state = normalizeState(npc.state, clock);
      ["thought", "feeling", "goal", "tension"].forEach(field => {
        const item = npc.state[field];
        if (item.value && clock - item.updatedClock >= runtime.stateLifetime) {
          npc.state[field] = { value: "", updatedClock: clock };
          expired += 1;
        }
      });
      if (npc.state.triggers.value.length && clock - npc.state.triggers.updatedClock >= runtime.stateLifetime) {
        npc.state.triggers = { value: [], updatedClock: clock };
      }
      if (npc.state.target.name && clock - npc.state.target.updatedClock >= runtime.stateLifetime) {
        npc.state.target = { key: "", name: "", updatedClock: clock };
      }
      if (npc.state.situation.value && clock - npc.state.situation.updatedClock >= runtime.stateLifetime) {
        npc.state.situation = blankSituation();
        expired += 1;
      }
    });
    return expired;
  }

  function resetSceneForTimeJump(preserveStateEvidenceId = "") {
    CC.sceneLastSeen = {};
    CC.activeKeys = [];
    CC.conversationKey = "";
    clearTemporaryState();
    CC.evidence.forEach(item => {
      if (item.id === preserveStateEvidenceId) return;
      characters.forEach(character => { item.usedStateBy[character.key] = true; });
    });
    CC.last.timeJumpReset = true;
  }

  function historyType(item) {
    return keyOf(item && item.type);
  }

  function historyText(item) {
    return item && typeof item === "object" ? textOf(item.text) : "";
  }

  function canonicalOutput(value) {
    return textOf(value).normalize("NFKC").replace(/\s+/g, " ").trim();
  }

  function outputAnchorFor(story, plan) {
    const canonical = canonicalOutput(story);
    if (!canonical) return null;
    const fragmentLength = Math.min(120, Math.max(40, Math.floor(canonical.length / 3)));
    return {
      hash: hashString(canonical),
      text: canonical.slice(0, 20000),
      start: canonical.slice(0, fragmentLength),
      end: canonical.slice(-fragmentLength),
      focusKey: plan && (plan.focusKey || plan.ownerKey) || "",
      activeKeys: clone(plan && plan.activeKeys || [])
    };
  }

  function recentStoryFromContext(value) {
    const marker = "Recent Story:";
    const source = textOf(value);
    const index = source.lastIndexOf(marker);
    if (index >= 0) {
      const start = index + marker.length;
      const remainder = source.slice(start);
      const laterSection = remainder.search(
        /\n[ \t]*(?:Author['’]s Note|Last Action|Front Memory|Buffer Tokens?)[ \t]*:/i
      );
      return (laterSection >= 0 ? remainder.slice(0, laterSection) : remainder).trim();
    }
    return historyList
      .slice(-30)
      .map(historyText)
      .filter(Boolean)
      .join("\n")
      .slice(-16000)
      .trim();
  }

  function evidenceExcerpt(value) {
    const maximum = settings.MAX_EVIDENCE_ITEM_CHARS;
    const source = canonicalOutput(value);
    if (source.length <= maximum) return { text: source, clipped: false, originalChars: source.length };
    const marker = " […] ";
    const allowance = maximum - marker.length;
    const leftLimit = Math.floor(allowance / 2);
    const rightLimit = allowance - leftLimit;
    let left = source.slice(0, leftLimit);
    let right = source.slice(-rightLimit);
    const leftBreak = left.lastIndexOf(" ");
    if (leftBreak >= Math.floor(leftLimit * 0.7)) left = left.slice(0, leftBreak);
    const rightBreak = right.indexOf(" ");
    if (rightBreak >= 0 && rightBreak <= Math.ceil(rightLimit * 0.3)) right = right.slice(rightBreak + 1);
    const text = (left.trimEnd() + marker + right.trimStart()).slice(0, maximum);
    return { text, clipped: true, originalChars: source.length };
  }

  function evidenceAnchor(value) {
    const canonical = canonicalOutput(value);
    if (!canonical) return null;
    const size = Math.min(160, Math.max(40, Math.floor(canonical.length / 3)));
    return {
      hash: hashString(canonical),
      start: canonical.slice(0, size),
      end: canonical.slice(-size),
      chars: canonical.length
    };
  }

  function anchorInText(anchor, value) {
    if (!anchor) return false;
    const canonical = canonicalOutput(value);
    if (!canonical) return false;
    return hashString(canonical) === anchor.hash
      || (!!anchor.start && !!anchor.end && canonical.includes(anchor.start) && canonical.includes(anchor.end));
  }

  function normalizeEvidenceItem(item) {
    const source = item && typeof item === "object" && !Array.isArray(item) ? item : {};
    return {
      id: /^E\d+$/.test(textOf(source.id)) ? source.id : "",
      number: Math.max(0, Number(source.number) || Number(textOf(source.id).slice(1)) || 0),
      source: ["opening", "input", "story"].includes(source.source) ? source.source : "story",
      text: wholeLine(source.text, settings.MAX_EVIDENCE_ITEM_CHARS),
      clipped: source.clipped === true,
      originalChars: Math.max(0, Number(source.originalChars) || textOf(source.text).length),
      stateClock: Math.max(0, Number(source.stateClock) || 0),
      ownerBirth: source.ownerBirth && typeof source.ownerBirth === "object" && !Array.isArray(source.ownerBirth) ? source.ownerBirth : {},
      usedStateBy: source.usedStateBy && typeof source.usedStateBy === "object" && !Array.isArray(source.usedStateBy) ? source.usedStateBy : {},
      usedViewsBy: source.usedViewsBy && typeof source.usedViewsBy === "object" && !Array.isArray(source.usedViewsBy) ? source.usedViewsBy : {},
      usedRelationshipsBy: source.usedRelationshipsBy && typeof source.usedRelationshipsBy === "object" && !Array.isArray(source.usedRelationshipsBy)
        ? source.usedRelationshipsBy
        : {},
      usedNamesBy: source.usedNamesBy && typeof source.usedNamesBy === "object" && !Array.isArray(source.usedNamesBy)
        ? source.usedNamesBy
        : {},
      anchor: source.anchor && typeof source.anchor === "object" && !Array.isArray(source.anchor) ? source.anchor : null
    };
  }

  CC.evidence = CC.evidence.map(normalizeEvidenceItem).filter(item => item.id && item.text);
  const highestEvidenceNumber = Math.max(0, ...CC.evidence.map(item => item.number));
  CC.nextEvidenceNumber = Math.max(CC.nextEvidenceNumber, highestEvidenceNumber + 1);

  function addEvidence(source, value) {
    const excerpt = evidenceExcerpt(value);
    if (!excerpt.text) return null;
    const number = CC.nextEvidenceNumber++;
    const ownerBirth = {};
    characters.forEach(character => {
      ownerBirth[character.key] = Math.max(0, Number(CC.ownerOpportunities[character.key]) || 0);
    });
    const item = {
      id: "E" + number,
      number,
      source,
      text: excerpt.text,
      clipped: excerpt.clipped,
      originalChars: excerpt.originalChars,
      stateClock: CC.stateClock,
      ownerBirth,
      usedStateBy: {},
      usedViewsBy: {},
      usedRelationshipsBy: {},
      usedNamesBy: {},
      anchor: evidenceAnchor(value)
    };
    CC.evidence.push(item);
    const maximum = settings.MAX_EVIDENCE_ITEMS;
    while (CC.evidence.length > maximum) {
      const retired = CC.evidence.shift();
      if (retired) CC.last.evidenceDiagnostics = (CC.last.evidenceDiagnostics || []).concat(
        retired.id + " retired when the " + maximum + "-item ledger overflowed."
      ).slice(-20);
    }
    if (item.clipped) CC.last.evidenceDiagnostics = (CC.last.evidenceDiagnostics || []).concat(
      item.id + " was mechanically clipped from " + item.originalChars + " to " + item.text.length + " characters."
    ).slice(-20);
    return item;
  }

  function evidenceForId(id) {
    return CC.evidence.find(item => item.id === textOf(id).toUpperCase()) || null;
  }

  function openingEvidenceEligible(item, recent) {
    return item.source !== "opening" || anchorInText(item.anchor, recent);
  }

  function stateEvidenceEligible(item, owner, recent) {
    if (!item || !owner || !openingEvidenceEligible(item, recent)) return false;
    if (item.usedStateBy[owner.key]) return false;
    return CC.stateClock - item.stateClock < runtime.stateLifetime;
  }

  function viewEvidenceAge(item, owner, opportunityOverride = null) {
    const now = opportunityOverride === null
      ? Math.max(0, Number(CC.ownerOpportunities[owner.key]) || 0)
      : Math.max(0, Number(opportunityOverride) || 0);
    const born = Math.max(0, Number(item.ownerBirth[owner.key]) || 0);
    return Math.max(0, now - born);
  }

  function viewEvidenceEligible(item, owner, recent, targetKey, opportunityOverride) {
    if (!item || !owner || !openingEvidenceEligible(item, recent)) return false;
    if (viewEvidenceAge(item, owner, opportunityOverride) >= settings.VIEW_EVIDENCE_OPPORTUNITIES) return false;
    if (!targetKey) return true;
    const ownerUses = item.usedViewsBy[owner.key];
    return !(ownerUses && ownerUses[targetKey]);
  }

  function relationshipEvidenceEligible(item, owner, recent, targetKey, opportunityOverride) {
    if (!item || !owner || !openingEvidenceEligible(item, recent)) return false;
    if (viewEvidenceAge(item, owner, opportunityOverride) >= settings.RELATIONSHIP_EVIDENCE_OPPORTUNITIES) return false;
    if (!targetKey) return true;
    const ownerUses = item.usedRelationshipsBy[owner.key];
    return !(ownerUses && ownerUses[targetKey]);
  }

  function nameEvidenceEligible(item, owner, recent, subjectKey, aliasKey, opportunityOverride) {
    if (!item || !owner || !openingEvidenceEligible(item, recent)) return false;
    if (viewEvidenceAge(item, owner, opportunityOverride) >= settings.NAME_EVIDENCE_OPPORTUNITIES) return false;
    if (!subjectKey || !aliasKey) return true;
    const subjectUses = item.usedNamesBy[subjectKey];
    return !(subjectUses && subjectUses[aliasKey]);
  }

  function consumeStateEvidence(items, owner) {
    items.forEach(item => { item.usedStateBy[owner.key] = true; });
  }

  function consumeViewEvidence(items, owner, targetKey) {
    (Array.isArray(items) ? items : []).forEach(item => {
      // Raw E# evidence keeps the existing owner-target consumption rule. R#/X#
      // interpretations remain uncommitted until the later V# transaction slice.
      if (!item || item.source === "provenance" || !/^E\d+$/.test(textOf(item.id))) return;
      if (!item.usedViewsBy || typeof item.usedViewsBy !== "object") item.usedViewsBy = {};
      if (!item.usedViewsBy[owner.key] || typeof item.usedViewsBy[owner.key] !== "object") {
        item.usedViewsBy[owner.key] = {};
      }
      item.usedViewsBy[owner.key][targetKey] = true;
    });
  }

  function consumeRelationshipEvidence(items, owner, targetKey) {
    (Array.isArray(items) ? items : []).forEach(item => {
      // Raw E# evidence is consumed only after the full Relationship, R#, and
      // derived narrow-use transaction succeeds. S#/X# use is stored on provenance.
      if (!item || item.source === "provenance" || !/^E\d+$/.test(textOf(item.id))) return;
      if (!item.usedRelationshipsBy || typeof item.usedRelationshipsBy !== "object") item.usedRelationshipsBy = {};
      if (!item.usedRelationshipsBy[owner.key] || typeof item.usedRelationshipsBy[owner.key] !== "object") {
        item.usedRelationshipsBy[owner.key] = {};
      }
      item.usedRelationshipsBy[owner.key][targetKey] = true;
    });
  }

  function consumeNameEvidence(items, subjectKey, aliasKey) {
    items.forEach(item => {
      if (!item.usedNamesBy[subjectKey] || typeof item.usedNamesBy[subjectKey] !== "object") {
        item.usedNamesBy[subjectKey] = {};
      }
      item.usedNamesBy[subjectKey][aliasKey] = true;
    });
  }

  function modelEvidenceText(item, currentInputId, recent) {
    if (item.id === currentInputId) return "See the current player input in Recent Story.";
    if (item.source === "opening" && anchorInText(item.anchor, recent)) return "See the opening prompt in Recent Story.";
    if (item.source === "story" && anchorInText(item.anchor, recent)) return "See the matching completed generated story in Recent Story.";
    return item.text.replace(/\{/g, "⦃").replace(/\}/g, "⦄");
  }

  function outputAnchorPresent(contextValue) {
    const anchor = CC.lastVisibleOutputAnchor;
    if (!anchor || !anchor.text) return true;
    const candidates = [];
    const recent = recentStoryFromContext(contextValue);
    if (recent) candidates.push(recent);
    historyList.forEach(item => {
      const value = historyText(item);
      if (value) candidates.push(value);
    });
    return candidates.some(value => {
      const canonical = canonicalOutput(value);
      return canonical && (canonical.includes(anchor.text) || hashString(canonical) === anchor.hash);
    });
  }

  function hasOpeningHistoryShape(inputValue) {
    const actions = historyList.filter(item => item && typeof item === "object" && !Array.isArray(item));
    if (!actions.length) return true;
    if (actions.length > 1 || historyType(actions[0]) !== "start") return false;
    return !inputValue || keyOf(historyText(actions[0])) === keyOf(inputValue);
  }

  function isOpeningInput(inputValue) {
    return !CC.openingSeen && CC.inputCount === 0 && CC.visibleGenerationCount === 0 && hasOpeningHistoryShape(inputValue);
  }

  function hasCompleteStory(value) {
    const source = clean(value, 20000);
    const words = source.split(/\s+/).filter(token => /[A-Za-z0-9\u00C0-\u024F]/.test(token));
    return words.length >= 1 && /[.!?…]["'’”)*_`\]}]*$/.test(source);
  }

  function aliasMentioned(source, alias) {
    const normalized = value => textOf(value).normalize("NFKC")
      .replace(/[‘’‛]/g, "'")
      .replace(/[‐‑‒–—―]/g, "-");
    const wanted = line(normalized(alias), 160);
    if (!wanted) return false;
    const pattern = wanted.split(/\s+/).map(escapeRegExp).join("\\s+");
    return new RegExp("(^|[^A-Za-z0-9])" + pattern + "(?=$|[^A-Za-z0-9])", "i").test(normalized(source));
  }

  function castFor(character) {
    if (!character) return blankCast("side");
    if (!CC.npcs[character.key]) CC.npcs[character.key] = blankNpc(character.startingStatus);
    CC.npcs[character.key].cast = normalizeCast(CC.npcs[character.key].cast, character.startingStatus);
    return CC.npcs[character.key].cast;
  }

  function currentCastStatus(character) {
    return castFor(character).status;
  }

  function identityForms(identity, includeEmerging) {
    if (!identity) return [];
    if (identity.player) {
      return uniqueNameForms((player.aliases || [player.name])
        .concat(includeEmerging ? player.emergingAliases || [] : []), 160);
    }
    return uniqueNameForms((identity.character.aliases || [identity.canonical])
      .concat(includeEmerging ? identity.character.emergingAliases || [] : []), 160);
  }

  function identityMentioned(source, identity, includeEmerging, sceneKeys) {
    const scene = new Set(Array.isArray(sceneKeys) ? sceneKeys : (CC.activeKeys || []));
    return identityForms(identity, includeEmerging).some(form => {
      if (!aliasMentioned(source, form)) return false;
      const matches = identityReferenceMatches(form, includeEmerging);
      if (matches.length === 1) return matches[0].key === identity.key;
      const sceneMatches = matches.filter(match => match.player || (match.character && scene.has(match.character.key)));
      if (sceneMatches.length === 1) return sceneMatches[0].key === identity.key;
      CC.last.nameDiagnostics = unique((CC.last.nameDiagnostics || []).concat(
        "Ambiguous name form " + form + " matched " + matches.map(match => match.canonical).join(", ") + "."
      ), 300).slice(-20);
      return false;
    });
  }

  function characterMentioned(source, character, includeEmerging, sceneKeys) {
    const identity = nameIdentityForKey("npc:" + character.key);
    return identity ? identityMentioned(source, identity, includeEmerging, sceneKeys) : false;
  }

  function activeCandidates(source, currentInput) {
    const recentTail = textOf(source).slice(-3500);
    return activeNpcRosterCharacters().map(character => {
      const direct = characterMentioned(currentInput, character, false, CC.activeKeys);
      const recent = characterMentioned(recentTail, character, false, CC.activeKeys);
      const lastSeen = Number(CC.sceneLastSeen[character.key]);
      const carried = Number.isFinite(lastSeen) && CC.visibleGenerationCount - lastSeen <= 2;
      return {
        character,
        direct,
        recent,
        eligible: direct || recent || carried
      };
    }).filter(item => item.eligible);
  }

  function preserveCastProgressForRetry() {
    if (!CC.preGenerationSnapshot || typeof CC.preGenerationSnapshot !== "object") return;
    if (!CC.preGenerationSnapshot.npcs || typeof CC.preGenerationSnapshot.npcs !== "object") {
      CC.preGenerationSnapshot.npcs = {};
    }
    characters.forEach(character => {
      if (!CC.preGenerationSnapshot.npcs[character.key]) {
        CC.preGenerationSnapshot.npcs[character.key] = blankNpc(character.startingStatus);
      }
      CC.preGenerationSnapshot.npcs[character.key].cast = clone(castFor(character));
    });
  }

  function updateDynamicCast(candidateRows, currentInput, plan) {
    if (!plan || plan.castProgressApplied) return;
    plan.castProgressApplied = true;
    if (!runtime.dynamicCast) {
      if (plan.kind === "input" && plan.genuine) CC.last.cast = "Frozen";
      return;
    }
    if (plan.kind !== "input" || !plan.genuine) return;

    const rosterCharacters = activeNpcRosterCharacters();
    const presentKeys = new Set(candidateRows.map(item => item.character.key));
    const interactionKeys = new Set(rosterCharacters.filter(character =>
      characterMentioned(currentInput, character, false, CC.activeKeys)
    ).map(character => character.key));
    if (!interactionKeys.size && CC.conversationKey && presentKeys.has(CC.conversationKey)) {
      interactionKeys.add(CC.conversationKey);
    }

    const updates = [];
    rosterCharacters.forEach(character => {
      const cast = castFor(character);
      const present = presentKeys.has(character.key);
      if (cast.status === "main") {
        if (present) {
          if (cast.inactiveStreak > 0) updates.push(character.name + " inactivity reset");
          cast.inactiveStreak = 0;
        } else {
          cast.inactiveStreak += 1;
          if (cast.inactiveStreak >= runtime.mainInactivityLimit) {
            cast.status = "side";
            cast.interactionProgress = 0;
            cast.inactiveStreak = 0;
            updates.push(character.name + " became Side");
          } else {
            updates.push(character.name + " inactive " + cast.inactiveStreak + "/" + runtime.mainInactivityLimit);
          }
        }
        return;
      }

      cast.inactiveStreak = 0;
      if (!interactionKeys.has(character.key)) return;
      cast.interactionProgress += 1;
      if (cast.interactionProgress >= runtime.sidePromotionInteractions) {
        cast.status = "main";
        cast.interactionProgress = 0;
        cast.inactiveStreak = 0;
        updates.push(character.name + " became Main");
      } else {
        updates.push(character.name + " interactions " + cast.interactionProgress + "/" + runtime.sidePromotionInteractions);
      }
    });
    CC.last.cast = updates.join("; ") || "None";
    preserveCastProgressForRetry();
  }

  function selectActive(source, currentInput, plan) {
    const candidates = activeCandidates(source, currentInput);
    updateDynamicCast(candidates, currentInput, plan);
    return candidates
      .sort((left, right) => Number(right.direct) - Number(left.direct)
        || Number(right.recent) - Number(left.recent)
        || Number(currentCastStatus(right.character) === "main") - Number(currentCastStatus(left.character) === "main")
        || left.character.index - right.character.index)
      .slice(0, runtime.maxActive)
      .map(item => item.character);
  }

  function interactionScore(character, currentInput) {
    const source = textOf(currentInput);
    if (!characterMentioned(source, character, false, CC.activeKeys)) return 0;
    let score = 0;
    character.aliases.forEach(alias => {
      if (!aliasMentioned(source, alias)) return;
      score = Math.max(score, 100);
      const wanted = escapeRegExp(line(alias, 120));
      const patterns = [
        new RegExp("\\b(?:to|toward|towards|at|beside|with|near)\\s+(?:the\\s+)?" + wanted + "(?=$|[^A-Za-z0-9])", "i"),
        new RegExp("\\b(?:ask|tell|thank|address|greet|approach|face|answer|help|comfort|confront|warn|invite|hug|kiss|touch)\\w*\\s+(?:to\\s+)?" + wanted + "(?=$|[^A-Za-z0-9])", "i"),
        new RegExp("(^|[\\s\\\"'“‘])" + wanted + "\\s*[,!:—-]", "i")
      ];
      if (patterns.some(pattern => pattern.test(source))) score = Math.max(score, 650);
    });
    return score;
  }

  function selectFocus(active, currentInput) {
    if (!active.length) return null;
    const scored = active.map(character => ({ character, score: interactionScore(character, currentInput) }));
    const named = scored.filter(item => item.score > 0);
    if (!named.length && CC.conversationKey) {
      const carried = active.find(character => character.key === CC.conversationKey);
      if (carried) return carried;
    }
    const pool = named.length ? named : scored;
    return pool.slice().sort((left, right) => {
      if (right.score !== left.score) return right.score - left.score;
      const leftServed = Number(CC.focusLastServed[left.character.key]);
      const rightServed = Number(CC.focusLastServed[right.character.key]);
      const leftAge = Number.isFinite(leftServed) ? leftServed : -1;
      const rightAge = Number.isFinite(rightServed) ? rightServed : -1;
      return leftAge - rightAge
        || Number(currentCastStatus(right.character) === "main") - Number(currentCastStatus(left.character) === "main")
        || active.indexOf(left.character) - active.indexOf(right.character);
    })[0].character;
  }

  function subjectPronoun(character) {
    const raw = line(character && Array.isArray(character.pronouns) ? character.pronouns[0] : "", 120);
    return keyOf(raw.split(/[\/\s]+/).filter(Boolean)[0] || "");
  }

  function resolveActiveSubjectPronoun(value, active) {
    const wanted = keyOf(value);
    const matches = wanted
      ? active.filter(character => subjectPronoun(character) === wanted)
      : [];
    return {
      recognized: matches.length > 0,
      ambiguous: matches.length > 1,
      character: matches.length === 1 ? matches[0] : null
    };
  }

  function inferredConversationSpeaker(story, active) {
    const source = textOf(story);
    const speechVerb = "(?:says?|asks?|answers?|replies?|responds?|adds?|calls?|murmurs?|whispers?|repeats?|remarks?|continues?)";
    let direct = null;
    active.forEach(character => character.aliases.forEach(alias => {
      const activeMatches = identityReferenceMatches(alias, false).filter(identity =>
        identity.character && active.some(item => item.key === identity.character.key)
      );
      if (activeMatches.length !== 1 || activeMatches[0].character.key !== character.key) return;
      const wanted = escapeRegExp(line(alias, 120));
      const patterns = [
        new RegExp("(^|[^A-Za-z0-9])" + wanted + "[^.!?…\\n]{0,100}\\b" + speechVerb + "\\b", "ig"),
        new RegExp("\\b" + speechVerb + "\\b[ \\t]*(?:,[ \\t]*)?(?:the\\s+)?" + wanted + "(?=$|[^A-Za-z0-9])", "ig")
      ];
      patterns.forEach(pattern => {
        let match;
        while ((match = pattern.exec(source))) {
          if (!direct || match.index >= direct.index) direct = { character, index: match.index };
        }
      });
    }));

    let pronounAttribution = null;
    const pronounToken = "([A-Za-z\\u00C0-\\u024F][A-Za-z0-9_\\u00C0-\\u024F'’.-]*)";
    const modifier = "(?:(?:quietly|softly|gently|dryly|warmly|coldly|carefully|hesitantly|firmly|flatly|simply|finally|then|also|just|still|now|immediately|eventually)[ \\t]+){0,2}";
    const afterTag = new RegExp(
      "^[ \\t]*(?:[,;:—–-][ \\t]*)?" + pronounToken + "[ \\t]+" + modifier + speechVerb + "\\b",
      "i"
    );
    const beforeTag = new RegExp(
      "\\b" + pronounToken + "[ \\t]+" + modifier + speechVerb + "\\b[^.!?…\\n]{0,80}$",
      "i"
    );
    const quotedSpan = /“[^”\n]*”|"[^"\n]*"/g;
    let quoteMatch;
    while ((quoteMatch = quotedSpan.exec(source))) {
      const before = source.slice(Math.max(0, quoteMatch.index - 140), quoteMatch.index);
      const after = source.slice(quoteMatch.index + quoteMatch[0].length, quoteMatch.index + quoteMatch[0].length + 140);
      const afterMatch = after.match(afterTag);
      const beforeMatch = afterMatch ? null : before.match(beforeTag);
      const token = afterMatch ? afterMatch[1] : (beforeMatch ? beforeMatch[1] : "");
      if (!token) continue;
      const resolved = resolveActiveSubjectPronoun(token, active);
      if (!resolved.recognized) continue;
      pronounAttribution = {
        character: resolved.character,
        ambiguous: resolved.ambiguous,
        index: quoteMatch.index
      };
    }

    const attributed = [direct, pronounAttribution]
      .filter(Boolean)
      .sort((left, right) => right.index - left.index)[0] || null;
    if (attributed) return attributed.ambiguous ? null : attributed.character;

    const quoteStarts = [];
    let straightOpen = true;
    for (let index = 0; index < source.length; index++) {
      if (source[index] === "“") quoteStarts.push(index);
      else if (source[index] === '"') {
        if (straightOpen) quoteStarts.push(index);
        straightOpen = !straightOpen;
      }
    }
    let quoted = null;
    quoteStarts.forEach(index => {
      const prefix = source.slice(0, index)
        .replace(/“[^”]*”/g, " ")
        .replace(/"[^"\n]*"/g, " ");
      const sentences = prefix.split(/[.!?…\n]+/).map(value => value.trim()).filter(Boolean).slice(-3).reverse();
      for (const sentence of sentences) {
        const mentions = active.map(character => {
          let first = Infinity;
          if (!characterMentioned(sentence, character, false, active.map(item => item.key))) return { character, first };
          character.aliases.forEach(alias => {
            const activeMatches = identityReferenceMatches(alias, false).filter(identity =>
              identity.character && active.some(item => item.key === identity.character.key)
            );
            if (activeMatches.length !== 1 || activeMatches[0].character.key !== character.key) return;
            const match = new RegExp("(^|[^A-Za-z0-9])" + escapeRegExp(line(alias, 120)) + "(?=$|[^A-Za-z0-9])", "i").exec(sentence);
            if (match) first = Math.min(first, match.index);
          });
          return { character, first };
        }).filter(item => Number.isFinite(item.first)).sort((left, right) => left.first - right.first);
        if (mentions.length) {
          quoted = mentions[0].character;
          break;
        }
      }
    });
    if (quoted) return quoted;
    const portrayed = active.filter(character => characterMentioned(source, character, false, active.map(item => item.key)));
    return portrayed.length === 1 ? portrayed[0] : null;
  }

  function updateScenePresence(story, focusKey, generation) {
    characters.forEach(character => {
      if (characterMentioned(story, character, false, CC.activeKeys)) CC.sceneLastSeen[character.key] = generation;
    });
    if (focusKey) CC.sceneLastSeen[focusKey] = generation;
  }

  function captureSnapshot() {
    return clone({
      npcs: CC.npcs,
      inputCount: CC.inputCount,
      visibleGenerationCount: CC.visibleGenerationCount,
      stateClock: CC.stateClock,
      openingSeen: CC.openingSeen,
      openingEvidenceId: CC.openingEvidenceId,
      focusLastServed: CC.focusLastServed,
      sceneLastSeen: CC.sceneLastSeen,
      recoveryPending: CC.recoveryPending,
      activeKeys: CC.activeKeys,
      modelActiveKeys: CC.modelActiveKeys,
      conversationKey: CC.conversationKey,
      focusKey: CC.focusKey,
      evidence: CC.evidence,
      nextEvidenceNumber: CC.nextEvidenceNumber,
      ownerOpportunities: CC.ownerOpportunities,
      recoveringViews: CC.recoveringViews,
      provenance: CC.provenance,
      operationState: CC.operationState,
      lastOperationOutcome: CC.last.operationOutcome,
      lastOperationDrainChange: CC.last.operationDrainChange,
      lastOperationDecay: CC.last.operationDecay,
      lastProvenanceCreated: CC.last.provenanceCreated,
      provenanceDiagnostics: CC.last.provenanceDiagnostics,
      relationshipSourceDiagnostics: CC.last.relationshipSourceDiagnostics,
      relationshipUseDiagnostics: CC.last.relationshipUseDiagnostics,
      viewSourceDiagnostics: CC.last.viewSourceDiagnostics,
      viewUseDiagnostics: CC.last.viewUseDiagnostics,
      viewRepairDiagnostics: CC.viewRepairDiagnostics,
      viewTransactionDiagnostics: CC.viewTransactionDiagnostics,
      lastTimeJumpEvidenceId: CC.lastTimeJumpEvidenceId,
      managedViewsCards: captureManagedViewsCards(),
      managedNamesCards: captureManagedNamesCards(),
      managedRelationshipsCards: captureManagedRelationshipsCards(),
      managedExperienceCards: captureManagedExperienceCards()
    });
  }

  function restoreSnapshot(snapshot) {
    if (!snapshot || typeof snapshot !== "object") return false;
    [
      "npcs", "inputCount", "visibleGenerationCount", "stateClock",
      "openingSeen", "openingEvidenceId", "focusLastServed", "sceneLastSeen", "recoveryPending",
      "activeKeys", "modelActiveKeys", "focusKey", "conversationKey", "evidence", "nextEvidenceNumber",
      "ownerOpportunities", "recoveringViews", "provenance", "operationState", "lastTimeJumpEvidenceId"
    ].forEach(field => { if (snapshot[field] !== undefined) CC[field] = clone(snapshot[field]); });
    if (snapshot.lastOperationOutcome !== undefined) {
      CC.last.operationOutcome = line(snapshot.lastOperationOutcome, 500) || "None";
    }
    if (snapshot.lastOperationDrainChange !== undefined) {
      CC.last.operationDrainChange = line(snapshot.lastOperationDrainChange, 500) || "None";
    }
    if (snapshot.lastOperationDecay !== undefined) {
      CC.last.operationDecay = line(snapshot.lastOperationDecay, 500) || "None";
    }
    if (snapshot.lastProvenanceCreated !== undefined) {
      CC.last.provenanceCreated = line(snapshot.lastProvenanceCreated, 500) || "None";
    }
    if (snapshot.provenanceDiagnostics !== undefined) {
      CC.last.provenanceDiagnostics = unique(snapshot.provenanceDiagnostics, 500).slice(-20);
    }
    if (snapshot.relationshipSourceDiagnostics !== undefined) {
      CC.last.relationshipSourceDiagnostics = unique(snapshot.relationshipSourceDiagnostics, 500).slice(-40);
    }
    if (snapshot.relationshipUseDiagnostics !== undefined) {
      CC.last.relationshipUseDiagnostics = unique(snapshot.relationshipUseDiagnostics, 500).slice(-40);
    }
    if (snapshot.viewSourceDiagnostics !== undefined) {
      CC.last.viewSourceDiagnostics = unique(snapshot.viewSourceDiagnostics, 500).slice(-40);
    }
    if (snapshot.viewUseDiagnostics !== undefined) {
      CC.last.viewUseDiagnostics = unique(snapshot.viewUseDiagnostics, 500).slice(-40);
    }
    if (snapshot.viewRepairDiagnostics !== undefined) {
      CC.viewRepairDiagnostics = unique(snapshot.viewRepairDiagnostics, 300).slice(-30);
    }
    if (snapshot.viewTransactionDiagnostics !== undefined) {
      CC.viewTransactionDiagnostics = unique(snapshot.viewTransactionDiagnostics, 300).slice(-30);
    }
    let cardsRestored = true;
    if (snapshot.managedViewsCards !== undefined) {
      cardsRestored = restoreManagedViewsCards(snapshot.managedViewsCards) && cardsRestored;
    }
    if (snapshot.managedNamesCards !== undefined) {
      cardsRestored = restoreManagedNamesCards(snapshot.managedNamesCards) && cardsRestored;
    }
    if (snapshot.managedRelationshipsCards !== undefined) {
      cardsRestored = restoreManagedRelationshipsCards(snapshot.managedRelationshipsCards) && cardsRestored;
    }
    if (snapshot.managedExperienceCards !== undefined) {
      cardsRestored = restoreManagedExperienceCards(snapshot.managedExperienceCards) && cardsRestored;
    }
    characters.forEach(character => {
      if (!CC.npcs[character.key]) CC.npcs[character.key] = blankNpc(character.startingStatus);
      else CC.npcs[character.key] = normalizeNpc(CC.npcs[character.key], character.startingStatus);
    });
    CC.evidence = (Array.isArray(CC.evidence) ? CC.evidence : []).map(normalizeEvidenceItem).filter(item => item.id && item.text);
    CC.provenance = normalizeProvenanceLedger(CC.provenance);
    CC.operationState = normalizeOperationState(CC.operationState);
    characters.forEach(character => {
      if (!CC.operationState.owners[character.key]) CC.operationState.owners[character.key] = blankOwnerOperationState();
    });
    return cardsRestored;
  }

  function restoreDiscardedGeneration() {
    restoreSnapshot(CC.preGenerationSnapshot);
    CC.lastVisibleOutputAnchor = null;
  }

  function frozenOperationSelectionFrom(plan) {
    const source = plan && typeof plan === "object" && !Array.isArray(plan) ? plan : {};
    if (source.operationSelectionFrozen !== true) return {};
    return {
      operationSelectionFrozen: true,
      selectedOperationKind: line(source.selectedOperationKind, 40),
      selectedCandidate: clone(source.selectedCandidate),
      operationCandidates: clone(Array.isArray(source.operationCandidates) ? source.operationCandidates : []),
      selectedEvidenceSignature: line(source.selectedEvidenceSignature, 500),
      selectedGain: Math.max(0, Math.floor(Number(source.selectedGain) || 0)),
      selectedDrain: Math.max(0, Math.floor(Number(source.selectedDrain) || 0)),
      selectedNet: Math.floor(Number(source.selectedNet) || 0),
      selectionReasons: clone(Array.isArray(source.selectionReasons) ? source.selectionReasons : []),
      operationTieBreak: line(source.operationTieBreak, 500)
    };
  }

  function beginInput(inputValue) {
    const discardedPlan = CC.currentPlan && typeof CC.currentPlan === "object" ? clone(CC.currentPlan) : null;
    const sameInput = keyOf(clean(inputValue, 5000)) === keyOf(CC.lastInput);
    const replacedOutput = !!(
      discardedPlan && discardedPlan.completed && CC.preGenerationSnapshot
      && CC.lastVisibleOutputAnchor && !outputAnchorPresent("")
    );
    const retry = replacedOutput && sameInput;
    if (replacedOutput) restoreDiscardedGeneration();

    const opening = retry ? !!(discardedPlan && discardedPlan.opening) : isOpeningInput(inputValue);
    CC.lastInput = clean(inputValue, 5000);
    CC.last.retry = retry;
    CC.last.continue = false;
    CC.last.error = "";
    CC.last.warning = "";
    if (retry) {
      CC.last.candidate = "rolled back";
      CC.last.update = "None";
      CC.last.output = "Retry restored the pre-generation snapshot, including provenance, operation meters, drains, Names, Relationships, and consumed evidence.";
    }

    if (opening) {
      let openingEvidence = retry && discardedPlan ? evidenceForId(discardedPlan.openingEvidenceId) : null;
      if (!retry) {
        CC.openingSeen = true;
        openingEvidence = addEvidence("opening", inputValue);
        CC.openingEvidenceId = openingEvidence ? openingEvidence.id : "";
        CC.preGenerationSnapshot = captureSnapshot();
      }
      CC.currentPlan = {
        kind: "opening", retry, opening: true, genuine: false, opportunity: false,
        task: "none", taskDelivered: false, completed: false, castProgressApplied: false,
        openingEvidenceId: openingEvidence ? openingEvidence.id : CC.openingEvidenceId,
        retryFocusKey: retry && discardedPlan ? discardedPlan.ownerKey || discardedPlan.focusKey || "" : "",
        retryActiveKeys: retry && discardedPlan ? clone(discardedPlan.activeKeys || []) : []
      };
      CC.last.context = "Opening automatic generation detected; its model output will be suppressed.";
      return;
    }

    let inputEvidence = retry && discardedPlan ? evidenceForId(discardedPlan.inputEvidenceId) : null;
    if (!retry) {
      CC.inputCount += 1;
      inputEvidence = addEvidence("input", inputValue);
      CC.preGenerationSnapshot = captureSnapshot();
    }
    CC.currentPlan = {
      kind: "input", retry, opening: false, genuine: !retry, opportunity: true,
      task: "none", taskDelivered: false, completed: false, castProgressApplied: false,
      inputEvidenceId: inputEvidence ? inputEvidence.id : (discardedPlan && discardedPlan.inputEvidenceId || ""),
      retryFocusKey: retry && discardedPlan ? discardedPlan.ownerKey || discardedPlan.focusKey || "" : "",
      retryActiveKeys: retry && discardedPlan ? clone(discardedPlan.activeKeys || []) : [],
      retryTargets: retry && discardedPlan ? clone(discardedPlan.targets || []) : [],
      retryEvidenceIds: retry && discardedPlan ? clone(discardedPlan.evidenceIds || []) : [],
      retryEvidenceEligibility: retry && discardedPlan ? clone(discardedPlan.evidenceEligibility || {}) : {},
      retrySourcePacket: retry && discardedPlan ? clone(discardedPlan.sourcePacket || []) : [],
      retrySourcePacketText: retry && discardedPlan ? textOf(discardedPlan.sourcePacketText) : "",
      retryOperationTaskText: retry && discardedPlan ? textOf(discardedPlan.operationTaskText) : "",
      retryOperationTaskKind: retry && discardedPlan ? line(discardedPlan.operationTaskKind, 40) : "",
      relationshipPace: retry && discardedPlan && discardedPlan.relationshipPace
        ? clone(discardedPlan.relationshipPace)
        : clone(runtime.relationshipPace),
      ...(retry ? frozenOperationSelectionFrom(discardedPlan) : {})
    };
    CC.last.context = retry
      ? "Retry restored the prior turn position and reused its operation opportunity."
      : "Portrayal input and one fixed-owner operation opportunity are ready.";
  }

  function beginContinueIfNeeded(contextValue) {
    if (CC.currentPlan && !CC.currentPlan.completed) return CC.currentPlan;
    const discardedPlan = CC.currentPlan && typeof CC.currentPlan === "object" ? clone(CC.currentPlan) : null;
    if (discardedPlan && CC.preGenerationSnapshot && CC.lastVisibleOutputAnchor && !outputAnchorPresent(contextValue)) {
      restoreDiscardedGeneration();
      CC.currentPlan = {
        kind: "retry", retry: true, opening: false,
        genuine: false, opportunity: true,
        task: "none", taskDelivered: false, completed: false, castProgressApplied: false,
        inputEvidenceId: discardedPlan.inputEvidenceId || "",
        retryFocusKey: discardedPlan.ownerKey || discardedPlan.focusKey || "",
        retryActiveKeys: clone(discardedPlan.activeKeys || []),
        retryTargets: clone(discardedPlan.targets || []),
        retryEvidenceIds: clone(discardedPlan.evidenceIds || []),
        retryEvidenceEligibility: clone(discardedPlan.evidenceEligibility || {}),
        retrySourcePacket: clone(discardedPlan.sourcePacket || []),
        retrySourcePacketText: textOf(discardedPlan.sourcePacketText),
        retryOperationTaskText: textOf(discardedPlan.operationTaskText),
        retryOperationTaskKind: line(discardedPlan.operationTaskKind, 40),
        relationshipPace: clone(discardedPlan.relationshipPace || runtime.relationshipPace),
        ...frozenOperationSelectionFrom(discardedPlan)
      };
      CC.last.retry = true;
      CC.last.continue = false;
      CC.last.candidate = "rolled back";
      CC.last.update = "None";
      CC.last.output = "Retry/revision restored the pre-generation snapshot, including provenance, operation meters, drains, Names, Relationships, and consumed evidence.";
      return CC.currentPlan;
    }
    CC.preGenerationSnapshot = captureSnapshot();
    CC.currentPlan = {
      kind: "continue", retry: false, opening: false, genuine: false, opportunity: false,
      task: "none", taskDelivered: false, completed: false, castProgressApplied: false
    };
    CC.last.retry = false;
    CC.last.continue = true;
    return CC.currentPlan;
  }

  function outerAnchor(character) {
    return clean(character && character.outer ? character.outer : "{ " + character.name + "'s Outer: }", 20000);
  }

  function innerAnchor(character) {
    const inner = clean(character && character.inner ? character.inner : "", 20000);
    return inner ? inner + "\nEach choice follows " + character.name + "'s Principles." : "";
  }

  function compactOperationField(source, label, maximum) {
    const value = extractLine(source, label);
    return value ? label + ": " + shortenProfileValue(value, maximum) : "";
  }

  function compactOperationOuterAnchor(character) {
    const source = character && character.outer ? character.outer : "";
    const rows = [
      compactOperationField(source, "Name, age, gender, pronouns", 180),
      compactOperationField(source, "Race/Species", 120),
      compactOperationField(source, "Physical attributes", 200),
      compactOperationField(source, "Clothing style", 120)
    ].filter(Boolean);
    return rows.length ? ["{ " + character.name + "'s compact Outer:", ...rows, "}"].join("\n") : "";
  }

  function compactOperationInnerAnchor(character) {
    const source = character && character.inner ? character.inner : "";
    const rows = [
      compactOperationField(source, "Personality", 180),
      compactOperationField(source, "Mannerisms", 120),
      compactOperationField(source, "Wants", 160),
      compactOperationField(source, "Fears", 120),
      compactOperationField(source, "Mental wounds", 120),
      compactOperationField(source, "Principles", 220)
    ].filter(Boolean);
    if (!rows.length) return "";
    return [
      "{ " + character.name + "'s compact Inner:",
      ...rows,
      "}",
      "Each choice follows " + character.name + "'s Principles."
    ].join("\n");
  }

  function temporaryStateLine(character) {
    const state = normalizeState(CC.npcs[character.key] && CC.npcs[character.key].state, CC.stateClock);
    const parts = [];
    if (state.thought.value) parts.push("Thought: " + state.thought.value);
    if (state.feeling.value) parts.push("Feeling: " + state.feeling.value);
    if (state.goal.value) parts.push("Goal: " + state.goal.value);
    if (state.tension.value) parts.push("Tension: " + state.tension.value);
    if (state.situation.value) parts.push("Situation: " + state.situation.value);
    if (state.target.name) parts.push("About: " + modelTargetName(state.target.key, state.target.name));
    if (state.triggers.value.length) parts.push("Triggers: " + state.triggers.value.join(", "));
    return parts.length ? "{ " + character.name + "'s current private State:\n" + parts.join("\n") + "\n}" : "";
  }

  const EXPERIENCE_STOP_WORDS = new Set([
    "about", "after", "again", "against", "being", "during", "from", "getting", "having",
    "into", "their", "there", "these", "they", "this", "through", "under", "with"
  ]);

  function experienceStem(value) {
    const word = keyOf(value).replace(/\s+/g, "");
    if (word.length <= 4) return word;
    if (word.endsWith("ies")) return word.slice(0, -3) + "y";
    if (word.endsWith("ing")) return word.slice(0, -3);
    if (word.endsWith("ion")) return word.slice(0, -3);
    if (word.endsWith("ed")) return word.slice(0, -2);
    if (word.endsWith("es")) return word.slice(0, -2);
    if (word.endsWith("s")) return word.slice(0, -1);
    return word;
  }

  function experienceSituationMentioned(record, source) {
    const haystack = keyOf(source);
    const phrase = keyOf(record && record.situation);
    if (!haystack || !phrase) return false;
    if (haystack.includes(phrase)) return true;
    const terms = unique(phrase.split(" ")
      .filter(word => word.length >= 4 && !EXPERIENCE_STOP_WORDS.has(word))
      .map(experienceStem)
      .filter(Boolean), 60);
    if (!terms.length) return false;
    const haystackTerms = new Set(haystack.split(" ").map(experienceStem).filter(Boolean));
    const matches = terms.filter(word => haystackTerms.has(word)).length;
    return matches >= Math.min(2, terms.length);
  }

  function experienceMentioned(record, owner, source) {
    return targetReferenceMentioned(record, owner, source)
      || experienceSituationMentioned(record, source);
  }

  function relevantExperienceRecords(owner, currentInput, recent, evidenceCandidates) {
    const ownerData = experiencesForOwner(owner.key);
    const records = ownerData ? ownerData.contextRecords : [];
    const evidenceText = (Array.isArray(evidenceCandidates) ? evidenceCandidates : [])
      .map(candidate => candidate.item.text)
      .join("\n");
    const state = normalizeState(CC.npcs[owner.key] && CC.npcs[owner.key].state, CC.stateClock);
    return records.map(record => {
      let score = 0;
      if (experienceMentioned(record, owner, currentInput)) {
        score = Math.max(score, 1000);
      }
      if (experienceMentioned(record, owner, evidenceText)) {
        score = Math.max(score, 900);
      }
      if (record.targetKey === state.situation.targetKey || record.targetKey === state.target.key) {
        score = Math.max(score, 850);
      }
      if (keyOf(record.situation) === keyOf(state.situation.value) && state.situation.value) {
        score = Math.max(score, 875);
      }
      if (experienceMentioned(record, owner, textOf(recent).slice(-2500))) {
        score = Math.max(score, 700);
      }
      return { record, score };
    }).filter(item => item.score > 0)
      .sort((left, right) => right.score - left.score || left.record.page - right.record.page || left.record.line - right.record.line);
  }

  function renderRelevantExperienceBlock(owner, selection) {
    const record = selection && (selection.record || selection);
    if (!record) return "";
    return [
      "{ " + owner.name + "'s relevant Experience:",
      "- (About: " + modelTargetName(record.targetKey, record.targetName) + ") " + owner.name
        + " experienced: " + situationPhrase(record.situation) + ".",
      "}"
    ].join("\n");
  }

  function recoveringViewKey(ownerKey, targetKey) {
    return ownerKey + "|" + targetKey;
  }

  function recoveringMarker(ownerKey, targetKey) {
    return CC.recoveringViews[recoveringViewKey(ownerKey, targetKey)] || null;
  }

  function availableEvidence(owner, recent, currentInputId = "", frozenIds = [], opportunityOverride = null, frozenEligibility = null) {
    const frozen = Array.isArray(frozenIds) && frozenIds.length ? new Set(frozenIds) : null;
    const order = frozen ? new Map(frozenIds.map((id, index) => [id, index])) : null;
    return CC.evidence.map(item => {
      const saved = frozenEligibility && typeof frozenEligibility[item.id] === "object"
        ? frozenEligibility[item.id]
        : null;
      return {
        item,
        stateEligible: saved ? saved.state === true : stateEvidenceEligible(item, owner, recent),
        viewEligible: saved ? saved.view === true : viewEvidenceEligible(item, owner, recent, "", opportunityOverride),
        relationshipEligible: saved
          ? saved.relationship === true
          : relationshipEvidenceEligible(item, owner, recent, "", opportunityOverride),
        nameEligible: saved
          ? saved.name === true
          : nameEvidenceEligible(item, owner, recent, "", "", opportunityOverride),
        age: saved && Number.isFinite(Number(saved.age))
          ? Math.max(0, Number(saved.age))
          : viewEvidenceAge(item, owner, opportunityOverride)
      };
    }).filter(candidate => (candidate.stateEligible || candidate.viewEligible || candidate.relationshipEligible || candidate.nameEligible)
      && (!frozen || frozen.has(candidate.item.id)))
      .sort((left, right) => {
        if (order) return (order.get(left.item.id) ?? Number.MAX_SAFE_INTEGER) - (order.get(right.item.id) ?? Number.MAX_SAFE_INTEGER);
        const leftCurrent = left.item.id === currentInputId ? 1 : 0;
        const rightCurrent = right.item.id === currentInputId ? 1 : 0;
        if (rightCurrent !== leftCurrent) return rightCurrent - leftCurrent;
        const leftRecent = anchorInText(left.item.anchor, recent) ? 1 : 0;
        const rightRecent = anchorInText(right.item.anchor, recent) ? 1 : 0;
        if (rightRecent !== leftRecent) return rightRecent - leftRecent;
        if (right.age !== left.age) return right.age - left.age;
        return right.item.number - left.item.number;
      });
  }

  function targetReferenceMentioned(record, owner, source) {
    if (!record) return false;
    if (record.targetKey === "self") {
      const identity = owner ? nameIdentityForKey("npc:" + owner.key) : null;
      return aliasMentioned(source, "Self")
        || !!(identity && identityMentioned(source, identity, false, CC.activeKeys));
    }
    if (record.targetKey === "player") {
      const identity = nameIdentityForKey("player");
      return ["Player", "the player", "you"].some(alias => aliasMentioned(source, alias))
        || !!(identity && identityMentioned(source, identity, false, CC.activeKeys));
