const CHARACTER_CONTINUITY_STABLE_SETTINGS = {
  VERSION: "Character Continuity Stable v1.0.53",
  OUTER_CHARACTER_LABEL: "Outer",
  INNER_CHARACTER_LABEL: "Inner",
  VIEWS_LABEL: "Views",
  BURIED_VIEWS_LABEL: "Buried Views",
  RELATIONSHIPS_LABEL: "Relationships",
  NAMES_LABEL: "Names",
  EXPERIENCES_LABEL: "Experiences",
  STATE_LABEL: "State",
  PLAYER_TITLE: "Player — Identity",
  ACTIVE_NPCS_TITLE: "CC — Active NPCs",
  SETTINGS_TITLE: "CC — Settings",
  STATUS_TITLE: "CC — Status",
  DEBUG_TITLE: "CC — Debug",
  CARD_TYPE: "Continuity",

  DEFAULT_ENABLED: true,
  DEFAULT_CONTINUITY_BUDGET: 2000,
  DEFAULT_STATE_LIFETIME: 3,
  DEFAULT_MAX_ACTIVE_NPCS: 5,
  DEFAULT_DYNAMIC_CAST: true,
  DEFAULT_SIDE_PROMOTION_INTERACTIONS: 5,
  DEFAULT_MAIN_INACTIVITY_LIMIT: 12,
  DEFAULT_RELATIONSHIP_PACE: "Balanced",
  DEFAULT_CUSTOM_RELATIONSHIP_ACCUMULATED: 2,
  DEFAULT_CUSTOM_RELATIONSHIP_DIRECT: 10,
  DEFAULT_CUSTOM_RELATIONSHIP_MAX_STAGES: 1,
  DEFAULT_DEBUG: false,

  MAX_ACTIVE_NPCS: 5,
  MIN_CONTINUITY_BUDGET: 1800,
  MAX_OUTER_CARD_CHARS: 2000,
  MAX_INNER_CARD_CHARS: 2000,
  MAX_VIEWS_CARD_CHARS: 1000,
  MAX_RELATIONSHIPS_CARD_CHARS: 1000,
  MAX_NAMES_CARD_CHARS: 1000,
  MAX_EXPERIENCES_CARD_CHARS: 1000,
  MAX_DEBUG_CARD_CHARS: 2000,
  MAX_PROVENANCE_RECORDS: 160,
  MAX_OPERATION_DRAIN_RECORDS: 160,
  OPERATION_DRAIN_CAP: 12,
  MAX_OPERATION_TASK_TOKENS: 600,
  MAX_OPERATION_TURN_TOKENS: 1400,
  MAX_OPERATION_EVIDENCE_CHARS: 300,
  OPERATION_POINTS: {
    EXPLICIT_DIRECT_GAIN: 12,
    STRONG_STATE_GAIN: 10,
    EXPLICIT_VIEW_GAIN: 10,
    EXPERIENCE_PATTERN_GAIN: 6,
    RELATIONSHIP_TO_VIEW_GAIN: 6,
    STATE_CONFIRMATION_GAIN: 4,
    SUPPORTING_EVIDENCE_GAIN: 2,
    SUCCESS_DRAIN: 2,
    UNCHANGED_DRAIN: 3,
    REJECTED_DRAIN: 5,
    MALFORMED_DRAIN: 7,
    REPEATED_SIGNATURE_DRAIN: 3,
    DECAY_PER_OWNER_OPPORTUNITY: 1
  },
  MAX_EVIDENCE_ITEM_CHARS: 1000,
  MAX_EVIDENCE_ITEMS: 48,
  VIEW_EVIDENCE_OPPORTUNITIES: 12,
  RELATIONSHIP_EVIDENCE_OPPORTUNITIES: 12,
  NAME_EVIDENCE_OPPORTUNITIES: 12,
  NAME_ESTABLISHMENT_CONFIRMATIONS: 3,
  MAX_STATE_VALUE_CHARS: 120,
  MAX_STATE_TRIGGERS: 3,
  SITUATION_EXPERIENCE_CONFIRMATIONS: 3,
  DEBUG_LOGS: false
};

function CharacterContinuity(hook, incomingText) {
  const settings = CHARACTER_CONTINUITY_STABLE_SETTINGS;
  const originalText = incomingText;
  const rootState = state;
  const historyList = history;
  const cards = storyCards;

  function finish(value) {
    return typeof value === "string" && value.length ? value : " ";
  }

  function debug(message) {
    if (settings.DEBUG_LOGS === true) {
      log("[Character Continuity Stable] " + message);
    }
  }

  function textOf(value) {
    return value === null || value === undefined ? "" : String(value);
  }

  function clean(value, limit) {
    return textOf(value)
      .replace(/\r/g, "")
      .replace(/[ \t]+/g, " ")
      .replace(/\n{3,}/g, "\n\n")
      .trim()
      .slice(0, Math.max(1, Number(limit) || 10000));
  }

  function line(value, limit) {
    return clean(value, Math.max(limit * 3, limit))
      .replace(/\s*\n\s*/g, " ")
      .trim()
      .slice(0, Math.max(1, Number(limit) || 500));
  }

  function wrappedLine(value, limit) {
    const max = Math.max(4, Number(limit) || 500);
    const source = clean(value, 20000).replace(/\s*\n\s*/g, " ").trim();
    if (source.length <= max) return source;
    const closing = source[0] === "{" && source.endsWith("}")
      ? "}"
      : (source[0] === "[" && source.endsWith("]") ? "]" : "");
    return closing
      ? source.slice(0, max - 2).trimEnd() + " " + closing
      : source.slice(0, max);
  }

  function wholeLine(value, max) {
    const result = clean(value, 20000).replace(/\s*\n\s*/g, " ").trim();
    if (!result) return "";
    const limit = Math.max(0, Number(max) || 0);
    return limit > 0 && result.length > limit ? "" : result;
  }

  function keyOf(value) {
    return textOf(value)
      .toLowerCase()
      .normalize("NFKD")
      .replace(/[\u0300-\u036f]/g, "")
      .replace(/[^a-z0-9]+/g, " ")
      .trim();
  }

  function nameKeyOf(value) {
    return textOf(value)
      .normalize("NFKC")
      .toLowerCase()
      .replace(/[‘’‛]/g, "'")
      .replace(/[‐‑‒–—―]/g, "-")
      .replace(/[ \t\r\n]+/g, " ")
      .trim();
  }

  function sameNameForm(left, right) {
    const leftKey = nameKeyOf(left);
    return !!leftKey && leftKey === nameKeyOf(right);
  }

  function escapeRegExp(value) {
    return textOf(value).replace(/[.*+?^${}()|[\]\\]/g, "\\$&");
  }

  function clone(value) {
    try { return JSON.parse(JSON.stringify(value)); } catch { return null; }
  }

  function unique(values, limit) {
    const result = [];
    (Array.isArray(values) ? values : []).forEach(value => {
      const item = line(value, limit);
      if (item && !result.some(existing => keyOf(existing) === keyOf(item))) result.push(item);
    });
    return result;
  }

  function uniqueNameForms(values, limit) {
    const result = [];
    (Array.isArray(values) ? values : []).forEach(value => {
      const item = line(value, limit);
      if (item && !result.some(existing => sameNameForm(existing, item))) result.push(item);
    });
    return result;
  }

  function boolValue(value, fallback) {
    const normalized = keyOf(value);
    if (["true", "yes", "on", "1", "enabled"].includes(normalized)) return true;
    if (["false", "no", "off", "0", "disabled"].includes(normalized)) return false;
    return fallback;
  }

  function numberValue(value, fallback, min, max) {
    const parsed = parseInt(value, 10);
    if (!Number.isFinite(parsed)) return fallback;
    return Math.max(min, Math.min(max, parsed));
  }

  function positiveWhole(value, fallback) {
    const source = textOf(value).trim();
    if (!/^\d+$/.test(source)) return fallback;
    const parsed = Number(source);
    return Number.isSafeInteger(parsed) && parsed > 0 ? parsed : fallback;
  }

  function estimateTokens(value) {
    const source = textOf(value).trim();
    if (!source) return 0;
    const structural = (source.match(/[{}[\]<>\":,\\]/g) || []).length;
    return Math.ceil((Math.max(0, source.length - structural) / 3.25) + (structural / 1.8));
  }

  function hashString(value) {
    const source = textOf(value);
    let hash = 2166136261;
    for (let index = 0; index < source.length; index++) {
      hash ^= source.charCodeAt(index);
      hash = Math.imul(hash, 16777619);
    }
    return (hash >>> 0).toString(16);
  }

  function titleOf(card) {
    if (!card) return "";
    return line(typeof card.title === "string" ? card.title : "", 220);
  }

  function entryOf(card) {
    return card && typeof card.entry === "string" ? card.entry : "";
  }

  function findCard(title) {
    const wanted = keyOf(title);
    return cards.find(card => keyOf(titleOf(card)) === wanted) || null;
  }

  function cardIndex(card) {
    if (!card) return -1;
    const direct = cards.indexOf(card);
    if (direct >= 0) return direct;
    const id = card.id === null || card.id === undefined ? "" : textOf(card.id);
    return id
      ? cards.findIndex(candidate => candidate && textOf(candidate.id) === id)
      : -1;
  }

  function extractLine(source, label) {
    const match = textOf(source).match(new RegExp(
      "^[ \\t]*(?:[\\{\\[][ \\t]*)?" + escapeRegExp(label)
      + "[ \\t]*:[ \\t]*([^\\r\\n]*?)[ \\t]*(?:[\\}\\]][ \\t]*)?$",
      "im"
    ));
    return match ? line(match[1], 2000) : "";
  }

  function updateCardAt(index, keys, entry, type) {
    if (!Number.isInteger(index) || index < 0 || index >= cards.length) return null;
    const current = cards[index];
    const nextKeys = textOf(keys).trim()
      ? textOf(keys)
      : (textOf(current && current.keys).trim() ? textOf(current.keys) : titleOf(current));
    const nextEntry = typeof entry === "string" ? entry : entryOf(current);
    const nextType = textOf(type).trim()
      ? textOf(type)
      : (textOf(current && current.type).trim() ? textOf(current.type) : settings.CARD_TYPE);
    if (textOf(current && current.keys) === nextKeys
      && entryOf(current) === nextEntry
      && textOf(current && current.type) === nextType) {
      return current;
    }
    try {
      updateStoryCard(index, nextKeys, nextEntry, nextType);
      return cards[index] || null;
    } catch (error) {
      debug("Could not update " + (titleOf(current) || nextKeys) + " through the Story Card API: " + error.message);
      return null;
    }
  }

  function saveCard(card, entry) {
    const index = cardIndex(card);
    if (index < 0) return null;
    const current = cards[index] || card;
    const keys = textOf(current.keys).trim() ? textOf(current.keys) : titleOf(current);
    return updateCardAt(index, keys, entry, settings.CARD_TYPE);
  }

  function addCard(title, entry) {
    const cardTitle = line(title, 220);
    if (!cardTitle) return null;
    const before = cards.length;
    let created = null;
    try {
      const result = addStoryCard(
        cardTitle,
        typeof entry === "string" ? entry : "",
        settings.CARD_TYPE
      );
      if (Number.isInteger(result)) created = cards[result - 1] || null;
      else if (cards.length > before) created = cards[cards.length - 1];
      else if (result === false) created = findCard(cardTitle);
    } catch (error) {
      debug("Could not create " + cardTitle + ": " + error.message);
    }
    return created || (cards.length > before ? cards[cards.length - 1] : null);
  }

  function upsertCard(title, entry) {
    const card = findCard(title);
    return card ? saveCard(card, entry) : addCard(title, entry);
  }

  function removeCard(card) {
    const index = cardIndex(card);
    if (index < 0) return false;
    try {
      removeStoryCard(index);
      return true;
    } catch (error) {
      debug("Could not remove " + (titleOf(card) || "Story Card") + ": " + error.message);
      return false;
    }
  }

  function removeCards(cardList) {
    const indices = unique((Array.isArray(cardList) ? cardList : [])
      .map(cardIndex)
      .filter(index => index >= 0)
      .map(String), 20)
      .map(Number)
      .sort((left, right) => right - left);
    if (!indices.length) return true;
    let removed = true;
    indices.forEach(index => {
      try { removeStoryCard(index); } catch (error) {
        debug("Could not remove Story Card at index " + index + ": " + error.message);
        removed = false;
      }
    });
    return removed;
  }

  function namedTitle(name, label) {
    return line(name, 120) + " — " + label;
  }

  function nameFromNamedTitle(title, label) {
    const match = line(title, 220).match(new RegExp("^(.+?)\\s+(?:—|–|-)\\s+" + escapeRegExp(label) + "$", "i"));
    return match ? line(match[1], 120) : "";
  }

  function namedCards(name, label) {
    const wanted = nameKeyOf(name);
    return cards.filter(card => nameKeyOf(nameFromNamedTitle(titleOf(card), label)) === wanted);
  }

  function namedCard(name, label) {
    const wanted = nameKeyOf(name);
    return cards.find(card => nameKeyOf(nameFromNamedTitle(titleOf(card), label)) === wanted) || null;
  }

  function duplicateCardEntrySignature(card) {
    return entryOf(card)
      .replace(/\r/g, "")
      .replace(/[ \t]+$/gm, "")
      .trim();
  }

  function strictBoundedWhole(value, fallback, minimum, maximum) {
    const source = textOf(value).trim();
    if (!/^\d+$/.test(source)) return { value: fallback, valid: false };
    const parsed = Number(source);
    if (!Number.isSafeInteger(parsed) || parsed < minimum || parsed > maximum) {
      return { value: fallback, valid: false };
    }
    return { value: parsed, valid: true };
  }

  function relationshipPaceSettings(source) {
    const presets = {
      slowburn: { name: "Slowburn", accumulated: 1, direct: 10, maxStages: 1 },
      balanced: { name: "Balanced", accumulated: 2, direct: 10, maxStages: 1 },
      fast: { name: "Fast", accumulated: 6, direct: 20, maxStages: 2 }
    };
    const rawPace = extractLine(source, "Relationship pace");
    const paceKey = keyOf(rawPace || settings.DEFAULT_RELATIONSHIP_PACE);
    const customAccumulated = strictBoundedWhole(
      extractLine(source, "Custom accumulated event value"),
      settings.DEFAULT_CUSTOM_RELATIONSHIP_ACCUMULATED,
      0,
      50
    );
    const customDirect = strictBoundedWhole(
      extractLine(source, "Custom direct event value"),
      settings.DEFAULT_CUSTOM_RELATIONSHIP_DIRECT,
      0,
      50
    );
    const customMaxStages = strictBoundedWhole(
      extractLine(source, "Custom maximum stages per operation"),
      settings.DEFAULT_CUSTOM_RELATIONSHIP_MAX_STAGES,
      1,
      6
    );
    const warnings = [];
    let pace;
    if (paceKey === "custom") {
      if (!customAccumulated.valid || !customDirect.valid || !customMaxStages.valid) {
        pace = { ...presets.balanced };
        warnings.push("Invalid Custom relationship values fell back to Balanced.");
      } else {
        pace = {
          name: "Custom",
          accumulated: customAccumulated.value,
          direct: customDirect.value,
          maxStages: customMaxStages.value
        };
      }
    } else if (presets[paceKey]) {
      pace = { ...presets[paceKey] };
    } else {
      pace = { ...presets.balanced };
      warnings.push("Relationship pace was missing or invalid and fell back to Balanced.");
    }
    return { pace, warning: warnings.join(" ") };
  }

  function settingsTemplate() {
    return [
      "Enabled: " + (settings.DEFAULT_ENABLED !== false),
      "Continuity budget: " + settings.DEFAULT_CONTINUITY_BUDGET,
      "State lifetime: " + settings.DEFAULT_STATE_LIFETIME,
      "Maximum active NPCs: " + settings.DEFAULT_MAX_ACTIVE_NPCS,
      "Dynamic cast: " + (settings.DEFAULT_DYNAMIC_CAST !== false),
      "Side promotion interactions: " + settings.DEFAULT_SIDE_PROMOTION_INTERACTIONS,
      "Main inactivity limit: " + settings.DEFAULT_MAIN_INACTIVITY_LIMIT,
      "Relationship pace: " + settings.DEFAULT_RELATIONSHIP_PACE,
      "Custom accumulated event value: " + settings.DEFAULT_CUSTOM_RELATIONSHIP_ACCUMULATED,
      "Custom direct event value: " + settings.DEFAULT_CUSTOM_RELATIONSHIP_DIRECT,
      "Custom maximum stages per operation: " + settings.DEFAULT_CUSTOM_RELATIONSHIP_MAX_STAGES,
      "Debug: " + (settings.DEFAULT_DEBUG === true)
    ].join("\n");
  }

  function hasSettingsField(source, label) {
    return new RegExp("^[ \\t]*" + escapeRegExp(label) + "[ \\t]*:", "im").test(textOf(source));
  }

  function ensureRelationshipSettings(card) {
    if (!card) return { card: null, warning: "" };
    const source = entryOf(card);
    const additions = [
      ["Relationship pace", settings.DEFAULT_RELATIONSHIP_PACE],
      ["Custom accumulated event value", settings.DEFAULT_CUSTOM_RELATIONSHIP_ACCUMULATED],
      ["Custom direct event value", settings.DEFAULT_CUSTOM_RELATIONSHIP_DIRECT],
      ["Custom maximum stages per operation", settings.DEFAULT_CUSTOM_RELATIONSHIP_MAX_STAGES]
    ].filter(([label]) => !hasSettingsField(source, label))
      .map(([label, value]) => label + ": " + value);
    if (!additions.length) return { card, warning: "" };
    const entry = [source.trimEnd(), additions.join("\n")].filter(Boolean).join("\n");
    const saved = saveCard(card, entry);
    return saved
      ? { card: saved, warning: "Added the missing Relationship pace controls to CC — Settings." }
      : { card, warning: "The missing Relationship pace controls could not be added to CC — Settings." };
  }

  function readRuntime() {
    const title = settings.SETTINGS_TITLE;
    let card = findCard(title);
    if (!card) {
      card = addCard(title, settingsTemplate());
    }
    const settingsUpgrade = ensureRelationshipSettings(card);
    card = settingsUpgrade.card || card;
    const source = card ? entryOf(card) : "";
    const rawContinuityBudget = extractLine(source, "Continuity budget");
    const defaultContinuityBudget = settings.DEFAULT_CONTINUITY_BUDGET;
    const minimumContinuityBudget = settings.MIN_CONTINUITY_BUDGET;
    const parsedContinuityBudget = positiveWhole(rawContinuityBudget, defaultContinuityBudget);
    const continuityBudget = Math.max(minimumContinuityBudget, parsedContinuityBudget);
    const budgetWarning = rawContinuityBudget && parsedContinuityBudget !== Number(rawContinuityBudget)
      ? "Continuity budget was invalid and defaulted to " + defaultContinuityBudget + "."
      : (rawContinuityBudget && parsedContinuityBudget < minimumContinuityBudget
        ? "Continuity budget was raised to the required " + minimumContinuityBudget + "-token minimum."
      : (!rawContinuityBudget && card
        ? "Continuity budget was missing and defaulted to " + defaultContinuityBudget + "."
        : ""));
    const relationshipPace = relationshipPaceSettings(source);
    return {
      enabled: boolValue(extractLine(source, "Enabled"), settings.DEFAULT_ENABLED !== false),
      continuityBudget,
      stateLifetime: numberValue(
        extractLine(source, "State lifetime"),
        settings.DEFAULT_STATE_LIFETIME,
        1,
        12
      ),
      maxActive: numberValue(
        extractLine(source, "Maximum active NPCs"),
        settings.DEFAULT_MAX_ACTIVE_NPCS,
        1,
        settings.MAX_ACTIVE_NPCS
      ),
      dynamicCast: boolValue(
        extractLine(source, "Dynamic cast"),
        settings.DEFAULT_DYNAMIC_CAST !== false
      ),
      sidePromotionInteractions: numberValue(
        extractLine(source, "Side promotion interactions"),
        settings.DEFAULT_SIDE_PROMOTION_INTERACTIONS,
        1,
        999
      ),
      mainInactivityLimit: numberValue(
        extractLine(source, "Main inactivity limit"),
        settings.DEFAULT_MAIN_INACTIVITY_LIMIT,
        1,
        999
      ),
      debug: boolValue(extractLine(source, "Debug"), settings.DEFAULT_DEBUG === true),
      relationshipPace: relationshipPace.pace,
      warning: [card ? "" : "The Settings card could not be created.", settingsUpgrade.warning, budgetWarning, relationshipPace.warning]
        .filter(Boolean).join(" ")
    };
  }

  const runtime = readRuntime();
  if (!runtime.enabled) return finish(originalText);

  function playerProfile() {
    const card = findCard(settings.PLAYER_TITLE);
    const source = card ? entryOf(card) : "";
    const name = extractLine(source, "Name") || "the player";
    const raw = (extractLine(source, "Pronouns") || "they/them").split(/[\/|,;\s]+/).filter(Boolean);
    let forms;
    if (raw.length >= 5) forms = raw.slice(0, 5);
    else {
      const subject = keyOf(raw[0] || "they");
      if (subject === "she") forms = ["she", "her", "her", "hers", "herself"];
      else if (subject === "he") forms = ["he", "him", "his", "his", "himself"];
      else forms = ["they", "them", "their", "theirs", "themselves"];
    }
    return {
      name,
      aliases: [name],
      emergingAliases: [],
      subject: forms[0], object: forms[1], possessiveAdjective: forms[2],
      possessivePronoun: forms[3], reflexive: forms[4],
      agreement: keyOf(forms[0]) === "they" ? "plural" : "singular"
    };
  }

  const player = playerProfile();

  function resolvePlayerTokens(value) {
    const forms = {
      name: player.name,
      subject: player.subject,
      object: player.object,
      possessive_adjective: player.possessiveAdjective,
      possessiveadjective: player.possessiveAdjective,
      possessive_pronoun: player.possessivePronoun,
      possessivepronoun: player.possessivePronoun,
      reflexive: player.reflexive,
      is: player.agreement === "plural" ? "are" : "is",
      has: player.agreement === "plural" ? "have" : "has",
      does: player.agreement === "plural" ? "do" : "does",
      was: player.agreement === "plural" ? "were" : "was",
      s: player.agreement === "plural" ? "" : "s"
    };
    return textOf(value).replace(/{{\s*(player|Player|PLAYER)\.([a-zA-Z_]+)\s*}}/g, (match, owner, field) => {
      const replacement = forms[keyOf(field).replace(/\s+/g, "_")];
      if (replacement === undefined) return match;
      if (owner === "PLAYER") return textOf(replacement).toUpperCase();
      if (owner === "Player") return replacement ? replacement.charAt(0).toUpperCase() + replacement.slice(1) : replacement;
      return replacement;
    });
  }

  function normalizeCastStatus(value, fallback) {
    const normalized = keyOf(value);
    if (normalized === "main" || normalized === "side") return normalized;
    return fallback;
  }

  function parseOuterPronouns(source) {
    const parts = textOf(extractLine(source, "Name, age, gender, pronouns"))
      .split(",")
      .map(value => value.trim());
    let pronouns = "";
    if (parts.length >= 4) {
      pronouns = line(parts.pop(), 120);
    } else {
      parts.shift();
      parts.shift();
      parts.shift();
      pronouns = line(parts.join(","), 120);
    }
    return pronouns;
  }

  function shortenProfileValue(value, maximum) {
    const source = line(value, 20000);
    const max = Math.max(1, Number(maximum) || 1);
    if (source.length <= max) return source;
    if (max === 1) return "…";
    const candidate = source.slice(0, max - 1).trimEnd();
    const wordBreak = candidate.lastIndexOf(" ");
    const kept = wordBreak >= Math.floor(max * 0.55)
      ? candidate.slice(0, wordBreak)
      : candidate;
    return kept.replace(/[,:;\-/]+$/g, "").trimEnd() + "…";
  }

  function renderOuterBlock(name, fields) {
    return [
      "{ " + name + "'s Outer:",
      ...fields.map(field => field.label + ": " + field.value),
      "}"
    ].join("\n");
  }

  function outerWrapperStatus(source) {
    const trimmed = textOf(source).replace(/\r/g, "").trim();
    return {
      opening: trimmed.startsWith("{"),
      closing: trimmed.endsWith("}")
    };
  }

  function buildOuterProfile(name, source) {
    const resolved = resolvePlayerTokens(source);
    const fields = [
      { label: "Name, age, gender, pronouns", value: extractLine(resolved, "Name, age, gender, pronouns") },
      { label: "Race/Species", value: extractLine(resolved, "Race/Species") },
      { label: "Physical attributes", value: extractLine(resolved, "Physical attributes") },
      { label: "Clothing style", value: extractLine(resolved, "Clothing style") }
    ].map(field => ({ label: field.label, value: line(field.value, 20000) }));
    const original = renderOuterBlock(name, fields);
    const maximum = settings.MAX_OUTER_CARD_CHARS;
    const fitted = fields.map(field => ({ label: field.label, value: field.value }));
    let rendered = original;
    let guard = 0;
    while (rendered.length > maximum && guard < 40) {
      guard += 1;
      const candidates = fitted.map((field, index) => ({
        index,
        reducible: Math.max(0, field.value.length - 24)
      })).filter(item => item.reducible > 0)
        .sort((left, right) => right.reducible - left.reducible || left.index - right.index);
      if (!candidates.length) break;
      const selected = candidates[0];
      const overflow = rendered.length - maximum;
      const reduction = Math.min(selected.reducible, Math.max(1, overflow));
      fitted[selected.index].value = shortenProfileValue(
        fitted[selected.index].value,
        fitted[selected.index].value.length - reduction
      );
      rendered = renderOuterBlock(name, fitted);
    }
    if (rendered.length > maximum) rendered = wrappedLine(rendered, maximum);
    return {
      text: rendered,
      originalChars: original.length,
      retainedChars: rendered.length,
      truncated: original.length > rendered.length,
      missing: fields.filter(field => !field.value).map(field => field.label)
    };
  }

  function renderInnerBlock(name, fields) {
    return [
      "{ " + name + "'s Inner:",
      ...fields.map(field => field.label + ": " + field.value),
      "}"
    ].join("\n");
  }

  function buildInnerProfile(name, source) {
    const resolved = resolvePlayerTokens(source);

    const fields = [
      { label: "Personality", value: extractLine(resolved, "Personality") },
      { label: "Mannerisms", value: extractLine(resolved, "Mannerisms") },
      { label: "Wants", value: extractLine(resolved, "Wants") },
      { label: "Fears", value: extractLine(resolved, "Fears") },
      { label: "Mental wounds", value: extractLine(resolved, "Mental wounds") },
      { label: "Principles", value: extractLine(resolved, "Principles") }
    ].map(field => ({ label: field.label, value: line(field.value, 20000) }));
    const original = renderInnerBlock(name, fields);
    const maximum = settings.MAX_INNER_CARD_CHARS;
    const fitted = fields.map(field => ({ label: field.label, value: field.value }));
    let rendered = original;
    let guard = 0;
    while (rendered.length > maximum && guard < 60) {
      guard += 1;
      const candidates = fitted.map((field, index) => ({
        index,
        reducible: Math.max(0, field.value.length - 24)
      })).filter(item => item.reducible > 0)
        .sort((left, right) => right.reducible - left.reducible || left.index - right.index);
      if (!candidates.length) break;
      const selected = candidates[0];
      const overflow = rendered.length - maximum;
      const reduction = Math.min(selected.reducible, Math.max(1, overflow));
      fitted[selected.index].value = shortenProfileValue(
        fitted[selected.index].value,
        fitted[selected.index].value.length - reduction
      );
      rendered = renderInnerBlock(name, fitted);
    }
    if (rendered.length > maximum) rendered = wrappedLine(rendered, maximum);
    return {
      text: rendered,
      originalChars: original.length,
      retainedChars: rendered.length,
      truncated: original.length > rendered.length,
      missing: fields.filter(field => !field.value).map(field => field.label)
    };
  }

  const activeRosterDiagnostics = [];

  function activeNpcSlotCode(number) {
    const slot = Number(number);
    return Number.isSafeInteger(slot) && slot >= 1 && slot <= settings.MAX_ACTIVE_NPCS
      ? "N" + slot
      : "";
  }

  function activeNpcRosterEntry(slotNames) {
    const names = Array.isArray(slotNames) ? slotNames : [];
    const rows = ["{", "Active NPC slots:"];
    for (let index = 0; index < settings.MAX_ACTIVE_NPCS; index++) {
      rows.push(activeNpcSlotCode(index + 1) + ": " + line(names[index], 120));
    }
    rows.push("}");
    return rows.join("\n");
  }

  function activeNpcRosterName(value) {
    const source = textOf(value).trim();
    if (!source || source.length > 120 || /[{}\[\]|\r\n]/.test(source)) return "";
    return line(source, 120);
  }

  function readActiveNpcRoster() {
    const matching = cards.filter(card => keyOf(titleOf(card)) === keyOf(settings.ACTIVE_NPCS_TITLE));
    let card = matching[0] || null;
    const slots = Array.from({ length: settings.MAX_ACTIVE_NPCS }, (_, index) => ({
      number: index + 1,
      code: activeNpcSlotCode(index + 1),
      name: "",
      valid: true
    }));
    if (!card) return { card: null, slots, source: "", wrapperValid: true };
    if (matching.length > 1) {
      activeRosterDiagnostics.push("Multiple CC — Active NPCs cards were found; only the first is authoritative.");
    }
    if (textOf(card.type) !== settings.CARD_TYPE) {
      const updated = updateCardAt(
        cardIndex(card),
        textOf(card.keys).trim() || settings.ACTIVE_NPCS_TITLE,
        entryOf(card),
        settings.CARD_TYPE
      );
      if (updated) card = updated;
      else activeRosterDiagnostics.push("CC — Active NPCs could not be internalized as a Continuity card.");
    }
    const source = entryOf(card);
    const trimmed = textOf(source).replace(/\r/g, "").trim();
    const wrapperValid = trimmed.startsWith("{") && trimmed.endsWith("}");
    if (!wrapperValid) activeRosterDiagnostics.push("CC — Active NPCs wrapper { } is incomplete.");
    const rows = textOf(source).replace(/\r/g, "").split("\n");
    slots.forEach(slot => {
      const pattern = new RegExp("^[ \\t]*" + escapeRegExp(slot.code) + "[ \\t]*:[ \\t]*(.*?)[ \\t]*$", "i");
      const matches = rows.map(row => row.match(pattern)).filter(Boolean);
      if (matches.length !== 1) {
        slot.valid = false;
        activeRosterDiagnostics.push(slot.code + " must appear exactly once in CC — Active NPCs.");
        return;
      }
      const supplied = textOf(matches[0][1]).trim();
      if (!supplied) return;
      const name = activeNpcRosterName(supplied);
      if (!name || name !== supplied) {
        slot.valid = false;
        activeRosterDiagnostics.push(slot.code + " contained an invalid or overlong canonical NPC name.");
        return;
      }
      slot.name = name;
    });
    rows.forEach(row => {
      const match = row.match(/^[ \\t]*N(\d+)[ \\t]*:/i);
      if (match && !activeNpcSlotCode(Number(match[1]))) {
        activeRosterDiagnostics.push("Unsupported active NPC slot N" + Number(match[1]) + " was ignored.");
      }
    });
    const seen = {};
    slots.forEach(slot => {
      if (!slot.valid || !slot.name) return;
      const key = nameKeyOf(slot.name);
      if (seen[key]) {
        slot.valid = false;
        activeRosterDiagnostics.push(slot.code + " duplicated " + seen[key] + " and was ignored without compacting the roster.");
      } else seen[key] = slot.code;
    });
    return { card, slots, source, wrapperValid };
  }

  function onboardingMarkerPresent(source) {
    return /^[ \\t]*Onboarding[ \\t]*:[ \\t]*Pending[ \\t]*$/im.test(textOf(source));
  }

  function onboardingMissingDetails(outerSource, innerSource, innerConflict) {
    const missing = [];
    const outerWrapper = outerWrapperStatus(outerSource);
    if (!outerWrapper.opening || !outerWrapper.closing) missing.push("Outer wrapper { }");
    const identityParts = textOf(extractLine(outerSource, "Name, age, gender, pronouns"))
      .split(",").map(value => value.trim());
    if (identityParts.length < 4 || identityParts.slice(0, 4).some(value => !value)) {
      missing.push("Name, age, gender, pronouns");
    }
    ["Race/Species", "Physical attributes", "Clothing style"].forEach(label => {
      if (!extractLine(outerSource, label)) missing.push(label);
    });
    if (!normalizeCastStatus(extractLine(outerSource, "Starting status"), "")) {
      missing.push("Starting status");
    }
    if (innerConflict) missing.push("one unambiguous Inner card");
    else if (!innerSource) missing.push("Inner card");
    else {
      const innerWrapper = outerWrapperStatus(innerSource);
      if (!innerWrapper.opening || !innerWrapper.closing) missing.push("Inner wrapper { }");
      ["Personality", "Mannerisms", "Wants", "Fears", "Mental wounds", "Principles"].forEach(label => {
        if (!extractLine(innerSource, label)) missing.push(label);
      });
    }
    return missing;
  }

  function onboardingOuterTemplate(name) {
    return [
      "{ " + name + "'s Outer:",
      "Onboarding: Pending",
      "Name, age, gender, pronouns: ",
      "Race/Species: ",
      "Physical attributes: ",
      "Clothing style: ",
      "Starting status: Side",
      "}"
    ].join("\n");
  }

  function onboardingInnerTemplate(name) {
    return [
      "{ " + name + "'s Inner:",
      "Onboarding: Pending",
      "Personality: ",
      "Mannerisms: ",
      "Wants: ",
      "Fears: ",
      "Mental wounds: ",
      "Principles: ",
      "}"
    ].join("\n");
  }

  function namesCardOwner(title) {
    const match = line(title, 260).match(new RegExp(
      "^(.+?)\\s+(?:—|–|-)\\s+" + escapeRegExp(settings.NAMES_LABEL) + "(?:\\s+\\d+)?$",
      "i"
    ));
    return match ? line(match[1], 120) : "";
  }

  function storedAliasOwners(alias) {
    const owners = [];
    cards.forEach(card => {
      const owner = namesCardOwner(titleOf(card));
      if (!owner) return;
      const aliases = textOf(entryOf(card)).replace(/\r/g, "").split("\n")
        .map(row => {
          const match = row.match(/^[ \\t]*Alias[ \\t]*:[ \\t]*(.*?)[ \\t]*$/i);
          return match ? line(match[1], 160) : "";
        }).filter(Boolean);
      if (aliases.some(value => sameNameForm(value, alias))
        && !owners.some(value => sameNameForm(value, owner))) owners.push(owner);
    });
    return owners;
  }

  function ensureConfirmedOnboarding(slot) {
    if (!slot || !slot.valid || !slot.name) return;
    const reserved = ["self", "player", "the player"].includes(nameKeyOf(slot.name));
    if (reserved || sameNameForm(slot.name, player.name)) {
      slot.valid = false;
      activeRosterDiagnostics.push(slot.code + " named the Player or Self and was ignored as an NPC slot.");
      return;
    }
    let outerCards = namedCards(slot.name, settings.OUTER_CHARACTER_LABEL);
    let innerCards = namedCards(slot.name, settings.INNER_CHARACTER_LABEL);
    if (!outerCards.length) {
      const aliasOwners = storedAliasOwners(slot.name);
      if (aliasOwners.length) {
        slot.valid = false;
        activeRosterDiagnostics.push(slot.code + " matched an existing Alias for "
          + aliasOwners.join(", ") + "; enter that identity's canonical name instead.");
        return;
      }
      const created = addCard(
        namedTitle(slot.name, settings.OUTER_CHARACTER_LABEL),
        onboardingOuterTemplate(slot.name)
      );
      if (created) {
        outerCards = [created];
        activeRosterDiagnostics.push(slot.name + " confirmed; blank Outer and Side status initialized.");
      } else {
        slot.valid = false;
        activeRosterDiagnostics.push(slot.name + " could not be onboarded because its Outer template could not be created.");
        return;
      }
    }
    if (outerCards.length !== 1) {
      slot.valid = false;
      activeRosterDiagnostics.push(slot.name + " has conflicting Outer cards and remains unavailable for onboarding.");
      return;
    }
    if (!innerCards.length) {
      const created = addCard(
        namedTitle(slot.name, settings.INNER_CHARACTER_LABEL),
        onboardingInnerTemplate(slot.name)
      );
      if (created) {
        innerCards = [created];
        activeRosterDiagnostics.push(slot.name + " received a blank Inner template.");
      } else {
        slot.valid = false;
        activeRosterDiagnostics.push(slot.name + " remains pending because its Inner template could not be created.");
        return;
      }
    }
    if (innerCards.length !== 1) {
      slot.valid = false;
      activeRosterDiagnostics.push(slot.name + " has conflicting Inner cards and remains unavailable for onboarding.");
    }
  }

  const activeNpcRoster = readActiveNpcRoster();
  activeNpcRoster.slots.forEach(ensureConfirmedOnboarding);

  const characterDiscoveryDiagnostics = [];

  function discoverCharacters() {
    const label = settings.OUTER_CHARACTER_LABEL;
    const candidates = cards.map((card, index) => {
      const name = nameFromNamedTitle(titleOf(card), label);
      if (!name) return null;
      return { card, index, name, key: nameKeyOf(name), source: entryOf(card), duplicateCount: 0 };
    }).filter(candidate => candidate && candidate.key);
    const groups = new Map();
    candidates.forEach(candidate => {
      if (!groups.has(candidate.key)) groups.set(candidate.key, []);
      groups.get(candidate.key).push(candidate);
    });
    const accepted = [];
    groups.forEach(group => {
      const first = group[0];
      if (group.length === 1) {
        accepted.push(first);
        return;
      }
      const signatures = new Set(group.map(candidate => duplicateCardEntrySignature(candidate.card)));
      if (signatures.size === 1) {
        first.duplicateCount = group.length - 1;
        accepted.push(first);
        characterDiscoveryDiagnostics.push(
          first.name + " has " + group.length + " exact Outer cards; using the first and excluding "
            + first.duplicateCount + " duplicate" + (first.duplicateCount === 1 ? "" : "s") + "."
        );
        return;
      }
      characterDiscoveryDiagnostics.push(
        first.name + " has " + group.length
          + " conflicting Outer cards; excluded this identity until only one remains."
      );
    });

    return accepted.map(candidate => {
      const { card: outerCard, index, name, source, duplicateCount } = candidate;
      const pronouns = parseOuterPronouns(source);
      const rawStartingStatus = extractLine(source, "Starting status");
      const parsedStartingStatus = normalizeCastStatus(rawStartingStatus, "");
      const outerProfile = buildOuterProfile(name, source);
      const wrapper = outerWrapperStatus(source);
      const matchingInnerCards = namedCards(name, settings.INNER_CHARACTER_LABEL);
      let innerCard = matchingInnerCards[0] || null;
      let innerConflict = false;
      let duplicateInnerCount = 0;
      if (matchingInnerCards.length > 1) {
        const signatures = new Set(matchingInnerCards.map(duplicateCardEntrySignature));
        if (signatures.size === 1) {
          duplicateInnerCount = matchingInnerCards.length - 1;
          characterDiscoveryDiagnostics.push(
            name + " has " + matchingInnerCards.length + " exact Inner cards; using the first and excluding "
              + duplicateInnerCount + " duplicate" + (duplicateInnerCount === 1 ? "" : "s") + "."
          );
        } else {
          innerCard = null;
          innerConflict = true;
          characterDiscoveryDiagnostics.push(
            name + " has " + matchingInnerCards.length
              + " conflicting Inner cards; omitted Inner until only one remains."
          );
        }
      }
      const innerSource = innerCard ? entryOf(innerCard) : "";
      const innerProfile = innerCard ? buildInnerProfile(name, innerSource) : null;
      const onboardingGenerated = onboardingMarkerPresent(source) || onboardingMarkerPresent(innerSource);
      const onboardingMissing = onboardingGenerated
        ? onboardingMissingDetails(source, innerSource, innerConflict)
        : [];
      const onboardingPending = onboardingGenerated && onboardingMissing.length > 0;
      const outerWarnings = [];
      const innerWarnings = [];
      if (duplicateCount) {
        outerWarnings.push("Using the first Outer card; excluded " + duplicateCount + " exact duplicate"
          + (duplicateCount === 1 ? "" : "s") + ".");
      }
      if (!wrapper.opening && !wrapper.closing) outerWarnings.push("Outer wrapper { } missing.");
      else if (!wrapper.opening) outerWarnings.push("Opening Outer wrapper { missing.");
      else if (!wrapper.closing) outerWarnings.push("Closing Outer wrapper } missing.");
      if (!parsedStartingStatus) outerWarnings.push("Starting status missing or invalid; defaulted to Side.");
      if (onboardingPending) {
        outerWarnings.push("Confirmed onboarding pending: complete " + onboardingMissing.join(", ") + ".");
      } else if (outerProfile.missing.length) {
        outerWarnings.push("Missing: " + outerProfile.missing.join(", ") + ".");
      }
      if (outerProfile.truncated) {
        outerWarnings.push("Shortened " + outerProfile.originalChars + " → " + outerProfile.retainedChars + " characters.");
      }
      if (innerConflict) {
        innerWarnings.push("Conflicting Inner cards; Inner omitted until only one remains.");
      } else if (!innerCard) {
        innerWarnings.push("Inner card missing.");
      } else {
        if (duplicateInnerCount) {
          innerWarnings.push("Using the first Inner card; excluded " + duplicateInnerCount + " exact duplicate"
            + (duplicateInnerCount === 1 ? "" : "s") + ".");
        }
        const innerWrapper = outerWrapperStatus(innerSource);
        if (!innerWrapper.opening && !innerWrapper.closing) innerWarnings.push("Inner wrapper { } missing.");
        else if (!innerWrapper.opening) innerWarnings.push("Opening Inner wrapper { missing.");
        else if (!innerWrapper.closing) innerWarnings.push("Closing Inner wrapper } missing.");
        if (!onboardingPending && innerProfile.missing.length) {
          innerWarnings.push("Missing: " + innerProfile.missing.join(", ") + ".");
        }
        if (innerProfile.truncated) {
          innerWarnings.push("Shortened " + innerProfile.originalChars + " → " + innerProfile.retainedChars + " characters.");
        }
      }
      return {
        key: nameKeyOf(name),
        legacyKey: keyOf(name),
        name,
        aliases: [name],
        emergingAliases: [],
        nameRecords: [],
        pronouns: pronouns ? [pronouns] : [],
        startingStatus: parsedStartingStatus || "side",
        outer: outerProfile.text,
        outerRetainedChars: outerProfile.retainedChars,
        outerWarnings,
        inner: innerProfile ? innerProfile.text : "",
        innerRetainedChars: innerProfile ? innerProfile.retainedChars : 0,
        innerWarnings,
        outerCard,
        innerCard,
        onboardingGenerated,
        onboardingPending,
        onboardingMissing,
        index
      };
    });
  }

  const characters = discoverCharacters();
  const VIEW_CATEGORIES = ["Loves", "Likes", "Neutrals", "Dislikes", "Hates"];
  const VIEW_CATEGORY_INDEX = VIEW_CATEGORIES.reduce((result, category, index) => {
    result[keyOf(category)] = index;
    return result;
  }, {});
  const RELATIONSHIP_FIELDS = ["Role", "Trust", "Closeness", "Boundaries", "Conflict"];
  const RELATIONSHIP_STAGES = {
    Role: [
      { label: "Emerging", minimum: 0, maximum: 9, midpoint: 5 },
      { label: "Established", minimum: 10, maximum: 19, midpoint: 15 }
    ],
    Trust: [
      { label: "Severe distrust", minimum: -20, maximum: -11, midpoint: -15 },
      { label: "Distrust", minimum: -10, maximum: -1, midpoint: -5 },
      { label: "Guarded", minimum: 0, maximum: 9, midpoint: 5 },
      { label: "Unproven", minimum: 10, maximum: 19, midpoint: 15 },
      { label: "Cautious trust", minimum: 20, maximum: 29, midpoint: 25 },
      { label: "Trust", minimum: 30, maximum: 39, midpoint: 35 },
      { label: "Deep trust", minimum: 40, maximum: 49, midpoint: 45 }
    ],
    Closeness: [
      { label: "Disconnected", minimum: -20, maximum: -11, midpoint: -15 },
      { label: "Distant", minimum: -10, maximum: -1, midpoint: -5 },
      { label: "Acquainted", minimum: 0, maximum: 9, midpoint: 5 },
      { label: "Familiar", minimum: 10, maximum: 19, midpoint: 15 },
      { label: "Close", minimum: 20, maximum: 29, midpoint: 25 },
      { label: "Deeply close", minimum: 30, maximum: 39, midpoint: 35 },
      { label: "Intimate", minimum: 40, maximum: 49, midpoint: 45 }
    ],
    Boundaries: [
      { label: "Implied", minimum: 0, maximum: 9, midpoint: 5 },
      { label: "Explicit", minimum: 10, maximum: 19, midpoint: 15 },
      { label: "Reinforced", minimum: 20, maximum: 29, midpoint: 25 }
    ],
    Conflict: [
      { label: "Clear", minimum: 0, maximum: 9, midpoint: 5 },
      { label: "Friction", minimum: 10, maximum: 19, midpoint: 15 },
      { label: "Strain", minimum: 20, maximum: 29, midpoint: 25 },
      { label: "Open conflict", minimum: 30, maximum: 39, midpoint: 35 },
      { label: "Rupture", minimum: 40, maximum: 49, midpoint: 45 }
    ]
  };

  function relationshipStage(field, score) {
    const stages = RELATIONSHIP_STAGES[field] || [];
    return stages.find(stage => score >= stage.minimum && score <= stage.maximum) || null;
  }

  function relationshipDestination(field, value) {
    const wanted = keyOf(value);
    if (field === "Role" && wanted === "former") return { special: "Former", label: "Former" };
    if (field === "Boundaries" && wanted === "released") return { special: "Released", label: "Released" };
    return (RELATIONSHIP_STAGES[field] || []).find(stage => keyOf(stage.label) === wanted) || null;
  }

  function relationshipRange(field) {
    const stages = RELATIONSHIP_STAGES[field] || [];
    return stages.length
      ? { minimum: stages[0].minimum, maximum: stages[stages.length - 1].maximum }
      : { minimum: 0, maximum: 0 };
  }

  const TRIGGER_RULES = {
    affection: { feeling: "affectionate", goal: "show care" },
    anger: { feeling: "angry", goal: "confront the cause", tension: "anger strains restraint" },
    anxiety: { feeling: "anxious", goal: "seek reassurance or control", tension: "fear complicates action" },
    curiosity: { feeling: "curious", goal: "learn more" },
    grief: { feeling: "grieving", goal: "process the loss", tension: "grief pulls against moving forward" },
    hope: { feeling: "hopeful", goal: "pursue the possibility" },
    hurt: { feeling: "hurt", goal: "protect themself", tension: "hurt complicates connection" },
    relief: { feeling: "relieved", goal: "preserve the new stability" },
    resolve: { feeling: "determined", goal: "follow through" },
    uncertainty: { feeling: "uncertain", goal: "seek clarity", tension: "wants certainty but does not yet have it" },
    nostalgia: { feeling: "nostalgic", goal: "revisit shared history" },
    protect: { feeling: "protective", goal: "keep the target safe" },
    reconnect: { feeling: "cautiously warm", goal: "rebuild connection" },
    withdraw: { feeling: "guarded", goal: "create distance", tension: "self-protection competes with connection" },
    responsibility: { feeling: "focused", goal: "carry out the responsibility" },
    conflict: { feeling: "tense", goal: "resolve or withstand the conflict", tension: "active conflict remains unresolved" },
    trust_gain: { feeling: "encouraged", goal: "risk greater reliance" },
    trust_loss: { feeling: "wary", goal: "reduce reliance", tension: "trust has been shaken" },
    closeness_gain: { feeling: "connected", goal: "deepen the connection" },
    closeness_loss: { feeling: "distant", goal: "reassess the connection", tension: "distance strains the relationship" },
    boundary_respected: { feeling: "safer", goal: "maintain clear boundaries" },
    boundary_crossed: { feeling: "unsafe and angry", goal: "reassert the boundary", tension: "a crossed boundary remains unresolved" },
    repair: { feeling: "cautiously relieved", goal: "continue repairing the relationship" },
    betrayal: { feeling: "betrayed", goal: "protect themself from further harm", tension: "betrayal ruptures trust" }
  };

  const TRIGGER_CODES = Object.keys(TRIGGER_RULES);
  const TIME_JUMP = /\b(?:(?:a|an|one|two|three|four|five|six|seven|eight|nine|ten|several|many|\d+)\s+(?:days?|weeks?|months?|years?|decades?)\s+later|(?:days?|weeks?|months?|years?|decades?)\s+(?:passed|went by)|after\s+(?:a|an|one|two|three|four|five|six|seven|eight|nine|ten|several|many|\d+)\s+(?:days?|weeks?|months?|years?|decades?)|the next (?:morning|day|week|month|year)|by the following (?:week|month|year))\b/i;

  function normalizeTriggerCode(value) {
    const code = keyOf(value).replace(/\s+/g, "_");
    return Object.prototype.hasOwnProperty.call(TRIGGER_RULES, code) ? code : "";
  }

  function triggerList(value) {
    const raw = Array.isArray(value) ? value : textOf(value).split(/[,;\s]+/);
    return unique(raw.map(normalizeTriggerCode).filter(Boolean), 40)
      .slice(0, settings.MAX_STATE_TRIGGERS);
  }

  function normalizedTargetKey(value) {
    const source = line(value, 240).toLowerCase();
    if (source === "self" || source === "player") return source;
    const prefixed = source.match(/^(npc|target):(.*)$/);
    if (prefixed) {
      const suffix = prefixed[1] === "npc" ? nameKeyOf(prefixed[2]) : keyOf(prefixed[2]);
      return suffix ? prefixed[1] + ":" + suffix : "";
    }
    return keyOf(source);
  }

  const PROVENANCE_KINDS = { S: "state", X: "experience", R: "relationship", V: "view" };
  const OPERATION_KINDS = ["name", "state", "relationship", "view", "experience"];
  const MODEL_OPERATION_KINDS = ["name", "state", "relationship", "view"];

  function provenanceId(value) {
    const id = textOf(value).trim().toUpperCase();
    return /^[SXRV]\d+$/.test(id) ? id : "";
  }

  function provenanceSourceIds(values) {
    return unique(Array.isArray(values) ? values : [], 40)
      .map(value => textOf(value).trim().toUpperCase())
      .filter(value => /^[ESXRV]\d+$/.test(value));
  }

  function canonicalRelationshipFieldName(value) {
    return RELATIONSHIP_FIELDS.find(field => keyOf(field) === keyOf(value)) || "";
  }

  function canonicalRelationshipUseSignature(ownerKey, targetKey, sourceId, sourceIdentity, field) {
    const canonicalField = canonicalRelationshipFieldName(field);
    const canonicalSourceId = provenanceId(sourceId);
    const normalizedOwner = line(ownerKey, 160);
    const normalizedTarget = normalizedTargetKey(targetKey);
    const normalizedIdentity = line(sourceIdentity, 500);
    if (!normalizedOwner || !normalizedTarget || !/^[SX]\d+$/.test(canonicalSourceId)
      || !normalizedIdentity || !canonicalField) return "";
    return line(JSON.stringify([
      "relationship",
      normalizedOwner,
      normalizedTarget,
      canonicalSourceId,
      normalizedIdentity,
      canonicalField
    ]), 500);
  }

  function parseRelationshipUseSignature(value) {
    let parsed;
    try { parsed = JSON.parse(textOf(value)); } catch { return null; }
    if (!Array.isArray(parsed) || parsed.length !== 6 || parsed[0] !== "relationship") return null;
    const signature = canonicalRelationshipUseSignature(
      parsed[1], parsed[2], parsed[3], parsed[4], parsed[5]
    );
    if (!signature) return null;
    return {
      kind: "relationship",
      ownerKey: line(parsed[1], 160),
      targetKey: normalizedTargetKey(parsed[2]),
      sourceId: provenanceId(parsed[3]),
      sourceIdentity: line(parsed[4], 500),
      field: canonicalRelationshipFieldName(parsed[5]),
      signature
    };
  }

  function canonicalViewDestination(value) {
    const category = VIEW_CATEGORIES.find(item => keyOf(item) === keyOf(value));
    if (category) return category;
    const normalized = keyOf(value);
    if (normalized === "buried") return "Buried";
    if (normalized === "recovered") return "Recovered";
    return "";
  }

  function canonicalViewOperationMode(value) {
    const normalized = keyOf(value);
    if (normalized === "o" || normalized === "ordinary") return "O";
    if (normalized === "m" || normalized === "major") return "M";
    if (normalized === "buried" || normalized === "bury" || normalized === "burial") return "Buried";
    if (normalized === "recovered" || normalized === "recover" || normalized === "recovery") return "Recovered";
    if (normalized === "reconciled" || normalized === "reconcile" || normalized === "reconciliation") return "Reconciled";
    return "";
  }

  function canonicalViewUseSignature(ownerKey, targetKey, sourceId, sourceIdentity, destination, operationMode) {
    const canonicalSourceId = provenanceId(sourceId);
    const normalizedOwner = line(ownerKey, 160);
    const normalizedTarget = normalizedTargetKey(targetKey);
    const normalizedIdentity = line(sourceIdentity, 500);
    const canonicalDestination = canonicalViewDestination(destination);
    const canonicalMode = canonicalViewOperationMode(operationMode);
    if (!normalizedOwner || !normalizedTarget || !/^[RX]\d+$/.test(canonicalSourceId)
      || !normalizedIdentity || !canonicalDestination) return "";
    return line(JSON.stringify([
      "view",
      normalizedOwner,
      normalizedTarget,
      canonicalSourceId,
      normalizedIdentity,
      canonicalDestination,
      canonicalMode
    ]), 500);
  }

  function parseViewUseSignature(value) {
    let parsed;
    try { parsed = JSON.parse(textOf(value)); } catch { return null; }
    if (!Array.isArray(parsed) || parsed.length !== 7 || parsed[0] !== "view") return null;
    const signature = canonicalViewUseSignature(
      parsed[1], parsed[2], parsed[3], parsed[4], parsed[5], parsed[6]
    );
    if (!signature) return null;
    return {
      kind: "view",
      ownerKey: line(parsed[1], 160),
      targetKey: normalizedTargetKey(parsed[2]),
      sourceId: provenanceId(parsed[3]),
      sourceIdentity: line(parsed[4], 500),
      destination: canonicalViewDestination(parsed[5]),
      operationMode: canonicalViewOperationMode(parsed[6]),
      signature
    };
  }

  function parseProvenanceUseSignature(value) {
    return parseRelationshipUseSignature(value) || parseViewUseSignature(value);
  }

  function provenanceUseSignatures(values) {
    const result = [];
    (Array.isArray(values) ? values : []).forEach(value => {
      const parsed = parseProvenanceUseSignature(value);
      if (parsed && !result.includes(parsed.signature)) result.push(parsed.signature);
    });
    return result;
  }

  function relationshipUseSignatureForRecord(record, ownerKey, targetKey, field) {
    if (!record || (record.kind !== "state" && record.kind !== "experience")) return "";
    return canonicalRelationshipUseSignature(
      ownerKey,
      targetKey,
      record.id,
      record.managedSignature || record.signature || record.id,
      field
    );
  }

  function viewUseSignatureForRecord(record, ownerKey, targetKey, destination, operationMode) {
    if (!record || (record.kind !== "relationship" && record.kind !== "experience")) return "";
    return canonicalViewUseSignature(
      ownerKey,
      targetKey,
      record.id,
      record.managedSignature || record.signature || record.id,
      destination,
      operationMode
    );
  }

  function provenanceUseCommitted(record, signature) {
    const parsed = parseProvenanceUseSignature(signature);
    return !!(record && parsed && parsed.sourceId === record.id
      && provenanceUseSignatures(record.uses).includes(parsed.signature));
  }

  function commitProvenanceUse(record, signature) {
    const parsed = parseProvenanceUseSignature(signature);
    const legalSource = parsed && (
      (parsed.kind === "relationship" && (record && (record.kind === "state" || record.kind === "experience")))
      || (parsed.kind === "view" && (record && (record.kind === "relationship" || record.kind === "experience")))
    );
    if (!record || !parsed || parsed.sourceId !== record.id || !legalSource) {
      return { ok: false, error: "The narrow provenance use signature was not canonical for its source record." };
    }
    const prior = provenanceUseSignatures(record.uses);
    if (prior.includes(parsed.signature)) return { ok: true, duplicate: true, signature: parsed.signature };
    record.uses = prior.concat(parsed.signature);
    return { ok: true, duplicate: false, signature: parsed.signature };
  }

  function blankProvenanceLedger() {
    return {
      records: [],
      nextNumbers: { S: 1, X: 1, R: 1, V: 1 }
    };
  }

  function normalizeProvenanceRecord(raw) {
    const source = raw && typeof raw === "object" && !Array.isArray(raw) ? raw : {};
    const id = provenanceId(source.id);
    if (!id) return null;
    const prefix = id.charAt(0);
    const sourceIds = provenanceSourceIds(source.sourceIds);
    const storyEvidenceIds = unique(
      (Array.isArray(source.storyEvidenceIds) ? source.storyEvidenceIds : [])
        .concat(sourceIds.filter(value => /^E\d+$/.test(value))),
      40
    ).map(value => textOf(value).trim().toUpperCase()).filter(value => /^E\d+$/.test(value));
    const targetKey = normalizedTargetKey(source.targetKey);
    const rawPace = source.pace && typeof source.pace === "object" && !Array.isArray(source.pace)
      ? source.pace
      : {};
    const rawActualChange = Number.isFinite(Number(source.actualChange))
      ? Number(source.actualChange)
      : Number(source.numericChange);
    const normalizedActualChange = Number.isFinite(rawActualChange)
      ? Math.trunc(rawActualChange)
      : 0;
    const normalizedPaceValue = Number.isFinite(Number(source.paceValue))
      ? Math.max(0, Math.trunc(Number(source.paceValue)))
      : Math.max(0, Math.trunc(Number(rawPace.value) || 0));
    const normalizedPace = {
      name: line(source.paceName || rawPace.name, 80),
      value: normalizedPaceValue,
      maxStages: Math.max(0, Math.floor(Number(source.paceMaxStages ?? rawPace.maxStages) || 0))
    };
    return {
      id,
      kind: PROVENANCE_KINDS[prefix],
      ownerKey: line(source.ownerKey, 160),
      targetKey,
      targetName: storedTargetName(targetKey, source.targetName),
      field: line(source.field, 80),
      destination: line(source.destination, 120),
      eventKind: ["A", "D"].includes(textOf(source.eventKind).trim().toUpperCase())
        ? textOf(source.eventKind).trim().toUpperCase()
        : "",
      actualChange: normalizedActualChange,
      numericChange: normalizedActualChange,
      priorValue: line(source.priorValue, 240),
      resultingValue: line(source.resultingValue, 240),
      resultingStage: line(source.resultingStage, 120),
      priorCategory: canonicalViewDestination(source.priorCategory),
      resultingCategory: canonicalViewDestination(source.resultingCategory),
      priorViewState: line(source.priorViewState, 500),
      resultingViewState: line(source.resultingViewState, 500),
      viewOperationMode: canonicalViewOperationMode(source.viewOperationMode || source.operationMode),
      viewSeverity: canonicalViewOperationMode(source.viewSeverity || source.severity),
      paceValue: normalizedPaceValue,
      pace: normalizedPace,
      signature: line(source.signature, 500),
      managedSignature: line(source.managedSignature, 500),
      uses: provenanceUseSignatures(source.uses),
      confirmation: Math.max(0, Math.floor(Number(source.confirmation) || 0)),
      sourceIds,
      storyEvidenceIds,
      triggers: triggerList(source.triggers),
      value: line(source.value, 240),
      thought: line(source.thought, settings.MAX_STATE_VALUE_CHARS),
      explanation: line(source.explanation, 500),
      createdClock: Math.max(0, Number(source.createdClock) || 0),
      ownerOpportunity: Math.max(0, Number(source.ownerOpportunity) || 0),
      active: source.active !== false
    };
  }

  function normalizeProvenanceLedger(raw) {
    const source = raw && typeof raw === "object" && !Array.isArray(raw) ? raw : {};
    const fallback = blankProvenanceLedger();
    const records = boundedProvenanceRecords(
      (Array.isArray(source.records) ? source.records : [])
        .map(normalizeProvenanceRecord)
        .filter(Boolean)
    );
    const nextNumbers = { ...fallback.nextNumbers };
    Object.keys(PROVENANCE_KINDS).forEach(prefix => {
      const supplied = source.nextNumbers && Number(source.nextNumbers[prefix]);
      const highest = Math.max(0, ...records
        .filter(record => record.id.charAt(0) === prefix)
        .map(record => Number(record.id.slice(1)) || 0));
      nextNumbers[prefix] = Math.max(1, Number.isSafeInteger(supplied) ? supplied : 1, highest + 1);
    });
    return { records, nextNumbers };
  }

  function continuitySourceId(value) {
    const id = textOf(value).trim().toUpperCase();
    return /^[ESXRV]\d+$/.test(id) ? id : "";
  }

  function legalSourcePrefixes(kind) {
    return {
      name: ["E"],
      state: ["E"],
      relationship: ["E", "S", "X"],
      view: ["E", "R", "X"]
    }[keyOf(kind)] || [];
  }

  function sourceIdLegalForOperation(kind, id) {
    const sourceId = continuitySourceId(id);
    return !!(sourceId && legalSourcePrefixes(kind).includes(sourceId.charAt(0)));
  }

  function provenanceRecordById(id) {
    const wanted = provenanceId(id);
    return wanted ? CC.provenance.records.find(record => record.id === wanted) || null : null;
  }

  function allocateProvenanceId(prefixValue) {
    const prefix = textOf(prefixValue).trim().toUpperCase();
    if (!Object.prototype.hasOwnProperty.call(PROVENANCE_KINDS, prefix)) return "";
    const number = Math.max(1, Number(CC.provenance.nextNumbers[prefix]) || 1);
    CC.provenance.nextNumbers[prefix] = number + 1;
    return prefix + number;
  }

  function stateSituationSignature(ownerKey, targetKey, situation) {
    return line([
      "state",
      ownerKey,
      normalizedTargetKey(targetKey),
      keyOf(situationPhrase(situation))
    ].join("|"), 500);
  }

  function managedSignatureStillValid(record) {
    if (!record || !record.managedSignature) return false;
    if (record.kind === "state") {
      const npc = CC.npcs[record.ownerKey];
      const current = normalizeState(npc && npc.state, CC.stateClock);
      return !!current.situation.value
        && record.managedSignature === stateSituationSignature(
          record.ownerKey,
          current.situation.targetKey,
          current.situation.value
        );
    }
    if (record.kind === "experience") {
      refreshExperiencesStore(false);
      const ownerData = experiencesForOwner(record.ownerKey);
      return !!ownerData && ownerData.contextRecords.some(item =>
        item.signature === record.managedSignature
        && item.signature === record.signature
      );
    }
    if (record.kind === "relationship") {
      const current = currentRelationshipManagedSignature(
        record.ownerKey,
        record.targetKey,
        record.field
      );
      return !!current && current === record.managedSignature;
    }
    if (record.kind === "view") {
      const current = currentViewManagedSignature(record.ownerKey, record.targetKey);
      return !!current && current === record.managedSignature;
    }
    return record.active !== false;
  }

  function rebindRelationshipExplanationProvenance(
    ownerKey,
    targetKey,
    field,
    priorManagedSignature,
    nextManagedSignature,
    actualStage,
    correctedExplanation
  ) {
    const canonicalField = canonicalRelationshipFieldName(field);
    const normalizedTarget = normalizedTargetKey(targetKey);
    if (!ownerKey || !normalizedTarget || !canonicalField || !priorManagedSignature
      || !nextManagedSignature || priorManagedSignature === nextManagedSignature) return 0;
    const useReplacements = {};
    let rebound = 0;
    CC.provenance.records.forEach(record => {
      if (record.kind !== "relationship" || record.ownerKey !== ownerKey
        || record.targetKey !== normalizedTarget || record.field !== canonicalField
        || record.managedSignature !== priorManagedSignature) return;
      record.managedSignature = nextManagedSignature;
      record.explanation = line(correctedExplanation, 500);
      const nextEventSignature = relationshipEventSignature({ key: ownerKey }, {
        targetKey: normalizedTarget,
        field: canonicalField,
        eventKind: record.eventKind,
        priorValue: record.priorValue,
        resultingValue: record.resultingValue,
        actualStage: record.resultingStage || record.destination || actualStage,
        actualChange: record.actualChange,
        sourceIds: record.sourceIds,
        managedSignature: nextManagedSignature
      });
      if (nextEventSignature) record.signature = nextEventSignature;
      record.uses = provenanceUseSignatures((record.uses || []).map(use => {
        const parsed = parseViewUseSignature(use);
        if (!parsed || parsed.sourceId !== record.id
          || parsed.sourceIdentity !== priorManagedSignature) return use;
        const migrated = canonicalViewUseSignature(
          parsed.ownerKey,
          parsed.targetKey,
          parsed.sourceId,
          nextManagedSignature,
          parsed.destination,
          parsed.operationMode
        );
        if (migrated) useReplacements[parsed.signature] = migrated;
        return migrated || use;
      }));
      record.active = true;
      rebound += 1;
    });
    if (Object.keys(useReplacements).length) {
      CC.provenance.records.forEach(record => {
        record.uses = provenanceUseSignatures((record.uses || []).map(use => useReplacements[use] || use));
      });
    }
    return rebound;
  }

  function rebindViewExplanationProvenance(
    ownerKey,
    targetKey,
    priorManagedSignature,
    nextManagedSignature,
    actualCategory
  ) {
    const normalizedTarget = normalizedTargetKey(targetKey);
    if (!ownerKey || !normalizedTarget || !priorManagedSignature || !nextManagedSignature
      || priorManagedSignature === nextManagedSignature) return 0;
    let rebound = 0;
    CC.provenance.records.forEach(record => {
      if (record.kind !== "view" || record.ownerKey !== ownerKey
        || record.targetKey !== normalizedTarget
        || record.managedSignature !== priorManagedSignature) return;
      record.managedSignature = nextManagedSignature;
      const category = record.resultingCategory || actualCategory;
      if (record.explanation && category) {
        record.explanation = line(correctedViewExplanation(record.explanation, category), 500);
      }
      const nextEventSignature = viewEventSignature({ key: ownerKey }, {
        targetKey: normalizedTarget,
        destination: record.destination,
        operationMode: record.viewOperationMode,
        severity: record.viewSeverity,
        priorCategory: record.priorCategory,
        resultingCategory: record.resultingCategory,
        priorViewState: record.priorViewState,
        resultingViewState: record.resultingViewState,
        sourceIds: record.sourceIds,
        managedSignature: nextManagedSignature
      });
      if (nextEventSignature) record.signature = nextEventSignature;
      record.active = true;
      rebound += 1;
    });
    return rebound;
  }

  function refreshProvenanceActivity() {
    if (CC.provenance.records.some(record => record.kind === "relationship")) {
      refreshRelationshipsStore();
    }
    if (CC.provenance.records.some(record => record.kind === "view")) {
      refreshViewsStore(false);
    }
    CC.provenance.records.forEach(record => {
      if (record.kind === "state" || record.kind === "experience"
        || record.kind === "relationship" || record.kind === "view") {
        record.active = managedSignatureStillValid(record);
      }
    });
    return CC.provenance.records;
  }

  function activeProvenanceRecords(filters = {}) {
    refreshProvenanceActivity();
    return CC.provenance.records.filter(record => {
      if (!record.active) return false;
      if (filters.ownerKey && record.ownerKey !== filters.ownerKey) return false;
      if (filters.targetKey && record.targetKey !== normalizedTargetKey(filters.targetKey)) return false;
      if (filters.kind && record.kind !== keyOf(filters.kind)) return false;
      if (filters.prefix && record.id.charAt(0) !== textOf(filters.prefix).toUpperCase()) return false;
      return true;
    });
  }

  function storyLineageForSources(sourceIds, seen = new Set()) {
    const rawIds = [];
    provenanceSourceIds(sourceIds).forEach(id => {
      if (/^E\d+$/.test(id)) {
        if (!rawIds.includes(id)) rawIds.push(id);
        return;
      }
      if (seen.has(id)) return;
      seen.add(id);
      const record = provenanceRecordById(id);
      if (!record) return;
      storyLineageForSources(record.sourceIds.concat(record.storyEvidenceIds || []), seen)
        .forEach(storyId => { if (!rawIds.includes(storyId)) rawIds.push(storyId); });
    });
    return rawIds;
  }

  function provenanceDependencyClosure(record, byId, seen = new Set()) {
    if (!record || seen.has(record.id)) return seen;
    seen.add(record.id);
    (Array.isArray(record.sourceIds) ? record.sourceIds : [])
      .filter(sourceId => !/^E\d+$/.test(sourceId))
      .forEach(sourceId => provenanceDependencyClosure(byId[sourceId], byId, seen));
    return seen;
  }

  function boundedProvenanceRecords(records) {
    const normalized = (Array.isArray(records) ? records : [])
      .map(normalizeProvenanceRecord)
      .filter(Boolean);
    const maximum = Math.max(1, Number(settings.MAX_PROVENANCE_RECORDS) || 1);
    if (normalized.length <= maximum) return normalized;

    const byId = {};
    normalized.forEach(record => { byId[record.id] = record; });
    const selected = new Set();
    const candidates = normalized.map((record, index) => ({ record, index }))
      .sort((left, right) => Number(right.record.active) - Number(left.record.active)
        || right.index - left.index);

    candidates.forEach(({ record }) => {
      if (selected.has(record.id)) return;
      const closure = provenanceDependencyClosure(record, byId, new Set());
      const additions = Array.from(closure).filter(id => !selected.has(id));
      if (selected.size + additions.length > maximum) return;
      additions.forEach(id => selected.add(id));
    });

    if (!selected.size) normalized.slice(-maximum).forEach(record => selected.add(record.id));
    return normalized.filter(record => selected.has(record.id));
  }

  function appendProvenanceRecord(rawRecord) {
    const source = rawRecord && typeof rawRecord === "object" && !Array.isArray(rawRecord)
      ? { ...rawRecord }
      : {};
    const prefix = textOf(source.prefix || source.id).trim().toUpperCase().charAt(0);
    if (!source.id) source.id = allocateProvenanceId(prefix);
    const record = normalizeProvenanceRecord(source);
    if (!record) return { ok: false, error: "The provenance record could not be normalized." };
    if (CC.provenance.records.some(item => item.id === record.id)) {
      return { ok: false, error: "The allocated provenance ID already existed." };
    }
    CC.provenance.records = boundedProvenanceRecords(CC.provenance.records.concat(record));
    if (!CC.provenance.records.some(item => item.id === record.id)) {
      return { ok: false, error: "The bounded provenance ledger could not retain the new record." };
    }
    CC.last.provenanceCreated = record.id + " " + record.kind + " from "
      + (record.sourceIds.join(",") || "no sources");
    return { ok: true, record: provenanceRecordById(record.id) };
  }

  function blankOperationMeter() {
    return {
      gain: 0,
      drain: 0,
      lastServedOpportunity: -1,
      lastResult: "",
      lastSignature: "",
      lastTargetKey: "",
      lastField: ""
    };
  }

  function normalizeOperationMeter(raw) {
    const source = raw && typeof raw === "object" && !Array.isArray(raw) ? raw : {};
    return {
      gain: Math.max(0, Math.floor(Number(source.gain) || 0)),
      drain: Math.max(0, Math.min(settings.OPERATION_DRAIN_CAP, Math.floor(Number(source.drain) || 0))),
      lastServedOpportunity: Number.isFinite(Number(source.lastServedOpportunity))
        ? Math.max(-1, Math.floor(Number(source.lastServedOpportunity)))
        : -1,
      lastResult: line(source.lastResult, 80),
      lastSignature: line(source.lastSignature, 500),
      lastTargetKey: normalizedTargetKey(source.lastTargetKey),
      lastField: line(source.lastField, 80)
    };
  }

  function blankOwnerOperationState() {
    const result = {};
    OPERATION_KINDS.forEach(kind => { result[kind] = blankOperationMeter(); });
    return result;
  }

  function normalizeOwnerOperationState(raw) {
    const source = raw && typeof raw === "object" && !Array.isArray(raw) ? raw : {};
    const result = blankOwnerOperationState();
    OPERATION_KINDS.forEach(kind => { result[kind] = normalizeOperationMeter(source[kind]); });
    return result;
  }

  function operationDrainKey(record) {
    const source = record && typeof record === "object" && !Array.isArray(record) ? record : {};
    return [
      line(source.ownerKey, 160),
      OPERATION_KINDS.includes(keyOf(source.kind)) ? keyOf(source.kind) : "",
      normalizedTargetKey(source.targetKey),
      keyOf(source.field),
      keyOf(source.destination),
      line(source.evidenceSignature, 500)
    ].join("|");
  }

  function normalizeOperationDrainRecord(raw) {
    const source = raw && typeof raw === "object" && !Array.isArray(raw) ? raw : {};
    const kind = keyOf(source.kind);
    if (!OPERATION_KINDS.includes(kind)) return null;
    const record = {
      key: "",
      ownerKey: line(source.ownerKey, 160),
      kind,
      targetKey: normalizedTargetKey(source.targetKey),
      field: line(source.field, 80),
      destination: line(source.destination, 120),
      evidenceSignature: line(source.evidenceSignature, 500),
      value: Math.max(0, Math.min(settings.OPERATION_DRAIN_CAP, Math.floor(Number(source.value) || 0))),
      updatedOpportunity: Math.max(0, Math.floor(Number(source.updatedOpportunity) || 0)),
      attempts: Math.max(0, Math.floor(Number(source.attempts) || 0)),
      lastResult: line(source.lastResult, 80)
    };
    record.key = operationDrainKey(record);
    return record.ownerKey && record.evidenceSignature ? record : null;
  }

  function blankOperationState() {
    return { owners: {}, drains: [] };
  }

  function effectiveOperationDrainValue(record, ownerOpportunity) {
    const normalized = normalizeOperationDrainRecord(record);
    if (!normalized) return 0;
    const opportunity = Math.max(0, Math.floor(Number(ownerOpportunity) || 0));
    const elapsed = Math.max(0, opportunity - normalized.updatedOpportunity);
    const decay = elapsed * Math.max(0, Number(settings.OPERATION_POINTS.DECAY_PER_OWNER_OPPORTUNITY) || 0);
    return Math.max(0, normalized.value - decay);
  }

  function materializeOwnerDrainDecay(ownerKey, ownerOpportunity) {
    const normalizedOwner = line(ownerKey, 160);
    const opportunity = Math.max(0, Math.floor(Number(ownerOpportunity) || 0));
    if (!normalizedOwner || !opportunity) return { changed: 0, removed: 0, summary: "No owner drain decay." };
    let changed = 0;
    let removed = 0;
    const next = [];
    (Array.isArray(CC.operationState.drains) ? CC.operationState.drains : []).forEach(raw => {
      const record = normalizeOperationDrainRecord(raw);
      if (!record) return;
      if (record.ownerKey !== normalizedOwner) {
        next.push(record);
        return;
      }
      const before = record.value;
      const after = effectiveOperationDrainValue(record, opportunity);
      if (after !== before || record.updatedOpportunity !== opportunity) changed += 1;
      if (after <= 0) {
        removed += 1;
        return;
      }
      record.value = after;
      record.updatedOpportunity = opportunity;
      record.key = operationDrainKey(record);
      next.push(record);
    });
    CC.operationState.drains = next
      .sort((left, right) => left.updatedOpportunity - right.updatedOpportunity)
      .slice(-settings.MAX_OPERATION_DRAIN_RECORDS);
    return {
      changed,
      removed,
      summary: normalizedOwner + " opportunity " + opportunity + ": decayed " + changed
        + " drain record" + (changed === 1 ? "" : "s") + ", removed " + removed + "."
    };
  }

  function normalizeOperationState(raw) {
    const source = raw && typeof raw === "object" && !Array.isArray(raw) ? raw : {};
    const owners = {};
    const rawOwners = source.owners && typeof source.owners === "object" && !Array.isArray(source.owners)
      ? source.owners
      : {};
    Object.keys(rawOwners).forEach(ownerKey => {
      owners[ownerKey] = normalizeOwnerOperationState(rawOwners[ownerKey]);
    });
    const drainsByKey = {};
    (Array.isArray(source.drains) ? source.drains : [])
      .map(normalizeOperationDrainRecord)
      .filter(Boolean)
      .forEach(record => { drainsByKey[record.key] = record; });
    const drains = Object.values(drainsByKey)
      .sort((left, right) => left.updatedOpportunity - right.updatedOpportunity)
      .slice(-settings.MAX_OPERATION_DRAIN_RECORDS);
    return { owners, drains };
  }

  function blankSituation() {
    return {
      value: "",
      updatedClock: 0,
      confirmations: 0,
      evidenceIds: [],
      targetKey: "",
      targetName: "",
      promotedSignature: ""
    };
  }

  function blankState() {
    return {
      thought: { value: "", updatedClock: 0 },
      feeling: { value: "", updatedClock: 0 },
      goal: { value: "", updatedClock: 0 },
      tension: { value: "", updatedClock: 0 },
      situation: blankSituation(),
      target: { key: "", name: "", updatedClock: 0 },
      triggers: { value: [], updatedClock: 0 }
    };
  }

  function normalizeState(raw, fallbackClock) {
    const source = raw && typeof raw === "object" && !Array.isArray(raw) ? raw : {};
    const result = blankState();
    ["thought", "feeling", "goal", "tension"].forEach(field => {
      const item = source[field] && typeof source[field] === "object" && !Array.isArray(source[field])
        ? source[field]
        : {};
      result[field] = {
        value: line(item.value, settings.MAX_STATE_VALUE_CHARS),
        updatedClock: Math.max(0, Number(item.updatedClock ?? fallbackClock) || 0)
      };
    });
    const rawTarget = source.target && typeof source.target === "object" && !Array.isArray(source.target)
      ? source.target
      : {};
    const targetKey = normalizedTargetKey(rawTarget.key);
    result.target = {
      key: targetKey,
      name: storedTargetName(targetKey, rawTarget.name),
      updatedClock: Math.max(0, Number(rawTarget.updatedClock ?? fallbackClock) || 0)
    };
    const rawTriggers = source.triggers && typeof source.triggers === "object" && !Array.isArray(source.triggers)
      ? source.triggers
      : {};
    result.triggers = {
      value: triggerList(rawTriggers.value),
