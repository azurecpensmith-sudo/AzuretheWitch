        && (interactionScore(owner, currentInput) > 0 || CC.conversationKey === owner.key)) score = 900;
      else if (record.targetKey === stateTarget) score = 800;
      else if (activeTargetKeys.has(record.targetKey) && relationshipRecordMentioned(record, owner, latestStory)) score = 700;
      else if (relationshipRecordMentioned(record, owner, latestStory)) score = 600;
      else if (record.targetKey === "player") score = 550;
      else if (activeTargetKeys.has(record.targetKey)) score = 500;
      const aliases = relationshipTargetAliases(record, owner);
