  function operationTargetMap(owner, active, activeSelections, buriedSelections, relationshipSelections, currentInput, evidenceCandidates, recent) {
    const result = [];
    const usedKeys = new Set();
    const add = target => {
      const signature = target.code + "|" + target.key + "|" + target.mode;
      if (!usedKeys.has(signature)) {
        usedKeys.add(signature);
        result.push(target);
      }
    };
    const activeByTarget = {};
    activeSelections.forEach(item => { activeByTarget[item.record.targetKey] = item.record; });
    const buriedByTarget = {};
    buriedSelections.forEach(item => { buriedByTarget[item.record.targetKey] = item.record; });
    const relationshipByTarget = {};
    (Array.isArray(relationshipSelections) ? relationshipSelections : []).forEach(item => {
      relationshipByTarget[item.record.targetKey] = item.record;
    });
    const targetSource = [currentInput, textOf(recent).slice(-2500)]
      .concat(evidenceCandidates.map(candidate => candidate.item.text))
      .join("\n");

    const special = [
      { code: "S", key: "self", name: "Self", mode: "known", relationship: false, nameSubject: true },
      { code: "P", key: "player", name: player.name, mode: "known", relationship: true, nameSubject: true }
    ];
    special.forEach(target => {
      const relevant = target.key === "self"
        ? true
        : (!!activeByTarget.player || !!buriedByTarget.player || !!relationshipByTarget.player
          || interactionScore(owner, currentInput) > 0
          || CC.conversationKey === owner.key
          || operationTargetMentioned(owner, target, targetSource));
      if (!relevant) return;
      const marker = recoveringMarker(owner.key, target.key);
      add(target);
      if (marker) add({
        code: "R" + (result.filter(item => item.code.startsWith("R")).length + 1),
        key: target.key, name: target.name, mode: "recovering", relationship: false, nameSubject: false
      });
    });

    activeNpcRosterCharacterSlots(false).forEach(slot => {
      const character = slot.character;
      if (character.key === owner.key) return;
      const targetKey = "npc:" + character.key;
      const relevant = !!activeByTarget[targetKey] || !!buriedByTarget[targetKey]
        || !!relationshipByTarget[targetKey]
        || characterMentioned(targetSource, character, false, active.map(item => item.key));
      if (!relevant) return;
      const marker = recoveringMarker(owner.key, targetKey);
      add({ code: slot.code, key: targetKey, name: character.name, mode: "known", relationship: true, nameSubject: true });
      if (marker) add({
        code: "R" + (result.filter(item => item.code.startsWith("R")).length + 1),
        key: targetKey, name: character.name, mode: "recovering", relationship: false, nameSubject: false
      });
    });

    let viewNumber = 1;
    activeSelections.forEach(item => {
      const record = item.record;
      if (result.some(target => target.key === record.targetKey)) return;
      const marker = recoveringMarker(owner.key, record.targetKey);
      add(marker
        ? { code: "R" + (result.filter(target => target.code.startsWith("R")).length + 1), key: record.targetKey, name: modelViewTargetName(record), mode: "recovering", relationship: false, nameSubject: false }
        : { code: "V" + viewNumber++, key: record.targetKey, name: modelViewTargetName(record), mode: "active", relationship: false, nameSubject: false });
    });

    let buriedNumber = 1;
    buriedSelections.forEach(item => {
      const record = item.record;
      if (recoveringMarker(owner.key, record.targetKey)) return;
      add({ code: "B" + buriedNumber++, key: record.targetKey, name: modelViewTargetName(record), mode: "buried", relationship: false, nameSubject: false });
    });
    return result;
  }


  function operationKindLabel(kind) {
    const normalized = keyOf(kind);
    return normalized ? normalized.charAt(0).toUpperCase() + normalized.slice(1) : "None";
  }

  function operationTargetAliases(owner, target) {
    if (!target) return [];
    if (target.key === "self") {
      return uniqueNameForms([owner && owner.name].concat(owner && owner.aliases || []), 160);
    }
    if (target.key === "player") {
      return uniqueNameForms(["Player", "the player", "you", player.name].concat(player.aliases || []), 160);
    }
    if (target.key && target.key.startsWith("npc:")) {
      const character = characters.find(item => "npc:" + item.key === target.key);
      return character
        ? uniqueNameForms([character.name].concat(character.aliases || []), 160)
        : uniqueNameForms([target.name], 160);
    }
    return uniqueNameForms([target.name], 160);
  }

  function operationOwnerMentioned(owner, source) {
    return !!owner && uniqueNameForms([owner.name].concat(owner.aliases || []), 160)
      .some(alias => aliasMentioned(source, alias));
  }

  function operationOwnerAliases(owner) {
    return uniqueNameForms([owner && owner.name].concat(owner && owner.aliases || []), 160);
  }

  function operationAliasRegExp(alias) {
    const wanted = line(alias, 160).split(/\s+/).map(escapeRegExp).join("\\s+");
    return wanted ? "(?:" + wanted + ")" : "";
  }

  function ownerSpeechAttributed(owner, source, statementPattern) {
    const text = textOf(source);
    if (!owner || !text || !(statementPattern instanceof RegExp)) return false;
    const flags = statementPattern.flags.includes("i") ? "ig" : "g";
    const matcher = new RegExp(statementPattern.source, flags);
    let match;
    while ((match = matcher.exec(text))) {
      const before = text.slice(Math.max(0, match.index - 180), match.index);
      const after = text.slice(match.index + match[0].length, match.index + match[0].length + 180);
      const attributed = operationOwnerAliases(owner).some(alias => {
        const wanted = operationAliasRegExp(alias);
        if (!wanted) return false;
        const beforeSpeaker = new RegExp(
          wanted + "[^.!?…\\n]{0,50}\\b(?:says?|said|asks?|asked|answers?|answered|replies?|replied|tells?|told|admits?|admitted|declares?|declared|insists?|insisted|whispers?|whispered|shouts?|shouted|murmurs?|murmured)\\b[^.!?…\\n]{0,90}$",
          "i"
        );
        const beforeLabel = new RegExp(wanted + "\\s*[:—-]\\s*[^.!?…\\n]{0,40}$", "i");
        const beforeQuotedSpeaker = new RegExp(
          wanted + "[^\"“”‘’\\n]{0,50}\\b(?:says?|said|asks?|asked|answers?|answered|replies?|replied|tells?|told|admits?|admitted|declares?|declared|insists?|insisted|whispers?|whispered|shouts?|shouted|murmurs?|murmured)\\b"
            + "[^\"“”‘’\\n]{0,25}[\"“‘][^\"”’\\n]{0,165}$",
          "i"
        );
        const beforeQuotedLabel = new RegExp(
          wanted + "\\s*[:—-]\\s*[\"“‘][^\"”’\\n]{0,165}$",
          "i"
        );
        const afterSpeaker = new RegExp(
          "^[^.!?…\\n]{0,90}(?:" + wanted
            + "[^.!?…\\n]{0,40}\\b(?:says?|said|asks?|asked|answers?|answered|replies?|replied|admits?|admitted|declares?|declared|insists?|insisted|whispers?|whispered|shouts?|shouted|murmurs?|murmured)\\b"
            + "|\\b(?:says?|said|asks?|asked|answers?|answered|replies?|replied|admits?|admitted|declares?|declared|insists?|insisted|whispers?|whispered|shouts?|shouted|murmurs?|murmured)\\b[^.!?…\\n]{0,20}" + wanted + ")",
          "i"
        );
        return beforeSpeaker.test(before)
          || beforeLabel.test(before)
          || beforeQuotedSpeaker.test(before)
          || beforeQuotedLabel.test(before)
          || afterSpeaker.test(after);
      });
      if (attributed) return true;
      if (match[0].length === 0) matcher.lastIndex += 1;
    }
    return false;
  }

  function ownerPredicateMatches(owner, source, predicatePattern) {
    const text = textOf(source);
    if (!owner || !text || !predicatePattern) return false;
    return operationOwnerAliases(owner).some(alias => {
      const wanted = operationAliasRegExp(alias);
      return !!wanted && new RegExp(
        "(?:^|[^A-Za-z0-9])" + wanted + "[^.!?…\\n]{0,55}(?:" + predicatePattern + ")",
        "i"
      ).test(text);
    });
  }

  function ownerNearEvent(owner, source, eventPattern, maximum = 120) {
    const text = textOf(source);
    if (!owner || !text || !eventPattern) return false;
    const distance = Math.max(20, Math.min(240, Number(maximum) || 120));
    return operationOwnerAliases(owner).some(alias => {
      const wanted = operationAliasRegExp(alias);
      if (!wanted) return false;
      return new RegExp(
        "(?:" + wanted + "[^.!?…\\n]{0," + distance + "}(?:" + eventPattern + ")"
          + "|(?:" + eventPattern + ")[^.!?…\\n]{0," + distance + "}" + wanted + ")",
        "i"
      ).test(text);
    });
  }

  function ownerTargetSentenceMatches(owner, target, source, eventPattern) {
    if (!owner || !target || !eventPattern) return false;
    return textOf(source).split(/[.!?…\n]+/).some(sentence => {
      if (!operationOwnerMentioned(owner, sentence) || !operationTargetMentioned(owner, target, sentence)) return false;
      return new RegExp(eventPattern, "i").test(sentence);
    });
  }

  function operationTargetMentioned(owner, target, source) {
    if (!target) return false;
    if (target.key === "player" && /\byou\b/i.test(textOf(source))) return true;
    if (target.key === "self" && operationOwnerMentioned(owner, source)) return true;
    return operationTargetAliases(owner, target).some(alias => aliasMentioned(source, alias));
  }

  function operationCurrentRelevance(item, currentInputId, recent) {
    if (!item) return 0;
    if (item.id === currentInputId) return 4;
    if (item.source === "provenance") return Math.max(1, Math.min(3, Number(item.relevance) || 1));
    if (item.source === "story" && anchorInText(item.anchor, recent)) return 3;
    if (item.source === "opening" && anchorInText(item.anchor, recent)) return 2;
    return item.source === "story" ? 1 : 0;
  }

  const RELATIONSHIP_TRIGGER_FIELDS = {
    affection: ["Closeness"],
    anger: ["Conflict"],
    reconnect: ["Closeness"],
    withdraw: ["Closeness"],
    responsibility: ["Role"],
    conflict: ["Conflict"],
    trust_gain: ["Trust"],
    trust_loss: ["Trust"],
    closeness_gain: ["Closeness"],
    closeness_loss: ["Closeness"],
    boundary_respected: ["Boundaries"],
    boundary_crossed: ["Boundaries", "Conflict"],
    repair: ["Trust", "Conflict"],
    betrayal: ["Trust", "Conflict"]
  };

  function relationshipLineageTriggers(record, seen = new Set()) {
    if (!record || seen.has(record.id)) return [];
    seen.add(record.id);
    const result = triggerList(record.triggers);
    (record.sourceIds || []).filter(id => /^[SX]\d+$/.test(id)).forEach(id => {
      relationshipLineageTriggers(provenanceRecordById(id), seen).forEach(trigger => {
        if (!result.includes(trigger)) result.push(trigger);
      });
    });
    return result.slice(0, 20);
  }

  function relationshipGroundedFields(triggers, content) {
    const fields = [];
    const add = field => {
      if (RELATIONSHIP_FIELDS.includes(field) && !fields.includes(field)) fields.push(field);
    };
    triggerList(triggers).forEach(trigger => {
      (RELATIONSHIP_TRIGGER_FIELDS[trigger] || []).forEach(add);
    });
    const source = keyOf(content);
    if (/\b(?:trust\w*|distrust\w*|betray\w*|reliab\w*|dependab\w*|deceiv\w*|dishonest\w*|lied|lying|repair\w*)\b/.test(source)) add("Trust");
    if (/\b(?:affection\w*|reconnect\w*|closeness|close|distant|distance|bond\w*|friendship|shared connection|intimacy|intimate|withdraw\w*)\b/.test(source)) add("Closeness");
    if (/\b(?:boundary|boundaries|consent\w*|permission|limit\w*|crossed|respected|reinforced|released)\b/.test(source)) add("Boundaries");
    if (/\b(?:conflict\w*|argument\w*|fight\w*|anger|angry|hostil\w*|rupture\w*|friction|strain\w*|betray\w*|repair\w*)\b/.test(source)) add("Conflict");
    if (/\b(?:accepted responsibility|responsibility|employ\w*|hired|job|position|role|partnership|partnered|marriage|married|spouse|promotion|promoted|in charge|duty)\b/.test(source)) add("Role");
    return fields;
  }

  function relationshipGroundedFieldsForRecord(record) {
    if (!record) return [];
    const rawLineage = storyLineageForSources((record.sourceIds || []).concat(record.storyEvidenceIds || []));
    const lineageText = rawLineage.map(id => evidenceForId(id)?.text || "").join(" ");
    const managedContent = record.kind === "state"
      ? [record.value, record.thought, lineageText]
      : [record.value, record.explanation, lineageText];
    return relationshipGroundedFields(
      relationshipLineageTriggers(record),
      managedContent.filter(Boolean).join(" ")
    );
  }

  function relationshipDerivedSourceText(record, allowedFields, rawLineage) {
    const targetName = modelTargetName(record.targetKey, record.targetName);
    const fields = (allowedFields || []).join(", ");
    if (record.kind === "state") {
      const triggers = relationshipLineageTriggers(record);
      return line(
        "Accepted State confirmation about " + targetName
          + ": Situation " + (record.value || "unspecified")
          + (triggers.length ? "; triggers " + triggers.join(", ") : "")
          + (record.thought ? "; private meaning " + record.thought : "")
          + "; allowed Relationship fields " + fields
          + (rawLineage.length ? "; raw lineage " + rawLineage.join(",") : ""),
        settings.MAX_EVIDENCE_ITEM_CHARS
      );
    }
    return line(
      "Promoted Experience about " + targetName
        + ": " + (record.value || record.explanation || "unspecified")
        + "; allowed Relationship fields " + fields
        + (rawLineage.length ? "; raw lineage " + rawLineage.join(",") : ""),
      settings.MAX_EVIDENCE_ITEM_CHARS
    );
  }

  function relationshipDerivedEvidenceCandidates(owner, targets, opportunityOverride = null, frozenPacket = null) {
    const legalTargets = new Map((Array.isArray(targets) ? targets : [])
      .filter(target => target.relationship === true && target.key !== "self")
      .map(target => [target.key, target]));
    const currentOpportunity = opportunityOverride === null
      ? Math.max(0, Number(CC.ownerOpportunities[owner.key]) || 0)
      : Math.max(0, Number(opportunityOverride) || 0);
    const frozenById = {};
    const frozenOrder = [];
    (Array.isArray(frozenPacket) ? frozenPacket : []).forEach(source => {
      const id = provenanceId(source && source.id);
      if (!id || !["S", "X"].includes(id.charAt(0))) return;
      frozenById[id] = source;
      frozenOrder.push(id);
    });
    refreshProvenanceActivity();
    const records = CC.provenance.records.filter(record =>
      ["state", "experience"].includes(record.kind)
      && record.ownerKey === owner.key
      && legalTargets.has(record.targetKey)
    );
    const ordered = frozenOrder.length
      ? frozenOrder.map(id => records.find(record => record.id === id)).filter(Boolean)
      : records.slice().sort((left, right) =>
        right.ownerOpportunity - left.ownerOpportunity
          || right.createdClock - left.createdClock
          || right.id.localeCompare(left.id)
      );
    const diagnostics = [];
    const candidates = [];
    ordered.forEach(record => {
      const frozen = frozenById[record.id] || null;
      const prefix = record.id.charAt(0);
      const expectedGain = prefix === "S"
        ? settings.OPERATION_POINTS.STATE_CONFIRMATION_GAIN
        : settings.OPERATION_POINTS.EXPERIENCE_PATTERN_GAIN;
      const age = Math.max(0, currentOpportunity - Math.max(0, Number(record.ownerOpportunity) || 0));
      const expectedManagedIdentity = record.kind === "state"
        ? stateSituationSignature(record.ownerKey, record.targetKey, record.value)
        : experienceSignature(record.ownerKey, record.targetKey, record.value);
      if (!record.active || !managedSignatureStillValid(record)
        || !expectedManagedIdentity || record.managedSignature !== expectedManagedIdentity) {
        diagnostics.push(record.id + " excluded: inactive, managed signature stale, or owner-target identity inconsistent.");
        return;
      }
      if (age >= settings.RELATIONSHIP_EVIDENCE_OPPORTUNITIES) {
        diagnostics.push(record.id + " excluded: age " + age + " reached the Relationship evidence window.");
        return;
      }
      const rawLineage = storyLineageForSources(record.sourceIds.concat(record.storyEvidenceIds || []));
      const grounded = relationshipGroundedFieldsForRecord(record);
      const frozenFields = frozen && Array.isArray(frozen.allowedFields)
        ? frozen.allowedFields.filter(field => RELATIONSHIP_FIELDS.includes(field))
        : null;
      const allowedFields = (frozenFields || grounded).filter(field => grounded.includes(field));
      const fieldUseSignatures = {};
      allowedFields.forEach(field => {
        const recomputed = relationshipUseSignatureForRecord(record, owner.key, record.targetKey, field);
        const frozenSignature = frozen && frozen.useSignatures && frozen.useSignatures[field];
        if (!recomputed || (frozenSignature && frozenSignature !== recomputed)) return;
        if (!provenanceUseCommitted(record, recomputed)) fieldUseSignatures[field] = recomputed;
      });
      const unusedFields = allowedFields.filter(field => fieldUseSignatures[field]);
      if (!unusedFields.length) {
        diagnostics.push(record.id + " excluded: no grounded unused Relationship field remained.");
        return;
      }
      const target = legalTargets.get(record.targetKey);
      const text = frozen && frozen.text
        ? line(frozen.text, settings.MAX_EVIDENCE_ITEM_CHARS)
        : relationshipDerivedSourceText(record, unusedFields, rawLineage);
      const itemNumber = 1000000 + Math.max(0, Number(record.createdClock) || 0) * 1000
        + Math.max(0, Number(record.id.slice(1)) || 0);
      candidates.push({
        item: {
          id: record.id,
          number: itemNumber,
          source: "provenance",
          text,
          anchor: null,
          relevance: age === 0 ? 3 : (age <= 2 ? 2 : 1)
        },
        stateEligible: false,
        viewEligible: false,
        relationshipEligible: true,
        nameEligible: false,
        age: frozen && Number.isFinite(Number(frozen.age)) ? Math.max(0, Number(frozen.age)) : age,
        derived: true,
        prefix,
        ownerKey: record.ownerKey,
        targetKey: record.targetKey,
        targetName: target && target.name || record.targetName,
        allowedFields: unusedFields,
        managedSignature: record.managedSignature,
        rawLineage,
        gain: frozen && Number.isFinite(Number(frozen.gain))
          ? Math.max(0, Number(frozen.gain))
          : expectedGain,
        useSignatures: fieldUseSignatures,
        directAllowed: false,
        eligibilityReason: record.id + " active, target-compatible, signature-valid, age " + age
          + ", allowed " + unusedFields.join(", ")
      });
      diagnostics.push(record.id + " eligible: " + unusedFields.join(", ")
        + "; gain " + expectedGain + "; raw " + (rawLineage.join(",") || "None") + ".");
    });
    CC.last.relationshipSourceDiagnostics = unique(diagnostics, 500).slice(-40);
    return candidates;
  }

  function viewInterpretationsForTarget(owner, targetKey, targets) {
    const legalModes = (Array.isArray(targets) ? targets : [])
      .filter(target => target && target.key === targetKey)
      .map(target => target.mode);
    if (!legalModes.length) return [];
    refreshViewsStore(false);
    const ownerData = viewsForOwner(owner.key);
    const activeRecord = ownerData && ownerData.activeRecords.find(record => record.targetKey === targetKey);
    const buriedRecord = ownerData && ownerData.buriedRecords.find(record => record.targetKey === targetKey);
    const recovering = !!recoveringMarker(owner.key, targetKey);
    const interpretations = [];
    const add = (destination, operationMode, targetMode) => {
      const normalizedDestination = canonicalViewDestination(destination);
      const normalizedMode = canonicalViewOperationMode(operationMode);
      if (!normalizedDestination || !normalizedMode) return;
      const key = [normalizedDestination, normalizedMode, targetMode || ""].join("|");
      if (!interpretations.some(item => item.key === key)) {
        interpretations.push({ key, destination: normalizedDestination, operationMode: normalizedMode, targetMode: targetMode || "" });
      }
    };
    if (legalModes.includes("known")) {
      VIEW_CATEGORIES.forEach(destination => {
        add(destination, "O", "known");
        add(destination, "M", "known");
      });
      if (activeRecord && !buriedRecord && !recovering) add("Buried", "Buried", "known");
    }
    if (legalModes.includes("buried") && buriedRecord) add("Recovered", "Recovered", "buried");
    if (legalModes.includes("recovering") && activeRecord && buriedRecord && recovering) {
      VIEW_CATEGORIES.forEach(destination => add(destination, "Reconciled", "recovering"));
    }
    return interpretations;
  }

  const DERIVED_VIEW_DESTINATION_PATTERNS = {
    Loves: /\b(?:love|loves|loved|loving|adore|adores|adored|adoring|cherish|cherishes|cherished|devoted|devotion|beloved)\b/i,
    Likes: /\b(?:like|likes|liked|liking|admire|admires|admired|admiration|respect|respects|respected|appreciate|appreciates|appreciated|value|values|valued|fond|fondness|esteem|grateful|gratitude|approve|approves|approved)\b/i,
    Neutrals: /\b(?:neutral|neutrality|indifferent|indifference|unmoved|no strong opinion|no opinion|neither likes? nor dislikes?)\b/i,
    Dislikes: /\b(?:dislike|dislikes|disliked|disliking|resent|resents|resented|resentment|annoyed|annoyance|irritated|irritation|disapprove|disapproves|disapproved|aversion)\b/i,
    Hates: /\b(?:hate|hates|hated|hating|despise|despises|despised|loathes?|loathed|detest|detests|detested|abhor|abhors|abhorred|contempt)\b/i
  };
  const DERIVED_VIEW_BURIAL_PATTERN = /\b(?:forgot|forgets|forgotten|no longer remembers?|memory (?:of|about).{0,40}(?:faded|is gone|was gone)|ceased to remember)\b/i;
  const DERIVED_VIEW_RECOVERY_PATTERN = /\b(?:remembered|remembers|recalled|recalls|recognized|recognizes|memory returned|memories returned)\b/i;
  const DERIVED_VIEW_MAJOR_PATTERN = /\b(?:betrayal|betrayed|saved (?:his|her|their|the) life|life[- ]threatening|sacrificed|sacrifice|murdered|murder|abused|abuse|assaulted|assault|tortured|torture|married|marriage|divorced|divorce|death|died|severed ties|cut ties|irreparable|ruined everything)\b/i;
  const VIEW_GROUNDING_STOP_WORDS = new Set([
    "a", "an", "and", "are", "as", "at", "be", "because", "been", "being", "by", "for", "from",
    "has", "have", "he", "her", "hers", "him", "his", "i", "in", "into", "is", "it", "its", "me",
    "my", "of", "on", "or", "our", "she", "that", "the", "their", "them", "they", "this", "to", "us",
    "was", "we", "were", "with", "you", "your", "accepted", "relationship", "movement", "experience",
    "pattern", "source", "view", "review", "eligible", "category", "destination", "mode", "ordinary", "major",
    "durable", "judgement", "stance", "toward", "towards", "feeling", "feels", "felt", "opinion",
    "love", "adore", "cherish", "devotion", "like", "admire", "admiration", "respect", "appreciate", "value",
    "fond", "fondness", "esteem", "grateful", "gratitude", "approve", "neutral", "neutrality", "indifferent",
    "indifference", "unmoved", "dislike", "resent", "resentment", "annoyed", "annoyance", "irritated",
    "irritation", "disapprove", "aversion", "hate", "despise", "loathe", "detest", "abhor", "contempt"
  ]);

  function provenanceViewSemanticTexts(record) {
    if (!record) return [];
    const rawTexts = storyLineageForSources((record.sourceIds || []).concat(record.storyEvidenceIds || []))
      .map(evidenceForId)
      .filter(Boolean)
      .map(item => item.text);
    return unique([
      record.explanation,
      record.value,
      record.priorValue,
      record.resultingValue,
      record.priorViewState,
      record.resultingViewState
    ].concat(rawTexts), 2000).filter(Boolean);
  }

  function derivedViewDestinationSupported(record, destination) {
    const normalizedDestination = canonicalViewDestination(destination);
    const source = provenanceViewSemanticTexts(record).join(" ");
    if (!normalizedDestination || !source) return false;
    if (VIEW_CATEGORIES.includes(normalizedDestination)) {
      const pattern = DERIVED_VIEW_DESTINATION_PATTERNS[normalizedDestination];
      return !!(pattern && pattern.test(source));
    }
    if (normalizedDestination === "Buried") return DERIVED_VIEW_BURIAL_PATTERN.test(source);
    if (normalizedDestination === "Recovered") return DERIVED_VIEW_RECOVERY_PATTERN.test(source);
    return false;
  }

  function derivedViewModeSupported(record, destination, operationMode) {
    const normalizedMode = canonicalViewOperationMode(operationMode);
    if (!normalizedMode) return false;
    if (!derivedViewDestinationSupported(record, destination)) return false;
    if (normalizedMode !== "M") return true;
    const source = provenanceViewSemanticTexts(record).join(" ");
    return DERIVED_VIEW_MAJOR_PATTERN.test(source)
      || (record.kind === "relationship" && record.eventKind === "D"
        && Math.abs(Number(record.actualChange) || 0) >= 10);
  }

  function viewGroundingTerms(value, excludedForms) {
    const excluded = new Set();
    const stopped = new Set(Array.from(VIEW_GROUNDING_STOP_WORDS).map(relationshipGroundingStem));
    (Array.isArray(excludedForms) ? excludedForms : []).forEach(form => {
      const parts = textOf(form).normalize("NFKC").match(/[\p{L}\p{N}]+/gu) || [];
      parts.forEach(part => excluded.add(relationshipGroundingStem(part)));
    });
    const attitudeStem = /^(?:lov|ador|cherish|devot|lik|admir|respect|appreciat|valu|fond|esteem|grat|approv|neutral|indiffer|unmov|dislik|resent|annoy|irrit|disapprov|aversion|hat|despis|loath|detest|abhor|contempt)/;
    return unique((textOf(value).normalize("NFKC").match(/[\p{L}\p{N}]+/gu) || [])
      .map(relationshipGroundingStem)
      .filter(token => token.length >= 3 && !stopped.has(token) && !attitudeStem.test(token) && !excluded.has(token)), 80);
  }

  function derivedViewInterpretationsForRecord(record, owner, targetKey, targets) {
    return viewInterpretationsForTarget(owner, targetKey, targets).filter(item =>
      derivedViewModeSupported(record, item.destination, item.operationMode)
    );
  }

  function derivedViewEvidenceSupportsCandidate(record, owner, target, candidate) {
    if (!record || !owner || !target || !candidate) {
      return { ok: false, error: "Derived View validation lacked its provenance source, owner, target, or candidate." };
    }
    const destination = canonicalViewDestination(candidate.destination);
    const operationMode = viewOperationModeForCandidate(candidate, target);
    if (!derivedViewModeSupported(record, destination, operationMode)) {
      return {
        ok: false,
        error: record.id + " did not semantically establish the proposed " + destination
          + " View interpretation and " + operationMode + " mode."
      };
    }
    const excludedForms = uniqueNameForms([owner.name]
      .concat(owner.aliases || [], operationTargetAliases(owner, target), [destination]), 160);
    const sourceTerms = viewGroundingTerms(provenanceViewSemanticTexts(record).join(" "), excludedForms);
    const explanationTerms = viewGroundingTerms(candidate.explanation, excludedForms);
    if (!explanationTerms.length) {
      if (!sourceTerms.length) return { ok: true };
      return { ok: false, error: record.id + " did not support any concrete term in the proposed View Explanation." };
    }
    if (!sourceTerms.length || !explanationTerms.some(term => sourceTerms.includes(term))) {
      return {
        ok: false,
        error: record.id + " did not support a concrete event, quality, or reason used by the proposed View Explanation."
      };
    }
    return { ok: true };
  }

  function viewDerivedSourceText(record, interpretations, rawLineage) {
    const targetName = modelTargetName(record.targetKey, record.targetName);
    const modes = unique((interpretations || []).map(item => item.operationMode), 40).join(", ");
    if (record.kind === "relationship") {
      const movement = [record.field, record.actualChange ? ((record.actualChange > 0 ? "+" : "") + record.actualChange) : "",
        record.resultingStage || record.resultingValue].filter(Boolean).join(" ");
      return line(
        "Accepted Relationship movement about " + targetName + ": " + (movement || record.explanation || "relationship changed")
          + "; this source makes View review eligible but selects no View category"
          + (modes ? "; legal operation modes " + modes : "")
          + (rawLineage.length ? "; raw lineage " + rawLineage.join(",") : ""),
        settings.MAX_EVIDENCE_ITEM_CHARS
      );
    }
    return line(
      "Promoted Experience about " + targetName + ": " + (record.value || record.explanation || "unspecified")
        + "; this source makes View review eligible but selects no View category"
        + (modes ? "; legal operation modes " + modes : "")
        + (rawLineage.length ? "; raw lineage " + rawLineage.join(",") : ""),
      settings.MAX_EVIDENCE_ITEM_CHARS
    );
  }

  function viewDerivedEvidenceCandidates(owner, targets, opportunityOverride = null, frozenPacket = null) {
    const targetLists = new Map();
    (Array.isArray(targets) ? targets : []).forEach(target => {
      if (!target || !target.key || /^NEW=/i.test(target.code || "")) return;
      if (!targetLists.has(target.key)) targetLists.set(target.key, []);
      targetLists.get(target.key).push(target);
    });
    const currentOpportunity = opportunityOverride === null
      ? Math.max(0, Number(CC.ownerOpportunities[owner.key]) || 0)
      : Math.max(0, Number(opportunityOverride) || 0);
    const frozenById = {};
    const frozenOrder = [];
    (Array.isArray(frozenPacket) ? frozenPacket : []).forEach(source => {
      const id = provenanceId(source && source.id);
      if (!id || !["R", "X"].includes(id.charAt(0))) return;
      frozenById[id] = source;
      frozenOrder.push(id);
    });
    refreshProvenanceActivity();
    const records = CC.provenance.records.filter(record =>
      ["relationship", "experience"].includes(record.kind)
      && record.ownerKey === owner.key
      && targetLists.has(record.targetKey)
    );
    const ordered = frozenOrder.length
      ? frozenOrder.map(id => records.find(record => record.id === id)).filter(Boolean)
      : records.slice().sort((left, right) =>
        right.ownerOpportunity - left.ownerOpportunity
          || right.createdClock - left.createdClock
          || right.id.localeCompare(left.id)
      );
    const diagnostics = [];
    const candidates = [];
    ordered.forEach(record => {
      const frozen = frozenById[record.id] || null;
      const prefix = record.id.charAt(0);
      const age = Math.max(0, currentOpportunity - Math.max(0, Number(record.ownerOpportunity) || 0));
      const expectedManagedIdentity = record.kind === "relationship"
        ? currentRelationshipManagedSignature(record.ownerKey, record.targetKey, record.field)
        : experienceSignature(record.ownerKey, record.targetKey, record.value);
      if (!record.active || !managedSignatureStillValid(record)
        || !expectedManagedIdentity || record.managedSignature !== expectedManagedIdentity) {
        diagnostics.push(record.id + " excluded: inactive, managed signature stale, or owner-target identity inconsistent.");
        return;
      }
      if (age >= settings.VIEW_EVIDENCE_OPPORTUNITIES) {
        diagnostics.push(record.id + " excluded: age " + age + " reached the View evidence window.");
        return;
      }
      const targetOptions = targetLists.get(record.targetKey) || [];
      const currentInterpretations = derivedViewInterpretationsForRecord(record, owner, record.targetKey, targetOptions);
      const frozenInterpretations = frozen && Array.isArray(frozen.interpretations)
        ? frozen.interpretations.map(item => {
          const destination = canonicalViewDestination(item && item.destination);
          const operationMode = canonicalViewOperationMode(item && item.operationMode);
          const targetMode = line(item && item.targetMode, 40);
          return {
            key: [destination, operationMode, targetMode || ""].join("|"),
            destination,
            operationMode,
            targetMode
          };
        }).filter(item => item.destination && item.operationMode)
        : null;
      const allowedInterpretations = (frozenInterpretations || currentInterpretations).filter(item =>
        currentInterpretations.some(current => current.destination === item.destination
          && current.operationMode === item.operationMode && current.targetMode === item.targetMode)
      );
      const rawLineage = storyLineageForSources(record.sourceIds.concat(record.storyEvidenceIds || []));
      const useSignatures = {};
      const unusedInterpretations = [];
      allowedInterpretations.forEach(item => {
        const key = [item.destination, item.operationMode, item.targetMode || ""].join("|");
        const recomputed = viewUseSignatureForRecord(
          record, owner.key, record.targetKey, item.destination, item.operationMode
        );
        const frozenSignature = frozen && frozen.useSignatures && frozen.useSignatures[key];
        if (!recomputed || (frozenSignature && frozenSignature !== recomputed)) return;
        if (!provenanceUseCommitted(record, recomputed)) {
          useSignatures[key] = recomputed;
          unusedInterpretations.push({ ...item, key });
        }
      });
      if (!unusedInterpretations.length) {
        diagnostics.push(record.id + " excluded: no unused legal View interpretation remained.");
        return;
      }
      const target = targetOptions[0];
      const text = frozen && frozen.text
        ? line(frozen.text, settings.MAX_EVIDENCE_ITEM_CHARS)
        : viewDerivedSourceText(record, unusedInterpretations, rawLineage);
      const itemNumber = 2000000 + Math.max(0, Number(record.createdClock) || 0) * 1000
        + Math.max(0, Number(record.id.slice(1)) || 0);
      const gain = frozen && Number.isFinite(Number(frozen.gain))
        ? Math.max(0, Number(frozen.gain))
        : (record.kind === "relationship"
          ? settings.OPERATION_POINTS.RELATIONSHIP_TO_VIEW_GAIN
          : settings.OPERATION_POINTS.EXPERIENCE_PATTERN_GAIN);
      candidates.push({
        item: {
          id: record.id,
          number: itemNumber,
          source: "provenance",
          text,
          anchor: null,
          relevance: age === 0 ? 3 : (age <= 2 ? 2 : 1)
        },
        stateEligible: false,
        viewEligible: true,
        relationshipEligible: false,
        nameEligible: false,
        age: frozen && Number.isFinite(Number(frozen.age)) ? Math.max(0, Number(frozen.age)) : age,
        derived: true,
        prefix,
        ownerKey: record.ownerKey,
        targetKey: record.targetKey,
        targetName: target && target.name || record.targetName,
        allowedFields: [],
        allowedDestinations: unique(unusedInterpretations.map(item => item.destination), 80),
        allowedModes: unique(unusedInterpretations.map(item => item.operationMode), 40),
        interpretations: unusedInterpretations,
        managedSignature: record.managedSignature,
        rawLineage,
        gain,
        useSignatures,
        directAllowed: false,
        eligibilityReason: record.id + " active, target-compatible, signature-valid, age " + age
          + "; View destination remains model-selected from legal interpretations"
      });
      diagnostics.push(record.id + " eligible for View review; gain " + gain
        + "; target " + record.targetKey + "; interpretations " + unusedInterpretations.length
        + "; raw " + (rawLineage.join(",") || "None") + ".");
    });
    CC.last.viewSourceDiagnostics = unique(diagnostics, 500).slice(-40);
    return candidates;
  }

  function orderedOperationStatement(source, subjects, verbs, objects) {
    const normalized = keyOf(source);
    if (!normalized) return false;
    const subjectList = unique(subjects, 160).map(keyOf).filter(Boolean);
    const objectList = unique(objects, 160).map(keyOf).filter(Boolean);
    return subjectList.some(subject => objectList.some(object => verbs.some(verb => {
      const pattern = new RegExp(
        "(?:^| )" + escapeRegExp(subject) + " (?:really |fully |completely |deeply )?"
        + verb + " " + escapeRegExp(object) + "(?: |$)",
        "i"
      );
      return pattern.test(normalized);
    })));
  }

  function nameSignal(owner, target, evidenceCandidate) {
    const item = evidenceCandidate && evidenceCandidate.item;
    if (!item || evidenceCandidate.nameEligible !== true || !target || target.nameSubject !== true) return null;
    const source = textOf(item.text);
    const ownerMentioned = operationOwnerMentioned(owner, source);
    const targetMentioned = operationTargetMentioned(owner, target, source);
    const firstPersonIdentityPattern = /\b(?:call me|address me as|refer to me as|i go by|my name is|i am now called|i'm now called|from now on[, ]+call me)\b/i;
    const ownerFirstPersonIdentity = ownerSpeechAttributed(owner, source, firstPersonIdentityPattern);
    const playerFirstPersonIdentity = (item.source === "input" || item.source === "opening")
      && firstPersonIdentityPattern.test(source)
      && !ownerFirstPersonIdentity;
    const explicitTransition = /\b(?:alias|nickname|title|name)\b[^.!?\n]{0,90}\b(?:adopted|accepted|rejected|retired|replaced|reactivated|changed|uses?|goes by|known as|called)\b/i.test(source)
      || /\b(?:adopted|accepted|rejected|retired|replaced|reactivated|changed)\b[^.!?\n]{0,90}\b(?:alias|nickname|title|name)\b/i.test(source)
      || /\b(?:do not|don't|no longer)\s+(?:call|address|refer to)\b/i.test(source)
      || /\b(?:nicknamed|renamed|titled)\b/i.test(source);
    const directFirstPerson = (target.key === "player" && playerFirstPersonIdentity)
      || (target.key === "self" && ownerFirstPersonIdentity);
    if (directFirstPerson || (explicitTransition && targetMentioned)) {
      return {
        kind: "name",
        targetKey: target.key,
        field: "",
        destination: "",
        gain: settings.OPERATION_POINTS.EXPLICIT_DIRECT_GAIN,
        direct: true,
        reason: "Explicit Name fact or transition in " + item.id + "."
      };
    }

    const identityKey = target.key === "self" ? "npc:" + owner.key : target.key;
    const identity = nameIdentityForKey(identityKey);
    const emerging = identity && Array.isArray(identity.emergingAliases) ? identity.emergingAliases : [];
    const confirmedReference = emerging.some(alias => aliasMentioned(source, alias))
      && (targetMentioned || ownerMentioned);
    if (confirmedReference) {
      return {
        kind: "name",
        targetKey: target.key,
        field: "",
        destination: "",
        gain: settings.OPERATION_POINTS.SUPPORTING_EVIDENCE_GAIN,
        direct: false,
        reason: "Distinct eligible use of an Emerging Name in " + item.id + "."
      };
    }
    return null;
  }

  function stateActingTarget(owner, targets, source) {
    if (!owner) return null;
    const action = "(?:offers?|offered|signs?|signed|gives?|gave|hands?|handed|entrusts?|entrusted"
      + "|transfers?|transferred|grants?|granted|invites?|invited|asks?|asked|tells?|told"
      + "|promises?|promised|proposes?|proposed|reveals?|revealed|admits?|admitted"
      + "|confesses?|confessed|announces?|announced|agrees?|agreed|accepts?|accepted"
      + "|refuses?|refused|helps?|helped|saves?|saved|protects?|protected|threatens?|threatened"
      + "|attacks?|attacked|betrays?|betrayed|hurts?|hurt|surprises?|surprised|shocks?|shocked"
      + "|reassures?|reassured|comforts?|comforted|embraces?|embraced|kisses?|kissed"
      + "|leaves?|left|returns?|returned|chooses?|chose|decides?|decided|vows?|vowed)";
    const ownerAliases = operationOwnerAliases(owner);
    const acting = (Array.isArray(targets) ? targets : []).filter(target => {
      if (!target || target.key === "self" || !operationTargetMentioned(owner, target, source)) return false;
      const targetAliases = operationTargetAliases(owner, target)
        .filter(alias => keyOf(alias) !== "you");
      return targetAliases.some(targetAlias => ownerAliases.some(ownerAlias => {
        const targetPattern = operationAliasRegExp(targetAlias);
        const ownerPattern = operationAliasRegExp(ownerAlias);
        if (!targetPattern || !ownerPattern) return false;
        return new RegExp(
          "(?:^|[^A-Za-z0-9])" + targetPattern
            + "[^.!?…\\n]{0,55}\\b" + action + "\\b"
            + "[^.!?…\\n]{0,120}" + ownerPattern + "(?=$|[^A-Za-z0-9])",
          "i"
        ).test(textOf(source));
      }));
    });
    return acting.length === 1 ? acting[0] : null;
  }

  function stateSignal(owner, targets, evidenceCandidate, currentInputId, recent) {
    const item = evidenceCandidate && evidenceCandidate.item;
    if (!item || evidenceCandidate.stateEligible !== true) return null;
    const source = textOf(item.text);
    const ownerMentioned = operationOwnerMentioned(owner, source);
    const current = item.id === currentInputId || (item.source === "story" && anchorInText(item.anchor, recent));
    if (!ownerMentioned || !current) return null;

    const dangerPattern = "\\b(?:danger|threat|threatens?|attack(?:s|ed)?|ambush|explosion|fire|flames?|collaps(?:e|es|ed|ing)|falling beam|beam (?:falls|fell)|crash(?:es|ed|ing)?|lung(?:e|es|ed|ing)|weapon|blade|gun|arrow|injured|bleeding|trapped|poisoned|drowning)\\b";
    const emotionPredicate = "\\b(?:(?:looks?|seems?|appears?|feels?|became|turns?)\\s+(?:visibly |suddenly )?(?:afraid|angry|anxious|ashamed|confused|devastated|frightened|furious|grieving|hopeful|hurt|relieved|shocked|stunned|terrified|uncertain|upset|worried)|flinches?|freezes?|gasps?|recoils?|trembles?|hesitates?|stiffens?|breaks down|bursts into tears)\\b";
    const firstPersonEmotion = /\b(?:i am|i'm|i feel|i felt|i became)\s+(?:afraid|angry|anxious|ashamed|confused|devastated|frightened|furious|grieving|hopeful|hurt|relieved|shocked|stunned|terrified|uncertain|upset|worried)\b/i;
    const revelationPattern = "\\b(?:confess(?:es|ed|ing)?|reveal(?:s|ed|ing)?|admit(?:s|ted|ting)?|discover(?:s|ed|ing)?|learn(?:s|ed|ing)?|realiz(?:e|es|ed|ing)|truth|secret|identity revealed|revelation)\\b";
    const decisionPredicate = "\\b(?:decides?|decided|chooses?|chose|vows?|vowed|swears?|swore|commits?|committed|intends?|resolved to|makes? (?:a )?decision)\\b";
    const firstPersonDecision = /\bi\s+(?:decide|choose|vow|swear|commit|intend|resolve|will|must)\b/i;
    const tensionPredicate = "\\b(?:is |was |became |seems? |looks? )?(?:torn|conflicted|under tension|strained|at odds)|\\b(?:struggles? between|hesitates? between)\\b";
    const situationPredicate = "\\b(?:is|was|became|has become|must now|now has to|is now|was now)\\b[^.!?…\\n]{0,40}\\b(?:trapped|alone|responsible|in charge|leaving|staying|fired|promoted|moving|married|separated)\\b";
    const firstPersonSituation = /\bi\s+(?:am now|was now|must now|have become|am|was)\s+(?:trapped|alone|responsible|in charge|leaving|staying|fired|promoted|moving|married|separated)\b/i;

    const categories = [];
    if (ownerNearEvent(owner, source, dangerPattern, 120)) categories.push("immediate danger");
    if (ownerPredicateMatches(owner, source, emotionPredicate)
      || ownerSpeechAttributed(owner, source, firstPersonEmotion)) {
      categories.push("explicit emotional reaction");
    }
    if (ownerNearEvent(owner, source, revelationPattern, 120)) categories.push("revelation");
    if (ownerPredicateMatches(owner, source, decisionPredicate)
      || ownerSpeechAttributed(owner, source, firstPersonDecision)) {
      categories.push("immediate decision or goal");
    }
    if (ownerPredicateMatches(owner, source, tensionPredicate)) categories.push("active tension");
    if (ownerPredicateMatches(owner, source, situationPredicate)
      || ownerSpeechAttributed(owner, source, firstPersonSituation)) {
      categories.push("materially changed Situation");
    }
    const npc = CC.npcs[owner.key];
    const currentState = normalizeState(npc && npc.state, CC.stateClock);
    const baselineState = !categories.length && !currentState.situation.value;

    if (!categories.length && !baselineState) return null;

    let targetKey = "self";
    const mentioned = (Array.isArray(targets) ? targets : [])
      .filter(target => target.key !== "self" && operationTargetMentioned(owner, target, source));
    if (mentioned.length === 1) targetKey = mentioned[0].key;
    else {
      const actingTarget = mentioned.length > 1
        ? stateActingTarget(owner, mentioned, source)
        : null;
      if (actingTarget) targetKey = actingTarget.key;
      else if ((item.source === "input" || item.source === "opening")
        && (Array.isArray(targets) ? targets : []).some(target => target.key === "player")) {
        targetKey = "player";
      }
    }
    return {
    kind: "state",
    targetKey,
    field: "",
    destination: "",
    gain: baselineState
    ? settings.OPERATION_POINTS.SUPPORTING_EVIDENCE_GAIN
    : settings.OPERATION_POINTS.STRONG_STATE_GAIN,
    direct: false,
    reason: baselineState
    ? "Current scene participation supports an initial State in " + item.id + "."
    : "Strong current State signal (" + categories.join(", ") + ") in " + item.id + "."
    };
  }

  function explicitRelationshipSignal(owner, target, evidenceCandidate) {
    const item = evidenceCandidate && evidenceCandidate.item;
    if (!item || evidenceCandidate.relationshipEligible !== true || !target || target.relationship !== true || target.key === "self") return null;
    const source = textOf(item.text);
    const ownerMentioned = operationOwnerMentioned(owner, source);
    const targetMentioned = operationTargetMentioned(owner, target, source);
    if (!ownerMentioned || !targetMentioned) return null;

    const targetObjects = target.key === "player"
      ? ["you", player.name].concat(player.aliases || [])
      : operationTargetAliases(owner, target);
    const ownerSubjects = [owner.name].concat(owner.aliases || []);
    const attributedTrust = targetObjects.some(targetAlias => {
      const wanted = operationAliasRegExp(targetAlias);
      return !!wanted && ownerSpeechAttributed(owner, source, new RegExp(
        "\\bi (?:really |fully |completely |deeply )?trust\\s+" + wanted + "\\b",
        "i"
      ));
    });
    const attributedDistrust = targetObjects.some(targetAlias => {
      const wanted = operationAliasRegExp(targetAlias);
      return !!wanted && ownerSpeechAttributed(owner, source, new RegExp(
        "\\bi (?:do not|don't|cannot|can't|never) trust\\s+" + wanted + "\\b",
        "i"
      ));
    });
    const positiveTrust = orderedOperationStatement(source, ownerSubjects, ["trusts?", "trusted"], targetObjects)
      || attributedTrust;
    const negativeTrust = orderedOperationStatement(source, ownerSubjects, ["distrusts?", "distrusted"], targetObjects)
      || attributedDistrust;
    if (positiveTrust || negativeTrust) {
      return {
        kind: "relationship",
        targetKey: target.key,
        field: "Trust",
        destination: negativeTrust ? "Distrust" : "Trust",
        gain: settings.OPERATION_POINTS.EXPLICIT_DIRECT_GAIN,
        direct: true,
        reason: "Explicit completed Trust fact in " + item.id + "."
      };
    }

    if (ownerTargetSentenceMatches(owner, target, source, "\\b(?:betrayed|betrayal)\\b")) {
      return {
        kind: "relationship",
        targetKey: target.key,
        field: "Trust",
        destination: "Severe distrust",
        gain: settings.OPERATION_POINTS.EXPLICIT_DIRECT_GAIN,
        direct: true,
        reason: "Explicit completed betrayal in " + item.id + "."
      };
    }
    if (ownerTargetSentenceMatches(owner, target, source, "\\b(?:got married|are married|is married|became (?:friends|partners)|are (?:friends|partners)|accepted (?:the )?(?:job|position|employment)|was hired|were hired|is employed|are employed|agreed to (?:work|partner)|formed (?:a )?partnership)\\b")) {
      return {
        kind: "relationship",
        targetKey: target.key,
        field: "Role",
        destination: "Established",
        gain: settings.OPERATION_POINTS.EXPLICIT_DIRECT_GAIN,
        direct: true,
        reason: "Explicit completed Role establishment in " + item.id + "."
      };
    }
    if (ownerTargetSentenceMatches(owner, target, source, "\\b(?:broke up|breakup|divorced|separated|ended (?:their|our|the) relationship|partnership ended|employment ended|was fired|were fired)\\b")) {
      return {
        kind: "relationship",
        targetKey: target.key,
        field: "Role",
        destination: "Former",
        gain: settings.OPERATION_POINTS.EXPLICIT_DIRECT_GAIN,
        direct: true,
        reason: "Explicit completed Role ending in " + item.id + "."
      };
    }
    if (ownerTargetSentenceMatches(owner, target, source, "\\b(?:explicit boundary|set (?:a|the) boundary|my boundary is|do not touch me|don't touch me|without my permission|not allowed to|must ask permission|consent required)\\b")) {
      return {
        kind: "relationship",
        targetKey: target.key,
        field: "Boundaries",
        destination: "Explicit",
        gain: settings.OPERATION_POINTS.EXPLICIT_DIRECT_GAIN,
        direct: true,
        reason: "Explicit completed boundary fact in " + item.id + "."
      };
    }
    return null;
  }

  function explicitViewSignal(owner, target, evidenceCandidate) {
    const item = evidenceCandidate && evidenceCandidate.item;
    if (!item || evidenceCandidate.viewEligible !== true || !target) return null;
    const source = textOf(item.text);
    const ownerMentioned = operationOwnerMentioned(owner, source);
    const targetMentioned = operationTargetMentioned(owner, target, source);
    if (!ownerMentioned || !targetMentioned) return null;

    const targetObjects = target.key === "player"
      ? ["you", player.name].concat(player.aliases || [])
      : operationTargetAliases(owner, target);
    const ownerSubjects = [owner.name].concat(owner.aliases || []);
    const checks = [
      { destination: "Hates", verbs: ["hates?", "hated", "despises?", "despised", "loathes?", "loathed"], firstVerbs: "(?:hate|despise|loathe)", emphasis: "(?:truly |absolutely )?", label: "hatred" },
      { destination: "Loves", verbs: ["loves?", "loved", "adores?", "adored"], firstVerbs: "(?:love|adore)", emphasis: "(?:truly |deeply )?", label: "love" },
      { destination: "Likes", verbs: ["admires?", "admired", "respects?", "respected", "likes?", "liked"], firstVerbs: "(?:admire|respect|like)", emphasis: "(?:deeply |really )?", label: "admiration" },
      { destination: "Dislikes", verbs: ["dislikes?", "disliked", "resents?", "resented"], firstVerbs: "(?:dislike|resent)", emphasis: "(?:really )?", label: "dislike" }
    ];
    for (const check of checks) {
      const attributedFirstPerson = targetObjects.some(targetAlias => {
        const wanted = operationAliasRegExp(targetAlias);
        return !!wanted && ownerSpeechAttributed(owner, source, new RegExp(
          "\\bi " + check.emphasis + check.firstVerbs + "\\s+" + wanted + "\\b",
          "i"
        ));
      });
      const matched = orderedOperationStatement(source, ownerSubjects, check.verbs, targetObjects)
        || attributedFirstPerson;
      if (!matched) continue;
      return {
        kind: "view",
        targetKey: target.key,
        field: "Category",
        destination: check.destination,
        gain: settings.OPERATION_POINTS.EXPLICIT_VIEW_GAIN,
        direct: true,
        reason: "Explicit durable " + check.label + " judgement in " + item.id + "."
      };
    }
    return null;
  }

  function operationEvidenceSignature(candidate, evidenceItems) {
    const items = (Array.isArray(evidenceItems) ? evidenceItems : []).filter(item => item && item.id);
    if (!items.length) return "";
    const ordered = items.slice().sort((left, right) => left.number - right.number || left.id.localeCompare(right.id));
    const lineage = ordered.map(item => item.id + ":" + hashString(keyOf(item.text))).join(",");
    return line(lineage + "@" + hashString([
      candidate.kind,
      candidate.ownerKey,
      candidate.targetKey,
      candidate.field,
      candidate.destination,
      lineage
    ].join("|")), 500);
  }

  function operationDrainForCandidate(candidate, ownerOpportunity) {
    if (!candidate || candidate.gain <= 0 || !candidate.evidenceSignature) return 0;
    const ownerKey = line(candidate.ownerKey, 160);
    const kind = keyOf(candidate.kind);
    const targetKey = normalizedTargetKey(candidate.targetKey);
    const field = keyOf(candidate.field);
    const destination = keyOf(candidate.destination);
    const matching = (Array.isArray(CC.operationState.drains) ? CC.operationState.drains : [])
      .map(normalizeOperationDrainRecord)
      .filter(record => record
        && record.ownerKey === ownerKey
        && record.kind === kind
        && record.evidenceSignature === candidate.evidenceSignature
        && (!targetKey || record.targetKey === targetKey)
        && (!field || keyOf(record.field) === field)
        && (!destination || keyOf(record.destination) === destination));
    return matching.length
      ? Math.max(...matching.map(record => effectiveOperationDrainValue(record, ownerOpportunity)))
      : 0;
  }

  function blankScoringCandidate(kind, owner) {
    const ownerState = CC.operationState.owners[owner.key] || blankOwnerOperationState();
    const meter = ownerState[kind] || blankOperationMeter();
    return {
      kind,
      ownerKey: owner.key,
      targetKey: "",
      field: "",
      destination: "",
      sourceIds: [],
      storyEvidenceIds: [],
      sourceMetadata: {},
      evidenceSignature: "",
      gain: 0,
      drain: 0,
      net: 0,
      currentRelevance: 0,
      lastServedOpportunity: meter.lastServedOpportunity,
      oldestEvidenceOrder: 0,
      direct: false,
      derived: false,
      allowedFields: [],
      reasons: ["No positive grounded " + operationKindLabel(kind) + " signal."]
    };
  }

  function operationCandidateGroups(owner, signals, currentInputId, recent, scoringOpportunity) {
    const groups = {};
    (Array.isArray(signals) ? signals : []).forEach(entry => {
      const signal = entry && entry.signal;
      const sourceCandidate = entry && (entry.sourceCandidate || (entry.item ? { item: entry.item } : null));
      const item = sourceCandidate && sourceCandidate.item;
      if (!signal || !item || signal.gain <= 0) return;
      const key = [signal.kind, signal.targetKey || "", signal.field || "", signal.destination || ""].join("|");
      if (!groups[key]) groups[key] = [];
      groups[key].push({ signal, sourceCandidate, item, relevance: operationCurrentRelevance(item, currentInputId, recent) });
    });
    return Object.values(groups).map(entries => {
      const best = entries.slice().sort((left, right) => right.signal.gain - left.signal.gain
        || Number(right.signal.direct) - Number(left.signal.direct)
        || right.relevance - left.relevance
        || left.item.number - right.item.number)[0];
      const kind = best.signal.kind;
      let contributing = entries.slice();
      let gain = best.signal.gain;
      if (kind === "name" && !best.signal.direct) {
        contributing = entries.slice().sort((left, right) => right.relevance - left.relevance || left.item.number - right.item.number)
          .slice(0, Math.ceil(settings.OPERATION_POINTS.EXPLICIT_DIRECT_GAIN / settings.OPERATION_POINTS.SUPPORTING_EVIDENCE_GAIN));
        gain = Math.min(settings.OPERATION_POINTS.EXPLICIT_DIRECT_GAIN,
          contributing.length * settings.OPERATION_POINTS.SUPPORTING_EVIDENCE_GAIN);
      } else if (kind === "state") {
        contributing = entries.slice().sort((left, right) => right.relevance - left.relevance || left.item.number - right.item.number).slice(0, 2);
        gain = settings.OPERATION_POINTS.STRONG_STATE_GAIN
          + (contributing.length > 1 ? settings.OPERATION_POINTS.SUPPORTING_EVIDENCE_GAIN : 0);
      } else if (kind === "relationship") {
        contributing = entries.slice().sort((left, right) => right.signal.gain - left.signal.gain
          || Number(right.signal.direct) - Number(left.signal.direct)
          || right.relevance - left.relevance
          || left.item.number - right.item.number).slice(0, 2);
        gain = Math.min(settings.OPERATION_POINTS.EXPLICIT_DIRECT_GAIN,
          contributing.reduce((total, entry) => total + Math.max(0, Number(entry.signal.gain) || 0), 0));
      } else if (kind === "view" && !best.signal.destination) {
        contributing = entries.slice().sort((left, right) => right.signal.gain - left.signal.gain
          || right.relevance - left.relevance || left.item.number - right.item.number).slice(0, 2);
        gain = Math.min(
          settings.OPERATION_POINTS.RELATIONSHIP_TO_VIEW_GAIN + settings.OPERATION_POINTS.EXPERIENCE_PATTERN_GAIN,
          contributing.reduce((total, entry) => total + Math.max(0, Number(entry.signal.gain) || 0), 0)
        );
      } else {
        contributing = entries.slice().sort((left, right) => right.relevance - left.relevance || left.item.number - right.item.number).slice(0, 2);
      }
      const evidenceItems = contributing.map(entry => entry.item);
      const sourceCandidates = contributing.map(entry => entry.sourceCandidate);
      const sourceMetadata = {};
      sourceCandidates.forEach(source => {
        if (!source || !source.item) return;
        sourceMetadata[source.item.id] = {
          prefix: source.item.id.charAt(0),
          ownerKey: source.ownerKey || owner.key,
          targetKey: source.targetKey || best.signal.targetKey || "",
          targetName: source.targetName || "",
          allowedFields: clone(source.allowedFields || []),
          allowedDestinations: clone(source.allowedDestinations || []),
          allowedModes: clone(source.allowedModes || []),
          interpretations: clone(source.interpretations || []),
          managedSignature: source.managedSignature || "",
          rawLineage: clone(source.rawLineage || (/^E\d+$/.test(source.item.id) ? [source.item.id] : [])),
          gain: Math.max(0, Number(source.gain) || Number(
            contributing.find(entry => entry.sourceCandidate === source)?.signal.gain
          ) || 0),
          useSignatures: clone(source.useSignatures || {}),
          directAllowed: source.directAllowed !== false && /^E\d+$/.test(source.item.id),
          age: Math.max(0, Number(source.age) || 0),
          reason: source.eligibilityReason || ""
        };
      });
      const ownerState = CC.operationState.owners[owner.key] || blankOwnerOperationState();
      const meter = ownerState[kind] || blankOperationMeter();
      const candidate = {
        kind,
        ownerKey: owner.key,
        targetKey: best.signal.targetKey || "",
        field: best.signal.field || "",
        destination: best.signal.destination || "",
        sourceIds: evidenceItems.map(item => item.id),
        storyEvidenceIds: unique(sourceCandidates.flatMap(source =>
          source && Array.isArray(source.rawLineage)
            ? source.rawLineage
            : (source && source.item && /^E\d+$/.test(source.item.id) ? [source.item.id] : [])
        ), 40),
        sourceMetadata,
        evidenceSignature: "",
        gain,
        drain: 0,
        net: gain,
        currentRelevance: Math.max(0, ...contributing.map(entry => entry.relevance)),
        lastServedOpportunity: meter.lastServedOpportunity,
        oldestEvidenceOrder: Math.min(...evidenceItems.map(item => item.number)),
        direct: contributing.some(entry => entry.signal.direct),
        derived: sourceCandidates.some(source => source && source.derived === true),
        allowedFields: unique(sourceCandidates.flatMap(source => source && source.allowedFields || []), 80),
        allowedDestinations: unique(sourceCandidates.flatMap(source => source && source.allowedDestinations || []), 80),
        allowedModes: unique(sourceCandidates.flatMap(source => source && source.allowedModes || []), 40),
        reasons: unique(contributing.map(entry => entry.signal.reason), 500)
      };
      candidate.evidenceSignature = operationEvidenceSignature(candidate, evidenceItems);
      candidate.drain = operationDrainForCandidate(candidate, scoringOpportunity);
      candidate.ownerOpportunity = Math.max(0, Number(scoringOpportunity) || 0);
      candidate.net = candidate.gain - candidate.drain;
      return candidate;
    });
  }

  function operationCandidateFallbackRank(kind) {
    const index = MODEL_OPERATION_KINDS.indexOf(keyOf(kind));
    return index >= 0 ? index : MODEL_OPERATION_KINDS.length;
  }

  function compareOperationCandidates(left, right) {
    if (right.gain !== left.gain) return right.gain - left.gain;
    if (left.drain !== right.drain) return left.drain - right.drain;
    if (right.currentRelevance !== left.currentRelevance) return right.currentRelevance - left.currentRelevance;
    if (left.lastServedOpportunity !== right.lastServedOpportunity) {
      return left.lastServedOpportunity - right.lastServedOpportunity;
    }
    const leftOldest = left.oldestEvidenceOrder > 0 ? left.oldestEvidenceOrder : Number.MAX_SAFE_INTEGER;
    const rightOldest = right.oldestEvidenceOrder > 0 ? right.oldestEvidenceOrder : Number.MAX_SAFE_INTEGER;
    if (leftOldest !== rightOldest) return leftOldest - rightOldest;
    const kindDifference = operationCandidateFallbackRank(left.kind) - operationCandidateFallbackRank(right.kind);
    if (kindDifference) return kindDifference;
    return [left.targetKey, left.field, left.destination, left.evidenceSignature].join("|")
      .localeCompare([right.targetKey, right.field, right.destination, right.evidenceSignature].join("|"));
  }

  function operationSelectionCriterion(selected, runnerUp) {
    if (!selected) return "No candidate had positive grounded gain.";
    if (!runnerUp) return "Only one positive grounded candidate was available.";
    if (selected.gain !== runnerUp.gain) return "Highest gain broke the tie.";
    if (selected.drain !== runnerUp.drain) return "Lowest candidate-specific drain broke the tie.";
    if (selected.currentRelevance !== runnerUp.currentRelevance) return "Strongest current relevance broke the tie.";
    if (selected.lastServedOpportunity !== runnerUp.lastServedOpportunity) return "Longest time since last served broke the tie.";
    const selectedOldest = selected.oldestEvidenceOrder > 0 ? selected.oldestEvidenceOrder : Number.MAX_SAFE_INTEGER;
    const runnerOldest = runnerUp.oldestEvidenceOrder > 0 ? runnerUp.oldestEvidenceOrder : Number.MAX_SAFE_INTEGER;
    if (selectedOldest !== runnerOldest) return "Oldest still-valid supporting evidence broke the tie.";
    if (selected.kind !== runnerUp.kind) return "Stable fallback Name → State → Relationship → View broke the final tie.";
    return "Stable lexical fallback broke the final same-kind tie.";
  }

  function operationCandidatesForOwner(owner, targets, evidenceCandidates, currentInputId, recent, scoringOpportunity) {
    const signals = [];
    const legalTargets = Array.isArray(targets) ? targets : [];
    (Array.isArray(evidenceCandidates) ? evidenceCandidates : []).forEach(evidenceCandidate => {
      const item = evidenceCandidate && evidenceCandidate.item;
      if (!item) return;
      if (/^E\d+$/.test(item.id)) {
        legalTargets.filter(target => target.nameSubject === true).forEach(target => {
          const signal = nameSignal(owner, target, evidenceCandidate);
          if (signal) signals.push({ signal, sourceCandidate: evidenceCandidate });
        });
        const state = stateSignal(owner, legalTargets, evidenceCandidate, currentInputId, recent);
        if (state) signals.push({ signal: state, sourceCandidate: evidenceCandidate });
        legalTargets.filter(target => target.relationship === true).forEach(target => {
          const signal = explicitRelationshipSignal(owner, target, evidenceCandidate);
          if (signal) signals.push({ signal, sourceCandidate: evidenceCandidate });
        });
        legalTargets.forEach(target => {
          const signal = explicitViewSignal(owner, target, evidenceCandidate);
          if (signal) signals.push({ signal, sourceCandidate: evidenceCandidate });
        });
        return;
      }
      if (["S", "X"].includes(item.id.charAt(0)) && evidenceCandidate.relationshipEligible === true) {
        const target = legalTargets.find(candidate =>
          candidate.relationship === true && candidate.key === evidenceCandidate.targetKey
        );
        if (!target) return;
        (evidenceCandidate.allowedFields || []).forEach(field => {
          signals.push({
            signal: {
              kind: "relationship",
              targetKey: target.key,
              field,
              destination: "",
              gain: evidenceCandidate.gain,
              direct: false,
              reason: item.id + " supplied grounded accumulated " + field + " meaning."
            },
            sourceCandidate: evidenceCandidate
          });
        });
        return;
      }
      if (["R", "X"].includes(item.id.charAt(0)) && evidenceCandidate.viewEligible === true) {
        const target = legalTargets.find(candidate => candidate.key === evidenceCandidate.targetKey);
        if (!target) return;
        signals.push({
          signal: {
            kind: "view",
            targetKey: target.key,
            field: "Category",
            destination: "",
            gain: evidenceCandidate.gain,
            direct: false,
            reason: item.id + " makes this owner-target View eligible without selecting a category or mode."
          },
          sourceCandidate: evidenceCandidate
        });
      }
    });

    const candidates = operationCandidateGroups(owner, signals, currentInputId, recent, scoringOpportunity);
    MODEL_OPERATION_KINDS.forEach(kind => {
      if (!candidates.some(candidate => candidate.kind === kind)) candidates.push(blankScoringCandidate(kind, owner));
    });
    return candidates.sort((left, right) => operationCandidateFallbackRank(left.kind) - operationCandidateFallbackRank(right.kind)
      || left.targetKey.localeCompare(right.targetKey)
      || left.field.localeCompare(right.field)
      || left.destination.localeCompare(right.destination));
  }

  function selectOperationCandidate(candidates) {
    const positive = (Array.isArray(candidates) ? candidates : []).filter(candidate => candidate.gain > 0)
      .slice().sort(compareOperationCandidates);
    const selected = positive[0] || null;
    const runnerUp = positive[1] || null;
    const tieBreak = operationSelectionCriterion(selected, runnerUp);
    const reasons = selected
      ? [
        "Selected " + operationKindLabel(selected.kind) + " with gain " + selected.gain
          + ", drain " + selected.drain + ", and net " + selected.net + ".",
        tieBreak
      ].concat(selected.reasons || [])
      : [tieBreak];
    return { selected, tieBreak, reasons };
  }

  function experienceReadinessGain(owner) {
    const state = normalizeState(CC.npcs[owner.key] && CC.npcs[owner.key].state, CC.stateClock);
    if (!state.situation.value || state.situation.promotedSignature) return 0;
    return Math.max(0, state.situation.confirmations) * settings.OPERATION_POINTS.EXPERIENCE_PATTERN_GAIN;
  }

  function syncOperationMeters(owner, candidates) {
    if (!owner) return;
    if (!CC.operationState.owners[owner.key]) CC.operationState.owners[owner.key] = blankOwnerOperationState();
    const ownerState = CC.operationState.owners[owner.key];
    MODEL_OPERATION_KINDS.forEach(kind => {
      const matching = (Array.isArray(candidates) ? candidates : []).filter(candidate => candidate.kind === kind)
        .slice().sort(compareOperationCandidates);
      const best = matching[0] || blankScoringCandidate(kind, owner);
      ownerState[kind].gain = Math.max(0, best.gain);
      ownerState[kind].drain = Math.max(0, Math.min(settings.OPERATION_DRAIN_CAP, best.drain));
    });
    ownerState.experience.gain = experienceReadinessGain(owner);
    ownerState.experience.drain = 0;
  }

  function freezeOperationSelection(plan, owner, targets, evidenceCandidates, currentInputId, recent) {
    if (!plan || !owner) return;
    if (plan.operationSelectionFrozen === true) {
      syncOperationMeters(owner, Array.isArray(plan.operationCandidates) ? plan.operationCandidates : []);
      return;
    }
    const scoringOpportunity = Math.max(0, Number(CC.ownerOpportunities[owner.key]) || 0) + 1;
    const candidates = operationCandidatesForOwner(
      owner, targets, evidenceCandidates, currentInputId, recent, scoringOpportunity
    );
    const selection = selectOperationCandidate(candidates);
    const selected = selection.selected;
    plan.operationSelectionFrozen = true;
    plan.selectedOperationKind = selected ? selected.kind : "";
    plan.selectedCandidate = selected ? clone(selected) : null;
    plan.operationCandidates = clone(candidates);
    plan.selectedEvidenceSignature = selected ? selected.evidenceSignature : "";
    plan.selectedGain = selected ? selected.gain : 0;
    plan.selectedDrain = selected ? selected.drain : 0;
    plan.selectedNet = selected ? selected.net : 0;
    plan.selectionReasons = clone(selection.reasons);
    plan.operationTieBreak = selection.tieBreak;
    syncOperationMeters(owner, candidates);
  }

  function operationEligibilityField(kind) {
    return {
      name: "nameEligible",
      state: "stateEligible",
      relationship: "relationshipEligible",
      view: "viewEligible"
    }[keyOf(kind)] || "";
  }

  function operationEvidenceEligible(candidate, kind) {
    const field = operationEligibilityField(kind);
    if (!field || !candidate || !candidate.item || candidate[field] !== true) return false;
    const id = continuitySourceId(candidate.item.id);
    if (!id) return false;
    if (keyOf(kind) === "relationship") return ["E", "S", "X"].includes(id.charAt(0));
    if (keyOf(kind) === "view") return ["E", "R", "X"].includes(id.charAt(0));
    return id.charAt(0) === "E";
  }

  function operationEvidenceLimit(kind, selectedCandidate) {
    const normalized = keyOf(kind);
    const direct = selectedCandidate && selectedCandidate.direct === true;
    if (normalized === "name") return direct ? 1 : 3;
    if (["state", "relationship", "view"].includes(normalized)) return direct ? 1 : 2;
    return 1;
  }

  function operationPacketSourceIds(kind, selectedCandidate, frozenIds) {
    const normalized = keyOf(kind);
    const source = Array.isArray(frozenIds) && frozenIds.length
      ? frozenIds
      : (selectedCandidate && Array.isArray(selectedCandidate.sourceIds) ? selectedCandidate.sourceIds : []);
    return unique(source, 20)
      .map(value => textOf(value).toUpperCase())
      .filter(value => {
        const id = continuitySourceId(value);
        if (!id) return false;
        if (normalized === "relationship") {
          return selectedCandidate && selectedCandidate.direct === true
            ? /^E\d+$/.test(id)
            : /^[SX]\d+$/.test(id);
        }
        if (normalized === "view") return /^[ERX]\d+$/.test(id);
        return /^E\d+$/.test(id);
      })
      .slice(0, operationEvidenceLimit(normalized, selectedCandidate));
  }

  function operationEvidenceCandidatesForKind(kind, candidates, selectedCandidate, frozenIds) {
    const normalizedKind = keyOf(kind);
    const directRelationship = normalizedKind === "relationship"
      && selectedCandidate && selectedCandidate.direct === true;
    const eligible = (Array.isArray(candidates) ? candidates : [])
      .filter(candidate => operationEvidenceEligible(candidate, kind))
      .filter(candidate => {
        if (normalizedKind !== "relationship") return true;
        const id = continuitySourceId(candidate && candidate.item && candidate.item.id);
        if (!id) return false;
        return directRelationship
          ? id.charAt(0) === "E"
          : ["S", "X"].includes(id.charAt(0));
      });
    const byId = {};
    eligible.forEach(candidate => { byId[candidate.item.id] = candidate; });
    const requested = operationPacketSourceIds(kind, selectedCandidate, frozenIds);
    const ordered = [];
    requested.forEach(id => {
      if (byId[id] && !ordered.includes(byId[id])) ordered.push(byId[id]);
    });
    return ordered;
  }

  function operationTargetsForKind(kind, targets) {
    const source = Array.isArray(targets) ? targets : [];
    if (kind === "name") return source.filter(target => target.nameSubject === true && target.mode === "known");
    if (kind === "state") return source.filter(target => target.mode === "known");
    if (kind === "relationship") return source.filter(target => target.relationship === true && target.key !== "self");
    if (kind === "view") return source.slice();
    return [];
  }

  function operationEvidenceSnippet(owner, target, kind, value) {
    const maximum = settings.MAX_OPERATION_EVIDENCE_CHARS;
    const source = canonicalOutput(value);
    if (source.length <= maximum) return source;
    const keywordPatterns = {
      name: /\b(?:name|alias|nickname|title|called|call me|known as|address|refer)\b/i,
      state: /\b(?:feel|felt|decide|choose|vow|fear|hope|hurt|angry|anxious|relieved|trapped|responsible|leaving|staying)\b/i,
      relationship: /\b(?:trust|distrust|close|distant|boundary|friend|partner|married|role|conflict|betray|permission|consent)\b/i,
      view: /\b(?:love|like|admire|respect|dislike|resent|hate|despise|judge|regard|remember|forget)\b/i
    };
    const sentences = (source.match(/[^.!?…]+[.!?…]+["'’”)*_`\]}]*|[^.!?…]+$/g) || [source])
      .map((text, index) => ({ text: text.trim(), index }))
      .filter(item => item.text)
      .map(item => ({
        ...item,
        score: (operationOwnerMentioned(owner, item.text) ? 4 : 0)
          + (target && operationTargetMentioned(owner, target, item.text) ? 4 : 0)
          + (keywordPatterns[keyOf(kind)] && keywordPatterns[keyOf(kind)].test(item.text) ? 3 : 0)
      }));
    const ranked = sentences.slice().sort((left, right) => right.score - left.score || left.index - right.index);
    const chosen = [];
    let used = 0;
    ranked.forEach(item => {
      if (used >= maximum || chosen.length >= 2) return;
      const remaining = maximum - used - (chosen.length ? 1 : 0);
      if (remaining <= 0) return;
      const text = shortenProfileValue(item.text, remaining);
      if (!text) return;
      chosen.push({ index: item.index, text });
      used += text.length + (chosen.length > 1 ? 1 : 0);
    });
    return chosen.sort((left, right) => left.index - right.index).map(item => item.text).join(" ")
      || shortenProfileValue(source, maximum);
  }

  function evidencePacketForKind(owner, kind, candidates, currentInputId, recent, target) {
    const eligible = (Array.isArray(candidates) ? candidates : [])
      .filter(candidate => operationEvidenceEligible(candidate, kind));
    if (!eligible.length) return "";
    const rows = ["Evidence:"];
    eligible.forEach(candidate => {
      const evidenceText = candidate.item.source === "provenance"
        ? candidate.item.text
        : modelEvidenceText(candidate.item, currentInputId, recent);
      const snippet = operationEvidenceSnippet(owner, target, kind, evidenceText);
      if (candidate.item.source === "provenance") {
        if (keyOf(kind) === "relationship") {
          rows.push(candidate.item.id + "[A;" + (candidate.allowedFields || []).join(",") + "]: " + snippet);
        } else if (keyOf(kind) === "view") {
          rows.push(candidate.item.id + "[V;dest="
            + ((candidate.allowedDestinations || []).join(",") || "choose")
            + ";mode=" + ((candidate.allowedModes || []).join(",") || "choose") + "]: " + snippet);
        }
        return;
      }
      const source = candidate.item.source === "input"
        ? (candidate.item.id === currentInputId ? "input-now" : "input")
        : (candidate.item.source === "opening" ? "opening" : "story");
      rows.push(candidate.item.id + "[" + source + "]: " + snippet);
    });
    return rows.join("\n");
  }

  const STATE_PRONOUN_FAMILIES = [
    { key: "she", label: "she/her", forms: ["she", "her", "hers", "herself"] },
    { key: "he", label: "he/him", forms: ["he", "him", "his", "himself"] },
    { key: "they", label: "they/them", forms: ["they", "them", "their", "theirs", "themself", "themselves"] }
  ];

  function statePronounProfileFromForms(forms) {
    const values = (Array.isArray(forms) ? forms : [])
      .map(value => line(value, 80))
      .filter(Boolean);
    if (!values.length) return null;
    const family = STATE_PRONOUN_FAMILIES.find(item => item.key === keyOf(values[0])) || null;
    return {
      forms: values,
      family: family ? family.key : "",
      display: values.slice(0, 2).join("/")
    };
  }

  function stateTargetPronounProfile(owner, target) {
    if (!target || target.key === "self") return null;
    if (target.key === "player") {
      return statePronounProfileFromForms([
        player.subject,
        player.object,
        player.possessiveAdjective,
        player.possessivePronoun,
        player.reflexive
      ]);
    }
    if (!target.key || !target.key.startsWith("npc:")) return null;
    const character = characters.find(item => "npc:" + item.key === target.key);
    const raw = line(character && character.pronouns && character.pronouns[0], 120);
    if (!raw) return null;
    const supplied = raw.split(/[\/|,;\s]+/).filter(Boolean);
    const subject = keyOf(supplied[0]);
    if (supplied.length >= 5) return statePronounProfileFromForms(supplied.slice(0, 5));
    if (subject === "she") return statePronounProfileFromForms(["she", "her", "her", "hers", "herself"]);
    if (subject === "he") return statePronounProfileFromForms(["he", "him", "his", "his", "himself"]);
    if (subject === "they") return statePronounProfileFromForms(["they", "them", "their", "theirs", "themselves"]);
    if (subject === "it") return statePronounProfileFromForms(["it", "it", "its", "its", "itself"]);
    return statePronounProfileFromForms(supplied);
  }

  function stateTargetPronounInstruction(owner, target) {
    if (target && target.key === "self" && owner) {
      return "Target reference: Self means " + owner.name
        + ". Thought uses direct first-person self-reference.";
    }
    const profile = stateTargetPronounProfile(owner, target);
    return profile && profile.display
      ? "Target reference: " + target.name + " uses " + profile.display
        + " pronouns. Plural references include an explicit group cue in the State record."
      : "";
  }

  function targetPacketForKind(owner, kind, targets) {
    const legal = operationTargetsForKind(kind, targets);
    if (!legal.length) return "";
    const rows = legal.map(target => target.code + "=" + target.name
      + (kind === "view" && target.mode === "buried" ? " (buried)" : "")
      + (kind === "view" && target.mode === "recovering" ? " (recovering)" : ""));
    if (kind === "name") {
      return "Subject: " + rows[0] + "\nUse codes: " + rows.join(", ");
    }
    const targetReference = kind === "state" ? stateTargetPronounInstruction(owner, legal[0]) : "";
    return ["Target: " + rows.join(", "), targetReference].filter(Boolean).join("\n");
  }

  function relationshipOperationDestinations(field, selectedCandidate) {
    const selected = line(selectedCandidate && selectedCandidate.destination, 120);
    if (selected) return [selected];
    const destinations = (RELATIONSHIP_STAGES[field] || []).map(stage => stage.label);
    if (field === "Role") destinations.push("Former");
    if (field === "Boundaries") destinations.push("Released");
    return unique(destinations, 120);
  }

  function relationshipFieldMeaning(field) {
    return {
      Role: "Role expresses an actual social status.",
      Trust: "Trust expresses reliance.",
      Closeness: "Closeness expresses interpersonal connection.",
      Boundaries: "Boundaries express the owner's established limits.",
      Conflict: "Conflict expresses active interpersonal friction."
    }[field] || "The selected field expresses its completed-event meaning.";
  }

  function viewOperationDestinations(target, selectedCandidate) {
    const selected = line(selectedCandidate && selectedCandidate.destination, 120);
    if (selected) return [selected];
    const allowed = unique(selectedCandidate && selectedCandidate.allowedDestinations || [], 120);
    if (allowed.length) return allowed;
    if (target && target.mode === "buried") return ["Recovered"];
    return VIEW_CATEGORIES.concat(target && target.mode === "known" ? ["Buried"] : []);
  }

  function operationTaskForKind(kind, owner, targets, evidenceCandidates, currentInputId, recent, frozenPace, selectedCandidate) {
    const normalized = keyOf(kind);
    if (!MODEL_OPERATION_KINDS.includes(normalized)) return "";
    const target = operationTargetsForKind(normalized, targets)[0] || null;
    const evidenceIds = unique((Array.isArray(evidenceCandidates) ? evidenceCandidates : [])
      .map(candidate => continuitySourceId(candidate && candidate.item && candidate.item.id))
      .filter(Boolean), 20);
    if (!target || !evidenceIds.length) return "";
    const evidenceField = evidenceIds.length === 1 ? evidenceIds[0] : "EvidenceIDs";
    const evidenceChoice = evidenceIds.length > 1
      ? "EvidenceIDs: " + evidenceIds.join(", ") + ". Cite each ID whose evidence supports the completed record."
      : "";
    const evidence = evidencePacketForKind(owner, normalized, evidenceCandidates, currentInputId, recent, target);
    const targetMap = targetPacketForKind(owner, normalized, targets);
    const commonEnding = [
      "Ground every record field and Explanation in the supplied evidence.",
      "For a continuity change, place one exact CCO record first, then write complete story prose. For stable continuity, begin with complete story prose.",
      "The Player authors the Player's inner life, choices, consent, commitments, memories, boundaries, names, and relationships."
    ];
    let rules = [];
    if (normalized === "state") {
      rules = [
        "State operation — owner " + owner.name + ".",
        evidence,
        targetMap,
        evidenceChoice,
        "Record: (CCO|S|" + target.code + "|" + evidenceField + "|TriggerList|Situation|Thought). The two routing fields immediately after CCO are the literal pair S|" + target.code + ". Use bare values in the last three fields. Complete TriggerList with 1-3 choices: " + TRIGGER_CODES.join(", ") + ". Situation is a character-voiced clause of at most 100 characters and keeps stable wording while current. Thought is direct first-person inner speech.",
        ...commonEnding
      ];
    } else if (normalized === "name") {
      rules = [
        "Name operation — owner " + owner.name + ".",
        evidence,
        targetMap,
        evidenceChoice,
        "Record: (CCO|N|" + target.code + "|" + evidenceField + "|Alias|Transition|Use|Explanation). The two routing fields immediately after CCO are the literal pair N|" + target.code + ". Copy the evidenced Alias exactly. Transitions: Observed, Adopted, Retired, Rejected, Reactivated, Replace=Old Alias. Use: General, None, or supplied S/P/N codes. Each Observed record captures one distinct use; three distinct events establish the alias. Identity-owner evidence supports lifecycle transitions, Player evidence supports Player aliases, and canonical names remain stable.",
        ...commonEnding
      ];
    } else if (normalized === "relationship") {
      const pace = frozenPace && typeof frozenPace === "object" ? frozenPace : runtime.relationshipPace;
      const field = RELATIONSHIP_FIELDS.includes(selectedCandidate && selectedCandidate.field)
        ? selectedCandidate.field
        : RELATIONSHIP_FIELDS[0];
      const direct = selectedCandidate && selectedCandidate.direct === true;
      const destinations = relationshipOperationDestinations(field, selectedCandidate);
      const destinationField = destinations.length === 1 ? destinations[0] : "Destination";
      rules = [
        "Relationship operation — owner " + owner.name + ".",
        evidence,
        targetMap,
        evidenceChoice,
        "Record: (CCO|R|" + target.code + "|" + evidenceField + "|" + field + "|"
          + (direct ? "D" : "A") + "|" + destinationField + "|Explanation). The two routing fields immediately after CCO are the literal pair R|"
          + target.code + ". Complete "
          + (destinationField === "Destination" ? "Destination and Explanation." : "Explanation."),
        "Destinations: " + destinations.join(", ") + ". Frozen " + pace.name + " pace: "
          + (direct ? "D " + pace.direct : "A " + pace.accumulated) + " per event, maximum "
          + pace.maxStages + " stage" + (pace.maxStages === 1 ? "" : "s") + "; the script assigns the score.",
        relationshipFieldMeaning(field),
        "Explanation describes the cited event and relationship meaning; the managed card supplies the resulting score and stage.",
        ...commonEnding
      ];
    } else if (normalized === "view") {
      const destinations = viewOperationDestinations(target, selectedCandidate);
      const modes = unique(selectedCandidate && selectedCandidate.allowedModes || [], 20);
      const legalModes = modes.length ? modes : ["O", "M"];
      const destinationField = destinations.length === 1 ? destinations[0] : "Destination";
      const modeField = legalModes.length === 1 ? legalModes[0] : "Mode";
      const openViewFields = [
        destinationField === "Destination" ? "Destination" : "",
        modeField === "Mode" ? "Mode" : "",
        "Explanation"
      ].filter(Boolean);
      rules = [
        "View operation — owner " + owner.name + ".",
        evidence,
        targetMap,
        evidenceChoice,
        "Record: (CCO|V|" + target.code + "|" + evidenceField + "|" + destinationField + "|"
          + modeField + "|Explanation). The two routing fields immediately after CCO are the literal pair V|" + target.code + ". Complete "
          + openViewFields.join(", ") + ". Destinations: "
          + destinations.join(", ") + ". Modes: " + (modes.length ? modes.join(", ") : "O, M")
          + ". O keeps the category or moves one adjacent step; M represents a major event and supports a larger jump.",
        "View expresses durable judgement. Supplied derived evidence guides the listed choices. Buried stores established forgetting, Recovered restores it, and a category reconciles a recovering View.",
        "Explanation describes the cited durable judgement and its evidence; the managed heading supplies the resulting View category.",
        ...commonEnding
      ];
    }
    return ["<SYSTEM>", ...rules.filter(Boolean), "</SYSTEM>"].join("\n");
  }

  function recoveryTask() {
    return [
      "<SYSTEM>",
      "Write a complete scene response in ordinary story prose. Active NPCs respond from their own perspectives; " + player.name + " authors the Player's choices.",
      "</SYSTEM>"
    ].join("\n");
  }

  function portrayalRules() {
    return [
      "Portray each active NPC distinctly from that NPC's supplied Outer, Names, Inner, State, Relationships, Views, and Experiences. Principles guide choices; Thought appears through behavior or subtext. Outer and Inner remain creator-authored anchors.",
      "Every named wrapper belongs to its named NPC. Read each Relationship and View in its owner-target direction. Situation and Experiences supply recorded events. Use canonical names and permitted Active aliases exactly; Emerging aliases are tentative, Retired aliases are historical, and Rejected aliases record declined forms. A shared alias resolves through one clear identity in the surrounding text.",
      player.name + " alone authors the Player's speech, actions, inner life, views, consent, commitments, memories, boundaries, names, and relationship choices.",
      "Player: " + player.name + " | "
        + [player.subject, player.object, player.possessiveAdjective, player.possessivePronoun, player.reflexive].join("/")
        + " | " + player.agreement
    ].join("\n");
  }

  function availableContinuityBudget(base, maxChars) {
    if (!maxChars) return runtime.continuityBudget;
    const availableChars = Math.max(0, maxChars - textOf(base).length - 4);
    return Math.min(runtime.continuityBudget, Math.floor(availableChars / 3.25));
  }

  function renderPortrayalComponents(components) {
    const body = components.map(component => component.text).filter(Boolean).join("\n");
    return body ? "<SYSTEM>\n" + body + "\n</SYSTEM>" : "";
  }

  function fitWithoutTrimming(base, prefix, tail, maxChars) {
    const joined = [prefix, base, tail].filter(Boolean).join("\n\n");
    if (!maxChars || joined.length <= maxChars) {
      return { ok: true, text: joined, recentChars: recentStoryFromContext(base).length };
    }
    return {
      ok: false,
      text: base,
      recentChars: recentStoryFromContext(base).length,
      reason: "The immutable platform context left insufficient room for this complete continuity packet."
    };
  }

  function assembleContext(base, active, focus, currentInput, recent, plan) {
    const components = [];
    let tail = CC.recoveryPending ? recoveryTask() : "";
    const selectedNames = [];
    const omittedNames = [];
    const selectedRelationships = [];
    const omittedRelationships = [];
    const selectedViews = [];
    const omittedViews = [];
    const selectedExperiences = [];
    const omittedExperiences = [];
    const modelActive = [];
    const maxChars = Number(info.maxChars) || 0;
    const configuredBudget = runtime.continuityBudget;
    const effectiveBudget = availableContinuityBudget(base, maxChars);
    let operationTurnLimitActive = false;
    let compactOperationCoreUsed = false;
    const operationCandidateReady = !!(
      plan && plan.opportunity && !CC.recoveryPending
      && MODEL_OPERATION_KINDS.includes(keyOf(plan.selectedOperationKind))
      && plan.selectedCandidate
    );

    const composition = (candidateComponents = components, candidateTail = tail, tokenLimit = 0) => {
      const prefix = renderPortrayalComponents(candidateComponents);
      const tokens = estimateTokens([prefix, candidateTail].filter(Boolean).join("\n"));
      const requestedLimit = Number(tokenLimit) > 0
        ? Number(tokenLimit)
        : (operationTurnLimitActive ? settings.MAX_OPERATION_TURN_TOKENS : configuredBudget);
      const allowedTokens = Math.min(configuredBudget, requestedLimit);
      if (tokens > allowedTokens) return { ok: false, reason: "continuity turn budget" };
      if (tokens > effectiveBudget) return { ok: false, reason: "effective context allowance" };
      const fitted = fitWithoutTrimming(base, prefix, candidateTail, maxChars);
      return fitted.ok ? { ok: true, tokens, fitted } : { ok: false, reason: fitted.reason };
    };
    const addGroup = group => {
      const usable = group.filter(component => component.text);
      if (!usable.length) return true;
      const candidate = components.concat(usable);
      const fit = composition(candidate, tail);
      if (!fit.ok) return false;
      components.push(...usable);
      return true;
    };
    const addNamesProjection = (identity, ownerKey, limit, marker) => {
      const relevant = relevantNameRecords(identity, currentInput, recent, modelActive);
      const chosen = [];
      let blocked = false;
      relevant.forEach(selection => {
        const label = identity.canonical + "→" + selection.record.alias;
        if (blocked || chosen.length >= limit) {
          omittedNames.push(label);
          return;
        }
        const next = chosen.concat(selection);
        const block = renderRelevantNamesBlock(identity, next);
        const priorIndex = components.findIndex(component => component.namesMarker === marker);
        const candidate = components.slice();
        const component = {
          text: block, type: "names", ownerKey, order: identity.player ? -1 : 1, namesMarker: marker
        };
        if (priorIndex >= 0) candidate[priorIndex] = component;
        else candidate.push(component);
        const fit = composition(candidate, tail);
        if (fit.ok) {
          if (priorIndex >= 0) components[priorIndex] = component;
          else components.push(component);
          chosen.push(selection);
          selectedNames.push(label);
        } else {
          blocked = true;
          omittedNames.push(label);
        }
      });
      return chosen;
    };

    const core = [{ text: portrayalRules(), type: "rules", order: -1 }];
    const focusAnchors = [
      { text: outerAnchor(focus), type: "outer", ownerKey: focus.key, order: 0 },
      { text: innerAnchor(focus), type: "inner", ownerKey: focus.key, order: 2 }
    ];
    if (!addGroup(core.concat(focusAnchors))) {
      const compactAnchors = [
        { text: compactOperationOuterAnchor(focus), type: "outer", ownerKey: focus.key, order: 0 },
        { text: compactOperationInnerAnchor(focus), type: "inner", ownerKey: focus.key, order: 2 }
      ].filter(component => component.text);
      const compactCore = core.concat(compactAnchors);
      const compactFit = operationCandidateReady
        ? composition(compactCore, tail, settings.MAX_OPERATION_TURN_TOKENS)
        : { ok: false };
      if (!compactFit.ok) {
        return {
          ok: false,
          reason: "Core rules plus the focused NPC's complete Outer and Inner could not fit safely.",
          effectiveBudget
        };
      }
      components.push(...compactCore);
      compactOperationCoreUsed = true;
      CC.last.modelOmitted.push(focus.name + " compact Outer/Inner reserved for the operation turn");
    }
    modelActive.push(focus);

    active.filter(character => character.key !== focus.key).forEach(character => {
      const pair = [
        { text: outerAnchor(character), type: "outer", ownerKey: character.key, order: 0 },
        { text: innerAnchor(character), type: "inner", ownerKey: character.key, order: 2 }
      ];
      if (addGroup(pair)) modelActive.push(character);
      else CC.last.modelOmitted.push(character.name + " Outer/Inner pair");
    });

    const playerNamesIdentity = nameIdentityForKey("player");
    if (playerNamesIdentity) addNamesProjection(playerNamesIdentity, focus.key, 3, "player");
    const focusNamesIdentity = nameIdentityForKey("npc:" + focus.key);
    if (focusNamesIdentity) addNamesProjection(focusNamesIdentity, focus.key, 3, "focus:" + focus.key);

    const focusState = temporaryStateLine(focus);
    if (focusState && !addGroup([{ text: focusState, type: "state", ownerKey: focus.key, order: 3 }])) {
      CC.last.modelOmitted.push(focus.name + " current State");
    }

    const frozenEvidenceIds = plan.retry && Array.isArray(plan.retryEvidenceIds) && plan.retryEvidenceIds.length
      ? plan.retryEvidenceIds
      : (plan.opportunityCounted && Array.isArray(plan.evidenceIds) ? plan.evidenceIds : []);
    const frozenEvidenceEligibility = plan.retry && plan.retryEvidenceEligibility
      ? plan.retryEvidenceEligibility
      : (plan.opportunityCounted && plan.evidenceEligibility ? plan.evidenceEligibility : null);
    const frozenOpportunity = plan.opportunityCounted && Number.isFinite(Number(plan.ownerOpportunity))
      ? Math.max(0, Number(plan.ownerOpportunity) - 1)
      : null;
    const allEvidence = availableEvidence(
      focus,
      recent,
      plan.inputEvidenceId || "",
      frozenEvidenceIds,
      frozenOpportunity,
      frozenEvidenceEligibility
    );
    const focusRelationshipSelections = relevantRelationshipRecords(focus, modelActive, currentInput, recent);
    const selectedFocusRelationships = [];
    focusRelationshipSelections.forEach(selection => {
      if (selectedFocusRelationships.length >= 2) {
        omittedRelationships.push(focus.name + "→" + modelRelationshipTargetName(selection.record));
        return;
      }
      const next = selectedFocusRelationships.concat(selection);
      const block = renderRelevantRelationshipsBlock(focus, next);
      const priorIndex = components.findIndex(component => component.focusRelationships === true);
      const candidateComponents = components.slice();
      const component = {
        text: block,
        type: "relationships",
        ownerKey: focus.key,
        order: 4,
        focusRelationships: true
      };
      if (priorIndex >= 0) candidateComponents[priorIndex] = component;
      else candidateComponents.push(component);
      const fit = composition(candidateComponents, tail);
      if (fit.ok) {
        if (priorIndex >= 0) components[priorIndex] = component;
        else components.push(component);
        selectedFocusRelationships.push(selection);
        selectedRelationships.push(focus.name + "→" + modelRelationshipTargetName(selection.record));
      } else {
        omittedRelationships.push(focus.name + "→" + modelRelationshipTargetName(selection.record));
      }
    });
    const focusExperience = relevantExperienceRecords(focus, currentInput, recent, allEvidence)[0] || null;
    if (focusExperience) {
      const block = renderRelevantExperienceBlock(focus, focusExperience);
      if (addGroup([{ text: block, type: "experiences", ownerKey: focus.key, order: 6 }])) {
        selectedExperiences.push(focus.name + "→"
          + modelTargetName(focusExperience.record.targetKey, focusExperience.record.targetName));
      } else {
        omittedExperiences.push(focus.name + "→"
          + modelTargetName(focusExperience.record.targetKey, focusExperience.record.targetName));
      }
    }
    const focusActiveSelections = relevantViewRecords(focus, modelActive, currentInput, recent, allEvidence, false);
    const focusBuriedSelections = relevantViewRecords(focus, modelActive, currentInput, recent, allEvidence, true);
    const recoveredBlocks = relevantRecoveredBlocks(focus, focusActiveSelections, focusBuriedSelections);
    const selectedRecoveredTargets = new Set();
    let recoveredBlocked = false;
    recoveredBlocks.forEach(block => {
      if (!recoveredBlocked && addGroup([{ text: block.text, type: "views", ownerKey: focus.key, order: 5 }])) {
        selectedRecoveredTargets.add(block.targetKey);
        selectedViews.push(focus.name + " recovered " + block.targetKey);
      } else {
        recoveredBlocked = true;
        omittedViews.push(focus.name + " recovered " + block.targetKey);
      }
    });

    const normalFocusSelections = focusActiveSelections.filter(item => !recoveringMarker(focus.key, item.record.targetKey));
    const selectedFocusSelections = [];
    let focusViewsBlocked = false;
    normalFocusSelections.forEach(selection => {
      if (focusViewsBlocked) {
        omittedViews.push(focus.name + "→" + modelViewTargetName(selection.record));
        return;
      }
      const candidateSelections = selectedFocusSelections.concat(selection);
      const block = renderRelevantViewsBlock(focus, candidateSelections);
      const priorIndex = components.findIndex(component => component.focusViews === true);
      const candidateComponents = components.slice();
      const component = { text: block, type: "views", ownerKey: focus.key, order: 5, focusViews: true };
      if (priorIndex >= 0) candidateComponents[priorIndex] = component;
      else candidateComponents.push(component);
      const fit = composition(candidateComponents, tail);
      if (fit.ok) {
        if (priorIndex >= 0) components[priorIndex] = component;
        else components.push(component);
        selectedFocusSelections.push(selection);
        selectedViews.push(focus.name + "→" + modelViewTargetName(selection.record));
      } else {
        focusViewsBlocked = true;
        omittedViews.push(focus.name + "→" + modelViewTargetName(selection.record));
      }
    });

    const contextVisibleFocusSelections = selectedFocusSelections.concat(
      focusActiveSelections.filter(item => selectedRecoveredTargets.has(item.record.targetKey))
    );
    const contextVisibleKeys = new Set(contextVisibleFocusSelections.map(item => item.record.targetKey));
    const hiddenRelevantKeys = new Set(
      focusActiveSelections.map(item => item.record.targetKey).filter(key => !contextVisibleKeys.has(key))
    );
    const visibleRelationshipKeys = new Set(selectedFocusRelationships.map(item => item.record.targetKey));
    const hiddenRelationshipKeys = new Set(
      focusRelationshipSelections.map(item => item.record.targetKey).filter(key => !visibleRelationshipKeys.has(key))
    );
    let targets = operationTargetMap(
      focus,
      modelActive,
      contextVisibleFocusSelections,
      focusBuriedSelections,
      selectedFocusRelationships,
      currentInput,
      allEvidence,
      recent
    ).filter(target => !hiddenRelevantKeys.has(target.key))
      .filter(target => target.mode !== "recovering" || selectedRecoveredTargets.has(target.key))
      .map(target => hiddenRelationshipKeys.has(target.key) ? { ...target, relationship: false } : target);
    if (plan.retry && Array.isArray(plan.retryTargets) && plan.retryTargets.length) targets = clone(plan.retryTargets);
    else if (plan.opportunityCounted && Array.isArray(plan.targets) && plan.targets.length) targets = clone(plan.targets);
    const selectedOperationKind = MODEL_OPERATION_KINDS.includes(keyOf(plan.selectedOperationKind))
      ? keyOf(plan.selectedOperationKind)
      : "";
    targets = operationTargetsForKind(selectedOperationKind, targets);
    const selectedOperationTargetKey = normalizedTargetKey(
      plan.selectedCandidate && plan.selectedCandidate.targetKey
    );
    if (selectedOperationTargetKey) {
      if (selectedOperationKind === "name") {
        targets = targets.slice().sort((left, right) => {
          const leftSelected = normalizedTargetKey(left.key) === selectedOperationTargetKey ? 0 : 1;
          const rightSelected = normalizedTargetKey(right.key) === selectedOperationTargetKey ? 0 : 1;
          return leftSelected - rightSelected;
        });
      } else {
        targets = targets.filter(target => normalizedTargetKey(target.key) === selectedOperationTargetKey);
      }
    }
    const frozenDerivedPacket = plan.retry && Array.isArray(plan.retrySourcePacket)
      ? plan.retrySourcePacket
      : (plan.opportunityCounted && Array.isArray(plan.sourcePacket) ? plan.sourcePacket : null);
    const derivedRelationshipEvidence = selectedOperationKind === "relationship"
      ? relationshipDerivedEvidenceCandidates(focus, targets, frozenOpportunity, frozenDerivedPacket)
      : [];
    const derivedViewEvidence = selectedOperationKind === "view"
      ? viewDerivedEvidenceCandidates(focus, targets, frozenOpportunity, frozenDerivedPacket)
      : [];
    const operationSources = allEvidence.concat(derivedRelationshipEvidence, derivedViewEvidence);
    const frozenTaskEvidenceIds = plan.retry && Array.isArray(plan.retryEvidenceIds) && plan.retryEvidenceIds.length
      ? plan.retryEvidenceIds
      : (plan.opportunityCounted && Array.isArray(plan.evidenceIds) ? plan.evidenceIds : []);
    const operationEvidence = operationEvidenceCandidatesForKind(
      selectedOperationKind,
      operationSources,
      plan.selectedCandidate,
      frozenTaskEvidenceIds
    );

    const fitOperationByEvictingOptionalContext = proposedTail => {
      let working = components.slice();
      let fit = composition(working, proposedTail, settings.MAX_OPERATION_TURN_TOKENS);
      if (fit.ok) return fit;
      const groups = [];
      const grouped = new Set();
      const pushGroup = group => {
        const usable = group.filter(component => component && !grouped.has(component));
        if (!usable.length) return;
        usable.forEach(component => grouped.add(component));
        groups.push(usable);
      };
      modelActive.filter(character => character.key !== focus.key).slice().reverse().forEach(character => {
        pushGroup(working.filter(component => component.ownerKey === character.key
          && (component.type === "outer" || component.type === "inner")));
      });
      const namesComponents = working.filter(component => component.type === "names");
      const componentAliases = component => (textOf(component.text).match(/^Alias:\s*(.+)$/gmi) || [])
        .map(value => line(value.replace(/^Alias:\s*/i, ""), 160));
      const namesMentioned = component => {
        return componentAliases(component).some(alias => aliasMentioned(currentInput, alias));
      };
      namesComponents.filter(component => !namesMentioned(component)).forEach(component => pushGroup([component]));
      working.filter(component => component.ownerKey === focus.key && component.type === "state")
        .forEach(component => pushGroup([component]));
      working.filter(component => component.ownerKey === focus.key && component.type === "experiences")
        .forEach(component => pushGroup([component]));
      working.filter(component => component.type === "relationships" || component.type === "views")
        .forEach(component => pushGroup([component]));
      namesComponents.filter(namesMentioned).forEach(component => pushGroup([component]));
      working.filter(component => component.type !== "rules"
        && !(component.ownerKey === focus.key && ["outer", "inner"].includes(component.type)))
        .forEach(component => pushGroup([component]));

      const commitWorking = (next, compactFocus) => {
        const kept = new Set(next);
        const removed = components.filter(component => !kept.has(component));
        const removedProfileKeys = new Set(removed
          .filter(component => component.type === "outer" || component.type === "inner")
          .map(component => component.ownerKey));
        removedProfileKeys.forEach(ownerKey => {
          const character = modelActive.find(item => item.key === ownerKey);
          if (!character || character.key === focus.key) return;
          const index = modelActive.indexOf(character);
          if (index >= 0) modelActive.splice(index, 1);
          const label = character.name + " Outer/Inner pair (reserved operation packet)";
          if (!CC.last.modelOmitted.includes(label)) CC.last.modelOmitted.push(label);
        });
        removed.filter(component => component.type === "names").forEach(component => {
          const canonical = extractLine(component.text, "Canonical");
          componentAliases(component).forEach(alias => {
            const selected = selectedNames.find(label => label === canonical + "→" + alias);
            if (!selected) return;
            const index = selectedNames.indexOf(selected);
            if (index >= 0) selectedNames.splice(index, 1);
            if (!omittedNames.includes(selected)) omittedNames.push(selected);
          });
        });
        removed.filter(component => component.type === "state").forEach(component => {
          const character = characters.find(item => item.key === component.ownerKey);
          const label = (character ? character.name : component.ownerKey)
            + " current State (reserved operation packet)";
          if (!CC.last.modelOmitted.includes(label)) CC.last.modelOmitted.push(label);
        });
        const moveOwnerLabels = (type, selectedList, omittedList, suffix) => {
          const ownerKeys = new Set(removed.filter(component => component.type === type)
            .map(component => component.ownerKey));
          ownerKeys.forEach(ownerKey => {
            const character = characters.find(item => item.key === ownerKey);
            const name = character ? character.name : ownerKey;
            selectedList.slice().filter(label => label.startsWith(name + "→")
              || label.startsWith(name + " recovered ")).forEach(label => {
              const index = selectedList.indexOf(label);
              if (index >= 0) selectedList.splice(index, 1);
              if (!omittedList.includes(label)) omittedList.push(label);
            });
            const diagnostic = name + " " + suffix + " (reserved operation packet)";
            if (!CC.last.modelOmitted.includes(diagnostic)) CC.last.modelOmitted.push(diagnostic);
          });
        };
        moveOwnerLabels("relationships", selectedRelationships, omittedRelationships, "Relationship projection");
        moveOwnerLabels("views", selectedViews, omittedViews, "View projection");
        removed.filter(component => component.type === "experiences").forEach(component => {
          const character = characters.find(item => item.key === component.ownerKey);
          const prefix = (character ? character.name : component.ownerKey) + "→";
          selectedExperiences.filter(label => label.startsWith(prefix)).forEach(label => {
            const index = selectedExperiences.indexOf(label);
            if (index >= 0) selectedExperiences.splice(index, 1);
            if (!omittedExperiences.includes(label)) omittedExperiences.push(label);
          });
        });
        if (compactFocus) {
          if (!compactOperationCoreUsed) {
            const label = focus.name + " compact Outer/Inner used for the operation turn";
            if (!CC.last.modelOmitted.includes(label)) CC.last.modelOmitted.push(label);
          }
          compactOperationCoreUsed = true;
        }
        components.splice(0, components.length, ...next);
      };

      for (const group of groups) {
        const removable = new Set(group);
        working = working.filter(component => !removable.has(component));
        fit = composition(working, proposedTail, settings.MAX_OPERATION_TURN_TOKENS);
        if (!fit.ok) continue;
        commitWorking(working, false);
        return fit;
      }

      const compactPair = [
        { text: compactOperationOuterAnchor(focus), type: "outer", ownerKey: focus.key, order: 0 },
        { text: compactOperationInnerAnchor(focus), type: "inner", ownerKey: focus.key, order: 2 }
      ].filter(component => component.text);
      const compactWorking = working.filter(component => !(
        component.ownerKey === focus.key && ["outer", "inner"].includes(component.type)
      )).concat(compactPair);
      fit = composition(compactWorking, proposedTail, settings.MAX_OPERATION_TURN_TOKENS);
      if (fit.ok) {
        commitWorking(compactWorking, true);
        return fit;
      }
      return fit;
    };

    let selectedEvidence = [];
    let taskDelivered = false;
    let taskDeferredReason = "";
    const retryTaskText = plan.retry && textOf(plan.retryOperationTaskText).trim()
      ? textOf(plan.retryOperationTaskText)
      : "";
    const selectedSourceIds = operationPacketSourceIds(
      selectedOperationKind,
      plan.selectedCandidate,
      frozenTaskEvidenceIds
    );
    const requiredEvidence = operationEvidence.filter(candidate => selectedSourceIds.includes(candidate.item.id));
    const selectedTargetAvailable = !!(
      plan.selectedCandidate && targets.some(target =>
        normalizedTargetKey(target.key) === normalizedTargetKey(plan.selectedCandidate.targetKey)
      )
    );
    if (plan.opportunity && !CC.recoveryPending && selectedOperationKind && retryTaskText) {
      selectedEvidence = operationEvidence.slice();
      const retryWithinTaskBudget = estimateTokens(retryTaskText) <= settings.MAX_OPERATION_TASK_TOKENS;
      const fit = retryWithinTaskBudget
        ? fitOperationByEvictingOptionalContext(retryTaskText)
        : { ok: false, reason: "operation task budget" };
      if (fit.ok && selectedEvidence.length && targets.length) {
        tail = retryTaskText;
        taskDelivered = true;
        operationTurnLimitActive = true;
      } else taskDeferredReason = "The frozen operation-specific Retry packet did not fit safely.";
    } else if (plan.opportunity && !CC.recoveryPending && selectedOperationKind
      && operationEvidence.length && targets.length && selectedTargetAvailable
      && requiredEvidence.length === selectedSourceIds.length) {
      let proposedEvidence = requiredEvidence.length ? requiredEvidence : [operationEvidence[0]];
      let proposedTail = operationTaskForKind(
        selectedOperationKind, focus, targets, proposedEvidence, plan.inputEvidenceId || "", recent,
        plan.relationshipPace || runtime.relationshipPace, plan.selectedCandidate
      );
      while (estimateTokens(proposedTail) > settings.MAX_OPERATION_TASK_TOKENS
        && proposedEvidence.length > 1) {
        proposedEvidence = proposedEvidence.slice(0, -1);
        proposedTail = operationTaskForKind(
          selectedOperationKind, focus, targets, proposedEvidence, plan.inputEvidenceId || "", recent,
          plan.relationshipPace || runtime.relationshipPace, plan.selectedCandidate
        );
      }
      const taskWithinBudget = estimateTokens(proposedTail) <= settings.MAX_OPERATION_TASK_TOKENS;
      const fit = taskWithinBudget
        ? fitOperationByEvictingOptionalContext(proposedTail)
        : { ok: false, reason: "operation task budget" };
      if (fit.ok && taskWithinBudget) {
        selectedEvidence = proposedEvidence;
        tail = proposedTail;
        taskDelivered = true;
        operationTurnLimitActive = true;
      } else taskDeferredReason = "The complete operation-specific packet did not fit safely.";
    } else if (plan.opportunity && !CC.recoveryPending && !selectedOperationKind) {
      taskDeferredReason = "No operation had positive grounded gain.";
    } else if (plan.opportunity && !CC.recoveryPending && selectedOperationKind && !targets.length) {
      taskDeferredReason = "No legal target was available for the frozen operation kind.";
    } else if (plan.opportunity && !CC.recoveryPending && selectedOperationKind && !selectedTargetAvailable) {
      taskDeferredReason = "The frozen operation target was unavailable in the legal target map.";
    } else if (plan.opportunity && !CC.recoveryPending && selectedOperationKind
      && requiredEvidence.length !== selectedSourceIds.length) {
      taskDeferredReason = "The frozen operation evidence was unavailable or ineligible.";
    } else if (plan.opportunity && !CC.recoveryPending) {
      taskDeferredReason = "No eligible completed evidence was available for the frozen operation kind.";
    }

    modelActive.filter(character => character.key !== focus.key).forEach(character => {
      const stateBlock = temporaryStateLine(character);
      if (stateBlock && !addGroup([{ text: stateBlock, type: "state", ownerKey: character.key, order: 3 }])) {
        CC.last.modelOmitted.push(character.name + " current State");
      }
      const namesIdentity = nameIdentityForKey("npc:" + character.key);
      if (namesIdentity) addNamesProjection(namesIdentity, character.key, 2, "other:" + character.key);
      const evidence = availableEvidence(character, recent, plan.inputEvidenceId || "");
      const relationships = relevantRelationshipRecords(character, modelActive, currentInput, recent);
      if (relationships.length) {
        const selection = relationships[0];
        const block = renderRelevantRelationshipsBlock(character, [selection]);
        if (addGroup([{
          text: block,
          type: "relationships",
          ownerKey: character.key,
          order: 4,
          otherRelationshipsOwner: character.key
        }])) {
          selectedRelationships.push(character.name + "→" + modelRelationshipTargetName(selection.record));
        } else {
          omittedRelationships.push(character.name + "→" + modelRelationshipTargetName(selection.record));
        }
        relationships.slice(1).forEach(item => omittedRelationships.push(
          character.name + "→" + modelRelationshipTargetName(item.record)
        ));
      }
      const experience = relevantExperienceRecords(character, currentInput, recent, evidence)[0] || null;
      if (experience) {
        const block = renderRelevantExperienceBlock(character, experience);
        if (addGroup([{ text: block, type: "experiences", ownerKey: character.key, order: 6 }])) {
          selectedExperiences.push(character.name + "→"
            + modelTargetName(experience.record.targetKey, experience.record.targetName));
        } else {
          omittedExperiences.push(character.name + "→"
            + modelTargetName(experience.record.targetKey, experience.record.targetName));
        }
      }
      const activeSelections = relevantViewRecords(character, modelActive, currentInput, recent, evidence, false);
      const buriedSelections = relevantViewRecords(character, modelActive, currentInput, recent, evidence, true);
      relevantRecoveredBlocks(character, activeSelections, buriedSelections).forEach(block => {
        if (addGroup([{ text: block.text, type: "views", ownerKey: character.key, order: 5 }])) selectedViews.push(character.name + " recovered " + block.targetKey);
        else omittedViews.push(character.name + " recovered " + block.targetKey);
      });
      const normal = activeSelections.filter(item => !recoveringMarker(character.key, item.record.targetKey));
      const chosen = [];
      let otherViewsBlocked = false;
      normal.forEach(selection => {
        if (otherViewsBlocked) {
          omittedViews.push(character.name + "→" + modelViewTargetName(selection.record));
          return;
        }
        const next = chosen.concat(selection);
        const block = renderRelevantViewsBlock(character, next);
        const index = components.findIndex(component => component.otherViewsOwner === character.key);
        const candidate = components.slice();
        const component = { text: block, type: "views", ownerKey: character.key, order: 5, otherViewsOwner: character.key };
        if (index >= 0) candidate[index] = component;
        else candidate.push(component);
        const fit = composition(candidate, tail);
        if (fit.ok) {
          if (index >= 0) components[index] = component;
          else components.push(component);
          chosen.push(selection);
          selectedViews.push(character.name + "→" + modelViewTargetName(selection.record));
        } else {
          otherViewsBlocked = true;
          omittedViews.push(character.name + "→" + modelViewTargetName(selection.record));
        }
      });
    });

    omittedNames.forEach(item => {
      const label = item + " Name projection";
      if (!CC.last.modelOmitted.includes(label)) CC.last.modelOmitted.push(label);
    });
    omittedRelationships.forEach(item => {
      const label = item + " Relationship projection";
      if (!CC.last.modelOmitted.includes(label)) CC.last.modelOmitted.push(label);
    });

    if (compactOperationCoreUsed && !taskDelivered) {
      return {
        ok: false,
        reason: taskDeferredReason || "The compact operation packet was unavailable.",
        effectiveBudget
      };
    }

    const ownerOrder = new Map(modelActive.map((character, index) => [character.key, index]));
    const orderedComponents = components.map((component, index) => ({ ...component, insertionOrder: index }))
      .sort((left, right) => {
        if (left.type === "rules" || right.type === "rules") {
          return left.type === right.type ? left.insertionOrder - right.insertionOrder : (left.type === "rules" ? -1 : 1);
        }
        const leftOwner = ownerOrder.has(left.ownerKey) ? ownerOrder.get(left.ownerKey) : Number.MAX_SAFE_INTEGER;
        const rightOwner = ownerOrder.has(right.ownerKey) ? ownerOrder.get(right.ownerKey) : Number.MAX_SAFE_INTEGER;
        return leftOwner - rightOwner || (left.order ?? 99) - (right.order ?? 99)
          || left.insertionOrder - right.insertionOrder;
      });
    const final = composition(orderedComponents, tail);
    if (!final.ok) return { ok: false, reason: final.reason, effectiveBudget };
    const byType = type => estimateTokens(orderedComponents.filter(component => component.type === type)
      .map(component => component.text).join("\n"));
    return {
      ok: true,
      text: final.fitted.text,
      taskDelivered,
      taskDeferredReason,
      targets,
      evidenceCandidates: selectedEvidence,
      evidenceIds: selectedEvidence.map(candidate => candidate.item.id),
      modelActive,
      selectedNames,
      omittedNames,
      selectedRelationships,
      omittedRelationships,
      selectedViews,
      omittedViews,
      selectedExperiences,
      omittedExperiences,
      tokens: final.tokens,
      rulesTokens: byType("rules"),
      outerTokens: byType("outer"),
      namesTokens: byType("names"),
      innerTokens: byType("inner"),
      stateTokens: byType("state"),
      relationshipsTokens: byType("relationships"),
      viewsTokens: byType("views"),
      experiencesTokens: byType("experiences"),
      evidenceTokens: taskDelivered ? estimateTokens(evidencePacketForKind(
        focus, selectedOperationKind, selectedEvidence, plan.inputEvidenceId || "", recent, targets[0] || null
      )) : 0,
      taskTokens: estimateTokens(tail),
      taskText: taskDelivered ? tail : "",
      taskKind: taskDelivered ? selectedOperationKind : "",
      operationEvidenceSignature: taskDelivered && plan.selectedCandidate
        ? operationEvidenceSignature(plan.selectedCandidate, selectedEvidence.map(candidate => candidate.item))
        : "",
      effectiveBudget,
      headroom: Math.max(0, Math.min(
        effectiveBudget,
        taskDelivered ? settings.MAX_OPERATION_TURN_TOKENS : configuredBudget
      ) - final.tokens),
      recentChars: final.fitted.recentChars
    };
  }

  function operationInstructionEchoLine(value) {
    const source = textOf(value).replace(/\r/g, "").trim();
    if (!source) return false;
    const normalized = source
      .replace(/[“”]/g, '"')
      .replace(/[‘’‛]/g, "'")
      .replace(/[‐‑‒–—―]/g, "-")
      .replace(/[ \t]+/g, " ");
    return [
      /^<\/?SYSTEM>$/i,
      /^[.\-:]*\s*(?:State\s*:\s*(?:copy\s+)?\(CCO\|S\||\(CCO\|S\|AboutCode\|)/i,
      /^[.\-:]*\s*Copy AboutCode and evidence IDs from (?:the )?(?:supplied )?packets\b/i,
      /^[.\-:]*\s*(?:Use|Copy)\s+1\s*-\s*3\s+(?:of|triggers?|trigger codes?)(?:\s+from)?\s*:/i,
      /^[.\-:]*\s*Situation(?:\s+(?:is|names)|\s*:)\s+.*\b(?:owner|current event|event phrase)\b/i,
      /^[.\-:]*\s*Thought(?:\s+is|\s*:)\s+.*\bfirst-person inner speech\b/i,
      /^[.\-:]*\s*(?:Use|Copy)\s+(?:a\s+)?distinct later confirmation\b/i,
      /^[.\-:]*\s*Three (?:distinct|matching) (?:Situation\+About )?confirmations\b/i,
      /^Name\s*:\s*\(CCO\|N\|/i,
      /^Build every operation and Explanation entirely from\b/i,
      /^Relationship\s*:\s*(?:begin exactly with\s*)?\(CCO\|R\|/i,
      /^Relationships are directional and belong to\b/i,
      /^View\s*:\s*\(CCO\|V\|/i,
      /^For a continuity change, copy one complete record format exactly\b/i,
      /^One (?:Name|State|directional Relationship|View) continuity operation is available for fixed owner\b/i,
      /^(?:State|Name|View) operation for fixed owner\b/i,
      /^Directional Relationship operation:\s*fixed owner\b/i,
      /^Formats?:\s*(?:accumulated\s*)?\(CCO\|[SNRV]\|/i,
      /^Build every record fact and Explanation from cited source IDs\.?$/i,
      /^When continuity changes, put one exact supplied \(CCO\|\.\.\.\) record\b/i,
      /^Create the direction when evidence establishes\b/i,
      /^R# Relationship movement and X# Experience patterns permit review\b/i,
      /\balone authors the Player's inner life, choices, consent, commitments, memories, boundaries, names, and relationships\.?$/i,
      /^(?:State|Name|Relationship|View) operation\s*-\s*owner\b/i,
      /^(?:Evidence|EvidenceIDs|Target|Subject|Use codes):(?:\s|$)/i,
      /^[ESRX]\d+\[[^\]]+\]:\s*/i,
      /^Record:\s*\(CCO\|[SNRV]\|/i,
      /^Use the supplied (?:AboutCode|SubjectCode|TargetCode|E#|S#|R#|X#)/i,
      /^Choose 1-3 triggers:/i,
      /^Transitions:\s*Observed,/i,
      /^Each Observed record captures one distinct use\b/i,
      /^Identity-owner evidence supports lifecycle transitions\b/i,
      /^Destinations:\s*/i,
      /^(?:Role|Trust|Closeness|Boundaries|Conflict) expresses\b/i,
      /^View expresses durable judgement\b/i,
      /^Ground every record field and Explanation in the supplied evidence\.?$/i,
      /^For a continuity change, place one exact CCO record first\b/i,
      /^The Player authors the Player's inner life, choices, consent, commitments, memories, boundaries, names, and relationships\.?$/i,
      /^Priority:\s*completed direct Name or Relationship fact\b/i,
      /^For a prose-only response, begin with prose\b/i,
      /^Copy the supplied S, P, or N code into each code field\b/i,
      /^Cite exactly the evidence IDs whose facts appear\b/i,
      /^Follow the record with complete normal story prose\b/i,
      /^Keep \|, \(, and \) for protocol structure\b/i
    ].some(pattern => pattern.test(normalized));
  }

  function stripOperationInstructionEchoes(value, plan) {
    const source = textOf(value).replace(/\r/g, "");
    if (!plan || plan.task !== "operation" || !plan.taskDelivered) {
      return { text: source, count: 0, sample: "" };
    }
    const removed = [];
    const kept = [];
    source.split("\n").forEach(rawLine => {
      if (operationInstructionEchoLine(rawLine)) removed.push(line(rawLine, 220));
      else kept.push(rawLine);
    });
    return {
      text: kept.join("\n").replace(/\n{3,}/g, "\n\n").trim(),
      count: removed.length,
      sample: removed[0] || ""
    };
  }

  function authorizedOperationKindFromCode(code) {
    return { N: "name", S: "state", R: "relationship", V: "view" }[textOf(code).toUpperCase()] || "";
  }

  function authorizedOperationCodeFromKind(kind) {
    return { name: "N", state: "S", relationship: "R", view: "V" }[keyOf(kind)] || "";
  }

  function frozenSelectedOperationTarget(plan) {
    const selectedKey = normalizedTargetKey(plan && plan.selectedCandidate && plan.selectedCandidate.targetKey);
    if (!selectedKey) return null;
    return (Array.isArray(plan && plan.targets) ? plan.targets : []).find(target =>
      normalizedTargetKey(target && target.key) === selectedKey
    ) || null;
  }

  function frozenTargetDisplayNames(owner, target) {
    if (!target) return [];
    const names = [target.name];
    if (target.key === "self") names.push("Self", owner && owner.name);
    else if (target.key === "player") names.push(player.name);
    else if (target.key && target.key.startsWith("npc:")) {
      const character = characters.find(item => "npc:" + item.key === target.key);
      if (character) names.push(character.name);
    }
    return uniqueNameForms(names, 160);
  }

  function canonicalizeFrozenOperationRouting(parts, plan) {
    const result = Array.isArray(parts) ? parts.slice() : [];
    const changed = [];
    let ownerNameInTarget = false;
    let expandedOwnerTargetRouting = "";
    let duplicatedTargetRouting = "";
    const frozenKindCode = authorizedOperationCodeFromKind(plan && plan.selectedOperationKind);
    const owner = characters.find(character => character.key === (plan && plan.ownerKey)) || null;
    if (frozenKindCode && owner
      && textOf(result[1]).trim().toUpperCase() !== frozenKindCode
      && sameNameForm(result[1], owner.name)) {
      result[1] = frozenKindCode;
      changed.push("owner");
    }
    const target = frozenSelectedOperationTarget(plan);
    const expectedFieldCount = { S: 7, N: 8, R: 8, V: 7 }[frozenKindCode] || 0;
    const targetDisplayNames = frozenTargetDisplayNames(owner, target);
    if (target && target.code && owner && expectedFieldCount
      && result.length === expectedFieldCount
      && !authorizedOperationKindFromCode(textOf(result[1]).trim())
      && sameNameForm(result[1], result[2])
      && targetDisplayNames.some(name => sameNameForm(result[1], name))) {
      result[1] = frozenKindCode;
      result[2] = target.code;
      duplicatedTargetRouting = frozenKindCode + "|" + target.code;
    }
    if (target && target.code && owner && expectedFieldCount
      && result.length === expectedFieldCount + 1
      && textOf(result[1]).trim().toUpperCase() === frozenKindCode
      && sameNameForm(result[2], owner.name)
      && (textOf(result[3]).trim().toUpperCase() === textOf(target.code).toUpperCase()
        || frozenTargetDisplayNames(owner, target).some(name => sameNameForm(result[3], name)))) {
      result.splice(2, 1);
      expandedOwnerTargetRouting = frozenKindCode + "|" + target.code;
    }
    if (target && target.code
      && textOf(result[2]).trim().toUpperCase() !== textOf(target.code).toUpperCase()) {
      if (frozenTargetDisplayNames(owner, target).some(name => sameNameForm(result[2], name))) {
        result[2] = target.code;
        changed.push("target");
      } else if (target.key !== "self" && owner && sameNameForm(result[2], owner.name)) {
        result[2] = target.code;
        ownerNameInTarget = true;
      }
    }
    return {
      parts: result,
      changed,
      ownerNameInTarget,
      expandedOwnerTargetRouting,
      duplicatedTargetRouting
    };
  }

  function parsedCcoReason(label, routing) {
    const fields = routing && Array.isArray(routing.changed) ? routing.changed : [];
    const canonicalized = fields.length
      ? label + " Frozen " + fields.join(" and ") + " name" + (fields.length === 1 ? " was" : "s were")
        + " canonicalized to the authorized codes."
      : label;
    return canonicalized
      + (routing && routing.expandedOwnerTargetRouting
        ? " Expanded frozen owner-and-target routing was collapsed to "
          + routing.expandedOwnerTargetRouting + "."
        : "")
      + (routing && routing.duplicatedTargetRouting
        ? " The duplicated frozen target name in both routing fields was canonicalized to "
          + routing.duplicatedTargetRouting + "."
        : "")
      + (routing && routing.ownerNameInTarget
        ? " Frozen owner name in the target field was canonicalized to the authorized target code."
        : "");
  }

  function exactStateFieldValue(value, label) {
    const source = textOf(value).trim();
    const normalized = source.replace(new RegExp("^" + escapeRegExp(label) + "\\s*:\\s*", "i"), "").trim();
    return { value: normalized, changed: normalized !== source };
  }

  function parseTerminalCandidate(output, plan) {
    const source = stripOperationInstructionEchoes(output, plan).text;
    const ccoMarkers = source.match(/\(\s*CCO\b/gi) || [];
    const shorthandMarkers = source.match(/\(\s*[SNRV]\s*\|/gi) || [];
    const protocolLikeCount = ccoMarkers.length + shorthandMarkers.length;
    const stripLine = value => {
      let result = value.replace(/\(\s*(?:CCO\b|[SNRV]\s*\|)[^()\r\n]*\)/gi, "");
      const leftover = result.search(/\(\s*(?:CCO\b|[SNRV]\s*\|)/i);
      if (leftover >= 0) result = result.slice(0, leftover);
      return result.replace(/[ \t]{2,}/g, " ").trimEnd();
    };
    const story = source.split("\n").map(stripLine).join("\n").replace(/\n{3,}/g, "\n\n").trim();
    if (!protocolLikeCount) {
      return { story, candidate: null, malformed: false, hadProtocol: false, reason: "No CCO record", raw: "" };
    }
    if (shorthandMarkers.length) {
      return {
        story, candidate: null, malformed: true, hadProtocol: true,
        reason: "A shorthand protocol-like record was stripped; a complete record begins with the literal (CCO|.",
        raw: line((source.split("\n")[0] || "").trim(), 300)
      };
    }
    if (ccoMarkers.length !== 1) {
      return {
        story, candidate: null, malformed: true, hadProtocol: true,
        reason: "Exactly one CCO record was allowed, but " + ccoMarkers.length + " were found.", raw: "multiple CCO records"
      };
    }
    const firstLineEnd = source.indexOf("\n");
    const firstLine = (firstLineEnd >= 0 ? source.slice(0, firstLineEnd) : source);
    const raw = firstLine.trim();
    if (firstLine !== raw || !/^\(CCO\|[^()\r\n]*\)$/.test(raw)) {
      return {
        story, candidate: null, malformed: true, hadProtocol: true,
        reason: "The CCO record was not the exact first line or had malformed delimiters.", raw: line(raw, 300)
      };
    }
    if (!plan || !plan.taskDelivered || plan.task !== "operation" || !MODEL_OPERATION_KINDS.includes(keyOf(plan.selectedOperationKind))) {
      return {
        story, candidate: null, malformed: false, unauthorized: true, hadProtocol: true,
        reason: "A CCO record appeared when no operation kind was authorized.", raw: line(raw, 300)
      };
    }
    const rawParts = raw.slice(1, -1).split("|");
    if (rawParts[0] !== "CCO") {
      return { story, candidate: null, malformed: true, hadProtocol: true, reason: "The protocol name was not exactly CCO.", raw: line(raw, 300) };
    }
    const routing = canonicalizeFrozenOperationRouting(rawParts, plan);
    const parts = routing.parts;
    const kind = textOf(parts[1]).toUpperCase();
    const parsedOperationKind = authorizedOperationKindFromCode(kind);
    if (parsedOperationKind && parsedOperationKind !== keyOf(plan.selectedOperationKind)) {
      return {
        story, candidate: null, malformed: false, unauthorized: true, hadProtocol: true,
        reason: "Unauthorized CCO kind " + kind + " was stripped; the frozen operation kind was "
          + operationKindLabel(plan.selectedOperationKind) + ".", raw: line(raw, 300)
      };
    }
    const evidenceIds = unique(textOf(parts[3]).split(",").map(value => value.trim().toUpperCase()), 20);
    const authorizedKind = keyOf(plan.selectedOperationKind);
    if (!evidenceIds.length || evidenceIds.some(id => !continuitySourceId(id))) {
      return { story, candidate: null, malformed: true, hadProtocol: true, reason: "The CCO record cited no valid source IDs.", raw: line(raw, 300) };
    }
    if (evidenceIds.some(id => !sourceIdLegalForOperation(authorizedKind, id))) {
      return {
        story, candidate: null, malformed: false, unauthorized: true, hadProtocol: true,
        reason: "The CCO record cited a source prefix not legal for the frozen "
          + operationKindLabel(authorizedKind) + " operation.", raw: line(raw, 300)
      };
    }
    if (kind === "S") {
      if (parts.length !== 7) {
        return { story, candidate: null, malformed: true, hadProtocol: true, reason: "The State CCO record did not contain exactly seven fields.", raw: line(raw, 300) };
      }
      const targetCode = textOf(parts[2]).trim().toUpperCase();
      const triggerField = exactStateFieldValue(parts[4], "TriggerList");
      const situationField = exactStateFieldValue(parts[5], "Situation");
      const thoughtField = exactStateFieldValue(parts[6], "Thought");
      const suppliedTriggers = triggerField.value.split(",").map(value => value.trim()).filter(Boolean);
      const triggers = triggerList(suppliedTriggers);
      const situationSource = situationField.value;
      const completeSituation = wholeLine(
        situationSource,
        settings.MAX_STATE_VALUE_CHARS
      );
      const situation = situationPhrase(completeSituation);
      const thoughtSource = thoughtField.value;
      const thought = line(thoughtSource, settings.MAX_STATE_VALUE_CHARS);
      if (!targetCode || !triggers.length || triggers.length !== suppliedTriggers.length) {
        return { story, candidate: null, malformed: true, hadProtocol: true, reason: "The State CCO record used an invalid target or trigger code.", raw: line(raw, 300) };
      }
      if (!completeSituation || !situation || /[{}|\r\n]/.test(situationSource)) {
        return { story, candidate: null, malformed: true, hadProtocol: true, reason: "The State Situation was empty, exceeded its complete-field limit, or used reserved characters.", raw: line(raw, 300) };
      }
      if (!thought || thought !== thoughtSource) {
        return { story, candidate: null, malformed: true, hadProtocol: true, reason: "The State Thought was empty or exceeded its complete-field limit.", raw: line(raw, 300) };
      }
      const stateLabelNormalized = triggerField.changed || situationField.changed || thoughtField.changed;
      const stateReason = parsedCcoReason("CCO State record parsed.", routing)
        + (stateLabelNormalized
          ? " Exact position-matched State field labels were normalized to bare values."
          : "");
      return {
        story, malformed: false, hadProtocol: true, reason: stateReason, raw: line(raw, 300),
        candidate: { kind: "state", targetCode, evidenceIds, triggers, situation, thought }
      };
    }
    if (kind === "N") {
      if (parts.length !== 8) {
        return { story, candidate: null, malformed: true, hadProtocol: true, reason: "The Name CCO record did not contain exactly eight fields.", raw: line(raw, 300) };
      }
      const subjectCode = textOf(parts[2]).trim().toUpperCase();
      const aliasSource = wholeLine(parts[4], 0);
      const alias = line(aliasSource, 160);
      const transitionSource = textOf(parts[5]).trim();
      const replacement = transitionSource.match(/^Replace=(.+)$/i);
      const transition = replacement
        ? "Replace"
        : ["Observed", "Adopted", "Retired", "Rejected", "Reactivated"]
          .find(item => nameKeyOf(item) === nameKeyOf(transitionSource));
      const replacedAliasSource = replacement ? wholeLine(replacement[1], 0) : "";
      const replacedAlias = line(replacedAliasSource, 160);
      const useField = wholeLine(parts[6], 0);
      const explanation = wholeLine(parts[7], 0);
      if (!subjectCode || !alias || alias !== aliasSource || replacedAlias !== replacedAliasSource
        || !transition || !useField || !explanation
        || /[{}\[\]|()\r\n]/.test(alias + useField + explanation + replacedAlias)) {
        return { story, candidate: null, malformed: true, hadProtocol: true, reason: "The Name CCO record used an invalid subject, alias, transition, permission, explanation, or reserved character.", raw: line(raw, 300) };
      }
      return {
        story, malformed: false, hadProtocol: true, reason: parsedCcoReason("CCO Name record parsed.", routing), raw: line(raw, 300),
        candidate: { kind: "name", subjectCode, evidenceIds, alias, transition, replacedAlias, useField, explanation }
      };
    }
    if (kind === "R") {
      if (parts.length !== 8) {
        return { story, candidate: null, malformed: true, hadProtocol: true, reason: "The Relationship CCO record did not contain exactly eight fields.", raw: line(raw, 300) };
      }
      const targetCode = textOf(parts[2]).trim().toUpperCase();
      const field = RELATIONSHIP_FIELDS.find(item => keyOf(item) === keyOf(parts[4]));
      const eventKind = textOf(parts[5]).trim().toUpperCase();
      const destinationSource = textOf(parts[6]).trim();
      const destination = field ? relationshipDestination(field, destinationSource) : null;
      const explanation = wholeLine(parts[7], 0);
      if (!targetCode || !field || !["A", "D"].includes(eventKind) || !destination) {
        return { story, candidate: null, malformed: true, hadProtocol: true, reason: "The Relationship CCO record used an invalid target, field, A/D flag, or destination.", raw: line(raw, 300) };
      }
      if (!explanation || /[{}\[\]|()\r\n]/.test(explanation)) {
        return { story, candidate: null, malformed: true, hadProtocol: true, reason: "The Relationship explanation was empty or used reserved record characters.", raw: line(raw, 300) };
      }
      return {
        story, malformed: false, hadProtocol: true, reason: parsedCcoReason("CCO Relationship record parsed.", routing), raw: line(raw, 300),
        candidate: {
          kind: "relationship", targetCode, evidenceIds, field, eventKind,
          destination: destination.label, explanation
        }
      };
    }
    if (kind === "V") {
      if (parts.length !== 7) {
        return { story, candidate: null, malformed: true, hadProtocol: true, reason: "The View CCO record did not contain exactly seven fields.", raw: line(raw, 300) };
      }
      const targetField = textOf(parts[2]).trim();
      const destinationSource = textOf(parts[4]).trim();
      const destination = VIEW_CATEGORIES.find(category => keyOf(category) === keyOf(destinationSource))
        || (["buried", "recovered"].includes(keyOf(destinationSource))
          ? keyOf(destinationSource).replace(/^./, value => value.toUpperCase())
          : "");
      const severity = textOf(parts[5]).trim().toUpperCase();
      const explanation = wholeLine(parts[6], 0);
      if (!targetField || !destination || !["O", "M"].includes(severity)) {
        return { story, candidate: null, malformed: true, hadProtocol: true, reason: "The View CCO record used an invalid target, destination, or O/M flag.", raw: line(raw, 300) };
      }
      if (!explanation || /[{}|\r\n]/.test(explanation)) {
        return { story, candidate: null, malformed: true, hadProtocol: true, reason: "The View explanation was empty or used reserved wrapper characters.", raw: line(raw, 300) };
      }
      return {
        story, malformed: false, hadProtocol: true, reason: parsedCcoReason("CCO View record parsed.", routing), raw: line(raw, 300),
        candidate: { kind: "view", targetField, evidenceIds, destination, severity, explanation }
      };
    }
    return { story, candidate: null, malformed: true, hadProtocol: true, reason: "The CCO operation kind was not S, N, R, or V.", raw: line(raw, 300) };
  }

  function targetForCode(plan, code) {
    return (plan.targets || []).find(target => target.code === code) || null;
  }

  function directPrivateThought(value, owner) {
    const thought = line(value, settings.MAX_STATE_VALUE_CHARS);
    if (!thought) return false;
    const ownerNames = uniqueNameForms([owner && owner.name].concat((owner && owner.aliases) || []), 120)
      .map(name => line(name, 120))
      .filter(Boolean);
    if (ownerNames.length) {
      const ownerPattern = ownerNames.map(escapeRegExp).join("|");
      const narratedState = "(?:thinks?|feels?|worries?|hopes?|wants?|fears?|believes?|wonders?|remembers?|realizes?|seems?|appears?|is\\s+(?:feeling|thinking|worried|afraid|anxious|hopeful|angry|sad|uncertain))";
      if (new RegExp("^(?:" + ownerPattern + ")\\s+" + narratedState + "\\b", "i").test(thought)) return false;
      if (new RegExp("^(?:" + ownerPattern + ")['’]s\\s+(?:thought|feeling|goal|tension)\\b", "i").test(thought)) return false;
    }
    if (/^(?:(?:the|this|that)\s+)?(?:npc|character|owner)\b/i.test(thought)) return false;
    return true;
  }

  function derivedStateFromTriggers(triggers) {
    const rules = triggers.map(code => TRIGGER_RULES[code]).filter(Boolean);
    const feelings = unique(rules.map(rule => rule.feeling).filter(Boolean), 60).slice(0, 2);
    const goals = unique(rules.map(rule => rule.goal).filter(Boolean), 96);
    const tensions = unique(rules.map(rule => rule.tension).filter(Boolean), 120);
    const positive = triggers.some(code => ["affection", "hope", "relief", "reconnect", "trust_gain", "closeness_gain", "boundary_respected", "repair"].includes(code));
    const negative = triggers.some(code => ["anger", "anxiety", "grief", "hurt", "uncertainty", "withdraw", "conflict", "trust_loss", "closeness_loss", "boundary_crossed", "betrayal"].includes(code));
    return {
      feeling: feelings.join(" and "),
      goal: goals[0] || "",
      tension: tensions[0] || (positive && negative ? "competing impulses remain unresolved" : "")
    };
  }

  function targetGroundingError(candidate, target, plan) {
    const thought = line(candidate && candidate.thought, settings.MAX_STATE_VALUE_CHARS);
    if (!thought || !target) return "";
    const profile = stateTargetPronounProfile(null, target);
    if (profile && profile.family) {
      const mentionedFamilies = STATE_PRONOUN_FAMILIES.filter(family =>
        family.forms.some(form => aliasMentioned(thought, form))
      );
      const expectedMentioned = mentionedFamilies.some(family => family.key === profile.family);
      const mismatched = mentionedFamilies.filter(family => family.key !== profile.family);
      const groupReference = [thought, line(candidate && candidate.situation, settings.MAX_STATE_VALUE_CHARS)]
        .filter(Boolean).join(" ");
      const groupCue = /\b(?:both|all|everyone|everybody|others|people|group|staff|team|crew|keepers|council|committee|audience|community|household|family|friends|guests|crowd|colleagues|classmates|parents|children|siblings|couple|pair|together|those two|the two of them)\b/i.test(groupReference);
      const targetNpcKey = target.key && target.key.startsWith("npc:") ? target.key.slice(4) : "";
      const otherNpcNamed = characters.some(character => character.key !== (plan && plan.ownerKey)
        && character.key !== targetNpcKey
        && characterMentioned(thought, character, false, CC.activeKeys));
      const playerNamedAsOther = target.key !== "player"
        && (aliasMentioned(thought, player.name) || /\byou\b/i.test(thought));
      if (!expectedMentioned && mismatched.length === 1 && !groupCue && !otherNpcNamed && !playerNamedAsOther) {
        return "State Thought used " + mismatched[0].label + " for the sole unambiguous About target "
          + target.name + ", whose configured pronouns are " + profile.display + ".";
      }
    }
    const firstPerson = /\b(?:I|me|my|mine|myself|we|us|our|ours|ourselves)\b/i.test(thought);
    if (firstPerson) return "";
    const explicitlyMentioned = (plan.targets || []).filter(item =>
      item.key !== "self" && item.name && aliasMentioned(thought, item.name)
    );
    if (explicitlyMentioned.length === 1 && explicitlyMentioned[0].key !== target.key) {
      return "State About conflicted with the only person explicitly named in Thought.";
    }
    const thirdPerson = /\b(?:he|him|his|himself|she|her|hers|herself|they|them|their|theirs|themself|themselves)\b/i.test(thought);
    if (target.key === "self" && thirdPerson) {
      return "Self About was rejected because the direct Thought concerned another person without any self-reference.";
    }
    return "";
  }

  function applyStateCandidate(owner, candidate, nextClock, plan, evidenceItems) {
    if (!owner || !candidate) return { ok: false, error: "State operation lacked its fixed owner or content." };
    const npc = CC.npcs[owner.key];
    if (!npc) return { ok: false, error: "State owner was not registered." };
    npc.state = normalizeState(npc.state, CC.stateClock);
    const target = targetForCode(plan, candidate.targetCode);
    if (!target) return { ok: false, error: "State used an About code that was not authorized for this owner." };
    const storedTarget = { ...target, name: storedTargetName(target.key, target.name) };
    const triggers = triggerList(candidate.triggers);
    if (!triggers.length) return { ok: false, error: "State contained no supported triggers." };
    const situation = situationPhrase(candidate.situation);
    if (!situation || /[{}|\r\n]/.test(situation)) {
      return { ok: false, error: "State contained no complete safe Situation phrase." };
    }
    const thought = line(candidate.thought, settings.MAX_STATE_VALUE_CHARS);
    const validThought = directPrivateThought(thought, owner);
    const groundingError = validThought ? targetGroundingError(candidate, target, plan) : "";
    if (groundingError) return { ok: false, error: groundingError };

    const citedIds = unique((Array.isArray(evidenceItems) ? evidenceItems : []).map(item => item && item.id), 20)
      .map(value => value.toUpperCase())
      .filter(value => /^E\d+$/.test(value));
    if (!citedIds.length) return { ok: false, error: "State Situation confirmation lacked completed evidence." };
    const priorSituation = npc.state.situation;
    const sameSituation = keyOf(priorSituation.value) === keyOf(situation)
      && normalizedTargetKey(priorSituation.targetKey) === normalizedTargetKey(target.key);
    const novelIds = citedIds.filter(id => !priorSituation.evidenceIds.includes(id));
    if (sameSituation && !novelIds.length) {
      return { ok: false, error: "The same Situation required distinct later evidence for another confirmation." };
    }
    const threshold = settings.SITUATION_EXPERIENCE_CONFIRMATIONS;
    const confirmations = sameSituation
      ? Math.min(threshold, priorSituation.confirmations + 1)
      : 1;
    const situationEvidenceIds = sameSituation
      ? unique(priorSituation.evidenceIds.concat(citedIds), 20)
      : citedIds;
    const signature = experienceSignature(owner.key, target.key, situation);
    let promotedSignature = sameSituation ? priorSituation.promotedSignature : "";
    const shouldPromote = confirmations >= threshold && promotedSignature !== signature;

    const priorStateSnapshot = clone(npc.state);
    const priorProvenance = clone(CC.provenance);
    const priorProvenanceCreated = CC.last.provenanceCreated;
    const priorExperienceCards = captureManagedExperienceCards();
    const rollback = error => {
      npc.state = normalizeState(priorStateSnapshot, CC.stateClock);
      CC.provenance = normalizeProvenanceLedger(priorProvenance);
      CC.last.provenanceCreated = priorProvenanceCreated;
      restoreManagedExperienceCards(priorExperienceCards);
      writeStateCard(owner);
      CC.last.provenanceDiagnostics = unique((CC.last.provenanceDiagnostics || []).concat(
        "State provenance transaction rolled back: " + error
      ), 500).slice(-20);
      return { ok: false, error };
    };

    let promotion = null;

    const derived = derivedStateFromTriggers(triggers);
    const changed = [];
    [["feeling", derived.feeling], ["goal", derived.goal], ["tension", derived.tension]].forEach(([field, value]) => {
      if (npc.state[field].value !== value) changed.push(field);
      npc.state[field] = { value, updatedClock: nextClock };
    });
    if (validThought) {
      if (npc.state.thought.value !== thought) changed.push("thought");
      npc.state.thought = { value: thought, updatedClock: nextClock };
    }
    if (npc.state.target.key !== target.key) changed.push("about");
    if (npc.state.triggers.value.join(",") !== triggers.join(",")) changed.push("triggers");
    if (!sameSituation) changed.push("situation");
    npc.state.target = { key: target.key, name: storedTarget.name, updatedClock: nextClock };
    npc.state.triggers = { value: triggers, updatedClock: nextClock };
    npc.state.situation = {
      value: sameSituation ? priorSituation.value : situation,
      updatedClock: nextClock,
      confirmations,
      evidenceIds: situationEvidenceIds,
      targetKey: target.key,
      targetName: storedTarget.name,
      promotedSignature
    };

    if (!writeStateCard(owner)) {
      return rollback("The managed State card could not be saved and verified.");
    }

    const stateProvenance = appendProvenanceRecord({
      prefix: "S",
      ownerKey: owner.key,
      targetKey: target.key,
      targetName: storedTarget.name,
      signature,
      managedSignature: stateSituationSignature(owner.key, target.key, situation),
      confirmation: confirmations,
      sourceIds: citedIds,
      storyEvidenceIds: citedIds,
      triggers,
      value: situation,
      thought: validThought ? thought : derived.feeling,
      explanation: validThought ? thought : derived.feeling,
      createdClock: nextClock,
      ownerOpportunity: plan && plan.ownerOpportunity || CC.ownerOpportunities[owner.key] || 0,
      active: true
    });
    if (!stateProvenance.ok) {
      return rollback("State changed but S# provenance could not commit: " + stateProvenance.error);
    }

    if (shouldPromote) {
      promotion = promoteExperienceWithProvenance(owner, storedTarget, situation, plan);
      if (!promotion.ok) {
        return rollback("Situation reached " + threshold + "/" + threshold
          + " but its Experience provenance transaction could not commit: " + promotion.error);
      }
      promotedSignature = signature;
      npc.state.situation.promotedSignature = promotedSignature;
      if (!writeStateCard(owner)) {
        return rollback("Experience and X# committed but the promoted State marker could not be saved and verified.");
      }
    }

    const stateChange = unique(changed, 30).join(",") || "refreshed";
    const confirmationSummary = "Situation " + confirmations + "/" + threshold
      + (promotion ? (promotion.deduplicated ? " deduplicated in Experiences" : " promoted to Experiences") : "")
      + "; provenance " + stateProvenance.record.id
      + (promotion && promotion.provenanceRecord ? ", " + promotion.provenanceRecord.id : "");
    return {
      ok: true,
      summary: owner.name + "/State " + stateChange + "; " + confirmationSummary,
      provenanceIds: [stateProvenance.record.id]
        .concat(promotion && promotion.provenanceRecord ? promotion.provenanceRecord.id : []),
      warning: validThought ? "" : "Applied trigger-derived State but ignored a missing or externally narrated Thought."
    };
  }

  function viewOperationModeForCandidate(candidate, target) {
    const destination = canonicalViewDestination(candidate && candidate.destination);
    if (destination === "Buried") return "Buried";
    if (destination === "Recovered") return "Recovered";
    if (target && target.mode === "recovering") return "Reconciled";
    return canonicalViewOperationMode(candidate && candidate.severity);
  }

  function viewInterpretationKeyForCandidate(candidate, target) {
    const destination = canonicalViewDestination(candidate && candidate.destination);
    const operationMode = viewOperationModeForCandidate(candidate, target);
    const targetMode = line(target && target.mode, 40);
    return destination && operationMode
      ? [destination, operationMode, targetMode || ""].join("|")
      : "";
  }

  function rawViewEvidenceSupportsCandidate(owner, target, candidate, item) {
    if (!owner || !target || !candidate || !item || !/^E\d+$/.test(textOf(item.id))) {
      return { ok: false, error: "View validation lacked a completed raw E# source." };
    }
    const source = textOf(item.text);
    if (!operationOwnerMentioned(owner, source) || !operationTargetMentioned(owner, target, source)) {
      return { ok: false, error: item.id + " did not clearly ground the fixed View owner and target." };
    }
    const destination = canonicalViewDestination(candidate.destination);
    if (VIEW_CATEGORIES.includes(destination)) {
      const explicit = explicitViewSignal(owner, target, {
        item,
        viewEligible: true
      });
      if (explicit && explicit.destination === destination) return { ok: true };
      if (destination === "Neutrals") {
        const neutralThirdPerson = ownerTargetSentenceMatches(
          owner,
          target,
          source,
          "\\b(?:is|was|became|remained|felt|feels)\\s+(?:emotionally\\s+)?(?:neutral|indifferent|unmoved)\\b|\\b(?:has|had)\\s+no\\s+(?:strong\\s+)?opinion\\b"
        );
        const targetObjects = operationTargetAliases(owner, target);
        const neutralFirstPerson = targetObjects.some(alias => {
          const wanted = operationAliasRegExp(alias);
          return !!wanted && ownerSpeechAttributed(owner, source, new RegExp(
            "\\bi\\s+(?:feel\\s+)?(?:neutral|indifferent|nothing)\\s+(?:about|toward|towards|for)\\s+" + wanted + "\\b",
            "i"
          ));
        });
        if (neutralThirdPerson || neutralFirstPerson) return { ok: true };
      }
      return {
        ok: false,
        error: item.id + " did not explicitly establish the proposed " + destination + " durable judgement."
      };
    }
    if (destination === "Buried") {
      const forgotten = ownerTargetSentenceMatches(
        owner,
        target,
        source,
        "\\b(?:forgot|forgets|forgotten|no longer remembers?|memory (?:of|about).{0,40}(?:faded|is gone|was gone)|ceased to remember)\\b"
      );
      if (forgotten) return { ok: true };
      return { ok: false, error: item.id + " did not establish completed forgetting for View burial." };
    }
    if (destination === "Recovered") {
      const remembered = ownerTargetSentenceMatches(
        owner,
        target,
        source,
        "\\b(?:remembered|remembers|recalled|recalls|recognized|recognizes|memory returned|memories returned)\\b"
      );
      if (remembered) return { ok: true };
      return { ok: false, error: item.id + " did not establish completed remembering for View recovery." };
    }
    return { ok: false, error: item.id + " did not support a recognized View destination." };
  }

  function citedEvidenceForOperation(owner, candidate, plan, targetKey) {
    const operationKind = keyOf(candidate && candidate.kind);
    const normalizedTarget = normalizedTargetKey(targetKey);
    const suppliedPacket = Array.isArray(plan.sourcePacket) ? plan.sourcePacket : [];
    const suppliedById = {};
    suppliedPacket.forEach(source => {
      const id = continuitySourceId(source && source.id);
      if (id) suppliedById[id] = source;
    });
    const items = [];
    const relationshipTarget = operationKind === "relationship"
      ? targetForCode(plan, candidate && candidate.targetCode)
      : null;
    const viewResolution = operationKind === "view"
      ? resolveViewTarget(owner, candidate, plan)
      : null;
    const viewTarget = viewResolution && viewResolution.ok ? viewResolution.target : null;
    if (operationKind === "relationship" && (!relationshipTarget || relationshipTarget.relationship !== true
      || relationshipTarget.key === "self" || relationshipTarget.key !== normalizedTarget)) {
      return { ok: false, error: "Relationship citations did not resolve to the exact frozen directional target." };
    }
    if (operationKind === "view" && (!viewResolution || !viewResolution.ok || !viewTarget
      || normalizedTargetKey(viewTarget.key) !== normalizedTarget)) {
      return { ok: false, error: "View citations did not resolve to the exact frozen owner-target state." };
    }
    if (operationKind === "relationship" && candidate.eventKind === "D"
      && (candidate.evidenceIds || []).some(value => /^[SX]\d+$/i.test(textOf(value).trim()))) {
      return { ok: false, error: "Direct Relationship movement may cite completed raw E# evidence only; S# and X# authorise A only." };
    }
    if (operationKind === "relationship" && candidate.eventKind === "A"
      && (candidate.evidenceIds || []).some(value => /^E\d+$/i.test(textOf(value).trim()))) {
      return { ok: false, error: "Accumulated Relationship movement may cite accepted S# and X# evidence only; raw E# evidence authorises D only." };
    }
    refreshProvenanceActivity();
    for (const rawId of candidate.evidenceIds || []) {
      const id = continuitySourceId(rawId);
      if (!id || !sourceIdLegalForOperation(operationKind, id)) {
        return { ok: false, error: textOf(rawId) + " was not a legal source for the frozen "
          + operationKindLabel(operationKind) + " operation." };
      }
      const frozenSource = suppliedById[id];
      if (!frozenSource) return { ok: false, error: id + " was not supplied in the frozen operation source packet." };
      const eligibility = plan.evidenceEligibility && plan.evidenceEligibility[id];
      if (operationKind === "state" && (!eligibility || eligibility.state !== true || frozenSource.state !== true)) {
        return { ok: false, error: id + " was not supplied as State-eligible evidence." };
      }
      if (operationKind === "view" && (!eligibility || eligibility.view !== true || frozenSource.view !== true)) {
        return { ok: false, error: id + " was not supplied as View-eligible evidence." };
      }
      if (operationKind === "relationship" && (!eligibility || eligibility.relationship !== true || frozenSource.relationship !== true)) {
        return { ok: false, error: id + " was not supplied as Relationship-eligible evidence." };
      }
      if (operationKind === "name" && (!eligibility || eligibility.name !== true || frozenSource.name !== true)) {
        return { ok: false, error: id + " was not supplied as Name-eligible evidence." };
      }

      if (id.charAt(0) === "E") {
        const item = evidenceForId(id);
        if (!item) return { ok: false, error: id + " was no longer present in the evidence ledger." };
        if (operationKind === "state" && item.usedStateBy[owner.key]) {
          return { ok: false, error: id + " was already consumed for this owner's State." };
        }
        if (operationKind === "view") {
          const ownerUses = item.usedViewsBy[owner.key];
          if (ownerUses && ownerUses[normalizedTarget]) {
            return { ok: false, error: id + " was already consumed for this owner-target View." };
          }
          const directView = rawViewEvidenceSupportsCandidate(owner, viewTarget, candidate, item);
          if (!directView.ok) return directView;
        }
        if (operationKind === "relationship") {
          const ownerUses = item.usedRelationshipsBy[owner.key];
          if (ownerUses && ownerUses[normalizedTarget]) {
            return { ok: false, error: id + " was already consumed for this owner-target Relationship." };
          }
          if (candidate.eventKind !== "D") {
            return { ok: false, error: id + " was raw evidence and may authorise direct Relationship movement only." };
          }
          const direct = directRelationshipEvidenceSupportsCandidate(owner, relationshipTarget, candidate, item);
          if (!direct.ok) return direct;
        }
        if (operationKind === "name") {
          const subjectUses = item.usedNamesBy[normalizedTarget];
          if (subjectUses && subjectUses[nameKeyOf(candidate.alias)]) {
            return { ok: false, error: id + " was already consumed for this identity-alias Name record." };
          }
        }
        items.push(item);
        continue;
      }

      if (operationKind === "relationship" && /^[SX]\d+$/.test(id)) {
        if (candidate.eventKind !== "A") {
          return { ok: false, error: id + " is derived continuity and may authorise accumulated Relationship movement only." };
        }
        const record = provenanceRecordById(id);
        if (!record || !["state", "experience"].includes(record.kind)) {
          return { ok: false, error: id + " did not resolve to an accepted State or Experience provenance record." };
        }
        if (frozenSource.source !== "provenance" || frozenSource.prefix !== id.charAt(0)) {
          return { ok: false, error: id + " did not match its frozen derived-source type." };
        }
        if (record.ownerKey !== owner.key || line(frozenSource.ownerKey, 160) !== owner.key) {
          return { ok: false, error: id + " belonged to a different Relationship owner." };
        }
        if (record.targetKey !== normalizedTarget || normalizedTargetKey(frozenSource.targetKey) !== normalizedTarget) {
          return { ok: false, error: id + " belonged to a different Relationship target." };
        }
        if (record.active === false || !managedSignatureStillValid(record)
          || record.managedSignature !== frozenSource.managedSignature) {
          return { ok: false, error: id + " was inactive or its managed continuity signature had become stale." };
        }
        if (Math.max(0, Number(frozenSource.age) || 0) >= settings.RELATIONSHIP_EVIDENCE_OPPORTUNITIES) {
          return { ok: false, error: id + " had aged outside the frozen Relationship evidence window." };
        }
        const allowedFields = (Array.isArray(frozenSource.allowedFields) ? frozenSource.allowedFields : [])
          .map(canonicalRelationshipFieldName).filter(Boolean);
        if (!allowedFields.includes(candidate.field)) {
          return { ok: false, error: id + " did not authorise the proposed " + candidate.field + " field." };
        }
        const recomputedFields = relationshipGroundedFieldsForRecord(record);
        if (!recomputedFields.includes(candidate.field)) {
          return { ok: false, error: id + " no longer grounded the proposed " + candidate.field + " field." };
        }
        const recomputedUse = relationshipUseSignatureForRecord(record, owner.key, normalizedTarget, candidate.field);
        const frozenUse = frozenSource.useSignatures && frozenSource.useSignatures[candidate.field];
        if (!recomputedUse || !frozenUse || recomputedUse !== frozenUse) {
          return { ok: false, error: id + " did not match the frozen narrow Relationship-use signature." };
        }
        if (provenanceUseCommitted(record, recomputedUse)) {
          return { ok: false, error: id + " had already succeeded for this exact Relationship field interpretation." };
        }
        const currentLineage = storyLineageForSources(record.sourceIds.concat(record.storyEvidenceIds || []));
        const frozenLineage = provenanceSourceIds(frozenSource.rawLineage || []).filter(value => /^E\d+$/.test(value));
        if (JSON.stringify(currentLineage) !== JSON.stringify(frozenLineage)) {
          return { ok: false, error: id + " no longer matched its frozen raw story lineage." };
        }
        items.push({
          id,
          number: 1000000 + Math.max(0, Number(record.createdClock) || 0) * 1000
            + Math.max(0, Number(id.slice(1)) || 0),
          source: "provenance",
          text: line(frozenSource.text, settings.MAX_EVIDENCE_ITEM_CHARS),
          ownerKey: record.ownerKey,
          targetKey: record.targetKey,
          targetName: record.targetName,
          allowedFields,
          managedSignature: record.managedSignature,
          rawLineage: currentLineage,
          useSignature: recomputedUse,
          provenanceRecord: record,
          directAllowed: false
        });
        continue;
      }

      if (operationKind === "view" && /^[RX]\d+$/.test(id)) {
        const record = provenanceRecordById(id);
        if (!record || !["relationship", "experience"].includes(record.kind)) {
          return { ok: false, error: id + " did not resolve to an accepted Relationship or Experience provenance record." };
        }
        if (frozenSource.source !== "provenance" || frozenSource.prefix !== id.charAt(0)) {
          return { ok: false, error: id + " did not match its frozen derived View-source type." };
        }
        if (record.ownerKey !== owner.key || line(frozenSource.ownerKey, 160) !== owner.key) {
          return { ok: false, error: id + " belonged to a different View owner." };
        }
        if (record.targetKey !== normalizedTarget || normalizedTargetKey(frozenSource.targetKey) !== normalizedTarget) {
          return { ok: false, error: id + " belonged to a different View target." };
        }
        if (record.active === false || !managedSignatureStillValid(record)
          || record.managedSignature !== frozenSource.managedSignature) {
          return { ok: false, error: id + " was inactive or its managed continuity signature had become stale." };
        }
        if (Math.max(0, Number(frozenSource.age) || 0) >= settings.VIEW_EVIDENCE_OPPORTUNITIES) {
          return { ok: false, error: id + " had aged outside the frozen View evidence window." };
        }
        const destination = canonicalViewDestination(candidate.destination);
        const operationMode = viewOperationModeForCandidate(candidate, viewTarget);
        const interpretationKey = viewInterpretationKeyForCandidate(candidate, viewTarget);
        if (!destination || !operationMode || !interpretationKey) {
          return { ok: false, error: id + " could not resolve the proposed View destination and operation mode." };
        }
        const frozenInterpretations = Array.isArray(frozenSource.interpretations)
          ? frozenSource.interpretations.map(item => ({
            destination: canonicalViewDestination(item && item.destination),
            operationMode: canonicalViewOperationMode(item && item.operationMode),
            targetMode: line(item && item.targetMode, 40)
          }))
          : [];
        if (!frozenInterpretations.some(item => item.destination === destination
          && item.operationMode === operationMode && item.targetMode === line(viewTarget.mode, 40))) {
          return { ok: false, error: id + " did not authorise this exact View destination and mode interpretation." };
        }
        const currentInterpretations = derivedViewInterpretationsForRecord(record, owner, normalizedTarget, plan.targets || []);
        if (!currentInterpretations.some(item => item.destination === destination
          && item.operationMode === operationMode && item.targetMode === line(viewTarget.mode, 40))) {
          return { ok: false, error: id + " no longer had this View interpretation under the current active, buried, or recovering state." };
        }
        const recomputedUse = viewUseSignatureForRecord(record, owner.key, normalizedTarget, destination, operationMode);
        const frozenUse = frozenSource.useSignatures && frozenSource.useSignatures[interpretationKey];
        if (!recomputedUse || !frozenUse || recomputedUse !== frozenUse) {
          return { ok: false, error: id + " did not match the frozen narrow View-use signature." };
        }
        if (provenanceUseCommitted(record, recomputedUse)) {
          return { ok: false, error: id + " had already succeeded for this exact View destination and mode." };
        }
        const currentLineage = storyLineageForSources(record.sourceIds.concat(record.storyEvidenceIds || []));
        const frozenLineage = provenanceSourceIds(frozenSource.rawLineage || []).filter(value => /^E\d+$/.test(value));
        if (JSON.stringify(currentLineage) !== JSON.stringify(frozenLineage)) {
          return { ok: false, error: id + " no longer matched its frozen raw story lineage." };
        }
        const semanticSupport = derivedViewEvidenceSupportsCandidate(record, owner, viewTarget, candidate);
        if (!semanticSupport.ok) return semanticSupport;
        items.push({
          id,
          number: 2000000 + Math.max(0, Number(record.createdClock) || 0) * 1000
            + Math.max(0, Number(id.slice(1)) || 0),
          source: "provenance",
          text: line(frozenSource.text, settings.MAX_EVIDENCE_ITEM_CHARS),
          ownerKey: record.ownerKey,
          targetKey: record.targetKey,
          targetName: record.targetName,
          destination,
          operationMode,
          targetMode: line(viewTarget.mode, 40),
          managedSignature: record.managedSignature,
          rawLineage: currentLineage,
          useSignature: recomputedUse,
          provenanceRecord: record,
          directAllowed: false
        });
        continue;
      }

      return { ok: false, error: id + " was not a compatible derived source for this model-facing operation." };
    }
    return { ok: true, items };
  }

  function categoryDistance(left, right) {
    const leftIndex = VIEW_CATEGORY_INDEX[keyOf(left)];
    const rightIndex = VIEW_CATEGORY_INDEX[keyOf(right)];
    return Number.isInteger(leftIndex) && Number.isInteger(rightIndex)
      ? Math.abs(leftIndex - rightIndex)
      : Infinity;
  }

  function resolveViewTarget(owner, candidate, plan) {
    const field = textOf(candidate.targetField).trim();
    const fresh = field.match(/^NEW=(.+)$/i);
    if (fresh) {
      const suppliedName = line(fresh[1], 120);
      if (!suppliedName || /[{}|()\r\n]/.test(suppliedName)) {
        return { ok: false, error: "The NEW target name was empty or used reserved characters." };
      }
      const target = canonicalViewTarget(owner, suppliedName);
      if (!target) return { ok: false, error: "The NEW target could not be normalized." };
      refreshViewsStore(false);
      const ownerData = viewsForOwner(owner.key);
      const active = ownerData && ownerData.activeRecords.find(record => record.targetKey === target.key);
      if (active) return { ok: false, error: "The NEW target already had an active View record." };
      const storedActive = ownerData && ownerData.activePages.flatMap(page => page.records)
        .find(record => record.targetKey === target.key);
      const storedBuried = ownerData && ownerData.buriedPages.flatMap(page => page.records)
        .find(record => record.targetKey === target.key);
      if (storedActive || storedBuried) {
        return {
          ok: false,
          error: "The NEW target already existed on a preserved but excluded Views page; repair that page before updating it."
        };
      }
      const knownTarget = (plan.targets || []).find(item => item.key === target.key && item.mode !== "buried");
      if (knownTarget) return { ok: false, error: "The NEW target already had the authorized code " + knownTarget.code + "." };
      return { ok: true, target: { key: target.key, name: target.name, mode: "new", code: "NEW" }, fresh: true };
    }
    const code = field.toUpperCase();
    const target = targetForCode(plan, code);
    return target
      ? { ok: true, target, fresh: false }
      : { ok: false, error: "The View target code was not present in the frozen owner-specific target map." };
  }

  function newTargetGrounded(target, evidenceItems) {
    if (!target || !target.name) return false;
    return evidenceItems.some(item => aliasMentioned(item.text, target.name));
  }

  function relationshipTargetGrounded(target, evidenceItems) {
    if (!target) return false;
    const items = Array.isArray(evidenceItems) ? evidenceItems : [];
    if (items.some(item => item && item.source === "provenance"
      && normalizedTargetKey(item.targetKey) === normalizedTargetKey(target.key))) return true;
    if (target.key === "player") {
      return items.some(item => item.source === "input" || item.source === "opening"
        || ["Player", "the player", "you", player.name].concat(player.aliases || [])
          .some(alias => aliasMentioned(item.text, alias)));
    }
    const character = target.key.startsWith("npc:")
      ? characters.find(item => "npc:" + item.key === target.key)
      : null;
    const identity = character ? nameIdentityForKey("npc:" + character.key) : null;
    return !!(identity && items.some(item => identityMentioned(item.text, identity, true, CC.activeKeys)));
  }

  const RELATIONSHIP_GROUNDING_STOP_WORDS = new Set([
    "a", "an", "and", "are", "as", "at", "be", "because", "been", "being", "by", "for", "from",
    "has", "have", "he", "her", "hers", "him", "his", "i", "in", "into", "is", "it", "its", "me",
    "my", "of", "on", "or", "our", "she", "that", "the", "their", "them", "they", "this", "to", "us",
    "was", "we", "were", "with", "you", "your", "actual", "completed", "event", "evidence", "fact",
    "relationship", "stage", "change",
    "establish", "establishes", "established", "recognize", "recognizes", "recognized", "respond", "responds"
  ]);

  function relationshipGroundingStem(value) {
    let token = textOf(value).toLowerCase().normalize("NFKD").replace(/[\u0300-\u036f]/g, "");
    if (token.length > 6 && token.endsWith("ies")) token = token.slice(0, -3) + "y";
    else if (token.length > 7 && token.endsWith("ing")) token = token.slice(0, -3);
    else if (token.length > 6 && token.endsWith("ance")) token = token.slice(0, -4);
    else if (token.length > 6 && token.endsWith("ence")) token = token.slice(0, -4);
    else if (token.length > 6 && token.endsWith("ment")) token = token.slice(0, -4);
    else if (token.length > 6 && token.endsWith("tion")) token = token.slice(0, -4);
    else if (token.length > 5 && token.endsWith("ed")) token = token.slice(0, -2);
    else if (token.length > 5 && token.endsWith("es")) token = token.slice(0, -2);
    else if (token.length > 4 && token.endsWith("s")) token = token.slice(0, -1);
    return token;
  }

  function relationshipGroundingTerms(value, excludedForms) {
    const excluded = new Set();
    (Array.isArray(excludedForms) ? excludedForms : []).forEach(form => {
      const parts = textOf(form).normalize("NFKC").match(/[\p{L}\p{N}]+/gu) || [];
      parts.forEach(part => excluded.add(relationshipGroundingStem(part)));
    });
    return unique((textOf(value).normalize("NFKC").match(/[\p{L}\p{N}]+/gu) || [])
      .map(relationshipGroundingStem)
      .filter(token => token.length >= 3 && !RELATIONSHIP_GROUNDING_STOP_WORDS.has(token) && !excluded.has(token)), 80);
  }

  function directRelationshipEvidenceSupportsCandidate(owner, target, candidate, item) {
    if (!owner || !target || !candidate || !item || !/^E\d+$/.test(textOf(item.id))) {
      return { ok: false, error: "Direct Relationship validation lacked a completed raw E# source." };
    }
    const source = textOf(item.text);
    if (!operationOwnerMentioned(owner, source) || !operationTargetMentioned(owner, target, source)) {
      return { ok: false, error: item.id + " did not clearly attribute the direct Relationship fact to the fixed NPC owner and target." };
    }
    const targetObjects = target.key === "player"
      ? ["you", player.name].concat(player.aliases || [])
      : operationTargetAliases(owner, target);
    const ownerSubjects = [owner.name].concat(owner.aliases || []);
    const firstPerson = pattern => targetObjects.some(targetAlias => {
      const wanted = operationAliasRegExp(targetAlias);
      return !!wanted && ownerSpeechAttributed(owner, source, new RegExp(pattern.replace("{TARGET}", wanted), "i"));
    });
    const attributedTrustQuestion = targetObjects.some(targetAlias => {
      const wanted = operationAliasRegExp(targetAlias);
      return !!wanted && ownerSpeechAttributed(owner, source, new RegExp(
        "\\b(?:can|could|should|would|do|may|might)\\s+i\\s+trust\\s+" + wanted + "\\b[^?]*\\?",
        "i"
      ));
    });
    let supported = false;
    if (candidate.field === "Trust" && candidate.destination === "Trust") {
      supported = (orderedOperationStatement(source, ownerSubjects, ["trusts?", "trusted"], targetObjects)
        || firstPerson("\\bi (?:really |fully |completely |deeply )?trust\\s+{TARGET}\\b"))
        && !attributedTrustQuestion;
    } else if (candidate.field === "Trust" && candidate.destination === "Distrust") {
      supported = orderedOperationStatement(source, ownerSubjects, ["distrusts?", "distrusted"], targetObjects)
        || firstPerson("\\bi (?:do not|don't|cannot|can't|never) trust\\s+{TARGET}\\b");
    } else if (candidate.field === "Trust" && candidate.destination === "Severe distrust") {
      supported = ownerTargetSentenceMatches(owner, target, source, "\\b(?:betrayed|betrayal)\\b");
    } else if (candidate.field === "Role" && candidate.destination === "Established") {
      supported = ownerTargetSentenceMatches(owner, target, source,
        "\\b(?:got married|are married|is married|became (?:friends|partners)|are (?:friends|partners)|accepted (?:the )?(?:job|position|employment)|was hired|were hired|is employed|are employed|agreed to (?:work|partner)|formed (?:a )?partnership)\\b");
    } else if (candidate.field === "Role" && candidate.destination === "Former") {
      supported = ownerTargetSentenceMatches(owner, target, source,
        "\\b(?:broke up|breakup|divorced|separated|ended (?:their|our|the) relationship|partnership ended|employment ended|was fired|were fired)\\b");
    } else if (candidate.field === "Boundaries" && candidate.destination === "Explicit") {
      supported = ownerTargetSentenceMatches(owner, target, source,
        "\\b(?:explicit boundary|set (?:a|the) boundary|my boundary is|do not touch me|don't touch me|without my permission|not allowed to|must ask permission|consent required)\\b");
    } else if (candidate.field === "Boundaries" && candidate.destination === "Reinforced") {
      supported = ownerTargetSentenceMatches(owner, target, source,
        "\\b(?:reinforced|enforced|reasserted|restated) (?:a|the|their|his|her)? ?boundar(?:y|ies)\\b");
    } else if (candidate.field === "Boundaries" && candidate.destination === "Released") {
      supported = ownerTargetSentenceMatches(owner, target, source,
        "\\b(?:released|lifted|withdrew|removed) (?:a|the|their|his|her)? ?boundar(?:y|ies)\\b");
    } else if (candidate.field === "Conflict" && candidate.destination === "Clear") {
      supported = ownerTargetSentenceMatches(owner, target, source,
        "\\b(?:resolved (?:the )?conflict|ended (?:the )?conflict|made peace|reconciled)\\b");
    } else if (candidate.field === "Conflict" && candidate.destination === "Open conflict") {
      supported = ownerTargetSentenceMatches(owner, target, source,
        "\\b(?:declared war|open conflict|became enemies|are enemies)\\b");
    } else if (candidate.field === "Conflict" && candidate.destination === "Rupture") {
      supported = ownerTargetSentenceMatches(owner, target, source,
        "\\b(?:severed ties|relationship ruptured|irreparable rupture|cut ties)\\b");
    }
    return supported
      ? { ok: true }
      : { ok: false, error: item.id + " did not directly establish the proposed " + candidate.field
        + " destination " + candidate.destination + "." };
  }

  function relationshipStageLabels() {
    return unique(RELATIONSHIP_FIELDS.flatMap(field => (RELATIONSHIP_STAGES[field] || []).map(stage => stage.label))
      .concat(["Former", "Released"]), 120).sort((left, right) => right.length - left.length);
  }

  function correctedRelationshipExplanation(value, actualStage) {
    let result = line(value, 2000);
    const actualKey = keyOf(actualStage);
    const stageLabels = relationshipStageLabels();
    const stageAlternation = stageLabels.map(escapeRegExp).join("|");
    const neutral = {
      "severe distrust": "distrust", "distrust": "distrust", "guarded": "trust",
      "unproven": "trust", "cautious trust": "trust", "trust": "trust", "deep trust": "trust",
      "disconnected": "connection", "distant": "connection", "acquainted": "connection",
      "familiar": "connection", "close": "connection", "deeply close": "closeness", "intimate": "connection",
      "implied": "boundary", "explicit": "boundary", "reinforced": "boundary", "released": "boundary",
      "clear": "conflict", "friction": "conflict", "strain": "conflict", "open conflict": "conflict", "rupture": "conflict",
      "emerging": "role", "established": "role", "former": "role"
    };
    if (stageAlternation) {
      const transitionClaim = new RegExp(
        "\\b(?:moving|moves?|moved|movement|advancing|advances?|advanced|advance|shifting|shifts?|shifted|shift|transitioning|transitions?|transitioned|transition|changing|changes?|changed|change)"
          + "[^.!?…\\n]{0,60}\\bfrom\\s+(?:the\\s+)?(" + stageAlternation + ")(?:\\s+stage)?"
          + "\\s+to\\s+(?:the\\s+)?(" + stageAlternation + ")(?:\\s+stage)?\\b",
        "gi"
      );
      result = result.replace(transitionClaim, (match, fromStage, toStage) =>
        keyOf(toStage) === actualKey
          ? match
          : "moving the relationship within the " + actualStage + " stage"
      );
    }
    stageLabels.forEach(labelValue => {
      if (keyOf(labelValue) === actualKey) return;
      const escaped = escapeRegExp(labelValue);
      const neutralWord = neutral[keyOf(labelValue)] || "the relationship";
      const levelClaim = new RegExp(
        "\\b(?:a|an|the)\\s+" + escaped
          + "\\s+(level|degree)\\s+of\\s+(trust|closeness|connection|distance|conflict|friction|boundaries|boundary|role|reliance|intimacy)\\b",
        "gi"
      );
      result = result.replace(levelClaim, (match, measure, dimension) =>
        "the " + actualStage + " " + measure + " of " + dimension
      );
      const labelledStage = new RegExp(
        "\\b((?:relationship|trust|closeness|boundary|boundaries|conflict|role)\\s+stage\\s+(?:is|was|became|reached|remains|at)?\\s*)"
          + escaped + "\\b",
        "gi"
      );
      result = result.replace(labelledStage, (match, prefix) => prefix + actualStage);
      const stageCue = "(?:reached|became|is|was|now|remains|moved\\s+to|advanced\\s+to|fell\\s+to|returned\\s+to|at|into|has|holds|shows|demonstrates|indicates?|marks|signals)";
      const contextualClaim = new RegExp(
        "(\\b" + stageCue + "\\s+(?:the\\s+)?)" + escaped + "(\\s+stage)?\\b",
        "gi"
      );
      result = result.replace(contextualClaim, (match, prefix, stageWord) =>
        prefix + (stageWord ? actualStage + stageWord : neutralWord)
      );
      result = result.replace(new RegExp("\\b" + escaped + "\\s+stage\\b", "gi"), actualStage + " stage");
    });
    result = result.replace(/\s{2,}/g, " ").replace(/\s+([,.;:!?])/g, "$1").trim();
    return line(result || ("The cited completed evidence changed the Relationship within the actual " + actualStage + " stage."), 2000);
  }

  function viewCategoryRegard(category) {
    return {
      Loves: "deeply positive regard",
      Likes: "positive regard",
      Neutrals: "neutral regard",
      Dislikes: "negative regard",
      Hates: "strongly negative regard"
    }[canonicalViewDestination(category)] || "durable regard";
  }

  function correctedViewExplanation(value, actualCategory) {
    let result = line(value, 2000);
    const regard = viewCategoryRegard(actualCategory);
    const stageLabels = relationshipStageLabels();
    const stageAlternation = stageLabels.map(escapeRegExp).join("|");
    if (stageAlternation) {
      const transitionClaim = new RegExp(
        "\\b(?:moving|moves?|moved|movement|advancing|advances?|advanced|advance|shifting|shifts?|shifted|shift|transitioning|transitions?|transitioned|transition|changing|changes?|changed|change)"
          + "[^.!?…\\n]{0,60}\\bfrom\\s+(?:the\\s+)?(" + stageAlternation + ")(?:\\s+stage)?"
          + "\\s+to\\s+(?:the\\s+)?(" + stageAlternation + ")(?:\\s+stage)?\\b",
        "gi"
      );
      result = result.replace(transitionClaim, "reinforcing " + regard);
    }
    stageLabels.forEach(labelValue => {
      const escaped = escapeRegExp(labelValue);
      const levelClaim = new RegExp(
        "\\b(?:a|an|the)\\s+" + escaped
          + "\\s+(?:level|degree)\\s+of\\s+(?:trust|closeness|connection|distance|conflict|friction|boundaries|boundary|role|reliance|intimacy)\\b",
        "gi"
      );
      result = result.replace(levelClaim, regard);
      const labelledStage = new RegExp(
        "\\b(?:relationship|trust|closeness|boundary|boundaries|conflict|role)\\s+(?:level|stage)"
          + "\\s+(?:is|was|became|reached|remains|at)?\\s*" + escaped + "\\b",
        "gi"
      );
      result = result.replace(labelledStage, regard);
      result = result.replace(
        new RegExp("\\b" + escaped + "\\s+(?:relationship\\s+)?stage\\b", "gi"),
        regard
      );
    });
    result = result.replace(/\s{2,}/g, " ").replace(/\s+([,.;:!?])/g, "$1").trim();
    return line(result || ("The cited evidence supports " + regard + "."), 2000);
  }

  function relationshipEvidenceSupportsCandidate(owner, target, candidate, evidenceItems) {
    const items = Array.isArray(evidenceItems) ? evidenceItems : [];
    const targetForms = target && target.key === "player"
      ? ["Player", "the player", "you", player.name].concat(player.aliases || [])
      : relationshipTargetAliases({ targetKey: target && target.key, targetName: target && target.name }, owner);
    const excludedForms = uniqueNameForms([owner && owner.name]
      .concat((owner && owner.aliases) || [], targetForms || [], [candidate.destination]), 160);
    const explanationTerms = relationshipGroundingTerms(candidate.explanation, excludedForms);
    if (!explanationTerms.length) {
      return { ok: false, error: "Relationship Explanation lacked a concrete evidence-grounded term after names and protocol labels were removed." };
    }
    if (candidate.eventKind === "D") {
      if (!relationshipGroundedFields([], candidate.explanation).includes(candidate.field)) {
        return { ok: false, error: "Direct Relationship Explanation did not describe the explicitly established "
          + candidate.field + " result." };
      }
      // Every raw source has already passed exact owner, target, field, and destination
      // validation. Do not reject a safe paraphrase merely because it uses a different
      // verb from the completed direct statement.
      return { ok: true };
    }
    for (const item of items) {
      if (item && item.source === "provenance") {
        if (normalizedTargetKey(item.targetKey) !== normalizedTargetKey(target && target.key)
          || !(item.allowedFields || []).includes(candidate.field)) {
          return { ok: false, error: (item.id || "Derived source")
            + " did not match the proposed Relationship target and field." };
        }
      } else if (!relationshipGroundedFields([], item && item.text).includes(candidate.field)) {
        return { ok: false, error: (item && item.id || "Cited evidence")
          + " did not ground the proposed " + candidate.field + " Relationship field." };
      }
      const evidenceTerms = new Set(relationshipGroundingTerms(item && item.text, excludedForms));
      if (!explanationTerms.some(term => evidenceTerms.has(term))) {
        return { ok: false, error: (item && item.id || "Cited evidence")
          + " did not support a concrete term used by the Relationship Explanation." };
      }
    }
    return { ok: true };
  }

  function relationshipStartingScore(field) {
    const startingLabels = {
      Role: "Emerging",
      Trust: "Guarded",
      Closeness: "Acquainted",
      Boundaries: "Implied",
      Conflict: "Clear"
    };
    const stage = (RELATIONSHIP_STAGES[field] || [])
      .find(item => keyOf(item.label) === keyOf(startingLabels[field]));
    return stage ? stage.midpoint : 0;
  }

  function mutualRoleDescription(value) {
    return /\b(?:friend(?:ship)?|employ(?:ee|er|ment)|partner(?:ship)?|romance|romantic|lover|dating|engaged|fianc(?:e|ee)|marriage|married|spouse|husband|wife)\b/i
      .test(textOf(value));
  }

  function nameSubjectForCandidate(owner, candidate, plan) {
    const target = targetForCode(plan, candidate.subjectCode);
    if (!target || target.nameSubject !== true) {
      return { ok: false, error: "Name used a Subject code not authorized for identity updates." };
    }
    const selectedTargetKey = normalizedTargetKey(plan && plan.selectedCandidate && plan.selectedCandidate.targetKey);
    if (selectedTargetKey && normalizedTargetKey(target.key) !== selectedTargetKey) {
      return { ok: false, error: "Name used a Subject code other than the frozen identity target." };
    }
    const identityKey = target.key === "self" ? "npc:" + owner.key : target.key;
    const identity = nameIdentityForKey(identityKey);
    return identity
      ? { ok: true, target, identity }
      : { ok: false, error: "Name Subject was not Player or a registered NPC identity." };
  }

  function resolveNameUseField(owner, value, plan) {
    const raw = line(value, 1000);
    const normalized = nameKeyOf(raw);
    if (normalized === "general") {
      return { ok: true, text: "General", permissions: [{ key: "general", name: "General" }] };
    }
    if (normalized === "none") {
      return { ok: true, text: "None", permissions: [{ key: "none", name: "None" }] };
    }
    const codes = raw.split(/\s*,\s*/).map(code => code.toUpperCase()).filter(Boolean);
    if (!codes.length) return { ok: false, error: "Name Use supplied no valid permission code." };
    const permissions = [];
    for (const code of codes) {
      const target = targetForCode(plan, code);
      if (!target || target.nameSubject !== true) {
        return { ok: false, error: "Name Use code " + code + " was outside the frozen identity target map." };
      }
      const identityKey = target.key === "self" ? "npc:" + owner.key : target.key;
      const identity = nameIdentityForKey(identityKey);
      if (!identity) return { ok: false, error: "Name Use code " + code + " did not resolve to Player or a registered NPC." };
      const permission = { key: identity.key, name: identity.player ? "Player" : identity.canonical };
      if (!permissions.some(existing => existing.key === permission.key)) permissions.push(permission);
    }
    return { ok: true, text: permissions.map(permission => permission.name).join(", "), permissions };
  }

  function formatNameProgress(progress) {
    const threshold = settings.NAME_ESTABLISHMENT_CONFIRMATIONS;
    return (Array.isArray(progress) ? progress : [])
      .filter(item => item && item.key !== "none" && item.count > 0 && item.count < threshold)
      .map(item => item.name + " " + item.count + "/" + threshold)
      .join("; ");
  }

  function permissionText(permissions) {
    const list = Array.isArray(permissions) ? permissions : [];
    if (list.some(permission => permission.key === "general")) return "General";
    if (!list.length || list.every(permission => permission.key === "none")) return "None";
    return list.filter(permission => permission.key !== "none")
      .map(permission => permission.name).join(", ");
  }

  function addPlannedNameRecord(identity, pages, record) {
    if (!record) return { ok: false, error: "The Alias record could not be formed safely." };
    let page = pages.find(item => item.movable && !item.remove);
    if (!page) page = createPlannedNamesPage(identity, pages);
    if (!plannedNamesPageFits(identity, page, page.items.concat(record))) {
      page = createPlannedNamesPage(identity, pages);
    }
    if (!plannedNamesPageFits(identity, page, page.items.concat(record))) {
      return { ok: false, error: "The complete Alias record could not fit an empty Names page." };
    }
    page.items.push(record);
    page.dirty = true;
    return { ok: true, page, record };
  }

  function setPlannedNameRecord(identity, found, status, use, progress, reason) {
    if (!found || !found.page.movable || !found.record.writable || Object.keys(found.record.fieldUnsafe).length) {
      return { ok: false, error: "The Alias record was structurally or field-level unsafe." };
    }
    found.record.values = {
      Status: status,
      Use: use,
      Progress: progress || "",
      Reason: line(reason, 2000)
    };
    if (!reparsePlannedNameRecord(identity, found.record)) {
      return { ok: false, error: "The updated Alias record could not be normalized safely." };
    }
    found.page.dirty = true;
    return { ok: true, record: found.record };
  }

  function nameEvidenceGrounded(owner, identity, alias, transition, replacedAlias, evidenceItems) {
    const items = Array.isArray(evidenceItems) ? evidenceItems : [];
    if (!items.length || !items.some(item => aliasMentioned(item.text, alias))) return false;
    if (transition === "Replace" && !items.some(item => aliasMentioned(item.text, replacedAlias))) return false;
    if (identity.player) return items.some(item => item.source === "input" || item.source === "opening");
    if (identity.character.key === owner.key) return true;
    return items.some(item => identityMentioned(item.text, identity, true, CC.activeKeys));
  }

  function applyNameCandidate(owner, candidate, plan, evidenceItems) {
    const subject = nameSubjectForCandidate(owner, candidate, plan);
    if (!subject.ok) return subject;
    const identity = subject.identity;
    if (!candidate.alias || sameNameForm(candidate.alias, identity.canonical)) {
      return { ok: false, error: "A Name operation cannot replace or duplicate the canonical name." };
    }
    if (identity.player && candidate.transition === "Observed") {
      return { ok: false, error: "Repeated NPC usage cannot establish a Player alias without Player-supplied acceptance." };
    }
    const use = resolveNameUseField(owner, candidate.useField, plan);
    if (!use.ok) return use;
    const isInactive = ["Retired", "Rejected"].includes(candidate.transition);
    if (isInactive && use.text !== "None") {
      return { ok: false, error: candidate.transition + " required Use=None." };
    }
    if (["Observed", "Adopted", "Reactivated", "Replace"].includes(candidate.transition) && use.text === "None") {
      return { ok: false, error: candidate.transition + " required General or named usage permission." };
    }
    if (!nameEvidenceGrounded(owner, identity, candidate.alias, candidate.transition, candidate.replacedAlias, evidenceItems)) {
      return { ok: false, error: "The exact Alias or its identity owner was not grounded in the cited completed evidence." };
    }

    return transactNames(identity, ({ pages }) => {
      const aliasResult = plannedNameAlias(pages, candidate.alias);
      if (!aliasResult.ok) return aliasResult;
      let found = aliasResult.found;
      const oldRecord = found ? copyNameItem(found.record) : null;
      const oldStatus = oldRecord ? oldRecord.status : "absent";
      const direct = candidate.transition !== "Observed";

      if (candidate.transition === "Observed") {
        if (found && ["Retired", "Rejected"].includes(found.record.status)) {
          return { ok: false, error: "A Retired or Rejected Alias requires explicit Reactivated evidence." };
        }
        if (!found) {
          const progress = use.permissions.filter(permission => permission.key !== "none")
            .map(permission => ({ ...permission, count: Math.min(
              settings.NAME_ESTABLISHMENT_CONFIRMATIONS,
              Math.max(1, evidenceItems.length)
            ) }));
          const completed = progress.filter(item => item.count >= settings.NAME_ESTABLISHMENT_CONFIRMATIONS);
          const activePermissions = completed.map(item => ({ key: item.key, name: item.name }));
          const pending = progress.filter(item => item.count < settings.NAME_ESTABLISHMENT_CONFIRMATIONS);
          const status = activePermissions.length ? "Active" : "Emerging";
          const record = baseNameRecord(
            identity,
            candidate.alias,
            status,
            permissionText(activePermissions),
            formatNameProgress(pending),
            candidate.explanation
          );
          const added = addPlannedNameRecord(identity, pages, record);
          if (!added.ok) return added;
          found = { page: added.page, record: added.record };
        } else {
          const existingPermissions = (found.record.use.permissions || []).filter(permission => permission.key !== "none");
          const existingProgress = (found.record.progress.progress || []).map(item => ({ ...item }));
          let changed = false;
          use.permissions.filter(permission => permission.key !== "none").forEach(permission => {
            if (existingPermissions.some(item => item.key === "general" || item.key === permission.key)) return;
            let progress = existingProgress.find(item => item.key === permission.key);
            if (!progress) {
              progress = { ...permission, count: 0 };
              existingProgress.push(progress);
            }
            progress.count = Math.min(settings.NAME_ESTABLISHMENT_CONFIRMATIONS, progress.count + Math.max(1, evidenceItems.length));
            changed = true;
            if (progress.count >= settings.NAME_ESTABLISHMENT_CONFIRMATIONS) {
              existingPermissions.push({ key: permission.key, name: permission.name });
            }
          });
          if (!changed) return { ok: false, unchanged: true, error: "" };
          const completedGeneral = existingPermissions.some(permission => permission.key === "general");
          const pending = completedGeneral ? [] : existingProgress.filter(progress =>
            progress.count < settings.NAME_ESTABLISHMENT_CONFIRMATIONS
              && !existingPermissions.some(permission => permission.key === progress.key)
          );
          const nextUse = permissionText(existingPermissions);
          const nextStatus = nextUse === "None" ? "Emerging" : "Active";
          const updated = setPlannedNameRecord(
            identity, found, nextStatus, nextUse, formatNameProgress(pending),
            nextStatus !== found.record.status ? candidate.explanation : found.record.reason
          );
          if (!updated.ok) return updated;
        }
      } else if (candidate.transition === "Retired") {
        if (!found) return { ok: false, error: "Retiring an Alias required an existing record." };
        const updated = setPlannedNameRecord(identity, found, "Retired", "None", "", candidate.explanation);
        if (!updated.ok) return updated;
      } else if (candidate.transition === "Rejected") {
        if (!found) {
          const record = baseNameRecord(identity, candidate.alias, "Rejected", "None", "", candidate.explanation);
          const added = addPlannedNameRecord(identity, pages, record);
          if (!added.ok) return added;
          found = { page: added.page, record: added.record };
        } else {
          const updated = setPlannedNameRecord(identity, found, "Rejected", "None", "", candidate.explanation);
          if (!updated.ok) return updated;
        }
      } else if (candidate.transition === "Adopted") {
        if (!found) {
          const record = baseNameRecord(identity, candidate.alias, "Active", use.text, "", candidate.explanation);
          const added = addPlannedNameRecord(identity, pages, record);
          if (!added.ok) return added;
          found = { page: added.page, record: added.record };
        } else {
          const updated = setPlannedNameRecord(identity, found, "Active", use.text, "", candidate.explanation);
          if (!updated.ok) return updated;
        }
      } else if (candidate.transition === "Reactivated") {
        if (!found || !["Retired", "Rejected"].includes(found.record.status)) {
          return { ok: false, error: "Reactivated required an existing Retired or Rejected Alias." };
        }
        const updated = setPlannedNameRecord(identity, found, "Active", use.text, "", candidate.explanation);
        if (!updated.ok) return updated;
      } else if (candidate.transition === "Replace") {
        if (!candidate.replacedAlias || sameNameForm(candidate.alias, candidate.replacedAlias)
          || sameNameForm(candidate.replacedAlias, identity.canonical)) {
          return { ok: false, error: "Replace required distinct noncanonical old and new Alias forms." };
        }
        const oldResult = plannedNameAlias(pages, candidate.replacedAlias);
        if (!oldResult.ok) return oldResult;
        if (!oldResult.found) return { ok: false, error: "Replace required the old Alias record to exist." };
        const retired = setPlannedNameRecord(
          identity,
          oldResult.found,
          "Retired",
          "None",
          "",
          "Replaced by " + candidate.alias + " — " + candidate.explanation
        );
        if (!retired.ok) return retired;
        if (!found) {
          const record = baseNameRecord(identity, candidate.alias, "Active", use.text, "", candidate.explanation);
          const added = addPlannedNameRecord(identity, pages, record);
          if (!added.ok) return added;
          found = { page: added.page, record: added.record };
        } else {
          const updated = setPlannedNameRecord(identity, found, "Active", use.text, "", candidate.explanation);
          if (!updated.ok) return updated;
        }
      }

      const nextRecord = found && found.record;
      if (!nextRecord) return { ok: false, error: "The Name transition produced no Alias record." };
      if (oldRecord && nameRecordSignature(oldRecord) === nameRecordSignature(nextRecord)
        && oldRecord.alias === nextRecord.alias && candidate.transition !== "Replace") {
        return { ok: false, unchanged: true, error: "" };
      }
      const detail = identity.canonical + " alias " + candidate.alias + " " + oldStatus + " → " + nextRecord.status
        + " (" + nameUseModelText(nextRecord) + "; " + (candidate.evidenceIds || []).join(",") + ")";
      return {
        ok: true,
        subjectKey: identity.key,
        aliasKey: nameKeyOf(candidate.alias),
        summary: detail,
        nameDetail: detail,
        direct
      };
    });
  }

  function baseRelationshipRecord(target) {
    const record = {
      kind: "record",
      targetKey: target.key,
      targetName: target.key === "player" ? "Player" : target.name,
      targetCorrected: false,
      values: RELATIONSHIP_FIELDS.reduce((result, field) => {
        result[field] = "";
        return result;
      }, {}),
      parsedFields: {},
      fieldUnsafe: {},
      page: 0,
      card: null,
      line: 0,
      duplicate: false,
      conflict: false,
      oversize: false,
      writable: true
    };
    return reparsePlannedRelationshipRecord(record);
  }

  function relationshipStoredValue(field, destination, score, description) {
    const safeDescription = line(description, 2000);
    if (field === "Role" && destination === "Former") {
      return "Former" + (safeDescription ? " — " + safeDescription : "");
    }
    const stage = relationshipStage(field, score);
    if (!stage) return "";
    return score + " (" + stage.label + ")" + (safeDescription ? " — " + safeDescription : "");
  }

  function relationshipScoreLabel(parsed) {
    if (!parsed || parsed.blank) return "blank";
    return parsed.special || textOf(parsed.score);
  }

  function applyRelationshipCandidate(owner, candidate, plan, evidenceItems) {
    if (!owner || !candidate) return { ok: false, error: "Relationship operation lacked its fixed owner or content." };
    const target = targetForCode(plan, candidate.targetCode);
    if (!target || target.relationship !== true) {
      return { ok: false, error: "Relationship used a target code not authorized for directional Relationships." };
    }
    const validTarget = target.key === "player"
      || (target.key.startsWith("npc:") && characters.some(character => "npc:" + character.key === target.key && character.key !== owner.key));
    if (!validTarget) return { ok: false, error: "Relationship target must be Player or another registered NPC, never Self." };
    if (!relationshipTargetGrounded(target, evidenceItems)) {
      return { ok: false, error: "The directional Relationship target was not grounded in its cited completed evidence." };
    }
    const evidenceSupport = relationshipEvidenceSupportsCandidate(owner, target, candidate, evidenceItems);
    if (!evidenceSupport.ok) return evidenceSupport;
    const relationshipItems = Array.isArray(evidenceItems) ? evidenceItems : [];
    const derivedItems = relationshipItems.filter(item => item && item.source === "provenance");
    const rawItems = relationshipItems.filter(item => item && item.source !== "provenance");
    if (derivedItems.length && candidate.eventKind !== "A") {
      return { ok: false, error: "Derived State and Experience sources authorise accumulated Relationship movement only." };
    }
    if (rawItems.length && candidate.eventKind !== "D") {
      return { ok: false, error: "Raw completed evidence authorises direct Relationship movement only." };
    }
    if (candidate.field === "Role" && candidate.destination === "Former" && candidate.eventKind !== "D") {
      return { ok: false, error: "Former Role requires a completed direct event." };
    }
    if (candidate.field === "Boundaries" && candidate.destination === "Released" && candidate.eventKind !== "D") {
      return { ok: false, error: "Released Boundaries require a completed direct event." };
    }
    if (candidate.field === "Role" && target.key === "player" && candidate.destination === "Established"
      && mutualRoleDescription(candidate.explanation)
      && !(Array.isArray(evidenceItems) && evidenceItems.some(item => item.source === "input" || item.source === "opening"))) {
      return { ok: false, error: "A mutual Player Role required completed Player-supplied establishment evidence." };
    }
    const destination = relationshipDestination(candidate.field, candidate.destination);
    if (!destination) return { ok: false, error: "Relationship destination did not belong to its field." };
    const pace = plan && plan.relationshipPace && typeof plan.relationshipPace === "object"
      ? plan.relationshipPace
      : runtime.relationshipPace;
    const magnitude = (candidate.eventKind === "D" ? pace.direct : pace.accumulated)
      * Math.max(1, (Array.isArray(evidenceItems) ? evidenceItems.length : 0));

    return transactRelationships(owner, ({ pages }) => {
      const targetResult = plannedRelationshipTarget(pages, target.key);
      if (!targetResult.ok) return targetResult;
      let found = targetResult.found;
      let record = found ? found.record : null;
      if (!record) {
        record = baseRelationshipRecord(target);
        let page = pages.find(item => item.movable && !item.remove);
        if (!page) page = createPlannedRelationshipsPage(owner, pages);
        page.items.push(record);
        page.dirty = true;
        found = { page, record };
      }
      const prior = record.parsedFields[candidate.field] || parseRelationshipField(candidate.field, record.values[candidate.field]);
      if (!prior.safe) {
        return { ok: false, error: candidate.field + " is unsafe and must be repaired before that field can update." };
      }

      const oldStage = prior.special || prior.stage || "blank";
      const oldScoreLabel = relationshipScoreLabel(prior);
      const priorStoredValue = canonicalRelationshipManagedValue(
        candidate.field,
        record.values[candidate.field]
      );
      let nextValue = "";
      let nextScore = null;
      let nextStage = "blank";
      let nextDescription = "";
      let descriptionChanged = false;
      let stageChanged = false;
      const directLifecycle = candidate.eventKind === "D"
        && (candidate.field === "Role" || candidate.field === "Boundaries");
      const directResolution = candidate.eventKind === "D"
        && candidate.field === "Conflict" && candidate.destination === "Clear";

      if (candidate.field === "Boundaries" && destination.special === "Released") {
        nextValue = "";
        nextStage = "Released";
        nextDescription = "";
        stageChanged = !prior.blank;
        descriptionChanged = !prior.blank;
      } else if (candidate.field === "Role" && destination.special === "Former") {
        nextStage = "Former";
        nextDescription = correctedRelationshipExplanation(candidate.explanation, nextStage);
        nextValue = relationshipStoredValue("Role", "Former", null, nextDescription);
        stageChanged = oldStage !== nextStage;
        descriptionChanged = keyOf(prior.description) !== keyOf(nextDescription);
      } else {
        const targetScore = destination.midpoint;
        if (prior.blank || prior.special) {
          if (directLifecycle || directResolution) {
            nextScore = targetScore;
          } else {
            const startingScore = relationshipStartingScore(candidate.field);
            const difference = targetScore - startingScore;
            if (difference !== 0 && magnitude <= 0) {
              if (!targetResult.found) removePlannedRelationshipItem(found.page, record);
              return { ok: false, unchanged: true, error: "" };
            }
            const movement = difference === 0
              ? 0
              : Math.min(Math.abs(difference), magnitude, Math.max(1, Number(pace.maxStages) || 1) * 10);
            nextScore = startingScore + Math.sign(difference) * movement;
            const range = relationshipRange(candidate.field);
            nextScore = Math.max(range.minimum, Math.min(range.maximum, nextScore));
          }
          const stage = relationshipStage(candidate.field, nextScore);
          if (!stage) return { ok: false, error: "The initialized Relationship score had no valid fixed stage." };
          nextStage = stage.label;
          nextDescription = correctedRelationshipExplanation(candidate.explanation, nextStage);
          nextValue = relationshipStoredValue(candidate.field, nextStage, nextScore, nextDescription);
          stageChanged = oldStage !== nextStage;
          descriptionChanged = true;
        } else if (directLifecycle || directResolution) {
          nextScore = targetScore;
          nextStage = destination.label;
          nextDescription = correctedRelationshipExplanation(candidate.explanation, nextStage);
          nextValue = relationshipStoredValue(candidate.field, destination.label, nextScore, nextDescription);
          stageChanged = oldStage !== nextStage;
          descriptionChanged = keyOf(prior.description) !== keyOf(nextDescription);
        } else {
          const difference = targetScore - prior.score;
          if (difference === 0 || magnitude <= 0) {
            if (!targetResult.found) removePlannedRelationshipItem(found.page, record);
            return { ok: false, unchanged: true, error: "" };
          }
          const movement = Math.min(Math.abs(difference), magnitude, Math.max(1, Number(pace.maxStages) || 1) * 10);
          nextScore = prior.score + Math.sign(difference) * movement;
          const range = relationshipRange(candidate.field);
          nextScore = Math.max(range.minimum, Math.min(range.maximum, nextScore));
          const stage = relationshipStage(candidate.field, nextScore);
          if (!stage) return { ok: false, error: "The computed Relationship score had no valid fixed stage." };
          nextStage = stage.label;
          stageChanged = keyOf(oldStage) !== keyOf(nextStage);
          nextDescription = stageChanged
            ? correctedRelationshipExplanation(candidate.explanation, nextStage)
            : prior.description;
          descriptionChanged = keyOf(prior.description) !== keyOf(nextDescription);
          nextValue = relationshipStoredValue(candidate.field, nextStage, nextScore, nextDescription);
        }
      }

      if (keyOf(record.values[candidate.field]) === keyOf(nextValue)) {
        if (!targetResult.found) removePlannedRelationshipItem(found.page, record);
        return { ok: false, unchanged: true, error: "" };
      }
      record.values[candidate.field] = nextValue;
      reparsePlannedRelationshipRecord(record);
      found.page.dirty = true;
      const recordRemoved = RELATIONSHIP_FIELDS.every(field => !textOf(record.values[field]).trim());
      if (recordRemoved) removePlannedRelationshipItem(found.page, record);
      const nextParsed = recordRemoved
        ? { blank: true }
        : record.parsedFields[candidate.field];
      const nextScoreLabel = recordRemoved
        ? "blank"
        : relationshipScoreLabel(nextParsed);
      const evidenceLabel = (candidate.evidenceIds || []).join(",");
      const stageLabel = recordRemoved ? "Released" : (nextParsed.special || nextParsed.stage || nextStage);
      const correctedExplanation = recordRemoved ? "" : line(nextParsed.description || nextDescription, 2000);
      const resultingStoredValue = recordRemoved
        ? ""
        : canonicalRelationshipManagedValue(candidate.field, record.values[candidate.field]);
      const baselineScore = !prior.blank && !prior.special && Number.isFinite(Number(prior.score))
        ? Number(prior.score)
        : relationshipStartingScore(candidate.field);
      const actualChange = Number.isFinite(Number(nextScore))
        ? Math.trunc(Number(nextScore) - baselineScore)
        : 0;
      const sourceIds = provenanceSourceIds((Array.isArray(evidenceItems) ? evidenceItems : [])
        .map(item => item && item.id));
      const storyEvidenceIds = unique((Array.isArray(evidenceItems) ? evidenceItems : [])
        .flatMap(item => {
          if (!item) return [];
          if (item.source === "provenance") return item.rawLineage || [];
          return /^E\d+$/.test(textOf(item.id)) ? [item.id] : [];
        }), 40).map(value => textOf(value).trim().toUpperCase()).filter(value => /^E\d+$/.test(value));
      const narrowUses = derivedItems.map(item => ({
        sourceId: provenanceId(item.id),
        signature: line(item.useSignature, 500),
        field: candidate.field
      })).filter(item => item.sourceId && item.signature);
      const paceValue = candidate.eventKind === "D" ? pace.direct : pace.accumulated;
      return {
        ok: true,
        targetKey: target.key,
        targetName: target.key === "player" ? "Player" : target.name,
        field: candidate.field,
        eventKind: candidate.eventKind,
        sourceIds,
        storyEvidenceIds,
        narrowUses,
        priorValue: oldScoreLabel,
        priorStoredValue: priorStoredValue === null ? "" : priorStoredValue,
        resultingValue: recordRemoved ? "Released" : nextScoreLabel,
        resultingStoredValue: resultingStoredValue === null ? "" : resultingStoredValue,
        actualChange,
        numericChange: actualChange,
        actualStage: stageLabel,
        actualScore: recordRemoved || nextParsed.special ? null : nextParsed.score,
        correctedExplanation,
        managedSignature: relationshipManagedSignature(
          owner.key,
          target.key,
          candidate.field,
          resultingStoredValue === null ? "" : resultingStoredValue
        ),
        paceValue: Math.max(0, Number(paceValue) || 0),
        pace: {
          name: line(pace.name, 80),
          value: Math.max(0, Number(paceValue) || 0),
          maxStages: Math.max(1, Number(pace.maxStages) || 1)
        },
        derivedUseSignatures: narrowUses.map(item => item.signature),
        summary: owner.name + "→" + target.name + " " + candidate.field + " "
          + oldScoreLabel + "→" + nextScoreLabel + " (" + stageLabel + ")",
        relationshipDetail: owner.name + " → " + (target.key === "player" ? "Player" : target.name)
          + " " + candidate.field + " " + oldScoreLabel + " → " + nextScoreLabel
          + " (" + stageLabel + "; " + evidenceLabel + ", " + candidate.eventKind + ")",
        stageChanged,
        descriptionChanged,
        recordRemoved
      };
    });
  }

  function captureRelationshipProvenanceTransaction() {
    return {
      cards: captureManagedRelationshipsCards(),
      provenance: clone(CC.provenance),
      provenanceCreated: CC.last.provenanceCreated,
      provenanceDiagnostics: clone(CC.last.provenanceDiagnostics || []),
      sourceDiagnostics: clone(CC.last.relationshipSourceDiagnostics || []),
      useDiagnostics: clone(CC.last.relationshipUseDiagnostics || [])
    };
  }

  function restoreRelationshipProvenanceTransaction(snapshot, reason) {
    if (!snapshot) return false;
    const cardsRestored = restoreManagedRelationshipsCards(snapshot.cards);
    CC.provenance = normalizeProvenanceLedger(snapshot.provenance);
    CC.last.provenanceCreated = line(snapshot.provenanceCreated, 500) || "None";
    CC.last.provenanceDiagnostics = unique(snapshot.provenanceDiagnostics || [], 500).slice(-20);
    CC.last.relationshipSourceDiagnostics = unique(snapshot.sourceDiagnostics || [], 500).slice(-40);
    CC.last.relationshipUseDiagnostics = unique((snapshot.useDiagnostics || []).concat(
      "Relationship provenance/use rollback: " + reason
    ), 500).slice(-40);
    refreshRelationshipsStore();
    refreshProvenanceActivity();
    return cardsRestored;
  }

  function relationshipEventSignature(owner, result) {
    if (!owner || !result) return "";
    return line(JSON.stringify([
      "relationship-event",
      owner.key,
      normalizedTargetKey(result.targetKey),
      canonicalRelationshipFieldName(result.field),
      result.eventKind,
      result.priorValue,
      result.resultingValue,
      result.actualStage,
      Math.trunc(Number(result.actualChange) || 0),
      provenanceSourceIds(result.sourceIds).join(","),
      result.managedSignature
    ]), 500);
  }

  function commitRelationshipProvenance(owner, result, plan) {
    if (!owner || !result || !result.ok || !result.managedSignature) {
      return { ok: false, error: "The committed Relationship result lacked provenance metadata." };
    }
    const field = canonicalRelationshipFieldName(result.field);
    const targetKey = normalizedTargetKey(result.targetKey);
    const sourceIds = provenanceSourceIds(result.sourceIds);
    const storyEvidenceIds = unique((Array.isArray(result.storyEvidenceIds) ? result.storyEvidenceIds : [])
      .map(value => textOf(value).trim().toUpperCase())
      .filter(value => /^E\d+$/.test(value)), 40);
    if (!field || !targetKey || targetKey === "self" || !sourceIds.length) {
      return { ok: false, error: "The committed Relationship result had incomplete owner, target, field, or source metadata." };
    }
    const eventSignature = relationshipEventSignature(owner, result);
    if (!eventSignature) return { ok: false, error: "The Relationship provenance signature could not be created." };

    const provenance = appendProvenanceRecord({
      prefix: "R",
      ownerKey: owner.key,
      targetKey,
      targetName: storedTargetName(targetKey, result.targetName),
      field,
      destination: line(result.actualStage, 120),
      eventKind: result.eventKind,
      actualChange: Math.trunc(Number(result.actualChange) || 0),
      numericChange: Math.trunc(Number(result.actualChange) || 0),
      priorValue: line(result.priorValue, 240),
      resultingValue: line(result.resultingValue, 240),
      resultingStage: line(result.actualStage, 120),
      paceValue: Math.max(0, Number(result.paceValue) || 0),
      pace: clone(result.pace),
      signature: eventSignature,
      managedSignature: result.managedSignature,
      sourceIds,
      storyEvidenceIds,
      uses: (result.narrowUses || []).map(use => use.signature),
      value: line(result.resultingValue, 240),
      explanation: line(result.correctedExplanation, 500),
      createdClock: CC.stateClock + 1,
      ownerOpportunity: plan && plan.ownerOpportunity || CC.ownerOpportunities[owner.key] || 0,
      active: true
    });
    if (!provenance.ok) {
      return { ok: false, error: "R# provenance could not commit: " + provenance.error };
    }

    for (const use of result.narrowUses || []) {
      const sourceRecord = provenanceRecordById(use.sourceId);
      if (!sourceRecord || !["state", "experience"].includes(sourceRecord.kind)) {
        return { ok: false, error: "Narrow use source " + use.sourceId + " disappeared during R# creation." };
      }
      if (!sourceRecord.active || !managedSignatureStillValid(sourceRecord)) {
        return { ok: false, error: "Narrow use source " + use.sourceId + " became stale before use commit." };
      }
      const recomputed = relationshipUseSignatureForRecord(sourceRecord, owner.key, targetKey, field);
      if (!recomputed || recomputed !== use.signature) {
        return { ok: false, error: "Narrow use signature for " + use.sourceId + " changed before commit." };
      }
      if (provenanceUseCommitted(sourceRecord, recomputed)) {
        return { ok: false, error: "Narrow use signature for " + use.sourceId + " was already committed." };
      }
      const committedUse = commitProvenanceUse(sourceRecord, recomputed);
      if (!committedUse.ok || committedUse.duplicate
        || !provenanceUseCommitted(sourceRecord, recomputed)) {
        return { ok: false, error: "Narrow use signature for " + use.sourceId + " could not commit exactly once." };
      }
    }

    refreshProvenanceActivity();
    const committed = provenanceRecordById(provenance.record.id);
    if (!committed || !committed.active || !managedSignatureStillValid(committed)) {
      return { ok: false, error: "The new R# could not bind to the committed managed Relationship value." };
    }
    CC.last.relationshipUseDiagnostics = unique((CC.last.relationshipUseDiagnostics || []).concat(
      "Committed " + committed.id + " after managed Relationship success"
        + ((result.narrowUses || []).length
          ? "; narrow uses " + result.narrowUses.map(use => use.sourceId + ":" + field).join(", ")
          : "; no derived uses")
    ), 500).slice(-40);
    CC.last.provenanceDiagnostics = unique((CC.last.provenanceDiagnostics || []).concat(
      "Relationship provenance committed: " + committed.id + " from "
        + (sourceIds.join(",") || "None")
        + " with raw lineage " + (storyEvidenceIds.join(",") || "None")
        + "; actual stage " + result.actualStage
        + "; actual change " + Math.trunc(Number(result.actualChange) || 0)
    ), 500).slice(-20);
    return { ok: true, record: committed };
  }

  function captureViewProvenanceTransaction() {
    return {
      cards: captureManagedViewsCards(),
      recoveringViews: clone(CC.recoveringViews),
      provenance: clone(CC.provenance),
      provenanceCreated: CC.last.provenanceCreated,
      provenanceDiagnostics: clone(CC.last.provenanceDiagnostics || []),
      sourceDiagnostics: clone(CC.last.viewSourceDiagnostics || []),
      useDiagnostics: clone(CC.last.viewUseDiagnostics || []),
      transactionDiagnostics: clone(CC.viewTransactionDiagnostics || [])
    };
  }

  function restoreViewProvenanceTransaction(snapshot, reason) {
    if (!snapshot) return false;
    const cardsRestored = restoreManagedViewsCards(snapshot.cards);
    CC.recoveringViews = snapshot.recoveringViews && typeof snapshot.recoveringViews === "object"
      ? clone(snapshot.recoveringViews)
      : {};
    CC.provenance = normalizeProvenanceLedger(snapshot.provenance);
    CC.last.provenanceCreated = line(snapshot.provenanceCreated, 500) || "None";
    CC.last.provenanceDiagnostics = unique(snapshot.provenanceDiagnostics || [], 500).slice(-20);
    CC.last.viewSourceDiagnostics = unique(snapshot.sourceDiagnostics || [], 500).slice(-40);
    CC.last.viewUseDiagnostics = unique((snapshot.useDiagnostics || []).concat(
      "View provenance/use rollback: " + reason
    ), 500).slice(-40);
    CC.viewTransactionDiagnostics = unique((snapshot.transactionDiagnostics || []).concat(
      "Rolled back View, V#, counter, recovering state, and narrow uses: " + reason
    ), 300).slice(-30);
    refreshViewsStore(false);
    refreshProvenanceActivity();
    return cardsRestored;
  }

  function viewEventSignature(owner, result) {
    if (!owner || !result) return "";
    return line(JSON.stringify([
      "view-event",
      owner.key,
      normalizedTargetKey(result.targetKey),
      canonicalViewDestination(result.destination),
      canonicalViewOperationMode(result.operationMode),
      canonicalViewOperationMode(result.severity),
      result.priorCategory,
      result.resultingCategory,
      result.priorViewState,
      result.resultingViewState,
      provenanceSourceIds(result.sourceIds).join(","),
      result.managedSignature
    ]), 500);
  }

  function finalizeViewMutationResult(owner, target, candidate, evidenceItems, priorState, result) {
    if (!result || !result.ok) return result;
    refreshViewsStore(false);
    const resultingState = viewManagedStateSnapshot(owner.key, target.key);
    const operationMode = viewOperationModeForCandidate(candidate, target);
    const derivedItems = (Array.isArray(evidenceItems) ? evidenceItems : [])
      .filter(item => item && item.source === "provenance");
    const sourceIds = provenanceSourceIds((Array.isArray(evidenceItems) ? evidenceItems : [])
      .map(item => item && item.id));
    const storyEvidenceIds = unique((Array.isArray(evidenceItems) ? evidenceItems : []).flatMap(item => {
      if (!item) return [];
      if (item.source === "provenance") return item.rawLineage || [];
      return /^E\d+$/.test(textOf(item.id)) ? [item.id] : [];
    }), 40).map(value => textOf(value).trim().toUpperCase()).filter(value => /^E\d+$/.test(value));
    const narrowUses = derivedItems.map(item => ({
      sourceId: provenanceId(item.id),
      signature: line(item.useSignature, 500),
      destination: canonicalViewDestination(item.destination || candidate.destination),
      operationMode: canonicalViewOperationMode(item.operationMode || operationMode)
    })).filter(item => item.sourceId && item.signature && item.destination && item.operationMode);
    const priorCategory = priorState.activeCategory || priorState.buriedCategory || "";
    const resultingCategory = resultingState.activeCategory || resultingState.buriedCategory || "";
    const destination = canonicalViewDestination(candidate.destination);
    let committedStateMatches = false;
    if (destination === "Buried") {
      committedStateMatches = !resultingState.activeCategory
        && resultingState.buriedCategory === priorState.activeCategory
        && keyOf(resultingState.buriedExplanation) === keyOf(priorState.activeExplanation);
    } else if (destination === "Recovered") {
      committedStateMatches = priorState.activeCategory && priorState.buriedCategory
        ? resultingState.recovering === true
          && resultingState.activeCategory === priorState.activeCategory
          && resultingState.buriedCategory === priorState.buriedCategory
        : resultingState.activeCategory === priorState.buriedCategory
          && !resultingState.buriedCategory && resultingState.recovering === false;
    } else if (operationMode === "Reconciled") {
      committedStateMatches = resultingState.activeCategory === destination
        && keyOf(resultingState.activeExplanation) === keyOf(candidate.explanation)
        && !resultingState.buriedCategory && resultingState.recovering === false;
    } else {
      committedStateMatches = resultingState.activeCategory === destination
        && keyOf(resultingState.activeExplanation) === keyOf(candidate.explanation);
    }
    if (!committedStateMatches || !resultingState.signature) {
      return {
        ok: false,
        rollbackRequired: true,
        error: "The managed View write did not persist the exact expected active, buried, recovered, or reconciled state."
      };
    }
    return {
      ...result,
      targetKey: target.key,
      targetName: target.key === "player" ? "Player" : (target.key === "self" ? "Self" : target.name),
      destination,
      operationMode,
      severity: canonicalViewOperationMode(candidate.severity),
      sourceIds,
      storyEvidenceIds,
      narrowUses,
      priorCategory,
      resultingCategory,
      priorViewState: priorState.description,
      resultingViewState: resultingState.description,
      managedSignature: resultingState.signature,
      correctedExplanation: line(candidate.explanation, 500),
      derivedUseSignatures: narrowUses.map(item => item.signature)
    };
  }

  function commitViewProvenance(owner, result, plan) {
    if (!owner || !result || !result.ok || !result.managedSignature) {
      return { ok: false, error: "The committed View result lacked provenance metadata." };
    }
    const targetKey = normalizedTargetKey(result.targetKey);
    const destination = canonicalViewDestination(result.destination);
    const operationMode = canonicalViewOperationMode(result.operationMode);
    const severity = canonicalViewOperationMode(result.severity);
    const sourceIds = provenanceSourceIds(result.sourceIds);
    const storyEvidenceIds = unique((Array.isArray(result.storyEvidenceIds) ? result.storyEvidenceIds : [])
      .map(value => textOf(value).trim().toUpperCase())
      .filter(value => /^E\d+$/.test(value)), 40);
    if (!targetKey || !destination || !operationMode || !sourceIds.length) {
