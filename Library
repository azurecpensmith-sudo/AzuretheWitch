    operationState.owners = migratedKeyedObject(operationState.owners);
    (Array.isArray(operationState.drains) ? operationState.drains : []).forEach(record => {
      if (!record || typeof record !== "object" || Array.isArray(record)) return;
      record.ownerKey = migratedCharacterKey(record.ownerKey);
      record.targetKey = migratedCharacterKey(record.targetKey);
      record.key = operationDrainKey(record);
    });
