      item.usedViewsBy = migratedKeyedObject(item.usedViewsBy, uses => migratedKeyedObject(uses));
      item.usedRelationshipsBy = migratedKeyedObject(item.usedRelationshipsBy, uses => migratedKeyedObject(uses));
