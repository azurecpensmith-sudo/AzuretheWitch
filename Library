  }

  function migrateRecoveringViewKeys(value) {
    const source = value && typeof value === "object" && !Array.isArray(value) ? value : {};
    const result = {};
    Object.keys(source).forEach(key => {
      const marker = source[key] && typeof source[key] === "object" && !Array.isArray(source[key])
        ? source[key]
        : {};
      const separator = key.indexOf("|");
      const ownerKey = migratedCharacterKey(marker.ownerKey || (separator >= 0 ? key.slice(0, separator) : ""));
      const targetKey = migratedCharacterKey(marker.targetKey || (separator >= 0 ? key.slice(separator + 1) : ""));
      const migrated = { ...marker, ownerKey, targetKey };
      result[ownerKey && targetKey ? ownerKey + "|" + targetKey : key] = migrated;
    });
    return result;
  }

  function migratePlanIdentityKeys(plan) {
    if (!plan || typeof plan !== "object" || Array.isArray(plan)) return;
    ["ownerKey", "focusKey", "retryFocusKey", "conversationKey"].forEach(field => {
      if (typeof plan[field] === "string") plan[field] = migratedCharacterKey(plan[field]);
    });
    ["activeKeys", "modelActiveKeys", "retryActiveKeys"].forEach(field => {
      if (Array.isArray(plan[field])) plan[field] = migratedCharacterKeys(plan[field]);
    });
    ["targets", "retryTargets"].forEach(field => {
      (Array.isArray(plan[field]) ? plan[field] : []).forEach(target => {
        if (target && typeof target === "object" && typeof target.key === "string") {
          target.key = migratedCharacterKey(target.key);
        }
      });
    });
    const migrateSourceMetadata = metadata => {
      if (!metadata || typeof metadata !== "object" || Array.isArray(metadata)) return;
      Object.values(metadata).forEach(source => {
        if (!source || typeof source !== "object" || Array.isArray(source)) return;
        if (typeof source.ownerKey === "string") source.ownerKey = migratedCharacterKey(source.ownerKey);
        if (typeof source.targetKey === "string") source.targetKey = migratedCharacterKey(source.targetKey);
        if (source.useSignatures && typeof source.useSignatures === "object" && !Array.isArray(source.useSignatures)) {
          Object.keys(source.useSignatures).forEach(field => {
            const migrated = migrateProvenanceUseIdentityKeys([source.useSignatures[field]])[0] || "";
            if (migrated) source.useSignatures[field] = migrated;
            else delete source.useSignatures[field];
          });
        }
      });
    };
